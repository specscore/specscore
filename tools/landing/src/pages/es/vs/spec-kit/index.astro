---
// /es/vs/spec-kit/ — SpecScore vs GitHub Spec Kit comparison.
// Honest, factual, side-by-side. Spec Kit is a workflow/methodology;
// SpecScore is the artifact format it can target. They compose.
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../../components/SiteHeader.astro';
import SiteFooterEs from '../../../../components/SiteFooterEs.astro';
import ComparisonFeedback from '../../../../components/ComparisonFeedback.astro';
---

<BaseLayout
  lang="es"
  title="SpecScore vs Spec Kit — Comparación honesta."
  description="Una comparación objetiva y lado a lado de SpecScore y GitHub Spec Kit: flujo de trabajo vs formato, linting, ciclo de vida, trazabilidad y CLI. Se componen — aquí está cómo."
  canonical="https://specscore.md/es/vs/spec-kit/"
>
  <SiteHeader />

  <main>
    {/* ── Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <p class="hero__breadcrumb"><a href="/es/vs/" class="xref">Comparaciones</a></p>
        <h1 id="hero-title" class="hero__headline">
          SpecScore vs Spec Kit
        </h1>
        <p class="hero__sub">
          Operan en capas distintas. Spec Kit es un <strong>flujo de trabajo</strong> —
          un proceso guiado que lleva a un agente de la idea a la implementación.
          SpecScore es el <strong>formato</strong> en el que se escriben las especificaciones, más un CLI
          que las lintea, consulta y traza. Spec Kit puede producir archivos de SpecScore.
        </p>
      </div>
    </section>

    {/* ── What they share ── */}
    <section class="section" aria-labelledby="shared-title">
      <div class="section-inner section-inner--prose">
        <h2 id="shared-title" class="section-title">Lo que tienen en común.</h2>
        <ul class="shared-list">
          <li>La misma estrella polar — especificaciones antes que código, con agentes de IA como lectores de primera clase.</li>
          <li>Las especificaciones viven en tu repositorio como Markdown — con control de versiones, revisables en PRs.</li>
          <li>Ambos son open source bajo la licencia MIT.</li>
          <li>Ambos apuntan a Claude Code, Cursor, Copilot y otros agentes de codificación de IA.</li>
        </ul>
      </div>
    </section>

    {/* ── What Spec Kit does well ── */}
    <section class="section" aria-labelledby="speckit-title">
      <div class="section-inner section-inner--prose">
        <h2 id="speckit-title" class="section-title">Lo que Spec Kit hace bien.</h2>
        <p class="section-note">
          <a href="https://github.com/github/spec-kit" rel="nofollow noopener" target="_blank" class="xref">Spec Kit</a>
          es un flujo de trabajo de desarrollo basado en especificaciones de GitHub Next.
        </p>

        <div class="credit-card">
          <h3 class="credit-card__title">Un proceso completo y con opinión</h3>
          <p class="credit-card__desc">
            Spec Kit te da todo el arco:
            <code>constitution → specify → plan → tasks → implement</code>.
            Cada paso tiene un slash command y un prompt diseñados para mantener al agente
            en raíles. Si quieres un proceso, Spec Kit te entrega uno.
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">Fuerte distribución y reconocimiento</h3>
          <p class="credit-card__desc">
            Respaldado por GitHub Next, con una gran comunidad y una biblioteca creciente de
            extensiones. Para muchos desarrolladores, Spec Kit es el primer flujo de trabajo
            basado en especificaciones que encuentran.
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">Comandos agnósticos del agente</h3>
          <p class="credit-card__desc">
            Los comandos de Spec Kit funcionan en Claude Code, Cursor, Copilot y más —
            el flujo de trabajo dirige al agente sin importar cuál ejecutes.
          </p>
        </div>
      </div>
    </section>

    {/* ── Feature comparison table ── */}
    <section class="section table-section" aria-labelledby="table-title">
      <div class="section-inner">
        <h2 id="table-title" class="section-title">Comparación de funcionalidades.</h2>
        <p class="section-note">
          Estas herramientas responden preguntas distintas, así que la tabla compara roles, no ganadores.
        </p>

        <div class="table-wrap">
          <table class="compare-table" aria-label="Comparación de funcionalidades SpecScore vs Spec Kit">
            <thead>
              <tr>
                <th scope="col">Capacidad</th>
                <th scope="col">Spec Kit</th>
                <th scope="col">SpecScore</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Rol principal</td>
                <td>Flujo de trabajo / metodología</td>
                <td><strong>Formato de almacenamiento + CLI</strong></td>
              </tr>
              <tr>
                <td>Salida de especificación</td>
                <td>Markdown libre</td>
                <td><strong>Markdown + YAML frontmatter</strong> (estructurado)</td>
              </tr>
              <tr>
                <td>Linting de especificaciones</td>
                <td>Ninguno</td>
                <td><strong>Calidad de contenido</strong> — verbos vagos, ACs faltantes, referencias colgantes</td>
              </tr>
              <tr>
                <td>IDs de requisitos / ACs</td>
                <td>Ninguno</td>
                <td><strong>IDs direccionables por máquina</strong> (<code>REQ: slug</code>)</td>
              </tr>
              <tr>
                <td>Estado del ciclo de vida</td>
                <td>Implícito (paso del flujo de trabajo)</td>
                <td><strong>Aplicado</strong> — Draft → Approved → Implementing → Stable → Deprecated</td>
              </tr>
              <tr>
                <td>Trazabilidad código-a-especificación</td>
                <td>Ninguna</td>
                <td><strong><code>specscore:</code> anotaciones</strong> + <code>Verifies:</code> trailers de commits</td>
              </tr>
              <tr>
                <td>Consultar especificaciones desde el CLI</td>
                <td>Andamiaje (<code>specify</code>, <code>plan</code>, <code>tasks</code>)</td>
                <td><strong>API de consulta</strong> — <code>feature list / show / deps</code>, <code>lint</code>, <code>code refs</code></td>
              </tr>
              <tr>
                <td>Dependencia de runtime</td>
                <td>Python</td>
                <td><strong>Ninguna</strong> — binario Go único</td>
              </tr>
              <tr>
                <td>Integración CI</td>
                <td>Ejecutar el flujo de trabajo</td>
                <td><strong><code>specscore lint</code></strong> sale con código no-cero, hooks de pre-commit</td>
              </tr>
              <tr>
                <td>Relación</td>
                <td colspan="2"><strong>Se componen</strong> — Spec Kit puede producir archivos de SpecScore</td>
              </tr>
              <tr>
                <td>Licencia</td>
                <td>MIT</td>
                <td>MIT</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {/* ── Where SpecScore goes further ── */}
    <section class="section" aria-labelledby="further-title">
      <div class="section-inner">
        <h2 id="further-title" class="section-title">Lo que SpecScore agrega.</h2>

        <div class="diff-grid">
          <div class="diff-card">
            <h3 class="diff-card__title">La salida es lintable</h3>
            <p class="diff-card__desc">
              Spec Kit produce Markdown libre — bueno o malo, se entrega.
              SpecScore verifica el resultado en dos capas: <code>lint</code>
              comprueba de forma determinista que cada requisito tenga criterios de aceptación,
              que las referencias cruzadas se resuelvan y que las transiciones de estado sean válidas — y un revisor de
              IA (<code>/review</code>, <code>/score</code>) detecta criterios ambiguos
              y verbos vagos.
            </p>
            <div class="diff-card__example">
<pre class="terminal"><span class="prompt">$</span> specscore lint checkout/apply-discount.md
  <span class="mark-fail">✗</span> R3  no acceptance criteria
  <span class="mark-fail">✗</span> link  <span class="dim">"Related Feature: discount-tiers" not found</span></pre>
            </div>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">La salida es consultable</h3>
            <p class="diff-card__desc">
              Spec Kit escribe archivos; leerlos de vuelta significa abrirlos. Las especificaciones de SpecScore
              responden preguntas desde el CLI: <code>specscore feature list</code>,
              <code>feature deps</code>, <code>code refs</code> — así un agente navega
              el grafo de especificaciones sin leer cada archivo del repositorio.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Cada requisito tiene un ID</h3>
            <p class="diff-card__desc">
              Spec Kit referencia requisitos por prosa. SpecScore asigna IDs basados en slug
              (<code>REQ: slug-format</code>) e IDs de ACs que sobreviven renombramientos,
              refactorizaciones y traspasos entre agentes.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">El ciclo de vida se aplica</h3>
            <p class="diff-card__desc">
              En Spec Kit, la etapa de una especificación es donde estés en el flujo de trabajo.
              En SpecScore, el ciclo de vida es un campo de estado aplicado — Draft → Approved
              → Implementing → Stable → Deprecated — validado por lint y transicionado
              por <code>specscore change-status</code> desde git hooks o CI.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">El código se traza de vuelta a las especificaciones</h3>
            <p class="diff-card__desc">
              Spec Kit no tiene mecanismo de trazabilidad. SpecScore tiene
              anotaciones de fuente <code>specscore:</code> y trailers de commit <code>Verifies:</code>
              — ejecuta <code>specscore code refs</code> para una respuesta determinista
              a "¿qué código implementa este requisito?"
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Sin dependencia de runtime</h3>
            <p class="diff-card__desc">
              SpecScore es un binario Go único — sin runtime que instalar.
              Funciona en proyectos Go, Rust, Python, Java o JavaScript sin
              agregar nada al toolchain.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── When to use which ── */}
    <section class="section" aria-labelledby="when-title">
      <div class="section-inner">
        <h2 id="when-title" class="section-title">Cuándo usar cada uno.</h2>

        <div class="when-grid">
          <div class="when-card">
            <h3 class="when-card__title">Recurre a Spec Kit cuando…</h3>
            <ul class="when-card__list">
              <li>Quieres un proceso guiado y con opinión de la idea a la implementación.</li>
              <li>Tu equipo necesita la disciplina de pasos explícitos de specify / plan / tasks.</li>
              <li>Estás estandarizando cómo se dirigen los agentes en un equipo.</li>
            </ul>
          </div>

          <div class="when-card when-card--primary">
            <h3 class="when-card__title">Usa SpecScore cuando…</h3>
            <ul class="when-card__list">
              <li>Necesitas especificaciones que los agentes puedan lintear, consultar y mutar sin leer cada archivo.</li>
              <li>Necesitas trazabilidad código-a-especificación con una respuesta determinista.</li>
              <li>Estás construyendo un sistema grande con muchas features y transiciones de ciclo de vida.</li>
              <li>Quieres cero dependencias de runtime — un binario, sin toolchain de lenguaje requerido.</li>
              <li>Necesitas puertas de calidad de especificaciones en CI que salgan con código no-cero, como ESLint o <code>go vet</code>.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── The integration opportunity ── */}
    <section class="section" aria-labelledby="bridge-title">
      <div class="section-inner section-inner--prose">
        <h2 id="bridge-title" class="section-title">SpecScore extiende Spec Kit — no lo reemplaza.</h2>
        <p class="prose-p">
          Spec Kit es el proceso para producir una especificación; SpecScore es el formato
          en el que esa especificación puede escribirse. Una extensión de Spec Kit que emita el formato
          de SpecScore está en camino — ejecuta el flujo de trabajo de Spec Kit y obtén especificaciones que se linteen,
          consulten y tracen del otro lado.
        </p>
        <p class="prose-p">
          Elige Spec Kit para el proceso. Elige SpecScore para el artefacto. Ejecuta ambos
          cuando quieras ambos.
        </p>
      </div>
    </section>

    <ComparisonFeedback page="spec-kit" />
  </main>

  {/* ── Final CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">Specs que pasan.</h2>
      <div class="final-cta__buttons">
        <a href="/cli/install/" class="btn btn--primary">Instalar el CLI</a>
        <a href="/ai/specstudio-skills/" class="btn btn--secondary">Obtener skills de IA para tu agente</a>
        <a
          href="https://github.com/specscore/specscore"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          Open-source en GitHub
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <SiteFooterEs />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-5);
    background: var(--cream);
  }
  .hero__inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms;
  }
  .hero__breadcrumb {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--pale-ink);
    margin-bottom: var(--space-2);
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
    max-width: 52ch;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Section titles ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }

  /* ── Shared list ── */
  .shared-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .shared-list li {
    position: relative;
    padding-left: 1.4rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
  }
  .shared-list li::before {
    content: '=';
    position: absolute;
    left: 0;
    font-family: var(--font-code);
    font-weight: 700;
    color: var(--pale-ink);
  }

  /* ── Section note ── */
  .section-note {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    margin-bottom: var(--space-3);
  }

  /* ── Credit cards ── */
  .credit-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .credit-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .credit-card__desc {
    color: var(--mid-ink);
    line-height: 1.6;
    font-size: var(--fs-body);
  }
  .credit-card__desc code {
    font-size: 0.9em;
    background: var(--cream);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Feature comparison table ── */
  .table-section { background: var(--cream-2); }
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-small);
    line-height: 1.5;
  }
  .compare-table th,
  .compare-table td {
    text-align: left;
    padding: 0.65rem 0.85rem;
    border-bottom: 1px solid var(--hairline);
    vertical-align: top;
  }
  .compare-table thead th {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mid-ink);
    border-bottom: 2px solid var(--graphite);
    white-space: nowrap;
  }
  .compare-table td:first-child {
    font-weight: 500;
    white-space: nowrap;
    min-width: 160px;
  }
  .compare-table td:nth-child(2),
  .compare-table td:nth-child(3) {
    min-width: 200px;
  }
  .compare-table td code {
    font-size: 0.88em;
    background: var(--surface);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .compare-table strong {
    font-weight: 600;
    color: var(--ink);
  }

  /* ── Diff grid ── */
  .diff-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .diff-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
  }
  .diff-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .diff-card__desc {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    line-height: 1.6;
  }
  .diff-card__desc code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .diff-card__example {
    margin-top: var(--space-2);
  }
  .diff-card__example .terminal {
    font-size: 0.78rem;
    line-height: 1.6;
  }

  @media (max-width: 860px) {
    .diff-grid { grid-template-columns: 1fr; }
  }

  /* ── When to use which ── */
  .when-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .when-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-4);
  }
  .when-card--primary {
    border-color: var(--validator-green);
    border-width: 2px;
  }
  .when-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .when-card__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .when-card__list li {
    position: relative;
    padding-left: 1.2rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
    font-size: var(--fs-small);
  }
  .when-card__list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--pale-ink);
    font-family: var(--font-code);
  }
  .when-card--primary .when-card__list li::before {
    color: var(--validator-green);
  }
  .when-card__list code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  @media (max-width: 860px) {
    .when-grid { grid-template-columns: 1fr; }
  }

  /* ── Bridge section ── */
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
    margin-bottom: var(--space-2);
  }
  .prose-p:last-child {
    margin-bottom: 0;
    font-weight: 500;
    color: var(--ink);
  }
  .prose-p code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    text-align: center;
  }
  .final-cta__title {
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .final-cta__buttons {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>
