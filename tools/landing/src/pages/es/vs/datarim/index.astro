---
// /es/vs/datarim/ — SpecScore vs Datarim comparison.
// Datarim is a Claude Code workflow pack; SpecScore is the open format
// a workflow can target. No public attack — two packs, one open format.
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../../components/SiteHeader.astro';
import SiteFooterEs from '../../../../components/SiteFooterEs.astro';
import ComparisonFeedback from '../../../../components/ComparisonFeedback.astro';
---

<BaseLayout
  lang="es"
  title="SpecScore vs Datarim — Comparación honesta."
  description="Una comparación objetiva de SpecScore y Datarim: un pack de flujo de trabajo para Claude Code vs un formato de especificación abierto y portable. Capas distintas — y se pueden componer."
  canonical="https://specscore.md/es/vs/datarim/"
>
  <SiteHeader />

  <main>
    {/* ── Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <p class="hero__breadcrumb"><a href="/es/vs/" class="xref">Comparaciones</a></p>
        <h1 id="hero-title" class="hero__headline">
          SpecScore vs Datarim
        </h1>
        <p class="hero__sub">
          Capas distintas. Datarim es un <strong>pack de flujo de trabajo</strong> con opinión para
          Claude Code — slash commands que llevan un proyecto desde los requisitos hasta su
          finalización. SpecScore es el <strong>formato abierto</strong> en el que se escriben las especificaciones,
          más un CLI para lintearlas, consultarlas y trazarlas. Un flujo de trabajo puede apuntar a él.
        </p>
      </div>
    </section>

    {/* ── What they share ── */}
    <section class="section" aria-labelledby="shared-title">
      <div class="section-inner section-inner--prose">
        <h2 id="shared-title" class="section-title">Lo que tienen en común.</h2>
        <ul class="shared-list">
          <li>Ambos aportan metodología estructurada al desarrollo asistido por IA.</li>
          <li>Ambos son open source bajo la licencia MIT.</li>
          <li>Ambos se ejecutan dentro de Claude Code — Datarim como comandos, SpecScore vía SpecStudio Skills.</li>
          <li>Ambos mantienen su estado como Markdown en el repositorio, con control de versiones.</li>
        </ul>
      </div>
    </section>

    {/* ── What Datarim does well ── */}
    <section class="section" aria-labelledby="datarim-title">
      <div class="section-inner section-inner--prose">
        <h2 id="datarim-title" class="section-title">Lo que Datarim hace bien.</h2>
        <p class="section-note">
          <a href="https://github.com/Arcanada-one/datarim" rel="nofollow noopener" target="_blank" class="xref">Datarim</a>
          es un framework universal de flujo de trabajo iterativo construido para Claude Code.
        </p>

        <div class="credit-card">
          <h3 class="credit-card__title">UX nativa de slash commands</h3>
          <p class="credit-card__desc">
            Un pipeline completo como comandos — <code>/dr-prd</code>, <code>/dr-plan</code>,
            <code>/dr-design</code>, <code>/dr-do</code>, <code>/dr-qa</code> — que se sienten
            como en casa en Claude Code. Un <code>install.sh</code> hacia <code>~/.claude/</code>
            y ya estás en marcha.
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">Enrutamiento consciente de la complejidad (L1–L4)</h3>
          <p class="credit-card__desc">
            Datarim dimensiona el trabajo y enruta en consecuencia: un arreglo rápido L1 omite
            la planificación, mientras que un cambio mayor L4 ejecuta un pipeline por fases con múltiples
            ciclos de revisión. Ajustar la ceremonia al alcance es una idea genuinamente buena.
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">Consilium y alcance multidominio</h3>
          <p class="credit-card__desc">
            Su "consilium" reúne un panel de agentes para debatir las concesiones antes de
            recomendar una decisión. Y no es solo software — Datarim también apunta a
            flujos de trabajo de investigación, legales y de contenido.
          </p>
        </div>
      </div>
    </section>

    {/* ── Feature comparison table ── */}
    <section class="section table-section" aria-labelledby="table-title">
      <div class="section-inner">
        <h2 id="table-title" class="section-title">Comparación de funcionalidades.</h2>
        <p class="section-note">
          Uno es un flujo de trabajo, el otro un formato — la tabla compara roles, no ganadores.
        </p>

        <div class="table-wrap">
          <table class="compare-table" aria-label="Comparación de funcionalidades SpecScore vs Datarim">
            <thead>
              <tr>
                <th scope="col">Capacidad</th>
                <th scope="col">Datarim</th>
                <th scope="col">SpecScore</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Rol principal</td>
                <td>Pack de flujo de trabajo para Claude Code</td>
                <td><strong>Formato de especificación abierto + CLI</strong></td>
              </tr>
              <tr>
                <td>Se ejecuta como</td>
                <td>Slash commands (<code>/dr-*</code>)</td>
                <td>Archivos de formato + CLI <span class="dim">(+ SpecStudio Skills en Claude Code)</span></td>
              </tr>
              <tr>
                <td>Almacenamiento de estado</td>
                <td><code>backlog.md</code> + <code>CLAUDE.md</code> (con forma de flujo de trabajo)</td>
                <td><strong>Árbol <code>spec/</code> portable</strong> (Markdown + YAML)</td>
              </tr>
              <tr>
                <td>Sobrevive sin la herramienta</td>
                <td>Atado al runtime de Datarim</td>
                <td><strong>Sí</strong> — portable por construcción</td>
              </tr>
              <tr>
                <td>Linting de especificaciones</td>
                <td>Ninguno</td>
                <td><strong>Calidad de contenido</strong> — verbos vagos, ACs faltantes, referencias colgantes</td>
              </tr>
              <tr>
                <td>IDs de requisitos / ACs</td>
                <td>Ninguno</td>
                <td><strong>IDs direccionables por máquina</strong> (<code>REQ: slug</code>)</td>
              </tr>
              <tr>
                <td>Trazabilidad código-a-especificación</td>
                <td>Ninguna</td>
                <td><strong><code>specscore:</code> anotaciones</strong> + <code>Verifies:</code> trailers</td>
              </tr>
              <tr>
                <td>Enrutamiento por complejidad (L1–L4)</td>
                <td><strong>Sí</strong></td>
                <td>No (formato, no flujo de trabajo)</td>
              </tr>
              <tr>
                <td>Grafo de especificaciones consultable</td>
                <td>No</td>
                <td><strong>Sí</strong> — <code>feature list / show / deps</code></td>
              </tr>
              <tr>
                <td>Atado a Claude Code</td>
                <td>Construido para él</td>
                <td><strong>No</strong> — cualquier agente, o ninguno</td>
              </tr>
              <tr>
                <td>Licencia</td>
                <td>MIT</td>
                <td>MIT / CC BY 4.0</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {/* ── Where SpecScore goes further ── */}
    <section class="section" aria-labelledby="further-title">
      <div class="section-inner">
        <h2 id="further-title" class="section-title">Lo que SpecScore agrega.</h2>

        <div class="diff-grid">
          <div class="diff-card">
            <h3 class="diff-card__title">La salida sobrevive al flujo de trabajo</h3>
            <p class="diff-card__desc">
              El estado de Datarim vive en su propio backlog y forma de <code>CLAUDE.md</code> —
              valioso mientras ejecutas Datarim. Las especificaciones de SpecScore son un formato portable que
              sigue siendo legible, lintable y consultable sin ningún tooling de SpecScore instalado
              en absoluto. El flujo de trabajo puede cambiar; las especificaciones vienen contigo.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Las especificaciones son lintables</h3>
            <p class="diff-card__desc">
              Un flujo de trabajo guía la redacción, pero no controla el resultado. El
              <code>lint</code> de SpecScore comprueba que cada requisito tenga criterios de aceptación,
              que las referencias cruzadas se resuelvan y que las transiciones de estado sean válidas.
            </p>
            <div class="diff-card__example">
<pre class="terminal"><span class="prompt">$</span> specscore lint checkout/apply-discount.md
  <span class="mark-fail">✗</span> R3  no acceptance criteria
  <span class="mark-fail">✗</span> link  <span class="dim">"Related Feature: discount-tiers" not found</span></pre>
            </div>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">El código se traza de vuelta a las especificaciones</h3>
            <p class="diff-card__desc">
              SpecScore agrega anotaciones de fuente <code>specscore:</code> y
              trailers de commit <code>Verifies:</code> — <code>specscore code refs</code>
              responde "¿qué código implementa este requisito?" de forma determinista,
              independientemente del flujo de trabajo que produjo la especificación.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">No está atado a un solo agente</h3>
            <p class="diff-card__desc">
              Datarim está construido para Claude Code. SpecScore es un formato que cualquier agente puede leer,
              y un binario Go único que cualquier CI puede ejecutar — sin Claude Code, sin
              instalación de <code>~/.claude/</code> requerida.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── When to use which ── */}
    <section class="section" aria-labelledby="when-title">
      <div class="section-inner">
        <h2 id="when-title" class="section-title">Cuándo usar cada uno.</h2>

        <div class="when-grid">
          <div class="when-card">
            <h3 class="when-card__title">Recurre a Datarim cuando…</h3>
            <ul class="when-card__list">
              <li>Quieres un pipeline completo y con opinión dentro de Claude Code hoy.</li>
              <li>Valoras el enrutamiento consciente de la complejidad y un ritual de decisión multiagente.</li>
              <li>Tu trabajo abarca dominios — investigación, legal, contenido, no solo código.</li>
            </ul>
          </div>

          <div class="when-card when-card--primary">
            <h3 class="when-card__title">Usa SpecScore cuando…</h3>
            <ul class="when-card__list">
              <li>Quieres especificaciones que sobrevivan a cualquier flujo de trabajo o herramienta individual.</li>
              <li>Necesitas lint, IDs, ciclo de vida y trazabilidad código-a-especificación.</li>
              <li>Trabajas entre agentes — o ninguno — no solo Claude Code.</li>
              <li>Quieres un CLI que los agentes puedan consultar en lugar de releer el repositorio.</li>
              <li>Necesitas puertas de calidad de especificaciones en CI que salgan con código no-cero.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── Two packs, one format ── */}
    <section class="section" aria-labelledby="bridge-title">
      <div class="section-inner section-inner--prose">
        <h2 id="bridge-title" class="section-title">Dos packs de flujo de trabajo, un formato abierto.</h2>
        <p class="prose-p">
          Datarim y SpecStudio Skills son ambos flujos de trabajo con opinión sobre Claude
          Code. SpecScore es el formato abierto subyacente — el artefacto que un flujo de trabajo puede
          producir para que las especificaciones se mantengan portables, lintables y trazables después de que el pipeline
          termine. Un Datarim que emita SpecScore conservaría su UX y ganaría una salida duradera.
        </p>
        <p class="prose-p">
          Elige Datarim para el pipeline. Usa SpecScore para el artefacto que deja atrás.
        </p>
      </div>
    </section>

    <ComparisonFeedback page="datarim" />
  </main>

  {/* ── Final CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">Specs que pasan.</h2>
      <div class="final-cta__buttons">
        <a href="/cli/install/" class="btn btn--primary">Instalar el CLI</a>
        <a href="/ai/specstudio-skills/" class="btn btn--secondary">Obtener skills de IA para tu agente</a>
        <a
          href="https://github.com/specscore/specscore"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          Open-source en GitHub
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <SiteFooterEs />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-5);
    background: var(--cream);
  }
  .hero__inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms;
  }
  .hero__breadcrumb {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--pale-ink);
    margin-bottom: var(--space-2);
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
    max-width: 52ch;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Section titles ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }

  /* ── Shared list ── */
  .shared-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .shared-list li {
    position: relative;
    padding-left: 1.4rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
  }
  .shared-list li::before {
    content: '=';
    position: absolute;
    left: 0;
    font-family: var(--font-code);
    font-weight: 700;
    color: var(--pale-ink);
  }

  /* ── Section note ── */
  .section-note {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    margin-bottom: var(--space-3);
  }

  /* ── Credit cards ── */
  .credit-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .credit-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .credit-card__desc {
    color: var(--mid-ink);
    line-height: 1.6;
    font-size: var(--fs-body);
  }
  .credit-card__desc code {
    font-size: 0.9em;
    background: var(--cream);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Feature comparison table ── */
  .table-section { background: var(--cream-2); }
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-small);
    line-height: 1.5;
  }
  .compare-table th,
  .compare-table td {
    text-align: left;
    padding: 0.65rem 0.85rem;
    border-bottom: 1px solid var(--hairline);
    vertical-align: top;
  }
  .compare-table thead th {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mid-ink);
    border-bottom: 2px solid var(--graphite);
    white-space: nowrap;
  }
  .compare-table td:first-child {
    font-weight: 500;
    white-space: nowrap;
    min-width: 160px;
  }
  .compare-table td:nth-child(2),
  .compare-table td:nth-child(3) {
    min-width: 200px;
  }
  .compare-table td code {
    font-size: 0.88em;
    background: var(--surface);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .compare-table strong {
    font-weight: 600;
    color: var(--ink);
  }
  .compare-table .dim {
    color: var(--pale-ink);
  }

  /* ── Diff grid ── */
  .diff-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .diff-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
  }
  .diff-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .diff-card__desc {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    line-height: 1.6;
  }
  .diff-card__desc code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .diff-card__example {
    margin-top: var(--space-2);
  }
  .diff-card__example .terminal {
    font-size: 0.78rem;
    line-height: 1.6;
  }

  @media (max-width: 860px) {
    .diff-grid { grid-template-columns: 1fr; }
  }

  /* ── When to use which ── */
  .when-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .when-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-4);
  }
  .when-card--primary {
    border-color: var(--validator-green);
    border-width: 2px;
  }
  .when-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .when-card__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .when-card__list li {
    position: relative;
    padding-left: 1.2rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
    font-size: var(--fs-small);
  }
  .when-card__list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--pale-ink);
    font-family: var(--font-code);
  }
  .when-card--primary .when-card__list li::before {
    color: var(--validator-green);
  }
  .when-card__list code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  @media (max-width: 860px) {
    .when-grid { grid-template-columns: 1fr; }
  }

  /* ── Bridge section ── */
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
    margin-bottom: var(--space-2);
  }
  .prose-p:last-child {
    margin-bottom: 0;
    font-weight: 500;
    color: var(--ink);
  }
  .prose-p code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    text-align: center;
  }
  .final-cta__title {
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .final-cta__buttons {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>
