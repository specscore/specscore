---
// SpecScore CLI — pagina de producto (ES).
// El linter open-source para especificaciones SpecScore.
// Parte de la familia estandar (gratis para siempre, MIT).
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooterEs from '../../../components/SiteFooterEs.astro';
import LintExample from '../../../components/LintExample.astro';
import HeroGitHubLink from '../../../components/HeroGitHubLink.astro';
import QsTabsScript from '../../../components/QsTabsScript.astro';
import InstallFromSourceEs from '../../../components/InstallFromSourceEs.astro';
---

<BaseLayout
  lang="es"
  title="SpecScore CLI — Lintea tus especificaciones como linteas tu codigo."
  description="Linter open-source para especificaciones SpecScore. Valida features, requisitos y criterios de aceptacion desde la linea de comandos o tu pipeline de CI. Sin cuenta, sin telemetria."
  canonical="https://specscore.md/es/cli/"
>
  <SiteHeader />

  <main>
    {/* ── Hero: copy left, terminal demo right ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <h1 id="hero-title" class="hero__headline">
          Lintea tus especificaciones<br />como linteas tu codigo.
        </h1>
        <div class="hero__copy">
          <p class="hero__sub">
            El SpecScore CLI valida features, requisitos y criterios de aceptacion
            desde la linea de comandos. Ejecutalo en local, conectalo a tu CI
            o deja que tu agente de IA lo llame. Open source, sin cuenta, sin telemetria.
          </p>
          <HeroGitHubLink repo="specscore/specscore-cli" label="Código abierto en GitHub" />
          <div class="hero__cta">
            <a href="/es/cli/install/" class="btn btn--primary">Instalar</a>
          </div>
        </div>

        <div
          class="hero__art"
          role="img"
          aria-label="Salida del terminal de specscore lint: R1 y R2 tienen criterios de aceptación (checks verdes); R3 no tiene, un enlace Related Feature no se resuelve y falta la sección obligatoria Open Questions (marcas rojas). 3 problemas, exit 1."
        >
<LintExample />
        </div>
      </div>
    </section>

    {/* ── Instalacion rapida ── */}
    <section class="section" id="install" aria-labelledby="install-title">
      <div class="section-inner">
        <h2 id="install-title" class="section-title">Instalacion en 60 segundos.</h2>

        <div class="qs-tabs" role="tablist" aria-label="Comando de instalacion para tu sistema operativo">
          <button type="button" role="tab" id="qs-tab-unix" aria-controls="qs-panel-unix" aria-selected="true" tabindex="0" class="qs-tab is-active" data-tab="unix">Linux / macOS</button>
          <button type="button" role="tab" id="qs-tab-win" aria-controls="qs-panel-win" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="win">Windows</button>
          <button type="button" role="tab" id="qs-tab-brew" aria-controls="qs-panel-brew" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="brew">Homebrew</button>
          <button type="button" role="tab" id="qs-tab-src" aria-controls="qs-panel-src" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="src">From source</button>
        </div>

        <div id="qs-panel-unix" role="tabpanel" aria-labelledby="qs-tab-unix" class="qs-panel is-active" data-panel="unix">
<pre class="terminal"><span class="prompt">$</span> curl -fsSL https://specscore.md/install/get-cli | sh</pre>
        </div>
        <div id="qs-panel-win" role="tabpanel" aria-labelledby="qs-tab-win" class="qs-panel" data-panel="win" hidden>
<pre class="terminal"><span class="prompt">PS&gt;</span> powershell -c "irm https://specscore.md/install/get-cli.ps1 | iex"</pre>
        </div>
        <div id="qs-panel-brew" role="tabpanel" aria-labelledby="qs-tab-brew" class="qs-panel" data-panel="brew" hidden>
<pre class="terminal"><span class="prompt">$</span> brew install specscore/tap/specscore</pre>
        </div>
        <div id="qs-panel-src" role="tabpanel" aria-labelledby="qs-tab-src" class="qs-panel" data-panel="src" hidden>
          <InstallFromSourceEs />
        </div>

        <p class="qs-more">
          <a class="xref" href="/es/cli/install/">Todos los metodos de instalacion →</a>
        </p>
      </div>
    </section>

    {/* ── Que incluye ── */}
    <section class="section features-section" aria-labelledby="features-title">
      <div class="section-inner">
        <h2 id="features-title" class="section-title">Que incluye.</h2>

        <div class="features-grid">
          <div class="feature-card">
            <h3 class="feature-card__title">Lint</h3>
            <p class="feature-card__desc">
              Valida estructura, metadatos, referencias cruzadas y unicidad de AC.
              Reporta pass/fail por requisito con sugerencias de correccion.
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">Score</h3>
            <p class="feature-card__desc">
              Califica la completitud de la especificación en una escala de 0 a 100. Detecta actores
              faltantes, triggers, estados de error, modelos de seguridad y limites de tasa.
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">Listo para CI</h3>
            <p class="feature-card__desc">
              Exit code distinto de cero si falla. Conecta <code>specscore lint</code>
              a tu pipeline de CI junto con ESLint, Prettier y tu suite de tests.
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">Sin telemetria</h3>
            <p class="feature-card__desc">
              El CLI no envia datos a ningun lado. Tus especificaciones y scores se quedan en tu maquina.
              Sin cuenta, sin API key, sin dependencia de la nube.
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">Portable</h3>
            <p class="feature-card__desc">
              Un solo binario. macOS, Linux, Windows. Sin dependencias de runtime.
              Funciona en cualquier directorio de especificaciones en Markdown.
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">Open source</h3>
            <p class="feature-card__desc">
              Licencia MIT. El codigo fuente esta en
              <a class="xref" href="https://github.com/specscore/specscore-cli">specscore/specscore-cli</a>.
              Gratis para siempre.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── Uso con agentes de IA ── */}
    <section class="section" aria-labelledby="agents-title">
      <div class="section-inner section-inner--prose">
        <h2 id="agents-title" class="section-title">Usalo con tu agente de IA.</h2>
        <p class="prose-p">
          El CLI es el motor detras de ambos plugins de Claude Code. Si tu
          agente escribe especificaciones, el CLI le dice si estan bien — antes de que
          el agente escriba una sola linea de codigo.
        </p>
        <div class="agent-links">
          <a href="/es/ai/specstudio-skills/" class="btn btn--secondary">SpecStudio Skills</a>
          <a href="/es/ai/cli-skills/" class="btn btn--tertiary">CLI Skills (wrapper liviano)</a>
        </div>
      </div>
    </section>
  </main>

  {/* ── CTA final ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">Specs que pasan.</h2>
      <div class="final-cta__buttons">
        <a href="/es/cli/install/" class="btn btn--primary">Instalar el CLI</a>
        <a href="/es/ai/specstudio-skills/" class="btn btn--secondary">Skills de IA para tu agente</a>
        <a
          href="https://github.com/specscore/specscore-cli"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          Open-source en GitHub
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <SiteFooterEs />
</BaseLayout>

<style>
  /* ── Hero: two-column on desktop (copy left, terminal right),
        stacked on mobile. Mirrors the landing hero's rhythm. ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-7);
    background: var(--cream);
    overflow: hidden;
  }
  .hero__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 30fr 70fr;
    gap: var(--space-3) var(--space-6);
    align-items: center;
  }
  .hero__copy {
    animation: hero-copy-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 280ms;
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__inner > .hero__headline {
    grid-column: 1 / -1;
    margin-bottom: 0;
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    line-height: 1.55;
    max-width: 42ch;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .hero__art {
    animation: hero-art-in 700ms cubic-bezier(0.22, 0.61, 0.36, 1) both 100ms;
    min-width: 0;
  }
  .hero__art pre.terminal {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.65;
  }

  @keyframes hero-copy-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-art-in {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 860px) {
    .hero { padding: var(--space-5) var(--space-3) var(--space-6); }
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .hero__copy { order: 1; }
    .hero__art  { order: 2; }
  }

  /* ── Section titles ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  .section-intro {
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    line-height: 1.6;
  }
  .section-intro code {
    background: var(--cream-2);
    padding: 0.05em 0.35em;
    border-radius: 2px;
    font-size: 0.92em;
    color: var(--ink);
  }

  /* ── Features grid ── */
  .features-section { background: var(--cream-2); }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .feature-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
  }
  .feature-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .feature-card__desc {
    font-size: var(--fs-small);
    color: var(--mid-ink);
    line-height: 1.55;
  }
  .feature-card__desc code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  @media (max-width: 860px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .features-grid { grid-template-columns: 1fr; }
  }

  /* ── AI agents section ── */
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
    margin-bottom: var(--space-3);
  }
  .agent-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: var(--space-3);
  }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    text-align: center;
  }
  .final-cta__title {
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .final-cta__buttons {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>

<QsTabsScript />
