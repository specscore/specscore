---
// SpecStudio Skills — landing page en español.
// Canonical campaign URL: specscore.md/es/ai/specstudio-skills/
// Per STRATEGY.md § Domain authority strategy: this is the mid-funnel
// surface where campaign links (articles, blog posts, social CTAs) point.
// Content follows the marketing draft at marketing/distribution/specstudio-skills-website-homepage.md
// Design matches the specscore.md homepage Astro app (paper-and-ink, same tokens).
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../../components/SiteHeader.astro';
import SiteFooterEs from '../../../../components/SiteFooterEs.astro';
import QsTabsScript from '../../../../components/QsTabsScript.astro';
---

<BaseLayout
  lang="es"
  title="SpecStudio Skills — Specs que tu agente de IA puede seguir de verdad."
  description="Plugin gratuito para Claude Code que convierte prompts improvisados en especificaciones estructuradas y puntuadas que tu agente lee antes de escribir una sola línea de código. Construido sobre el protocolo abierto SpecScore."
  canonical="https://specscore.md/es/ai/specstudio-skills/"
>
  <SiteHeader />

  <main>
    {/* ── Sección 1: Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <h1 id="hero-title" class="hero__headline">
          Specs que tu agente de IA<br />puede seguir de verdad.
        </h1>
        <p class="hero__sub">
          SpecStudio Skills es un plugin gratuito para Claude Code que convierte
          prompts improvisados en especificaciones estructuradas y puntuadas que tu agente
          lee antes de escribir una sola línea de código. Construido sobre el
          protocolo abierto
          <a class="xref" href="/">SpecScore</a>.
        </p>
        <div class="hero__install" id="install">
          <div class="qs-tabs" role="tablist" aria-label="Método de instalación">
            <button type="button" role="tab" id="qs-tab-claude" aria-controls="qs-panel-claude" aria-selected="true" tabindex="0" class="qs-tab is-active" data-tab="claude">Claude Code</button>
            <button type="button" role="tab" id="qs-tab-setup" aria-controls="qs-panel-setup" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="setup">Otros agentes de IA</button>
            <button type="button" role="tab" id="qs-tab-manual" aria-controls="qs-panel-manual" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="manual">Manual</button>
          </div>

          <div id="qs-panel-claude" role="tabpanel" aria-labelledby="qs-tab-claude" class="qs-panel is-active" data-panel="claude">
<pre class="terminal"><span class="prompt">$</span> /plugin marketplace add specscore/ai-marketplace
<span class="prompt">$</span> /plugin install specstudio@specscore</pre>
          </div>
          <div id="qs-panel-setup" role="tabpanel" aria-labelledby="qs-tab-setup" class="qs-panel" data-panel="setup" hidden>
<pre class="terminal"><span class="prompt">$</span> specscore agent setup &lt;nombre-del-agente&gt;</pre>
            <p class="qs-note">
              Escribe el archivo de instrucciones correcto para tu agente —
              <code>claude</code>, <code>copilot</code>, <code>cursor</code>, <code>codex</code>,
              <code>antigravity.google</code>, <code>pi.dev</code> u <code>opencode</code>.
              Ejecuta dentro de un proyecto gestionado por SpecScore. Requiere la
              <a class="xref" href="/es/cli/">SpecScore CLI</a>.
            </p>
          </div>
          <div id="qs-panel-manual" role="tabpanel" aria-labelledby="qs-tab-manual" class="qs-panel" data-panel="manual" hidden>
<pre class="terminal"><span class="prompt">$</span> git clone https://github.com/specscore/specstudio-skills
<span class="prompt">$</span> cp -r specstudio-skills/commands /ruta/a/tu/agente/commands/
<span class="prompt">$</span> cp -r specstudio-skills/skills /ruta/a/tu/agente/skills/</pre>
            <p class="qs-note">
              Clona el repositorio del plugin y copia los directorios
              <code>commands/</code> y <code>skills/</code> donde tu agente carga
              los archivos de comandos y skills.
            </p>
          </div>
        </div>
        <p class="hero__demo-link">
          <a href="#demo" class="xref">Mira el demo de 60 segundos ↓</a>
        </p>
      </div>
    </section>

    {/* ── Sección 2: Demo ── */}
    <section class="section" id="demo" aria-labelledby="demo-title">
      <div class="section-inner">
        <h2 id="demo-title" class="section-title">
          De idea vaga a especificación puntuada, en 60 segundos.
        </h2>

        <div class="demo-placeholder">
          <div class="terminal-frame">
            <div class="terminal-frame__head">
              <span class="terminal-frame__title">Claude Code</span>
              <span class="terminal-frame__hint">demo</span>
            </div>
<pre class="terminal terminal-frame__body"><span class="prompt">&gt;</span> /specstudio:ideate A password reset flow for our SaaS app.

<span class="dim">Refining idea...</span>
<span class="dim">Producing spec/ideas/password-reset.md</span>

<span class="prompt">&gt;</span> /specstudio:specify spec/ideas/password-reset.md

<span class="dim">Writing Feature spec...</span>
<span class="dim">spec/features/password-reset/README.md</span>

<span class="prompt">$</span> specscore lint spec/features/password-reset/
<span class="mark-pass">PASS</span>  Feature: password-reset
  <span class="mark-pass">PASS</span>  has title, status, and description
  <span class="mark-pass">PASS</span>  requirements have acceptance criteria
  <span class="mark-pass">PASS</span>  all AC IDs are unique
  <span class="mark-pass">PASS</span>  no orphan cross-references

<span class="mark-pass">Score: 92 / 100</span></pre>
          </div>
          <p class="demo-caption">
            Sin editar. Sin cortes. Claude Code en blanco → instalar el plugin →
            puntuar una especificación real → tu agente construye lo correcto.
          </p>
        </div>
      </div>
    </section>

    {/* ── Sección 3: El problema ── */}
    <section class="section" aria-labelledby="wedge-title">
      <div class="section-inner section-inner--prose">
        <h2 id="wedge-title" class="section-title">
          Por qué tu agente sigue construyendo lo incorrecto.
        </h2>
        <p class="prose-p">
          Los prompts improvisados funcionan hasta que dejan de hacerlo. El
          agente construyó la mitad del feature. Malinterpretó el requisito.
          Se inventó una llamada a la API. Eligió la librería equivocada. Tú
          vuelves a escribir el prompt. Lo reescribes otra vez. A la tercera
          ronda ya estás escribiendo la especificación completa a mano en el chat.
        </p>
        <p class="prose-p">
          El problema no es el agente. Es que "constrúyeme un feature" no es
          una especificación — es un deseo. Los agentes son estocásticos. Los deseos son
          amigables con lo estocástico. Las especificaciones no.
        </p>
        <p class="prose-p">
          SpecStudio Skills te da un flujo de trabajo para escribir especificaciones que tu
          agente realmente puede interpretar: features estructurados, requisitos,
          criterios de aceptación, puntuados por completitud antes de que el
          agente siquiera los vea. La misma velocidad que el vibe-coding,
          dramáticamente menos varianza en el resultado.
        </p>
      </div>
    </section>

    {/* ── Sección 4: El pipeline ── */}
    <section class="section pipeline-section" aria-labelledby="pipeline-title">
      <div class="section-inner">
        <h2 id="pipeline-title" class="section-title">
          Cuatro comandos. Un pipeline.
        </h2>
        <p class="pipeline-intro">
          Instala una vez, luego ejecútalos en orden — de idea cruda a plan ejecutable.
        </p>

        <div class="pipeline-grid">
          <div class="pipeline-card">
            <div class="pipeline-card__head">
              <span class="pipeline-card__cmd">/ideate</span>
            </div>
            <p class="pipeline-card__desc">
              Refina una idea cruda mediante pensamiento divergente y convergente
              estructurado. Produce un one-pager pre-especificación linteable.
            </p>
          </div>

          <div class="pipeline-card">
            <div class="pipeline-card__head">
              <span class="pipeline-card__cmd">/specify</span>
            </div>
            <p class="pipeline-card__desc">
              Convierte una idea aprobada en un Feature de SpecScore con
              requisitos, criterios de aceptación y bloques Given/When/Then.
            </p>
          </div>

          <div class="pipeline-card">
            <div class="pipeline-card__head">
              <span class="pipeline-card__cmd">/plan</span>
            </div>
            <p class="pipeline-card__desc">
              Descompone un feature en una lista ordenada de tareas. Cada tarea
              se mapea a uno o más criterios de aceptación.
            </p>
          </div>

          <div class="pipeline-card">
            <div class="pipeline-card__head">
              <span class="pipeline-card__cmd">/implement</span>
            </div>
            <p class="pipeline-card__desc">
              Ejecuta la siguiente tarea del plan. Un subagente por tarea,
              commits trazables a AC, diff staged para tu aprobación.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── Sección 5: Qué incluye ── */}
    <section class="section" aria-labelledby="box-title">
      <div class="section-inner section-inner--prose">
        <h2 id="box-title" class="section-title">
          Qué incluye.
        </h2>

        <h3 class="list-heading">Hace:</h3>
        <ul class="feature-list feature-list--does">
          <li>Agrega slash commands para el flujo SDD completo: <code>/ideate</code>, <code>/specify</code>, <code>/plan</code>, <code>/implement</code>.</li>
          <li>Puntúa la completitud y ambigüedad de la especificación antes de que el agente la vea.</li>
          <li>Escribe especificaciones en el formato abierto SpecScore — sin extensiones propietarias.</li>
        </ul>

        <h3 class="list-heading">No hace:</h3>
        <ul class="feature-list feature-list--doesnt">
          <li>Ejecutar el agente por ti. El plugin es una capa de flujo de trabajo; el agente sigue siendo Claude.</li>
          <li>Enviar datos a ningún lado. Las especificaciones y puntuaciones se quedan locales.</li>
          <li>Encerrarte. Si lo desinstalas, tus especificaciones siguen siendo Markdown válido y puntuable con la CLI <a class="xref" href="https://github.com/specscore/specscore">specscore</a>.</li>
        </ul>

        <p class="sibling-callout">
          ¿Buscas la interfaz CLI neutral?
          <a class="xref" href="https://github.com/specscore/ai-plugin-specscore">ai-plugin-specscore</a>
          es el wrapper liviano. SpecStudio Skills es el flujo de trabajo opinado construido encima.
        </p>
      </div>
    </section>

    {/* ── Sección 6: Abierto por dentro ── */}
    <section class="section" aria-labelledby="open-title">
      <div class="section-inner section-inner--prose">
        <h2 id="open-title" class="section-title">
          Construido sobre el protocolo abierto SpecScore.
        </h2>
        <p class="prose-p">
          SpecStudio Skills escribe especificaciones en
          <a class="xref" href="/">SpecScore</a>, un estándar
          abierto. El formato es Markdown legible por humanos. El schema está
          publicado. La CLI es open source. Sin vendor lock-in. Si algún día
          dejas SpecStudio, tus especificaciones se van contigo.
        </p>
      </div>
    </section>
  </main>

  {/* ── CTA final ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">Pruébalo.</h2>
      <div class="final-cta__install">
        <div class="qs-tabs" role="tablist" aria-label="Método de instalación">
          <button type="button" role="tab" id="qs-tab-claude-b" aria-controls="qs-panel-claude-b" aria-selected="true" tabindex="0" class="qs-tab is-active" data-tab="claude">Claude Code</button>
          <button type="button" role="tab" id="qs-tab-setup-b" aria-controls="qs-panel-setup-b" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="setup">Otros agentes de IA</button>
          <button type="button" role="tab" id="qs-tab-manual-b" aria-controls="qs-panel-manual-b" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="manual">Manual</button>
        </div>

        <div id="qs-panel-claude-b" role="tabpanel" aria-labelledby="qs-tab-claude-b" class="qs-panel is-active" data-panel="claude">
<pre class="terminal"><span class="prompt">$</span> /plugin marketplace add specscore/ai-marketplace
<span class="prompt">$</span> /plugin install specstudio@specscore</pre>
        </div>
        <div id="qs-panel-setup-b" role="tabpanel" aria-labelledby="qs-tab-setup-b" class="qs-panel" data-panel="setup" hidden>
<pre class="terminal"><span class="prompt">$</span> specscore agent setup &lt;nombre-del-agente&gt;</pre>
          <p class="qs-note">
            Escribe el archivo de instrucciones correcto para tu agente —
            <code>claude</code>, <code>copilot</code>, <code>cursor</code>, <code>codex</code>,
            <code>antigravity.google</code>, <code>pi.dev</code> u <code>opencode</code>.
            Ejecuta dentro de un proyecto gestionado por SpecScore. Requiere la
            <a class="xref" href="/es/cli/">SpecScore CLI</a>.
          </p>
        </div>
        <div id="qs-panel-manual-b" role="tabpanel" aria-labelledby="qs-tab-manual-b" class="qs-panel" data-panel="manual" hidden>
<pre class="terminal"><span class="prompt">$</span> git clone https://github.com/specscore/specstudio-skills
<span class="prompt">$</span> cp -r specstudio-skills/commands /ruta/a/tu/agente/commands/
<span class="prompt">$</span> cp -r specstudio-skills/skills /ruta/a/tu/agente/skills/</pre>
          <p class="qs-note">
            Clona el repositorio del plugin y copia los directorios
            <code>commands/</code> y <code>skills/</code> donde tu agente carga
            los archivos de comandos y skills.
          </p>
        </div>
      </div>
      <p class="final-cta__note">
        Gratuito para repositorios públicos y open-source. Licencia MIT.
      </p>
    </div>
  </section>

  {/* ── Footer ── */}
  <SiteFooterEs />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-7) var(--space-3) var(--space-6);
    background: var(--cream);
  }
  .hero__inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms;
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    line-height: 1.55;
  }
  .hero__install {
    margin-bottom: var(--space-3);
  }
  .hero__demo-link {
    font-size: var(--fs-small);
    color: var(--mid-ink);
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Section titles ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }

  /* ── Demo ── */
  .demo-placeholder {
    margin-top: var(--space-3);
  }
  .demo-caption {
    margin-top: var(--space-2);
    font-size: var(--fs-small);
    color: var(--mid-ink);
  }

  /* Terminal frame (shared with homepage AiSkills pattern) */
  .terminal-frame {
    border: 1px solid var(--hairline);
    background: var(--surface);
  }
  .terminal-frame__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.5rem 0.875rem;
    border-bottom: 1px solid var(--hairline);
    background: var(--cream-2);
    font-family: var(--font-code);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .terminal-frame__title { color: var(--graphite); font-weight: 700; }
  .terminal-frame__hint  { color: var(--mid-ink); }
  .terminal-frame__body  { border: none !important; }

  /* ── Wedge (prose sections) ── */
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
    margin-bottom: var(--space-3);
  }
  .prose-p:last-child {
    margin-bottom: 0;
  }

  /* ── Pipeline grid ── */
  .pipeline-section {
    background: var(--cream-2);
  }
  .pipeline-intro {
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    line-height: 1.6;
  }
  .pipeline-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
  }
  .pipeline-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
  }
  .pipeline-card__head {
    margin-bottom: var(--space-2);
  }
  .pipeline-card__cmd {
    font-family: var(--font-code);
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
  }
  .pipeline-card__desc {
    font-size: var(--fs-small);
    color: var(--mid-ink);
    line-height: 1.55;
  }

  @media (max-width: 860px) {
    .pipeline-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .pipeline-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── What's in the box ── */
  .list-heading {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-top: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .list-heading:first-of-type {
    margin-top: 0;
  }
  .feature-list {
    margin: 0 0 var(--space-3) 0;
    padding-left: 1.25rem;
    color: var(--mid-ink);
    line-height: 1.65;
  }
  .feature-list li {
    margin-bottom: 0.5rem;
  }
  .feature-list li:last-child {
    margin-bottom: 0;
  }
  .feature-list code {
    font-size: 0.9em;
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: 0.1em 0.35em;
    border-radius: 2px;
  }
  .sibling-callout {
    margin-top: var(--space-4);
    padding: var(--space-2) var(--space-3);
    border-left: 3px solid var(--hairline);
    font-size: var(--fs-small);
    color: var(--mid-ink);
    line-height: 1.55;
  }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    text-align: center;
  }
  .final-cta__title {
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .final-cta__install {
    display: inline-block;
    text-align: left;
    margin-bottom: var(--space-3);
  }
  .final-cta__note {
    color: var(--mid-ink);
    font-size: var(--fs-small);
  }
</style>

<QsTabsScript />
