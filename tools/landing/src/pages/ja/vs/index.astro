---
// /ja/vs/ — Comparison index page (ja).
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooterJa from '../../../components/SiteFooterJa.astro';
import ComparisonFeedback from '../../../components/ComparisonFeedback.astro';
---

<BaseLayout
  lang="ja"
  title="SpecScore vs — SpecScore との比較"
  description="SpecScore と他のスペック駆動開発ツールとの誠実で詳細な比較。機能比較表、アーキテクチャの違い、適切な使い分けをご紹介します。"
  canonical="https://specscore.md/ja/vs/"
>
  <SiteHeader />

  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <h1 id="hero-title" class="hero__headline">
          SpecScore との比較
        </h1>
        <p class="hero__sub">
          スペック駆動開発は成長中の分野です。これらの比較は事実に基づき、各ツールの強みを正直に並べて紹介しています。
        </p>
      </div>
    </section>

    <section class="section" aria-labelledby="comparisons-title">
      <div class="section-inner">
        <h2 id="comparisons-title" class="sr-only">比較一覧</h2>

        <div class="compare-grid">
          <a href="/ja/vs/openspec/" class="compare-card">
            <h3 class="compare-card__name">SpecScore vs OpenSpec</h3>
            <p class="compare-card__desc">
              どちらも Markdown でスペックを記述します。OpenSpec はスペックを整理し、SpecScore は lint、スコアリング、トレーサビリティを提供します。フォーマット、CLI、ライフサイクル、トレーサビリティ、エージェント対応の完全比較です。
            </p>
            <span class="compare-card__cta">比較を読む →</span>
          </a>
        </div>
      </div>
    </section>

    <ComparisonFeedback />
  </main>

  <SiteFooterJa />
</BaseLayout>

<style>
  .hero { padding: var(--space-6) var(--space-3) var(--space-5); background: var(--cream); }
  .hero__inner { max-width: var(--max-prose); margin: 0 auto; animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms; }
  .hero__headline { font-size: var(--fs-h2); font-weight: 700; letter-spacing: -0.01em; margin-bottom: var(--space-3); }
  .hero__sub { font-size: 1.125rem; color: var(--mid-ink); line-height: 1.55; }
  @keyframes fade-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }
  .compare-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-3); }
  .compare-card { display: block; background: var(--surface); border: 1px solid var(--hairline); padding: var(--space-4); transition: border-color 160ms ease, box-shadow 160ms ease; text-decoration: none; color: inherit; }
  .compare-card:hover { border-color: var(--graphite); box-shadow: 0 2px 8px rgba(26, 26, 26, 0.06); }
  .compare-card:focus-visible { outline: 2px solid var(--ink-blue); outline-offset: 2px; }
  .compare-card__name { font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; margin-bottom: var(--space-2); }
  .compare-card__desc { color: var(--mid-ink); font-size: var(--fs-body); line-height: 1.6; margin-bottom: var(--space-3); }
  .compare-card__cta { font-family: var(--font-display); font-size: var(--fs-small); font-weight: 600; color: var(--validator-green); }
  @media (max-width: 720px) { .compare-grid { grid-template-columns: 1fr; } }
</style>
