---
// /ja/vs/codespeak/ — SpecScore vs CodeSpeak comparison (ja).
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../../components/SiteHeader.astro';
import SiteFooterJa from '../../../../components/SiteFooterJa.astro';
import ComparisonFeedback from '../../../../components/ComparisonFeedback.astro';
---

<BaseLayout
  lang="ja"
  title="SpecScore vs CodeSpeak — 誠実な比較"
  description="SpecScore と CodeSpeak の事実に基づいた並列比較：スペック・アズ・ソース vs スペック・アズ・コントラクト、コード生成、可搬性、linting、トレーサビリティ。"
  canonical="https://specscore.md/ja/vs/codespeak/"
>
  <SiteHeader />

  <main>
    {/* ── Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <p class="hero__breadcrumb"><a href="/ja/vs/" class="xref">比較一覧</a></p>
        <h1 id="hero-title" class="hero__headline">
          SpecScore vs CodeSpeak
        </h1>
        <p class="hero__sub">
          「スペックは何のためにあるべきか」への2つの答え。CodeSpeak はスペックを
          <strong>ソースコード</strong> として扱います — LLM がそれをコンパイルし、あなたは
          コードの代わりにスペックを保守します。SpecScore はスペックを <strong>永続的で
          オープンな契約</strong> として扱います — あなたはコードを保ち、どんなエージェント
          （あるいはなし）でも、それを読み・lint し・トレースできます。
        </p>
      </div>
    </section>

    {/* ── What they share ── */}
    <section class="section" aria-labelledby="shared-title">
      <div class="section-inner section-inner--prose">
        <h2 id="shared-title" class="section-title">共通点。</h2>
        <ul class="shared-list">
          <li>どちらもソフトウェア開発の中心に仕様を置きます。</li>
          <li>どちらも AI 支援の世界のために作られています — 実装の前に意図を。</li>
          <li>どちらもスペックを変えることでソフトウェアを変えやすくすることを目指します。</li>
        </ul>
      </div>
    </section>

    {/* ── What CodeSpeak does well ── */}
    <section class="section" aria-labelledby="codespeak-title">
      <div class="section-inner section-inner--prose">
        <h2 id="codespeak-title" class="section-title">CodeSpeak の優れた点。</h2>
        <p class="section-note">
          <a href="https://codespeak.dev/" rel="nofollow noopener" target="_blank" class="xref">CodeSpeak</a>
          は構造化英語のスペックをコードにコンパイルする、LLM 駆動のプログラミングシステムです。
        </p>

        <div class="credit-card">
          <h3 class="credit-card__title">大胆な、説得力ある主張</h3>
          <p class="credit-card__desc">
            「コードではなくスペックを保守する」は、漸進的な微調整ではなく本物の再定義です。
            これは Kotlin 言語の設計者から生まれたもので、真剣に受け止める価値があります：
            スペックがソースなら、生成されたコードは実装の詳細になります。
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">コードからスペックへの引き継ぎ</h3>
          <p class="credit-card__desc">
            <code>codespeak takeover</code> は既存のソースを読み、その振る舞いを捉えるスペックを
            生成します — ブラウンフィールドのコードへの摩擦の少ない入り口で、報告されている
            スペック対コードの圧縮率はおよそ 5〜10× です。
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">エージェントセッションからの意図の復元</h3>
          <p class="credit-card__desc">
            CodeSpeak の Intent Studio は、過去のエージェントセッションから要件を抽出します —
            白紙からスペックを書くよう求める代わりに、すでに表現された意図を収穫します。
          </p>
        </div>
      </div>
    </section>

    {/* ── Feature comparison table ── */}
    <section class="section table-section" aria-labelledby="table-title">
      <div class="section-inner">
        <h2 id="table-title" class="section-title">機能比較。</h2>
        <p class="section-note">
          両者は異なる賭けをしているため、この表は勝者ではなく哲学とメカニズムを比較します。
        </p>

        <div class="table-wrap">
          <table class="compare-table" aria-label="SpecScore vs CodeSpeak 機能比較">
            <thead>
              <tr>
                <th scope="col">機能</th>
                <th scope="col">CodeSpeak</th>
                <th scope="col">SpecScore</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>真実の源</td>
                <td>スペック（コンパイル入力）</td>
                <td><strong>スペックは契約、コードは成果物</strong></td>
              </tr>
              <tr>
                <td>生成されたコード</td>
                <td>LLM が生成、手で保守しない</td>
                <td><strong>あなたとエージェントがコードを書き、所有する</strong></td>
              </tr>
              <tr>
                <td>スペックフォーマット</td>
                <td>平易な英語、CodeSpeak 定義</td>
                <td><strong>オープンな Markdown + YAML 標準</strong>、公開スキーマ</td>
              </tr>
              <tr>
                <td>スペック → コード</td>
                <td>中核機能（プロプライエタリな LLM コンパイラ）</td>
                <td>対象外 — どんなエージェントでも実装</td>
              </tr>
              <tr>
                <td>ベンダーなしで動作</td>
                <td>スペックは CodeSpeak を通じてコンパイル</td>
                <td><strong>あり</strong> — スペックはどんなエージェントでも、あるいはなしでも動作</td>
              </tr>
              <tr>
                <td>スペック linting</td>
                <td>ドキュメントなし</td>
                <td><strong>コンテンツ品質</strong> — 曖昧な動詞、欠落した AC、未解決の参照</td>
              </tr>
              <tr>
                <td>コードからスペックへのトレーサビリティ</td>
                <td>再生成を通じて</td>
                <td><strong><code>specscore:</code> アノテーション</strong> + <code>Verifies:</code> トレーラー</td>
              </tr>
              <tr>
                <td>決定論性</td>
                <td>LLM コンパイル（非決定論的）</td>
                <td><strong>決定論的な CLI クエリ</strong>。コードは通常どおり記述</td>
              </tr>
              <tr>
                <td>コード → スペック</td>
                <td><strong><code>codespeak takeover</code></strong></td>
                <td><code>survey</code> + 執筆</td>
              </tr>
              <tr>
                <td>オープン性</td>
                <td>プロプライエタリなシステム</td>
                <td><strong>オープン</strong> — CC BY 4.0 フォーマット、MIT / Apache-2.0 ツール</td>
              </tr>
              <tr>
                <td>ステージ</td>
                <td>アルファプレビュー</td>
                <td>リリース済み</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {/* ── Where SpecScore differs ── */}
    <section class="section" aria-labelledby="further-title">
      <div class="section-inner">
        <h2 id="further-title" class="section-title">SpecScore が異なる点。</h2>

        <div class="diff-grid">
          <div class="diff-card">
            <h3 class="diff-card__title">コードはあなたのもの</h3>
            <p class="diff-card__desc">
              CodeSpeak は実装を生成・再生成します。コードは出力であって、資産ではありません。
              SpecScore はコードをあるべき場所に残します — あなたの手の中、あなたの言語で、
              一行ずつレビュー可能に。スペックはコードを奪うことなく、明瞭さとトレーサビリティを
              加えます。
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">スペックは可搬</h3>
            <p class="diff-card__desc">
              CodeSpeak のスペックは、CodeSpeak がコンパイルするからこそ価値があります。SpecScore の
              スペックはそれ自体で価値があります — どんなエージェントも読める、よく構造化された
              Markdown であり、SpecScore のツールを一切インストールしなくても有用であり続けます。
              どんなツールでも、あるいはなしでも導入できます。いつでも離れられます。
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">曖昧さはコストになる前に検出される</h3>
            <p class="diff-card__desc">
              LLM コンパイラでは、曖昧なスペックはビルド時に誤ったコードになります。
              SpecScore の <code>lint</code> は、曖昧な動詞、欠落した受け入れ基準、未解決の参照を、
              エージェントが行動する <em>前に</em> 表面化させます。
            </p>
            <div class="diff-card__example">
<pre class="terminal"><span class="prompt">$</span> specscore lint checkout/apply-discount.md
  <span class="mark-fail">✗</span> R3  no acceptance criteria
  <span class="mark-fail">✗</span> verb  <span class="dim">"handle gracefully" — 測定不能</span></pre>
            </div>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">決定論性とトレーサビリティ</h3>
            <p class="diff-card__desc">
              「これを実装しているコードはどれか？」への CodeSpeak の答えは「すべて、再生成される」です。
              SpecScore の答えは特定のファイルと行です — <code>specscore code refs</code> と
              <code>Verifies:</code> コミットトレーラーを介して — 決定論的、監査可能、diff 可能です。
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">構造化されたアーティファクトグラフ</h3>
            <p class="diff-card__desc">
              CodeSpeak の単位は散文のスペックファイルです。SpecScore は型付けされた階層を持ちます —
              アイデアはフィーチャーに昇格し、フィーチャーは ID 付きの要件と受け入れ基準を含み、
              プランは AC を参照し、タスクはプランを参照します — すべて機械的にナビゲート可能です。
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">ビルドパスにベンダーなし</h3>
            <p class="diff-card__desc">
              SpecScore は単一の Go バイナリです。Lint は CI や pre-commit フックで実行され、
              アカウントも、サービス呼び出しも、ビルド中の LLM ラウンドトリップもありません。
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── When to use which ── */}
    <section class="section" aria-labelledby="when-title">
      <div class="section-inner">
        <h2 id="when-title" class="section-title">使い分けの指針。</h2>

        <div class="when-grid">
          <div class="when-card">
            <h3 class="when-card__title">CodeSpeak を選ぶべきなのは…</h3>
            <ul class="when-card__list">
              <li>コードの保守をやめ、スペックをソースにしたい場合。</li>
              <li>そのレバレッジのために、ベンダーのコンパイラへの依存を許容できる場合。</li>
              <li>既存のコードベースをはるかに短いスペックに圧縮したい場合。</li>
            </ul>
          </div>

          <div class="when-card when-card--primary">
            <h3 class="when-card__title">SpecScore を使うべきなのは…</h3>
            <ul class="when-card__list">
              <li>単一のツールより長生きするスペックが欲しい場合 — 構造上、可搬。</li>
              <li>コードをあなたの言語で、レビュー可能・所有可能なまま保ちたい場合。</li>
              <li>スペック品質の強制が必要な場合 — lint が曖昧さを早期に検出します。</li>
              <li>決定論的なコードからスペックへのトレーサビリティが必要な場合。</li>
              <li>ビルドパスにベンダーも LLM ラウンドトリップも欲しくない場合。</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── Two different bets ── */}
    <section class="section" aria-labelledby="bets-title">
      <div class="section-inner section-inner--prose">
        <h2 id="bets-title" class="section-title">2つの異なる賭け。</h2>
        <p class="prose-p">
          CodeSpeak はコンパイラへの賭けです：スペックを渡し、コードを生成・再現することを信頼します。
          SpecScore はフォーマットへの賭けです：スペックをオープンで可搬に保ち、コードをあなたのものに保ち、
          どんなエージェントもそれに対して作業できるようにします。
        </p>
        <p class="prose-p">
          一方は可搬性をレバレッジと引き換えにします。もう一方はあなたを自由に保ちます — そして lint 可能に。
        </p>
      </div>
    </section>

    <ComparisonFeedback page="codespeak" />
  </main>

  {/* ── Final CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">合格するスペックを。</h2>
      <div class="final-cta__buttons">
        <a href="/cli/install/" class="btn btn--primary">CLI をインストール</a>
        <a href="/ai/specstudio-skills/" class="btn btn--secondary">エージェント用 AI スキルを入手</a>
        <a
          href="https://github.com/specscore/specscore"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          GitHub でオープンソース公開中
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <SiteFooterJa />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-5);
    background: var(--cream);
  }
  .hero__inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms;
  }
  .hero__breadcrumb {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--pale-ink);
    margin-bottom: var(--space-2);
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
    max-width: 52ch;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Section titles ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }

  /* ── Shared list ── */
  .shared-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .shared-list li {
    position: relative;
    padding-left: 1.4rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
  }
  .shared-list li::before {
    content: '=';
    position: absolute;
    left: 0;
    font-family: var(--font-code);
    font-weight: 700;
    color: var(--pale-ink);
  }

  /* ── Section note ── */
  .section-note {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    margin-bottom: var(--space-3);
  }

  /* ── Credit cards ── */
  .credit-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .credit-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .credit-card__desc {
    color: var(--mid-ink);
    line-height: 1.6;
    font-size: var(--fs-body);
  }
  .credit-card__desc code {
    font-size: 0.9em;
    background: var(--cream);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Feature comparison table ── */
  .table-section { background: var(--cream-2); }
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-small);
    line-height: 1.5;
  }
  .compare-table th,
  .compare-table td {
    text-align: left;
    padding: 0.65rem 0.85rem;
    border-bottom: 1px solid var(--hairline);
    vertical-align: top;
  }
  .compare-table thead th {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mid-ink);
    border-bottom: 2px solid var(--graphite);
    white-space: nowrap;
  }
  .compare-table td:first-child {
    font-weight: 500;
    white-space: nowrap;
    min-width: 160px;
  }
  .compare-table td:nth-child(2),
  .compare-table td:nth-child(3) {
    min-width: 200px;
  }
  .compare-table td code {
    font-size: 0.88em;
    background: var(--surface);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .compare-table strong {
    font-weight: 600;
    color: var(--ink);
  }

  /* ── Diff grid ── */
  .diff-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .diff-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
  }
  .diff-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .diff-card__desc {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    line-height: 1.6;
  }
  .diff-card__desc code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .diff-card__example {
    margin-top: var(--space-2);
  }
  .diff-card__example .terminal {
    font-size: 0.78rem;
    line-height: 1.6;
  }

  @media (max-width: 860px) {
    .diff-grid { grid-template-columns: 1fr; }
  }

  /* ── When to use which ── */
  .when-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .when-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-4);
  }
  .when-card--primary {
    border-color: var(--validator-green);
    border-width: 2px;
  }
  .when-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .when-card__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .when-card__list li {
    position: relative;
    padding-left: 1.2rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
    font-size: var(--fs-small);
  }
  .when-card__list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--pale-ink);
    font-family: var(--font-code);
  }
  .when-card--primary .when-card__list li::before {
    color: var(--validator-green);
  }
  .when-card__list code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  @media (max-width: 860px) {
    .when-grid { grid-template-columns: 1fr; }
  }

  /* ── Bets section ── */
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
    margin-bottom: var(--space-2);
