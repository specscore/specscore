---
// /ja/vs/datarim/ — SpecScore vs Datarim comparison (ja).
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../../components/SiteHeader.astro';
import SiteFooterJa from '../../../../components/SiteFooterJa.astro';
import ComparisonFeedback from '../../../../components/ComparisonFeedback.astro';
---

<BaseLayout
  lang="ja"
  title="SpecScore vs Datarim — 誠実な比較"
  description="SpecScore と Datarim の事実に基づいた比較：Claude Code ワークフローパック vs オープンで可搬なスペックフォーマット。異なるレイヤー — そして組み合わせられます。"
  canonical="https://specscore.md/ja/vs/datarim/"
>
  <SiteHeader />

  <main>
    {/* ── Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <p class="hero__breadcrumb"><a href="/ja/vs/" class="xref">比較一覧</a></p>
        <h1 id="hero-title" class="hero__headline">
          SpecScore vs Datarim
        </h1>
        <p class="hero__sub">
          異なるレイヤーです。Datarim は Claude Code 向けの意見を持った
          <strong>ワークフローパック</strong> — 要件から完了までプロジェクトを動かす
          スラッシュコマンドです。SpecScore はスペックを書く <strong>オープンフォーマット</strong>
          であり、それを lint・クエリ・トレースする CLI です。ワークフローはこれを対象にできます。
        </p>
      </div>
    </section>

    {/* ── What they share ── */}
    <section class="section" aria-labelledby="shared-title">
      <div class="section-inner section-inner--prose">
        <h2 id="shared-title" class="section-title">共通点。</h2>
        <ul class="shared-list">
          <li>どちらも AI 支援開発に構造化された方法論をもたらします。</li>
          <li>どちらも MIT ライセンスのオープンソースです。</li>
          <li>どちらも Claude Code の中で動作します — Datarim はコマンドとして、SpecScore は SpecStudio Skills を介して。</li>
          <li>どちらも状態を Markdown としてリポジトリに保持し、バージョン管理します。</li>
        </ul>
      </div>
    </section>

    {/* ── What Datarim does well ── */}
    <section class="section" aria-labelledby="datarim-title">
      <div class="section-inner section-inner--prose">
        <h2 id="datarim-title" class="section-title">Datarim の優れた点。</h2>
        <p class="section-note">
          <a href="https://github.com/Arcanada-one/datarim" rel="nofollow noopener" target="_blank" class="xref">Datarim</a>
          は Claude Code 向けに作られた汎用的な反復ワークフローフレームワークです。
        </p>

        <div class="credit-card">
          <h3 class="credit-card__title">ネイティブなスラッシュコマンド UX</h3>
          <p class="credit-card__desc">
            コマンドとしての完全なパイプライン — <code>/dr-prd</code>、<code>/dr-plan</code>、
            <code>/dr-design</code>、<code>/dr-do</code>、<code>/dr-qa</code> — が Claude Code に
            馴染みます。<code>~/.claude/</code> へ <code>install.sh</code> を一度実行すれば、
            すぐに動き出します。
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">複雑さを意識したルーティング（L1〜L4）</h3>
          <p class="credit-card__desc">
            Datarim は作業の規模を測り、それに応じてルーティングします：L1 のクイックフィックスは
            計画をスキップし、L4 の大規模変更は複数のレビューサイクルを含む段階的パイプラインを
            実行します。儀式をスコープに合わせるのは、実に優れたアイデアです。
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">consilium とマルチドメインの広がり</h3>
          <p class="credit-card__desc">
            その「consilium」は、決定を推奨する前にエージェントのパネルを招集してトレードオフを
            議論させます。そしてソフトウェア専用ではありません — Datarim はリサーチ、法務、
            コンテンツのワークフローも対象としています。
          </p>
        </div>
      </div>
    </section>

    {/* ── Feature comparison table ── */}
    <section class="section table-section" aria-labelledby="table-title">
      <div class="section-inner">
        <h2 id="table-title" class="section-title">機能比較。</h2>
        <p class="section-note">
          一方はワークフロー、もう一方はフォーマット — この表は勝者ではなく役割を比較します。
        </p>

        <div class="table-wrap">
          <table class="compare-table" aria-label="SpecScore vs Datarim 機能比較">
            <thead>
              <tr>
                <th scope="col">機能</th>
                <th scope="col">Datarim</th>
                <th scope="col">SpecScore</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>主な役割</td>
                <td>Claude Code ワークフローパック</td>
                <td><strong>オープンなスペックフォーマット + CLI</strong></td>
              </tr>
              <tr>
                <td>実行形態</td>
                <td>スラッシュコマンド（<code>/dr-*</code>）</td>
                <td>フォーマットファイル + CLI <span class="dim">（+ Claude Code 内の SpecStudio Skills）</span></td>
              </tr>
              <tr>
                <td>状態の保存</td>
                <td><code>backlog.md</code> + <code>CLAUDE.md</code>（ワークフロー形式）</td>
                <td><strong>可搬な <code>spec/</code> ツリー</strong>（Markdown + YAML）</td>
              </tr>
              <tr>
                <td>ツールなしでも残る</td>
                <td>Datarim ランタイムに結びついている</td>
                <td><strong>あり</strong> — 構造上、可搬</td>
              </tr>
              <tr>
                <td>スペック linting</td>
                <td>なし</td>
                <td><strong>コンテンツ品質</strong> — 曖昧な動詞、欠落した AC、未解決の参照</td>
              </tr>
              <tr>
                <td>要件 / AC ID</td>
                <td>なし</td>
                <td><strong>機械可読な ID</strong>（<code>REQ: slug</code>）</td>
              </tr>
              <tr>
                <td>コードからスペックへのトレーサビリティ</td>
                <td>なし</td>
                <td><strong><code>specscore:</code> アノテーション</strong> + <code>Verifies:</code> トレーラー</td>
              </tr>
              <tr>
                <td>複雑さルーティング（L1〜L4）</td>
                <td><strong>あり</strong></td>
                <td>なし（フォーマットであり、ワークフローではない）</td>
              </tr>
              <tr>
                <td>クエリ可能なスペックグラフ</td>
                <td>なし</td>
                <td><strong>あり</strong> — <code>feature list / show / deps</code></td>
              </tr>
              <tr>
                <td>Claude Code への結びつき</td>
                <td>そのために作られている</td>
                <td><strong>なし</strong> — どんなエージェントでも、あるいはなしでも</td>
              </tr>
              <tr>
                <td>ライセンス</td>
                <td>MIT</td>
                <td>MIT / CC BY 4.0</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {/* ── Where SpecScore goes further ── */}
    <section class="section" aria-labelledby="further-title">
      <div class="section-inner">
        <h2 id="further-title" class="section-title">SpecScore が加えるもの。</h2>

        <div class="diff-grid">
          <div class="diff-card">
            <h3 class="diff-card__title">出力はワークフローより長生きする</h3>
            <p class="diff-card__desc">
              Datarim の状態は、それ自身のバックログと <code>CLAUDE.md</code> の形に存在します —
              Datarim を実行している間は価値があります。SpecScore のスペックは、SpecScore のツールを
              一切インストールしなくても、読め・lint でき・クエリできる可搬なフォーマットです。
              ワークフローは変わってもいい。スペックはあなたと共に残ります。
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">スペックは lint 可能</h3>
            <p class="diff-card__desc">
              ワークフローは執筆を導きますが、結果をゲートしません。SpecScore の
              <code>lint</code> は、すべての要件に受け入れ基準があるか、相互参照が解決するか、
              ステータス遷移が妥当かを検査します。
            </p>
            <div class="diff-card__example">
<pre class="terminal"><span class="prompt">$</span> specscore lint checkout/apply-discount.md
  <span class="mark-fail">✗</span> R3  no acceptance criteria
  <span class="mark-fail">✗</span> link  <span class="dim">"Related Feature: discount-tiers" not found</span></pre>
            </div>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">コードがスペックまでトレースできる</h3>
            <p class="diff-card__desc">
              SpecScore は <code>specscore:</code> ソースアノテーションと
              <code>Verifies:</code> コミットトレーラーを加えます — <code>specscore code refs</code>
              が「この要件を実装しているコードはどれか？」に、スペックを生み出したワークフローとは
              独立して確定的に答えます。
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">1つのエージェントに縛られない</h3>
            <p class="diff-card__desc">
              Datarim は Claude Code 向けに作られています。SpecScore はどんなエージェントも読める
              フォーマットであり、どんな CI も実行できる単一の Go バイナリです — Claude Code も、
              <code>~/.claude/</code> へのインストールも不要です。
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── When to use which ── */}
    <section class="section" aria-labelledby="when-title">
      <div class="section-inner">
        <h2 id="when-title" class="section-title">使い分けの指針。</h2>

        <div class="when-grid">
          <div class="when-card">
            <h3 class="when-card__title">Datarim を選ぶべきなのは…</h3>
            <ul class="when-card__list">
              <li>今すぐ Claude Code の中で、完結した意見を持つパイプラインが欲しい場合。</li>
              <li>複雑さを意識したルーティングと、マルチエージェントの意思決定儀式を重視する場合。</li>
              <li>作業がドメインをまたぐ場合 — コードだけでなく、リサーチ、法務、コンテンツ。</li>
            </ul>
          </div>

          <div class="when-card when-card--primary">
            <h3 class="when-card__title">SpecScore を使うべきなのは…</h3>
            <ul class="when-card__list">
              <li>単一のワークフローやツールより長生きするスペックが欲しい場合。</li>
              <li>lint、ID、ライフサイクル、コードからスペックへのトレーサビリティが必要な場合。</li>
              <li>Claude Code だけでなく、エージェントをまたいで — あるいはなしで — 作業する場合。</li>
              <li>リポジトリの再読の代わりに、エージェントがクエリできる CLI が欲しい場合。</li>
              <li>ゼロ以外で終了するスペック品質ゲートが CI に必要な場合。</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── Two packs, one format ── */}
    <section class="section" aria-labelledby="bridge-title">
      <div class="section-inner section-inner--prose">
        <h2 id="bridge-title" class="section-title">2つのワークフローパック、1つのオープンフォーマット。</h2>
        <p class="prose-p">
          Datarim と SpecStudio Skills は、どちらも Claude Code の上に乗る意見を持ったワークフローです。
          SpecScore はその下にあるオープンフォーマット — パイプラインが終わった後もスペックが
          可搬で・lint 可能で・トレース可能であり続けるよう、ワークフローが生成できるアーティファクトです。
          SpecScore を出力する Datarim なら、その UX を保ちつつ永続的な出力を得られるでしょう。
        </p>
        <p class="prose-p">
          パイプラインには Datarim を。それが残すアーティファクトには SpecScore を。
        </p>
      </div>
    </section>

    <ComparisonFeedback page="datarim" />
  </main>

  {/* ── Final CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">合格するスペックを。</h2>
      <div class="final-cta__buttons">
        <a href="/cli/install/" class="btn btn--primary">CLI をインストール</a>
        <a href="/ai/specstudio-skills/" class="btn btn--secondary">エージェント用 AI スキルを入手</a>
        <a
          href="https://github.com/specscore/specscore"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          GitHub でオープンソース公開中
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <SiteFooterJa />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-5);
    background: var(--cream);
  }
  .hero__inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms;
  }
  .hero__breadcrumb {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--pale-ink);
    margin-bottom: var(--space-2);
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
    max-width: 52ch;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Section titles ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }

  /* ── Shared list ── */
  .shared-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .shared-list li {
    position: relative;
    padding-left: 1.4rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
  }
  .shared-list li::before {
    content: '=';
    position: absolute;
    left: 0;
    font-family: var(--font-code);
    font-weight: 700;
    color: var(--pale-ink);
  }

  /* ── Section note ── */
  .section-note {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    margin-bottom: var(--space-3);
  }

  /* ── Credit cards ── */
  .credit-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .credit-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .credit-card__desc {
    color: var(--mid-ink);
    line-height: 1.6;
    font-size: var(--fs-body);
  }
  .credit-card__desc code {
    font-size: 0.9em;
    background: var(--cream);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Feature comparison table ── */
  .table-section { background: var(--cream-2); }
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-small);
    line-height: 1.5;
  }
  .compare-table th,
  .compare-table td {
    text-align: left;
    padding: 0.65rem 0.85rem;
    border-bottom: 1px solid var(--hairline);
    vertical-align: top;
  }
  .compare-table thead th {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mid-ink);
    border-bottom: 2px solid var(--graphite);
    white-space: nowrap;
  }
  .compare-table td:first-child {
    font-weight: 500;
    white-space: nowrap;
    min-width: 160px;
  }
  .compare-table td:nth-child(2),
  .compare-table td:nth-child(3) {
    min-width: 200px;
  }
  .compare-table td code {
    font-size: 0.88em;
    background: var(--surface);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .compare-table strong {
    font-weight: 600;
    color: var(--ink);
  }
  .compare-table .dim {
    color: var(--pale-ink);
  }

  /* ── Diff grid ── */
  .diff-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .diff-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
  }
  .diff-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .diff-card__desc {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    line-height: 1.6;
  }
  .diff-card__desc code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .diff-card__example {
    margin-top: var(--space-2);
  }
  .diff-card__example .terminal {
    font-size: 0.78rem;
    line-height: 1.6;
  }

  @media (max-width: 860px) {
    .diff-grid { grid-template-columns: 1fr; }
  }

  /* ── When to use which ── */
  .when-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .when-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-4);
  }
  .when-card--primary {
    border-color: var(--validator-green);
    border-width: 2px;
  }
  .when-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .when-card__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .when-card__list li {
    position: relative;
    padding-left: 1.2rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
    font-size: var(--fs-small);
  }
  .when-card__list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--pale-ink);
    font-family: var(--font-code);
  }
  .when-card--primary .when-card__list li::before {
    color: var(--validator-green);
  }
  .when-card__list code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  @media (max-width: 860px) {
    .when-grid { grid-template-columns: 1fr; }
  }

  /* ── Bridge section ── */
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
    margin-bottom: var(--space-2);
  }
  .prose-p:last-child {
    margin-bottom: 0;
    font-weight: 500;
    color: var(--ink);
  }
  .prose-p code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-content);
    margin: 0 auto;
