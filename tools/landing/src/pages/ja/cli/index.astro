---
// SpecScore CLI — プロダクトページ (JA).
// SpecScore仕様のためのオープンソースリンター。
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooterJa from '../../../components/SiteFooterJa.astro';
import LintExample from '../../../components/LintExample.astro';
import HeroGitHubLink from '../../../components/HeroGitHubLink.astro';
import QsTabsScript from '../../../components/QsTabsScript.astro';
---

<BaseLayout
  lang="ja"
  title="SpecScore CLI — 仕様をリントしよう。コードと同じように。"
  description="SpecScore仕様のオープンソースリンター。コマンドラインまたはCIパイプラインから機能、要件、受け入れ基準を検証。アカウント不要、テレメトリなし。"
  canonical="https://specscore.md/ja/cli/"
>
  <SiteHeader />

  <main>
    {/* ── ヒーロー ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <h1 id="hero-title" class="hero__headline">
          仕様をリントしよう。<br />コードと同じように。
        </h1>
        <div class="hero__copy">
          <p class="hero__sub">
            SpecScore CLIはコマンドラインから機能、要件、受け入れ基準を
            検証します。ローカルで実行、CIに組み込み、またはAIエージェントから
            呼び出し。オープンソース、アカウント不要、テレメトリなし。
          </p>
          <HeroGitHubLink repo="specscore/specscore-cli" label="GitHubでオープンソース公開中" />
          <div class="hero__cta">
            <a href="/ja/cli/install/" class="btn btn--primary">インストール</a>
          </div>        </div>

        <div
          class="hero__art"
          role="img"
          aria-label="specscore lint のターミナル出力：R1 と R2 には受け入れ基準があり（緑のチェック）、R3 には存在せず、Related Feature リンクが解決されず、必須の Open Questions セクションが欠落（赤のマーク）。3 problems、exit 1。"
        >
<LintExample />
        </div>
      </div>
    </section>

    {/* ── クイックインストール ── */}
    <section class="section" id="install" aria-labelledby="install-title">
      <div class="section-inner">
        <h2 id="install-title" class="section-title">60秒でインストール。</h2>

        <div class="qs-tabs" role="tablist" aria-label="お使いのOSに合わせたインストールコマンド">
          <button type="button" role="tab" id="qs-tab-unix" aria-controls="qs-panel-unix" aria-selected="true" tabindex="0" class="qs-tab is-active" data-tab="unix">Linux / macOS</button>
          <button type="button" role="tab" id="qs-tab-win" aria-controls="qs-panel-win" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="win">Windows</button>
          <button type="button" role="tab" id="qs-tab-brew" aria-controls="qs-panel-brew" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="brew">Homebrew</button>
        </div>

        <div id="qs-panel-unix" role="tabpanel" aria-labelledby="qs-tab-unix" class="qs-panel is-active" data-panel="unix">
<pre class="terminal"><span class="prompt">$</span> curl -fsSL https://specscore.md/install/get-cli | sh</pre>
        </div>
        <div id="qs-panel-win" role="tabpanel" aria-labelledby="qs-tab-win" class="qs-panel" data-panel="win" hidden>
<pre class="terminal"><span class="prompt">PS&gt;</span> powershell -c "irm https://specscore.md/install/get-cli.ps1 | iex"</pre>
        </div>
        <div id="qs-panel-brew" role="tabpanel" aria-labelledby="qs-tab-brew" class="qs-panel" data-panel="brew" hidden>
<pre class="terminal"><span class="prompt">$</span> brew install specscore/tap/specscore</pre>
        </div>

        <p class="qs-more">
          <a class="xref" href="/ja/cli/install/">すべてのインストール方法 →</a>
        </p>
      </div>
    </section>

    {/* ── 何が得られるか ── */}
    <section class="section features-section" aria-labelledby="features-title">
      <div class="section-inner">
        <h2 id="features-title" class="section-title">含まれるもの。</h2>

        <div class="features-grid">
          <div class="feature-card">
            <h3 class="feature-card__title">Lint</h3>
            <p class="feature-card__desc">
              構造、メタデータ、相互参照、ACの一意性を検証。
              要件ごとにpass/failを修正提案付きで報告。
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">Score</h3>
            <p class="feature-card__desc">
              仕様の完全性を0-100スケールで評価。アクター、トリガー、
              エラー状態、セキュリティモデル、レートリミットの欠落を検出。
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">CI対応</h3>
            <p class="feature-card__desc">
              失敗時はゼロ以外の終了コード。<code>specscore lint</code>を
              ESLint、Prettier、テストスイートと並べてCIパイプラインに組み込み。
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">テレメトリなし</h3>
            <p class="feature-card__desc">
              CLIはデータを外部送信しません。仕様とスコアはマシン上に保持。
              アカウント不要、APIキー不要、クラウド依存なし。
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">ポータブル</h3>
            <p class="feature-card__desc">
              シングルバイナリ。macOS、Linux、Windows。ランタイム依存なし。
              Markdown仕様のどのディレクトリでも動作。
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">オープンソース</h3>
            <p class="feature-card__desc">
              MITライセンス。ソースは
              <a class="xref" href="https://github.com/specscore/specscore-cli">specscore/specscore-cli</a>に。
              永久に無料。
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── AIエージェントとの使用 ── */}
    <section class="section" aria-labelledby="agents-title">
      <div class="section-inner section-inner--prose">
        <h2 id="agents-title" class="section-title">AIエージェントと一緒に使う。</h2>
        <p class="prose-p">
          CLIは両方のClaude Codeプラグインの内部エンジンです。エージェントが
          仕様を書くなら、CLIがコードを1行も書く前にそれが適切かどうかを判定します。
        </p>
        <div class="agent-links">
          <a href="/ja/ai/specstudio-skills/" class="btn btn--secondary">SpecStudio Skills</a>
          <a href="/ja/ai/cli-skills/" class="btn btn--tertiary">CLI Skills（薄いラッパー）</a>
        </div>
      </div>
    </section>
  </main>

  {/* ── 最終CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">リントを通る仕様を。</h2>
      <div class="final-cta__buttons">
        <a href="/ja/cli/install/" class="btn btn--primary">CLIをインストール</a>
        <a href="/ja/ai/specstudio-skills/" class="btn btn--secondary">AIエージェント用スキルを入手</a>
        <a
          href="https://github.com/specscore/specscore-cli"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          GitHubでオープンソース公開中
        </a>
      </div>
    </div>
  </section>

  {/* ── フッター ── */}
  <SiteFooterJa />
</BaseLayout>

<style>
  /* ── Hero: two-column on desktop (copy left, terminal right),
        stacked on mobile. Mirrors the landing hero's rhythm. ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-7);
    background: var(--cream);
    overflow: hidden;
  }
  .hero__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 30fr 70fr;
    gap: var(--space-3) var(--space-6);
    align-items: center;
  }
  .hero__copy {
    animation: hero-copy-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 280ms;
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__inner > .hero__headline {
    grid-column: 1 / -1;
    margin-bottom: 0;
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    line-height: 1.55;
    max-width: 42ch;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .hero__art {
    animation: hero-art-in 700ms cubic-bezier(0.22, 0.61, 0.36, 1) both 100ms;
    min-width: 0;
  }
  .hero__art pre.terminal {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.65;
  }

  @keyframes hero-copy-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-art-in {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 860px) {
    .hero { padding: var(--space-5) var(--space-3) var(--space-6); }
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .hero__copy { order: 1; }
    .hero__art  { order: 2; }
  }

  /* ── Section titles ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  .section-intro {
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    line-height: 1.6;
  }
  .section-intro code {
    background: var(--cream-2);
    padding: 0.05em 0.35em;
    border-radius: 2px;
    font-size: 0.92em;
    color: var(--ink);
  }

  /* ── Features grid ── */
  .features-section { background: var(--cream-2); }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .feature-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
  }
  .feature-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .feature-card__desc {
    font-size: var(--fs-small);
    color: var(--mid-ink);
    line-height: 1.55;
  }
  .feature-card__desc code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  @media (max-width: 860px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .features-grid { grid-template-columns: 1fr; }
  }

  /* ── AI agents section ── */
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
    margin-bottom: var(--space-3);
  }
  .agent-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: var(--space-3);
  }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    text-align: center;
  }
  .final-cta__title {
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .final-cta__buttons {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>

<QsTabsScript />
