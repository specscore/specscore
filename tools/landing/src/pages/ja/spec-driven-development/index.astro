const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      headline: 'AIコーディングエージェントのための仕様駆動開発',
      description:
        '仕様駆動開発とは何か、なぜAIコーディングエージェントにとって重要なのか、ワークフローはどう機能するのか、そしてTDDやプロンプトのみのコーディングとどう違うのかを解説します。',
      inLanguage: 'ja',
      datePublished: '2026-05-29',
      dateModified: '2026-05-29',
      mainEntityOfPage: 'https://specscore.md/ja/spec-driven-development/',
      image: 'https://specscore.md/hero-og.webp',
      author: { '@type': 'Organization', name: 'SpecScore', url: 'https://specscore.md/' },
      publisher: { '@type': 'Organization', name: 'SpecScore', url: 'https://specscore.md/' },
      about: {
        '@type': 'DefinedTerm',
        name: '仕様駆動開発',
        description:
          '書かれた仕様 — 要件と受け入れ基準 — を、コードを構築し検証するための信頼できる唯一の情報源とするソフトウェア開発のプラクティス。',
      },
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: '仕様駆動開発はテスト駆動開発と同じものですか？',
          acceptedAnswer: {
            '@type': 'Answer',
            text:
              'いいえ。TDDはコードレベルの失敗するテストから実装を駆動します。仕様駆動開発はその一つ上のレベルで機能します。まず、意図する振る舞いと受け入れ基準を書かれた仕様に固定します。両者は補完的です — 仕様の受け入れ基準は、しばしばTDDがその後に駆動するテストになります。',
          },
        },
        {
          '@type': 'Question',
          name: '仕様駆動開発は作業を遅くしますか？',
          acceptedAnswer: {
            '@type': 'Answer',
            text:
              'コードを書く前に時間を足しますが、間違ったものを作り直すために費やす時間を減らします。使い捨てのスクリプトではそのオーバーヘッドは見合いません。AIエージェントが大規模に生成するもの、あるいはチームが保守しなければならないものについては、先に仕様を書くほうが最初から最後まで通常は速いです。',
          },
        },
        {
          '@type': 'Question',
          name: '仕様とPRDの違いは何ですか？',
          acceptedAnswer: {
            '@type': 'Answer',
            text:
              'PRDは通常、人間向けの文章です。仕様駆動開発における仕様は構造化されていてテスト可能です — 明示的な受け入れ基準を伴う個別の要件 — そのため、レビュアーもAIエージェントも正確にそれに基づいて行動できます。',
          },
        },
        {
          '@type': 'Question',
          name: 'AIコーディングエージェントは仕様をどう使いますか？',
          acceptedAnswer: {
            '@type': 'Answer',
            text:
              '仕様が機械可読であるとき、エージェントはコードベース全体を読み込む代わりに、現在のタスクに関連する要件と受け入れ基準を仕様に問い合わせ、その後で自分の出力をそれらの基準に照らして確認します — もっともらしいが誤ったコードに対するガードレールです。',
          },
