---
// Japanese variant of /validators. Prose is a draft pending native review; terminal output stays English.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import LintExample from '../../../components/LintExample.astro';
import ScoreExample from '../../../components/ScoreExample.astro';
---

<BaseLayout
  lang="ja"
  title="SpecScore が検証するもの — そして検証できないもの。"
  description="SpecScore は2つのバリデーターで仕様を検査します：決定論的なリンターと AI レビュー。それぞれが何を捉えるのか — そしてどこで自動検証が止まり、あなたの判断に委ねられるのかを正確にお見せします。"
  canonical="https://specscore.md/ja/validators/"
>
  <SiteHeader />

  <main>
    {/* ── Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <h1 id="hero-title" class="hero__headline">
          SpecScore が<br />検証するもの。
        </h1>
        <div class="hero__copy">
          <p class="hero__sub">
            SpecScore は機能、要件、受け入れ基準のためのオープンな Markdown
            フォーマットで、2つのバリデーターが検査します：決定論的な
            <strong>リンター</strong>と <strong>AI レビュー</strong>です。それぞれが
            何を捉え、どこで自動チェックが止まるのかをご紹介します。
          </p>
          <p class="hero__context">
            SpecScore は初めてですか？ <a class="xref" href="/ja/">ここから始める</a> ·
            <a class="xref" href="/ja/cli/">CLI</a> ·
            <a class="xref" href="/ja/ai/">AI スキル</a>
          </p>
        </div>

        <div
          class="hero__art"
          role="img"
          aria-label="ターミナル出力：checkout 仕様に対する specscore lint が24件すべての要件に合格 — 構造、参照、ID が有効で、インデックスのずれもリンク切れもなし。0 problems、exit 0。"
        >
<pre class="terminal terminal--window"><span class="prompt">$</span> specscore lint checkout/

  <span class="mark-pass">✓</span> 24 requirements — structure, references, IDs valid
  <span class="mark-pass">✓</span> no index drift · no broken links · no slug collisions

  <span class="dim">0 problems   exit 0</span></pre>
        </div>
      </div>
    </section>

    {/* ── 3つの層 ── */}
    <section class="section" aria-labelledby="layers-title">
      <div class="section-inner section-inner--prose">
        <h2 id="layers-title" class="section-title">1つではなく、3つの層。</h2>
        <p class="prose-p">
          SpecScore は層ごとに検証します — 最も安く、最も確実なものから先に。
          <strong>リンター</strong>は決定論的です — 高速、無料、コミットごとに走ります。
          <strong>AI レビュー</strong>は確率的です — より深く、トークンを消費し、
          リンターが届かないものを捉えます。<strong>人間の判断</strong>が3つめの層です：
          最初の2つが閉じられない隙間には、やはり人が必要です — 今日、どのツールも
          それを確実に閉じることはできないからです。2つの自動化された層は、重複では
          なく補完し合います：リンターは AI が根拠を示せないものを捉え、AI は
          リンターが届かないものを捉えます。
        </p>
      </div>
    </section>

    {/* ── 各バリデーターが検査するもの ── */}
    <section class="section validators-section" aria-labelledby="checks-title">
      <div class="section-inner">
        <h2 id="checks-title" class="section-title">各バリデーターが検査するもの。</h2>
        <div class="vcols">
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">層 1</span>
              <h3 class="validator__title">CLI リンター</h3>
              <span class="validator__kind">決定論的</span>
            </div>
            <p class="validator__lead">
              実行のたびに同じ結果、LLM なし、コストなし。ここで合格すれば、
              それは意見ではなく事実です。
            </p>
            <div
              class="checks-terminal"
              role="img"
              aria-label="specscore lint の出力：R1 と R2 には受け入れ基準がある一方、R3 には存在せず、Related Feature リンクが解決されず、必須の Open Questions セクションが欠落。3 problems、exit 1。"
            >
              <LintExample />
            </div>
            <ul class="vlist">
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 参照整合性 — リンクが解決し、ID が一意である</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 構造の取り決め — 必須セクション、frontmatter の形</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> ステータスの整合性とインデックスのずれ</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> slug の衝突</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> メタデータ項目のプレフィックスの妥当性（例：<code>Related Ideas:</code>）</li>
            </ul>
          </div>
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">層 2</span>
              <h3 class="validator__title">AI レビュー＆スコア</h3>
              <span class="validator__kind">非決定論的</span>
            </div>
            <p class="validator__lead">
              人間のレビュアーのように意味を読み取ります — そして人間と同じく、
              完全には再現できません。
            </p>
            <div
              class="checks-terminal"
              role="img"
              aria-label="/score の出力：仕様は B 評価を得て、2つの実行可能な指摘 — AC-2 の曖昧なトリガーと AC-3 の欠落したエラーパス。"
            >
              <ScoreExample />
            </div>
            <ul class="vlist">
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 検証可能な Given/When/Then の形で書かれた AC</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> アーティファクト内部の一貫性</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 曖昧な、またはプレースホルダーの内容</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 人間のレビュアーにとっての読みやすさ</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 作成者が対応でき、重要度が示されたフィードバック</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> A〜F の準備度評価</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── #limits — 捉えられないもの ── */}
    <section class="section limits-section" id="limits" aria-labelledby="limits-title">
      <div class="section-inner">
        <h2 id="limits-title" class="section-title">捉えられないもの。</h2>
        <p class="section-lead">
          魔法のバリデーターはありません。それぞれがどこで止まるのか — あなた自身の
          判断がどこでまだ働かなければならないのかを、正確にお伝えします。
        </p>
        <div class="vcols">
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">層 1</span>
              <h3 class="validator__title">CLI リンター</h3>
            </div>
            <ul class="vlist">
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 深い階層をまたぐ暗黙の矛盾</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 仕様とコードのずれ <span class="vnote">（<code>specstudio:recap</code> の登場とともに改善中）</span></li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 受け入れ基準の意味的な正しさ</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 名前が実際に意味をなしているか</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 要件が掲げた課題を解決しているか</li>
            </ul>
          </div>
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">層 2</span>
              <h3 class="validator__title">AI レビュー＆スコア</h3>
              <span class="validator__kind">捉え方にばらつきがある</span>
            </div>
            <ul class="vlist">
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 実行ごとの完全な再現性 — 判定は許容範囲内で揺れることがある</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 明示的な相互チェックなしに、大きなツリー全体にまたがる矛盾</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 要件が本当に課題を解決しているか — 明白な抜けは指摘するが、ドメイン固有のものは見落とす</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 基盤となる LLM から受け継いだバイアス</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 絶対的な確実性をもった意味的な正しさ</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> ルーブリックが重み付けしないもの全般</li>
            </ul>
          </div>
        </div>

        <ol class="bands" aria-label="検証の3つの層を、到達できる範囲の順に">
          <li class="band">
            <span class="band__step">1</span>
            <h3 class="band__title">リンターはここまで届く</h3>
            <p class="band__desc">
              構造、参照、整合性。安く確実 — しかし意味には盲目です。
            </p>
          </li>
          <li class="band band--mid">
            <span class="band__step">2</span>
            <h3 class="band__title">AI はここまで届く</h3>
            <p class="band__desc">
              アーティファクト内部の意味、明確さ、一貫性。より深く — しかし
              確率的で、大きなツリーには弱いです。
            </p>
          </li>
          <li class="band band--human">
            <span class="band__step">3</span>
            <h3 class="band__title">ここはあなた次第</h3>
            <p class="band__desc">
              システム全体を横断する判断 — 今日どのツールも確実にはできない
              仕事なので、やはり人間のレビュアーが必要です。これは見落とされた
              穴ではなく、現在できることの正直な境界です。
            </p>
          </li>
        </ol>

        <div class="worked">
          <h3 class="worked__title">どちらのツールも救ってくれないケース</h3>
          <p class="worked__body">
            実在する、深い仕様ツリーを思い浮かべてください。機能&nbsp;A は
            <em>X</em> を要求します。機能&nbsp;B は <em>Y</em> を要求します。
            機能&nbsp;C は <em>Z</em> を要求します。そして機能&nbsp;D が、ひそかに
            B と矛盾する何かを要求します — ただし A も同時に有効なときに限って。
            リンターは4つの妥当で、きれいにリンクされた文書を見て、合格させます。
            AI レビューはアーティファクトを1つずつ読むので、4つすべてを読み込んで
            三者間の相互作用に気づく理由がありません。
          </p>
          <p class="worked__body">
            <strong>どちらの層もこれを確実には捉えられません — そして私たちは
            そうでないふりをするつもりはありません。</strong> まさにこの種の矛盾こそ、
            3つめの層が存在する理由です。SpecScore の役割は、隙間をレビューする人が
            矛盾を<em>見つけ</em>られるよう、ツリーを十分にたどりやすくすること
            です — オープンクエスチョンは階層を上へ伝播し、関連する要件は1つの
            クエリの先にあります — ツールがすでに見つけたと主張することではありません。
          </p>
        </div>
      </div>
    </section>
  </main>

  {/* ── 最終CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">誠実なツール、誠実な仕様。</h2>
      <div class="final-cta__buttons">
        <a href="/ja/cli/install/" class="btn btn--primary">CLI をインストール</a>
        <a href="/ja/ai/specstudio-skills/" class="btn btn--secondary">エージェント用 AI スキルを入手</a>
        <a
          href="https://github.com/specscore/specscore-cli"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          GitHub でオープンソース公開中
        </a>
      </div>
    </div>
  </section>

  {/* ── フッター ── */}
  <footer class="page-footer">
    <div class="page-footer__inner">
      <div class="page-footer__col page-footer__brand">
        <a href="/ja/" class="wordmark" aria-label="SpecScore ホーム">
          <span class="wordmark__clef" aria-hidden="true">&#x1D11E;</span>
          <span class="wordmark__name">SpecScore.md</span>
        </a>
        <p class="page-footer__tagline">
          仕様、要件、受け入れ基準のための
          オープンスタンダード。
        </p>
        <p class="page-footer__copyright">
          &copy; 2026 SpecScore contributors. MIT license.
        </p>
      </div>

      <div class="page-footer__col">
        <h4 class="page-footer__heading">SpecScore CLI</h4>
        <ul class="page-footer__list">
          <li><a href="/ja/cli/">概要</a></li>
          <li><a href="/ja/cli/install/">インストール</a></li>
          <li><a href="https://github.com/specscore/specscore-cli">GitHub</a></li>
        </ul>
      </div>

      <div class="page-footer__col">
        <h4 class="page-footer__heading">エコシステム</h4>
        <ul class="page-footer__list">
          <li><a href="/ja/">SpecScore</a> — オープンスタンダード</li>
          <li><a href="/ja/ai/specstudio-skills/">SpecStudio Skills</a> — Claude Code プラグイン</li>
          <li><a href="https://specscore.studio">SpecScore Studio</a> — Web ビューア</li>
        </ul>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ── Hero (mirrors /cli two-column rhythm) ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-7);
    background: var(--cream);
    overflow: hidden;
  }
  .hero__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 38fr 62fr;
    gap: var(--space-3) var(--space-6);
    align-items: center;
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
  }
  .hero__inner > .hero__headline {
    grid-column: 1 / -1;
    margin-bottom: 0;
  }
  .hero__copy {
    animation: hero-copy-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 280ms;
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
    max-width: 52ch;
  }
  .hero__sub strong { color: var(--ink); }
  .hero__context {
    margin-top: var(--space-3);
    font-size: var(--fs-small);
    color: var(--pale-ink);
  }
  .hero__art {
    animation: hero-art-in 700ms cubic-bezier(0.22, 0.61, 0.36, 1) both 100ms;
    min-width: 0;
  }
  .hero__art pre.terminal {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.65;
  }

  @keyframes hero-copy-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-art-in {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 860px) {
    .hero { padding: var(--space-5) var(--space-3) var(--space-6); }
    .hero__inner { grid-template-columns: 1fr; gap: var(--space-4); }
    .hero__copy { order: 1; }
    .hero__art  { order: 2; }
  }

  /* ── Section scaffolding ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  .section-lead {
    color: var(--mid-ink);
    line-height: 1.6;
    max-width: 60ch;
    margin-bottom: var(--space-4);
  }
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
  }
  .prose-p strong { color: var(--ink); }

  /* ── Validator columns (used by both "checks" and "#limits") ── */
  .validators-section { background: var(--cream); }
  .limits-section {
    background: var(--cream-2);
    scroll-margin-top: var(--space-5);
  }

  .validator__head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .validator__layer {
    font-family: var(--font-display);
    font-size: var(--fs-tiny);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--pale-ink);
  }
  .validator__title {
    font-size: var(--fs-h3);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .validator__kind {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--mid-ink);
  }
  .validator__lead {
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .checks-terminal {
    margin-bottom: var(--space-3);
  }
  .checks-terminal pre.terminal {
    margin: 0;
    font-size: 0.72rem;
    line-height: 1.65;
  }

  .vcols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }
  .vlist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .vlist li {
    position: relative;
    padding-left: 1.6rem;
    color: var(--ink);
    line-height: 1.5;
    font-size: var(--fs-small);
  }
  .vlist code {
    font-size: 0.9em;
    background: var(--surface);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .mark {
    position: absolute;
    left: 0;
    font-weight: 700;
    font-family: var(--font-code);
  }
  .mark--pass { color: var(--validator-green); }
  .mark--fail { color: var(--mark-red); }
  .vnote { color: var(--pale-ink); }

  @media (max-width: 640px) {
    .vcols { grid-template-columns: 1fr; gap: var(--space-4); }
  }

  /* ── Synthesis bands ── */
  .bands {
    list-style: none;
    margin: var(--space-5) 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .band {
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-top: 3px solid var(--validator-green);
    padding: var(--space-3);
  }
  .band--mid { border-top-color: var(--ink-blue); }
  .band--human { border-top-color: var(--mark-red); }
  .band__step {
    font-family: var(--font-display);
    font-size: var(--fs-small);
    font-weight: 700;
    color: var(--pale-ink);
  }
  .band__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin: var(--space-1) 0;
  }
  .band__desc {
    font-size: var(--fs-small);
    color: var(--mid-ink);
    line-height: 1.55;
  }

  @media (max-width: 720px) {
    .bands { grid-template-columns: 1fr; }
  }

  /* ── Worked example ── */
  .worked {
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-left: 3px solid var(--ink);
    padding: var(--space-4);
  }
  .worked__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .worked__body {
    color: var(--mid-ink);
    line-height: 1.65;
  }
