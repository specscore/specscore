import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooterRu from '../../../components/SiteFooterRu.astro';

const ld = {
  '@context': 'https://schema.org',
