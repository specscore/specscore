---
// Russian variant of /validators.
// terminal output stays English (literal CLI stdout).
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooterRu from '../../../components/SiteFooterRu.astro';
import LintExample from '../../../components/LintExample.astro';
import ScoreExample from '../../../components/ScoreExample.astro';
---

<BaseLayout
  lang="ru"
  title="Что проверяет SpecScore — и что не может."
  description="SpecScore проверяет спецификации двумя валидаторами: детерминированным линтером и проверкой ИИ. Узнайте, что именно ловит каждый из них — и где автоматическая проверка заканчивается, а в дело вступает ваше суждение."
  canonical="https://specscore.md/ru/validators/"
>
  <SiteHeader />

  <main>
    {/* ── Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <h1 id="hero-title" class="hero__headline">
          Что проверяет<br />SpecScore.
        </h1>
        <div class="hero__copy">
          <p class="hero__sub">
            SpecScore — это открытый формат на основе Markdown для фич,
            требований и критериев приёмки, который проверяют два валидатора:
            детерминированный <strong>линтер</strong> и
            <strong>проверка ИИ</strong>. Вот что ловит каждый из них и где
            автоматическая проверка заканчивается.
          </p>
          <p class="hero__context">
            Впервые о SpecScore? <a class="xref" href="/ru/">Начните здесь</a> ·
            <a class="xref" href="/ru/cli/">CLI</a> ·
            <a class="xref" href="/ru/ai/">Навыки ИИ</a>
          </p>
        </div>

        <div
          class="hero__art"
          role="img"
          aria-label="Вывод терминала: specscore lint на спецификации checkout проходит все 24 требования — структура, ссылки и ID корректны, нет расхождения индексов и битых ссылок. 0 проблем, exit 0."
        >
<pre class="terminal terminal--window"><span class="prompt">$</span> specscore lint checkout/

  <span class="mark-pass">✓</span> 24 requirements — structure, references, IDs valid
  <span class="mark-pass">✓</span> no index drift · no broken links · no slug collisions

  <span class="dim">0 problems   exit 0</span></pre>
        </div>
      </div>
    </section>

    {/* ── Три слоя ── */}
    <section class="section" aria-labelledby="layers-title">
      <div class="section-inner section-inner--prose">
        <h2 id="layers-title" class="section-title">Три слоя, а не один.</h2>
        <p class="prose-p">
          SpecScore проверяет послойно — сначала самое дешёвое и самое надёжное.
          <strong>Линтер</strong> детерминирован — быстрый, бесплатный, работает
          на каждом коммите. <strong>Проверка ИИ</strong> вероятностна — глубже,
          тратит токены, ловит то, до чего линтер не дотянется.
          <strong>Человеческое суждение</strong> — третий слой: стыки, которые
          не закрывают первые два, по-прежнему требуют человека — ни один
          инструмент пока не закрывает их надёжно. Два автоматических слоя
          дополняют друг друга, а не дублируют: линтер ловит
          то, что ИИ не может обосновать; ИИ ловит то, до чего линтер не
          дотягивается.
        </p>
      </div>
    </section>

    {/* ── Что проверяет каждый валидатор ── */}
    <section class="section validators-section" aria-labelledby="checks-title">
      <div class="section-inner">
        <h2 id="checks-title" class="section-title">Что проверяет каждый валидатор.</h2>
        <div class="vcols">
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">Слой 1</span>
              <h3 class="validator__title">Линтер CLI</h3>
              <span class="validator__kind">детерминированный</span>
            </div>
            <p class="validator__lead">
              Одинаковый результат при каждом запуске, без LLM, без затрат. Если
              здесь пройдено — это факт, а не мнение.
            </p>
            <div
              class="checks-terminal"
              role="img"
              aria-label="Вывод specscore lint: у R1 и R2 есть критерии приёмки; у R3 их нет, ссылка Related Feature не разрешается, отсутствует обязательная секция Open Questions. 3 проблемы, exit 1."
            >
              <LintExample />
            </div>
            <ul class="vlist">
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Ссылочная целостность — ссылки разрешаются, ID уникальны</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Структурные соглашения — обязательные секции, форма frontmatter</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Гигиена статусов и расхождение индексов</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Коллизии slug</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Корректность префиксов в полях метаданных (например, <code>Related Ideas:</code>)</li>
            </ul>
          </div>
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">Слой 2</span>
              <h3 class="validator__title">Проверка и оценка ИИ</h3>
              <span class="validator__kind">недетерминированный</span>
            </div>
            <p class="validator__lead">
              Читает по смыслу, как живой рецензент, — и, как человек, не идеально
              воспроизводим.
            </p>
            <div
              class="checks-terminal"
              role="img"
              aria-label="Вывод /score: спецификация получает оценку B с двумя замечаниями — расплывчатый триггер в AC-2 и отсутствие пути ошибки в AC-3."
            >
              <ScoreExample />
            </div>
            <ul class="vlist">
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Критерии приёмки в проверяемом виде Given/When/Then</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Внутренняя согласованность внутри артефакта</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Расплывчатый или заглушечный текст</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Читаемость для живого рецензента</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Действенная обратная связь с пометкой важности</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Оценка готовности от A до F</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── #limits — чего они не ловят ── */}
    <section class="section limits-section" id="limits" aria-labelledby="limits-title">
      <div class="section-inner">
        <h2 id="limits-title" class="section-title">Чего они не ловят.</h2>
        <p class="section-lead">
          Ни один валидатор не волшебный. Вот где останавливается каждый — чтобы
          вы точно знали, где по-прежнему нужно ваше собственное суждение.
        </p>
        <div class="vcols">
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">Слой 1</span>
              <h3 class="validator__title">Линтер CLI</h3>
            </div>
            <ul class="vlist">
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Неявные противоречия в глубоких иерархиях</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Расхождение между спецификацией и кодом <span class="vnote">(улучшится с выходом <code>specstudio:recap</code>)</span></li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Смысловую корректность критериев приёмки</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Имеет ли название смысл на самом деле</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Решают ли требования заявленную проблему</li>
            </ul>
          </div>
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">Слой 2</span>
              <h3 class="validator__title">Проверка и оценка ИИ</h3>
              <span class="validator__kind">ловит непостоянно</span>
            </div>
            <ul class="vlist">
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Полную воспроизводимость между запусками — вердикты могут меняться в пределах допуска</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Межартефактные противоречия в большом дереве без явных перекрёстных проверок</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Действительно ли требования решают проблему — заметит очевидные пробелы, пропустит специфичные для предметной области</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Смещения, унаследованные от базовой LLM</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Смысловую корректность с абсолютной уверенностью</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Всё, что не учитывает рубрика</li>
            </ul>
          </div>
        </div>

        <ol class="bands" aria-label="Три слоя проверки, по глубине охвата">
          <li class="band">
            <span class="band__step">1</span>
            <h3 class="band__title">Линтер достаёт сюда</h3>
            <p class="band__desc">
              Структура, ссылки, гигиена. Дёшево и надёжно — но слепо к смыслу.
            </p>
          </li>
          <li class="band band--mid">
            <span class="band__step">2</span>
            <h3 class="band__title">ИИ достаёт сюда</h3>
            <p class="band__desc">
              Смысл, ясность, согласованность внутри артефакта. Глубже — но
              вероятностно и слабо на большом дереве.
            </p>
          </li>
          <li class="band band--human">
            <span class="band__step">3</span>
            <h3 class="band__title">Остаётся на вас</h3>
            <p class="band__desc">
              Сквозное суждение обо всей системе. Ни один инструмент пока не
              может это надёжно — поэтому здесь по-прежнему нужен человек. Это не
              забытый пробел, а честная граница сегодняшних возможностей.
            </p>
          </li>
        </ol>

        <div class="worked">
          <h3 class="worked__title">Случай, от которого не спасёт ни один инструмент</h3>
          <p class="worked__body">
            Представьте реальное глубокое дерево спецификаций. Фича&nbsp;A требует
            <em>X</em>. Фича&nbsp;B требует <em>Y</em>. Фича&nbsp;C требует
            <em>Z</em>. Затем фича&nbsp;D незаметно требует то, что противоречит
            B — но только когда активна и A. Линтер видит четыре корректных,
            хорошо связанных документа и проходит. Проверка ИИ, читая артефакты
            по одному, не имеет причин загрузить все четыре и заметить
            взаимодействие трёх из них.
          </p>
          <p class="worked__body">
            <strong>Ни один слой надёжно это не ловит — и мы не будем делать вид,
            что иначе.</strong> Именно этот класс противоречий — причина
            существования третьего слоя. Задача SpecScore — сделать дерево
            достаточно навигируемым, чтобы человек, просматривающий стыки, мог
            <em>найти</em> конфликт: открытые вопросы поднимаются вверх по
            иерархии, связанные требования — в одном запросе, — а не утверждать,
            что инструмент уже его нашёл.
          </p>
        </div>
      </div>
    </section>
  </main>

  {/* ── Финальный призыв ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">Честные инструменты — честные спецификации.</h2>
      <div class="final-cta__buttons">
        <a href="/ru/cli/install/" class="btn btn--primary">Установить CLI</a>
        <a href="/ru/ai/specstudio-skills/" class="btn btn--secondary">Навыки ИИ для вашего агента</a>
        <a
          href="https://github.com/specscore/specscore-cli"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          Открытый код на GitHub
        </a>
      </div>
    </div>
  </section>

  {/* ── Подвал ── */}
  <SiteFooterRu />
</BaseLayout>

<style>
  /* ── Hero (mirrors /cli two-column rhythm) ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-7);
    background: var(--cream);
    overflow: hidden;
  }
  .hero__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 38fr 62fr;
    gap: var(--space-3) var(--space-6);
    align-items: center;
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
  }
  .hero__inner > .hero__headline {
    grid-column: 1 / -1;
    margin-bottom: 0;
  }
  .hero__copy {
    animation: hero-copy-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 280ms;
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
    max-width: 52ch;
  }
  .hero__sub strong { color: var(--ink); }
  .hero__context {
    margin-top: var(--space-3);
    font-size: var(--fs-small);
    color: var(--pale-ink);
  }
  .hero__art {
    animation: hero-art-in 700ms cubic-bezier(0.22, 0.61, 0.36, 1) both 100ms;
    min-width: 0;
  }
  .hero__art pre.terminal {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.65;
  }

  @keyframes hero-copy-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-art-in {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 860px) {
    .hero { padding: var(--space-5) var(--space-3) var(--space-6); }
    .hero__inner { grid-template-columns: 1fr; gap: var(--space-4); }
    .hero__copy { order: 1; }
    .hero__art  { order: 2; }
  }

  /* ── Section scaffolding ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  .section-lead {
    color: var(--mid-ink);
    line-height: 1.6;
    max-width: 60ch;
    margin-bottom: var(--space-4);
  }
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
  }
  .prose-p strong { color: var(--ink); }

  /* ── Validator columns ── */
  .validators-section { background: var(--cream); }
  .limits-section {
    background: var(--cream-2);
    scroll-margin-top: var(--space-5);
  }

  .validator__head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .validator__layer {
    font-family: var(--font-display);
    font-size: var(--fs-tiny);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--pale-ink);
  }
  .validator__title {
    font-size: var(--fs-h3);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .validator__kind {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--mid-ink);
  }
  .validator__lead {
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .checks-terminal {
    margin-bottom: var(--space-3);
  }
  .checks-terminal pre.terminal {
    margin: 0;
    font-size: 0.72rem;
    line-height: 1.65;
  }

  .vcols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }
  .vlist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .vlist li {
    position: relative;
    padding-left: 1.6rem;
    color: var(--ink);
    line-height: 1.5;
    font-size: var(--fs-small);
  }
  .vlist code {
    font-size: 0.9em;
    background: var(--surface);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .mark {
    position: absolute;
    left: 0;
    font-weight: 700;
    font-family: var(--font-code);
  }
  .mark--pass { color: var(--validator-green); }
  .mark--fail { color: var(--mark-red); }
  .vnote { color: var(--pale-ink); }

  @media (max-width: 640px) {
    .vcols { grid-template-columns: 1fr; gap: var(--space-4); }
  }

  /* ── Synthesis bands ── */
  .bands {
    list-style: none;
    margin: var(--space-5) 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .band {
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-top: 3px solid var(--validator-green);
    padding: var(--space-3);
  }
  .band--mid { border-top-color: var(--ink-blue); }
  .band--human { border-top-color: var(--mark-red); }
  .band__step {
    font-family: var(--font-display);
    font-size: var(--fs-small);
    font-weight: 700;
    color: var(--pale-ink);
  }
  .band__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin: var(--space-1) 0;
  }
  .band__desc {
    font-size: var(--fs-small);
    color: var(--mid-ink);
    line-height: 1.55;
  }

  @media (max-width: 720px) {
    .bands { grid-template-columns: 1fr; }
  }

  /* ── Worked example ── */
  .worked {
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-left: 3px solid var(--ink);
    padding: var(--space-4);
  }
  .worked__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .worked__body {
    color: var(--mid-ink);
    line-height: 1.65;
  }
  .worked__body + .worked__body { margin-top: var(--space-2); }
  .worked__body strong { color: var(--ink); }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    text-align: center;
  }
  .final-cta__title {
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .final-cta__buttons {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>
