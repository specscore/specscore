---
// /ru/vs/plain-markdown/ — SpecScore vs plain Markdown / Notion / Jira (ru).
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../../components/SiteHeader.astro';
import SiteFooterRu from '../../../../components/SiteFooterRu.astro';
import ComparisonFeedback from '../../../../components/ComparisonFeedback.astro';
---

<BaseLayout
  lang="ru"
  title="SpecScore vs Plain Markdown — Честное сравнение."
  description="Фактологическое сравнение SpecScore и варианта по умолчанию: разрозненный Markdown, Notion и тикеты в Jira. Тот же Markdown плюс структура, которую агенты могут линтовать, запрашивать и прослеживать."
  canonical="https://specscore.md/ru/vs/plain-markdown/"
>
  <SiteHeader />

  <main>
    {/* ── Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <p class="hero__breadcrumb"><a href="/ru/vs/" class="xref">Сравнения</a></p>
        <h1 id="hero-title" class="hero__headline">
          SpecScore vs Plain Markdown
        </h1>
        <p class="hero__sub">
          У большинства команд уже есть «спецификации» — в виде разрозненного Markdown
          в папке с документацией, страниц Notion или тикетов Jira. Это бесплатно, это
          уже на месте и это работает. SpecScore — это <strong>тот же Markdown</strong>,
          плюс структура, которую ИИ-агент может линтовать, запрашивать и прослеживать
          обратно к коду.
        </p>
      </div>
    </section>

    {/* ── What they share ── */}
    <section class="section" aria-labelledby="shared-title">
      <div class="section-inner section-inner--prose">
        <h2 id="shared-title" class="section-title">Что у них общего.</h2>
        <ul class="shared-list">
          <li>В любом случае это Markdown — простой текст, читаемый человеком, удобный для diff.</li>
          <li>Спецификации могут жить в репозитории — с контролем версий и ревью через PR.</li>
          <li>Нет проприетарного формата, нет привязки — вы можете читать их в любом редакторе.</li>
          <li>Вы продолжаете писать прозу; SpecScore добавляет структуру вокруг неё, а не вместо неё.</li>
        </ul>
      </div>
    </section>

    {/* ── What plain Markdown does well ── */}
    <section class="section" aria-labelledby="default-title">
      <div class="section-inner section-inner--prose">
        <h2 id="default-title" class="section-title">В чём силён вариант по умолчанию.</h2>
        <p class="section-note">
          Plain Markdown, Notion и Jira — это настоящий вариант по умолчанию. И не зря.
        </p>

        <div class="credit-card">
          <h3 class="credit-card__title">Нулевой порог входа</h3>
          <p class="credit-card__desc">
            Нет схемы, нет обязательных полей, нет CLI в цепочке. Откройте файл и
            начните печатать. Для разовой заметки или крошечного проекта это именно
            то, что нужно — структура, которая вам не нужна, — это просто трение.
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">Уже установлено</h3>
          <p class="credit-card__desc">
            Ваша команда уже в Notion, Confluence или папке <code>docs/</code>.
            Нечего внедрять, нечего мигрировать. Вариант с наименьшим трением — тот,
            которым вы уже пользуетесь.
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">Универсально переносим</h3>
          <p class="credit-card__desc">
            Plain Markdown открывается где угодно и переживёт любой инструмент. SpecScore
            построен именно на этом свойстве — поэтому SpecScore тоже Markdown, а не база данных.
          </p>
        </div>
      </div>
    </section>

    {/* ── Feature comparison table ── */}
    <section class="section table-section" aria-labelledby="table-title">
      <div class="section-inner">
        <h2 id="table-title" class="section-title">Сравнение возможностей.</h2>
        <p class="section-note">
          Разница не в файле — а в том, что агент может с ним сделать.
        </p>

        <div class="table-wrap">
          <table class="compare-table" aria-label="Сравнение возможностей SpecScore и Plain Markdown">
            <thead>
              <tr>
                <th scope="col">Возможность</th>
                <th scope="col">Plain Markdown / Notion</th>
                <th scope="col">SpecScore</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Формат</td>
                <td>Свободный Markdown / документация</td>
                <td><strong>Markdown + YAML frontmatter</strong> (структурированный)</td>
              </tr>
              <tr>
                <td>Где живут требования</td>
                <td>Jira, Notion, Slack, в чьей-то голове</td>
                <td><strong>В репозитории, рядом с кодом</strong></td>
              </tr>
              <tr>
                <td>«Полна ли эта спецификация?»</td>
                <td>Человек читает и решает</td>
                <td><strong><code>specscore lint</code></strong> — автоматически</td>
              </tr>
              <tr>
                <td>Выявление неоднозначности</td>
                <td>Нет — расплывчатые глаголы проходят молча</td>
                <td><strong>Расплывчатые глаголы, отсутствующие критерии приёмки, висячие ссылки помечаются</strong></td>
              </tr>
              <tr>
                <td>ID требований / критериев приёмки</td>
                <td>Нет</td>
                <td><strong>Машинно-адресуемые ID</strong> (<code>REQ: slug</code>)</td>
              </tr>
              <tr>
                <td>Статус жизненного цикла</td>
                <td>Неявный, если вообще отслеживается</td>
                <td><strong>Контролируемый</strong> — Draft → Approved → Implementing → Stable</td>
              </tr>
              <tr>
                <td>Трассируемость кода к спецификациям</td>
                <td>Нет</td>
                <td><strong><code>specscore:</code> аннотации</strong> + <code>Verifies:</code> трейлеры</td>
              </tr>
              <tr>
                <td>Навигация для агента</td>
                <td>Читать каждый файл, чтобы что-то найти</td>
                <td><strong>Запрос к графу спецификаций</strong> из CLI</td>
              </tr>
              <tr>
                <td>Гейт качества в CI</td>
                <td>Нет</td>
                <td><strong><code>specscore lint</code></strong> завершается с ненулевым кодом, как линтер</td>
              </tr>
              <tr>
                <td>Порог входа</td>
                <td><strong>Нулевой</strong></td>
                <td>Формат, который надо изучить (постепенно)</td>
              </tr>
              <tr>
                <td>Стоимость / лицензия</td>
                <td>Бесплатно</td>
                <td>Бесплатно, открытый код</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {/* ── Where SpecScore goes further ── */}
    <section class="section" aria-labelledby="further-title">
      <div class="section-inner">
        <h2 id="further-title" class="section-title">В чём SpecScore идёт дальше.</h2>

        <div class="diff-grid">
          <div class="diff-card">
            <h3 class="diff-card__title">Неоднозначность ловится, а не интерпретируется</h3>
            <p class="diff-card__desc">
              При свободных спецификациях каждое взаимодействие с агентом начинается с
              интерпретации — «логин должен работать» — это подброс монетки между «верно»
              и «правдоподобно, но неверно». <code>lint</code> в SpecScore помечает
              расплывчатый глагол и отсутствующий критерий приёмки до того, как агент
              начнёт действовать.
            </p>
            <div class="diff-card__example">
<pre class="terminal"><span class="prompt">$</span> specscore lint auth/login.md
  <span class="mark-fail">✗</span> R1  <span class="dim">"should work" — unmeasurable</span>
  <span class="mark-fail">✗</span> R1  no acceptance criteria</pre>
            </div>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Неверная интерпретация перестаёт накапливаться</h3>
            <p class="diff-card__desc">
              Один агент неправильно прочитал требование, второй строит на нём, третий
              зависит от обоих — и вы замечаете это тремя агентами позже. Структурированные
              критерии приёмки дают каждому агенту одинаковые условия прохождения/непрохождения,
              так что интерпретация не дрейфует между ними.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Код прослеживается до спецификации</h3>
            <p class="diff-card__desc">
              У обычной документации нет связи с кодом, который её реализует. SpecScore
              добавляет аннотации <code>specscore:</code> в исходниках и трейлеры
              <code>Verifies:</code> в коммитах — <code>specscore code refs</code> отвечает
              на вопрос «какой код реализует это требование?» детерминированно.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Одна спецификация вместо сорока тикетов</h3>
            <p class="diff-card__desc">
              Новый коллега (или свежий агент) читает одну спецификацию функции со всем
              контекстом, вместо того чтобы реконструировать намерение из сорока тикетов
              Jira и треда в Slack.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Агенты запрашивают, а не перечитывают</h3>
            <p class="diff-card__desc">
              В папке с документацией поиск «что в работе?» означает открытие файлов.
              В SpecScore это <code>specscore feature list</code> — граф спецификаций
              отвечает из CLI, так что агенты не сжигают контекст на перечитывание репозитория.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Качество контролируется в CI</h3>
            <p class="diff-card__desc">
              У свободных спецификаций нет гейта — недописанная сливается так же легко,
              как и полная. <code>specscore lint</code> завершается с ненулевым кодом при
              проблемах, так же как ESLint или <code>go vet</code> охраняют код.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── When to use which ── */}
    <section class="section" aria-labelledby="when-title">
      <div class="section-inner">
        <h2 id="when-title" class="section-title">Когда что использовать.</h2>

        <div class="when-grid">
          <div class="when-card">
            <h3 class="when-card__title">Plain Markdown подходит, когда…</h3>
            <ul class="when-card__list">
              <li>Это разовая заметка, эксперимент или проект, слишком маленький, чтобы нуждаться в структуре.</li>
              <li>Ни один ИИ-агент не будет строить по документу — человек читает его и просто понимает.</li>
              <li>Вы фиксируете грубую идею, а не требование, которое кто-то будет реализовывать.</li>
            </ul>
          </div>

          <div class="when-card when-card--primary">
            <h3 class="when-card__title">Берите SpecScore, когда…</h3>
            <ul class="when-card__list">
              <li>ИИ-агент строит по спецификации — неоднозначность превращается в неверный код.</li>
              <li>Несколько агентов или людей зависят от одних и тех же требований.</li>
              <li>Вам нужно знать, какой код реализует какое требование.</li>
              <li>На вопрос «готова ли эта спецификация?» должен отвечать инструмент, а не совещание.</li>
              <li>Проект достаточно велик, чтобы перечитывание всего не масштабировалось.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── The adoption path ── */}
    <section class="section" aria-labelledby="bridge-title">
      <div class="section-inner section-inner--prose">
        <h2 id="bridge-title" class="section-title">Дорастите спецификации, которые у вас уже есть.</h2>
        <p class="prose-p">
          Вы не конвертируете свой бэклог и не меняете инструменты. Выберите следующую
          функцию, напишите для неё спецификацию SpecScore и запустите
          <code>specscore lint</code> — посмотрите, поймает ли он то, что упустил ваш
          тикет. Добавьте аннотации <code>specscore:</code>, когда будете реализовывать.
          Расширяйтесь на следующий спринт только если это помогло.
        </p>
        <p class="prose-p">
          Plain Markdown — это въезд на эстакаду. SpecScore — это то, во что он вырастает.
        </p>
      </div>
    </section>

    <ComparisonFeedback page="plain-markdown" />
  </main>

  {/* ── Final CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">Спецификации, которые проходят проверку.</h2>
      <div class="final-cta__buttons">
        <a href="/cli/install/" class="btn btn--primary">Установить CLI</a>
        <a href="/ai/specstudio-skills/" class="btn btn--secondary">AI-навыки для вашего агента</a>
        <a
          href="https://github.com/specscore/specscore"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          Открытый код на GitHub
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <SiteFooterRu />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-5);
    background: var(--cream);
  }
  .hero__inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms;
  }
  .hero__breadcrumb {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--pale-ink);
    margin-bottom: var(--space-2);
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
    max-width: 52ch;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Section titles ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }

  /* ── Shared list ── */
  .shared-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .shared-list li {
    position: relative;
    padding-left: 1.4rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
  }
  .shared-list li::before {
    content: '=';
    position: absolute;
    left: 0;
    font-family: var(--font-code);
    font-weight: 700;
    color: var(--pale-ink);
  }

  /* ── Section note ── */
  .section-note {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    margin-bottom: var(--space-3);
  }

  /* ── Credit cards ── */
  .credit-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .credit-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .credit-card__desc {
    color: var(--mid-ink);
    line-height: 1.6;
    font-size: var(--fs-body);
  }
  .credit-card__desc code {
    font-size: 0.9em;
    background: var(--cream);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Feature comparison table ── */
  .table-section { background: var(--cream-2); }
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-small);
    line-height: 1.5;
  }
  .compare-table th,
  .compare-table td {
    text-align: left;
    padding: 0.65rem 0.85rem;
    border-bottom: 1px solid var(--hairline);
    vertical-align: top;
  }
  .compare-table thead th {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mid-ink);
    border-bottom: 2px solid var(--graphite);
    white-space: nowrap;
  }
  .compare-table td:first-child {
    font-weight: 500;
    white-space: nowrap;
    min-width: 160px;
  }
  .compare-table td:nth-child(2),
  .compare-table td:nth-child(3) {
    min-width: 200px;
  }
  .compare-table td code {
    font-size: 0.88em;
    background: var(--surface);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .compare-table strong {
    font-weight: 600;
    color: var(--ink);
  }

  /* ── Diff grid ── */
  .diff-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .diff-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
  }
  .diff-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .diff-card__desc {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    line-height: 1.6;
  }
  .diff-card__desc code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .diff-card__example {
    margin-top: var(--space-2);
  }
  .diff-card__example .terminal {
    font-size: 0.78rem;
    line-height: 1.6;
  }

  @media (max-width: 860px) {
    .diff-grid { grid-template-columns: 1fr; }
  }

  /* ── When to use which ── */
  .when-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .when-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-4);
  }
  .when-card--primary {
    border-color: var(--validator-green);
    border-width: 2px;
  }
  .when-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .when-card__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .when-card__list li {
    position: relative;
    padding-left: 1.2rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
    font-size: var(--fs-small);
  }
  .when-card__list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--pale-ink);
    font-family: var(--font-code);
  }
  .when-card--primary .when-card__list li::before {
