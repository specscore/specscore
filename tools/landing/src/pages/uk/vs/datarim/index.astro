---
// /uk/vs/datarim/ — SpecScore vs Datarim comparison (uk).
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../../components/SiteHeader.astro';
import SiteFooterUk from '../../../../components/SiteFooterUk.astro';
import ComparisonFeedback from '../../../../components/ComparisonFeedback.astro';
---

<BaseLayout
  lang="uk"
  title="SpecScore vs Datarim — Чесне порівняння."
  description="Фактичне порівняння SpecScore та Datarim: набір робочих процесів для Claude Code проти відкритого, портативного формату специфікацій. Різні рівні — і вони можуть поєднуватися."
  canonical="https://specscore.md/uk/vs/datarim/"
>
  <SiteHeader />

  <main>
    {/* ── Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <p class="hero__breadcrumb"><a href="/uk/vs/" class="xref">Порівняння</a></p>
        <h1 id="hero-title" class="hero__headline">
          SpecScore vs Datarim
        </h1>
        <p class="hero__sub">
          Різні рівні. Datarim — це виразний <strong>набір робочих процесів</strong> для
          Claude Code — слеш-команди, що ведуть проєкт від вимог до завершення.
          SpecScore — це <strong>відкритий формат</strong>, у якому пишуться специфікації,
          плюс CLI для лінтингу, запитів та простежування. Робочий процес може орієнтуватися на нього.
        </p>
      </div>
    </section>

    {/* ── What they share ── */}
    <section class="section" aria-labelledby="shared-title">
      <div class="section-inner section-inner--prose">
        <h2 id="shared-title" class="section-title">Що в них спільного.</h2>
        <ul class="shared-list">
          <li>Обидва привносять структуровану методологію в розробку за допомогою ШІ.</li>
          <li>Обидва мають відкритий вихідний код під ліцензією MIT.</li>
          <li>Обидва працюють усередині Claude Code — Datarim як команди, SpecScore через SpecStudio Skills.</li>
          <li>Обидва зберігають свій стан як Markdown у репозиторії, з контролем версій.</li>
        </ul>
      </div>
    </section>

    {/* ── What Datarim does well ── */}
    <section class="section" aria-labelledby="datarim-title">
      <div class="section-inner section-inner--prose">
        <h2 id="datarim-title" class="section-title">Що Datarim робить добре.</h2>
        <p class="section-note">
          <a href="https://github.com/Arcanada-one/datarim" rel="nofollow noopener" target="_blank" class="xref">Datarim</a>
          — це універсальний фреймворк ітеративного робочого процесу, створений для Claude Code.
        </p>

        <div class="credit-card">
          <h3 class="credit-card__title">Нативний UX слеш-команд</h3>
          <p class="credit-card__desc">
            Повний конвеєр як команди — <code>/dr-prd</code>, <code>/dr-plan</code>,
            <code>/dr-design</code>, <code>/dr-do</code>, <code>/dr-qa</code> — що почуваються
            як удома в Claude Code. Один <code>install.sh</code> у <code>~/.claude/</code>
            — і ви вже працюєте.
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">Маршрутизація з урахуванням складності (L1–L4)</h3>
          <p class="credit-card__desc">
            Datarim оцінює обсяг роботи й маршрутизує відповідно: швидке виправлення L1
            пропускає планування, тоді як велика зміна L4 запускає поетапний конвеєр із
            кількома циклами рев'ю. Відповідність церемонії до масштабу — справді гарна ідея.
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">Consilium та багатодоменний охват</h3>
          <p class="credit-card__desc">
            Його «consilium» збирає панель агентів, щоб обговорити компроміси перед
            рекомендацією рішення. І це не лише про програмне забезпечення — Datarim також
            орієнтований на дослідницькі, юридичні та контентні робочі процеси.
          </p>
        </div>
      </div>
    </section>

    {/* ── Feature comparison table ── */}
    <section class="section table-section" aria-labelledby="table-title">
      <div class="section-inner">
        <h2 id="table-title" class="section-title">Порівняння функцій.</h2>
        <p class="section-note">
          Один — це робочий процес, інший — формат, тож таблиця порівнює ролі, а не переможців.
        </p>

        <div class="table-wrap">
          <table class="compare-table" aria-label="Порівняння функцій SpecScore та Datarim">
            <thead>
              <tr>
                <th scope="col">Можливість</th>
                <th scope="col">Datarim</th>
                <th scope="col">SpecScore</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Основна роль</td>
                <td>Набір робочих процесів для Claude Code</td>
                <td><strong>Відкритий формат специфікацій + CLI</strong></td>
              </tr>
              <tr>
                <td>Запускається як</td>
                <td>Слеш-команди (<code>/dr-*</code>)</td>
                <td>Файли формату + CLI <span class="dim">(+ SpecStudio Skills у Claude Code)</span></td>
              </tr>
              <tr>
                <td>Зберігання стану</td>
                <td><code>backlog.md</code> + <code>CLAUDE.md</code> (під форму робочого процесу)</td>
                <td><strong>Портативне дерево <code>spec/</code></strong> (Markdown + YAML)</td>
              </tr>
              <tr>
                <td>Виживає без інструмента</td>
                <td>Прив'язаний до середовища виконання Datarim</td>
                <td><strong>Так</strong> — портативний за побудовою</td>
              </tr>
              <tr>
                <td>Лінтинг специфікацій</td>
                <td>Немає</td>
                <td><strong>Якість вмісту</strong> — нечіткі дієслова, відсутні критерії приймання, висячі посилання</td>
              </tr>
              <tr>
                <td>Ідентифікатори вимог / критеріїв приймання</td>
                <td>Немає</td>
                <td><strong>Машинно-адресовані ідентифікатори</strong> (<code>REQ: slug</code>)</td>
              </tr>
              <tr>
                <td>Простежуваність коду до специфікацій</td>
                <td>Немає</td>
                <td><strong><code>specscore:</code> анотації</strong> + <code>Verifies:</code> трейлери</td>
              </tr>
              <tr>
                <td>Маршрутизація за складністю (L1–L4)</td>
                <td><strong>Так</strong></td>
                <td>Ні (формат, не робочий процес)</td>
              </tr>
              <tr>
                <td>Граф специфікацій із запитами</td>
                <td>Ні</td>
                <td><strong>Так</strong> — <code>feature list / show / deps</code></td>
              </tr>
              <tr>
                <td>Прив'язка до Claude Code</td>
                <td>Створений для нього</td>
                <td><strong>Ні</strong> — будь-який агент або жоден</td>
              </tr>
              <tr>
                <td>Ліцензія</td>
                <td>MIT</td>
                <td>MIT / CC BY 4.0</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {/* ── Where SpecScore goes further ── */}
    <section class="section" aria-labelledby="further-title">
      <div class="section-inner">
        <h2 id="further-title" class="section-title">Що додає SpecScore.</h2>

        <div class="diff-grid">
          <div class="diff-card">
            <h3 class="diff-card__title">Результат переживає робочий процес</h3>
            <p class="diff-card__desc">
              Стан Datarim живе у власному беклозі та формі <code>CLAUDE.md</code> —
              цінний, поки ви запускаєте Datarim. Специфікації SpecScore — це портативний
              формат, який залишається читабельним, лінтованим та доступним для запитів
              узагалі без жодного встановленого інструментарію SpecScore. Робочий процес
              може змінитися; специфікації йдуть з вами.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Специфікації можна лінтувати</h3>
            <p class="diff-card__desc">
              Робочий процес скеровує авторство, але не контролює результат. <code>lint</code>
              у SpecScore перевіряє, що кожна вимога має критерії приймання,
              перехресні посилання розв'язуються, а переходи статусів коректні.
            </p>
            <div class="diff-card__example">
<pre class="terminal"><span class="prompt">$</span> specscore lint checkout/apply-discount.md
  <span class="mark-fail">✗</span> R3  no acceptance criteria
  <span class="mark-fail">✗</span> link  <span class="dim">"Related Feature: discount-tiers" not found</span></pre>
            </div>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Код простежується назад до специфікацій</h3>
            <p class="diff-card__desc">
              SpecScore додає джерельні анотації <code>specscore:</code> та
              трейлери комітів <code>Verifies:</code> — <code>specscore code refs</code>
              детерміновано відповідає «який код реалізує цю вимогу?»,
              незалежно від робочого процесу, що створив специфікацію.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Не прив'язаний до одного агента</h3>
            <p class="diff-card__desc">
              Datarim створений для Claude Code. SpecScore — це формат, який може читати
              будь-який агент, та один Go-бінарник, який може запустити будь-який CI — без
              Claude Code, без встановлення в <code>~/.claude/</code>.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── When to use which ── */}
    <section class="section" aria-labelledby="when-title">
      <div class="section-inner">
        <h2 id="when-title" class="section-title">Коли який використовувати.</h2>

        <div class="when-grid">
          <div class="when-card">
            <h3 class="when-card__title">Беріть Datarim, коли…</h3>
            <ul class="when-card__list">
              <li>Вам потрібен повний, виразний конвеєр усередині Claude Code вже сьогодні.</li>
              <li>Ви цінуєте маршрутизацію з урахуванням складності та мультиагентний ритуал прийняття рішень.</li>
              <li>Ваша робота охоплює різні домени — дослідження, право, контент, а не лише код.</li>
            </ul>
          </div>

          <div class="when-card when-card--primary">
            <h3 class="when-card__title">Використовуйте SpecScore, коли…</h3>
            <ul class="when-card__list">
              <li>Вам потрібні специфікації, що переживають будь-який окремий робочий процес чи інструмент.</li>
              <li>Вам потрібні лінт, ідентифікатори, життєвий цикл та простежуваність коду до специфікацій.</li>
              <li>Ви працюєте з різними агентами — або без них — не лише з Claude Code.</li>
              <li>Вам потрібен CLI, який агенти можуть запитувати замість перечитування репозиторію.</li>
              <li>Вам потрібні шлюзи якості специфікацій у CI, що завершуються з ненульовим кодом.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── Two packs, one format ── */}
    <section class="section" aria-labelledby="bridge-title">
      <div class="section-inner section-inner--prose">
        <h2 id="bridge-title" class="section-title">Два набори робочих процесів, один відкритий формат.</h2>
        <p class="prose-p">
          Datarim та SpecStudio Skills — обидва виразні робочі процеси поверх Claude
          Code. SpecScore — це відкритий формат під ними — артефакт, який робочий процес
          може створити, щоб специфікації залишалися портативними, лінтованими та
          простежуваними після завершення конвеєра. Datarim, що видає SpecScore, зберіг
          би свій UX і отримав би довговічний результат.
        </p>
        <p class="prose-p">
          Виберіть Datarim для конвеєра. Використовуйте SpecScore для артефакту, який він залишає по собі.
        </p>
      </div>
    </section>

    <ComparisonFeedback page="datarim" />
  </main>

  {/* ── Final CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">Специфікації, що проходять перевірку.</h2>
      <div class="final-cta__buttons">
        <a href="/cli/install/" class="btn btn--primary">Встановити CLI</a>
        <a href="/ai/specstudio-skills/" class="btn btn--secondary">Отримати AI-навички для вашого агента</a>
        <a
          href="https://github.com/specscore/specscore"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          Відкритий код на GitHub
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <SiteFooterUk />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-5);
    background: var(--cream);
  }
  .hero__inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms;
  }
  .hero__breadcrumb {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--pale-ink);
    margin-bottom: var(--space-2);
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
    max-width: 52ch;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Section titles ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }

  /* ── Shared list ── */
  .shared-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .shared-list li {
    position: relative;
    padding-left: 1.4rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
  }
  .shared-list li::before {
    content: '=';
    position: absolute;
    left: 0;
    font-family: var(--font-code);
    font-weight: 700;
    color: var(--pale-ink);
  }

  /* ── Section note ── */
  .section-note {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    margin-bottom: var(--space-3);
  }

  /* ── Credit cards ── */
  .credit-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .credit-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .credit-card__desc {
    color: var(--mid-ink);
    line-height: 1.6;
    font-size: var(--fs-body);
  }
  .credit-card__desc code {
    font-size: 0.9em;
    background: var(--cream);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Feature comparison table ── */
  .table-section { background: var(--cream-2); }
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-small);
    line-height: 1.5;
  }
  .compare-table th,
  .compare-table td {
    text-align: left;
    padding: 0.65rem 0.85rem;
    border-bottom: 1px solid var(--hairline);
    vertical-align: top;
  }
  .compare-table thead th {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mid-ink);
    border-bottom: 2px solid var(--graphite);
    white-space: nowrap;
  }
  .compare-table td:first-child {
    font-weight: 500;
    white-space: nowrap;
    min-width: 160px;
  }
  .compare-table td:nth-child(2),
  .compare-table td:nth-child(3) {
    min-width: 200px;
  }
  .compare-table td code {
    font-size: 0.88em;
    background: var(--surface);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .compare-table strong {
    font-weight: 600;
    color: var(--ink);
  }
  .compare-table .dim {
    color: var(--pale-ink);
  }

  /* ── Diff grid ── */
  .diff-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .diff-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
  }
  .diff-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .diff-card__desc {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    line-height: 1.6;
  }
  .diff-card__desc code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .diff-card__example {
    margin-top: var(--space-2);
  }
  .diff-card__example .terminal {
    font-size: 0.78rem;
    line-height: 1.6;
  }

  @media (max-width: 860px) {
    .diff-grid { grid-template-columns: 1fr; }
  }

  /* ── When to use which ── */
  .when-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .when-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-4);
  }
  .when-card--primary {
    border-color: var(--validator-green);
    border-width: 2px;
  }
  .when-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .when-card__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .when-card__list li {
    position: relative;
    padding-left: 1.2rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
    font-size: var(--fs-small);
  }
