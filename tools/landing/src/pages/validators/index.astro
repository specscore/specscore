---
// SpecScore /validators — what the two validators check, and where they stop.
//
// Value-first: a cold reader (e.g. from a Habr link or Google) is oriented in
// the hero, sees what each validator CATCHES, then reaches the honest-limits
// section at #limits. Framing: a layered system with honest seams —
// deterministic lint, probabilistic AI review, human judgment.
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import LintExample from '../../components/LintExample.astro';
import ScoreExample from '../../components/ScoreExample.astro';
---

<BaseLayout
  title="What SpecScore validates — and what it can't."
  description="SpecScore checks your specs with two validators: a deterministic linter and an AI reviewer. See exactly what each one catches — and where automated validation stops and your judgment takes over."
  canonical="https://specscore.md/validators/"
>
  <SiteHeader />

  <main>
    {/* ── Hero: orient the cold reader, then show lint passing ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <h1 id="hero-title" class="hero__headline">
          What SpecScore<br />validates.
        </h1>
        <div class="hero__copy">
          <p class="hero__sub">
            SpecScore is an open Markdown format for features, requirements, and
            acceptance criteria — checked by two validators: a deterministic
            <strong>linter</strong> and an <strong>AI reviewer</strong>. Here's
            what each one catches, and where automated checking stops.
          </p>
          <p class="hero__context">
            New to SpecScore? <a class="xref" href="/">Start here</a> ·
            <a class="xref" href="/cli/">The CLI</a> ·
            <a class="xref" href="/ai/">AI Skills</a>
          </p>
        </div>

        <div
          class="hero__art"
          role="img"
          aria-label="Terminal output: specscore lint on a checkout spec passes all 24 requirements — structure, references, IDs valid, no index drift, no broken links. 0 problems, exit 0."
        >
<pre class="terminal terminal--window"><span class="prompt">$</span> specscore lint checkout/

  <span class="mark-pass">✓</span> 24 requirements — structure, references, IDs valid
  <span class="mark-pass">✓</span> no index drift · no broken links · no slug collisions

  <span class="dim">0 problems   exit 0</span></pre>
        </div>
      </div>
    </section>

    {/* ── The three layers ── */}
    <section class="section" aria-labelledby="layers-title">
      <div class="section-inner section-inner--prose">
        <h2 id="layers-title" class="section-title">Three layers, not one.</h2>
        <p class="prose-p">
          SpecScore validates in layers, cheapest and most certain first.
          <strong>Lint</strong> is deterministic — fast, free, runs on every
          commit. <strong>AI review</strong> is probabilistic — deeper, costs
          tokens, catches things lint can't reach. <strong>Human judgment</strong>
          is the third layer, and the seams the first two can't close are its job
          on purpose. The two automated layers are complementary, not redundant:
          lint catches what AI can't defend; AI catches what lint can't reach.
        </p>
      </div>
    </section>

    {/* ── What each validator checks (the positive half) ── */}
    <section class="section validators-section" aria-labelledby="checks-title">
      <div class="section-inner">
        <h2 id="checks-title" class="section-title">What each validator checks.</h2>
        <div class="vcols">
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">Layer 1</span>
              <h3 class="validator__title">CLI linter</h3>
              <span class="validator__kind">deterministic</span>
            </div>
            <p class="validator__lead">
              Same result every run, no LLM, no cost. If it passes here, it's a
              fact — not an opinion.
            </p>
            <div
              class="checks-terminal"
              role="img"
              aria-label="specscore lint output: R1 and R2 have acceptance criteria; R3 has none, a Related Feature link doesn't resolve, and the required Open Questions section is missing. 3 problems, exit 1."
            >
              <LintExample />
            </div>
            <ul class="vlist">
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Referential integrity — links resolve, IDs are unique</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Structural conventions — required sections, frontmatter shape</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Status hygiene and index drift</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Slug collisions</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Prefix validity on metadata fields (e.g. <code>Related Ideas:</code>)</li>
            </ul>
          </div>
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">Layer 2</span>
              <h3 class="validator__title">AI review &amp; score</h3>
              <span class="validator__kind">non-deterministic</span>
            </div>
            <p class="validator__lead">
              Reads for meaning, the way a human reviewer would — and like a
              human, it isn't perfectly repeatable.
            </p>
            <div
              class="checks-terminal"
              role="img"
              aria-label="/score output: the spec earns a B grade with two actionable notes — a vague trigger on AC-2 and a missing error path on AC-3."
            >
              <ScoreExample />
            </div>
            <ul class="vlist">
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> ACs phrased as verifiable Given/When/Then</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Internal consistency within an artifact</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Vague or placeholder content</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Readability for a human reviewer</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Author-actionable, severity-marked feedback</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> An A–F readiness grade</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── #limits — what they don't catch (the honest half) ── */}
    <section class="section limits-section" id="limits" aria-labelledby="limits-title">
      <div class="section-inner">
        <h2 id="limits-title" class="section-title">What they don't catch.</h2>
        <p class="section-lead">
          No validator is magic. Here's where each one stops — so you know
          exactly where your own judgment still has to do the work.
        </p>
        <div class="vcols">
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">Layer 1</span>
              <h3 class="validator__title">CLI linter</h3>
            </div>
            <ul class="vlist">
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Implicit contradictions across deep hierarchies</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Drift between spec and code <span class="vnote">(improving as <code>specstudio:recap</code> lands)</span></li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Semantic correctness of acceptance criteria</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Whether a name actually makes sense</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Whether the requirements solve the stated problem</li>
            </ul>
          </div>
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">Layer 2</span>
              <h3 class="validator__title">AI review &amp; score</h3>
              <span class="validator__kind">catches inconsistently</span>
            </div>
            <ul class="vlist">
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Full run-to-run reproducibility — verdicts may shift within tolerance</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Cross-artifact contradictions across a large tree without explicit cross-checks</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Whether requirements truly solve the problem — flags obvious gaps, misses domain-specific ones</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Biases inherited from the underlying LLM</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Semantic correctness with absolute certainty</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Anything the rubric doesn't weight</li>
            </ul>
          </div>
        </div>

        <ol class="bands" aria-label="The three layers of validation, in order of reach">
          <li class="band">
            <span class="band__step">1</span>
            <h3 class="band__title">Lint reaches here</h3>
            <p class="band__desc">
              Structure, references, hygiene. Cheap and certain — but blind to
              meaning.
            </p>
          </li>
          <li class="band band--mid">
            <span class="band__step">2</span>
            <h3 class="band__title">AI reaches here</h3>
            <p class="band__desc">
              Meaning, clarity, consistency within an artifact. Deeper — but
              probabilistic, and weak across a large tree.
            </p>
          </li>
          <li class="band band--human">
            <span class="band__step">3</span>
            <h3 class="band__title">Still on you</h3>
            <p class="band__desc">
              Cross-cutting judgment over the whole system. Not a gap we forgot
              to close — a layer we put humans in on purpose.
            </p>
          </li>
        </ol>

        <div class="worked">
          <h3 class="worked__title">The case neither tool will save you from</h3>
          <p class="worked__body">
            Picture a real, deep spec tree. Feature&nbsp;A requires <em>X</em>.
            Feature&nbsp;B requires <em>Y</em>. Feature&nbsp;C requires
            <em>Z</em>. Then feature&nbsp;D quietly requires something that
            contradicts B — but only when A is also active. Lint sees four valid,
            well-linked documents and passes. The AI reviewer, reading artifacts
            one at a time, has no reason to load all four and notice the
            three-way interaction.
          </p>
          <p class="worked__body">
            <strong>Neither layer reliably catches this — and we're not going to
            pretend otherwise.</strong> This exact class of contradiction is why
            the third layer exists. SpecScore's job is to make the tree
            navigable enough that a human reviewing the seams can <em>find</em>
            the conflict — open questions propagate up the hierarchy, related
            requirements are one query away — not to claim a tool already found
            it.
          </p>
        </div>
      </div>
    </section>
  </main>

  {/* ── Final CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">Honest tools, honest specs.</h2>
      <div class="final-cta__buttons">
        <a href="/cli/install/" class="btn btn--primary">Install the CLI</a>
        <a href="/ai/specstudio-skills/" class="btn btn--secondary">Get AI skills for your agent</a>
        <a
          href="https://github.com/specscore/specscore-cli"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          Open-source on GitHub
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <footer class="page-footer">
    <div class="page-footer__inner">
      <div class="page-footer__col page-footer__brand">
        <a href="/" class="wordmark" aria-label="SpecScore home">
          <span class="wordmark__clef" aria-hidden="true">&#x1D11E;</span>
          <span class="wordmark__name">SpecScore.md</span>
        </a>
        <p class="page-footer__tagline">
          An open standard for specifications, requirements,
          and acceptance criteria.
        </p>
        <p class="page-footer__copyright">
          &copy; 2026 SpecScore contributors. MIT license.
        </p>
      </div>

      <div class="page-footer__col">
        <h4 class="page-footer__heading">SpecScore CLI</h4>
        <ul class="page-footer__list">
          <li><a href="/cli/">Overview</a></li>
          <li><a href="/cli/install/">Install</a></li>
          <li><a href="https://github.com/specscore/specscore-cli">GitHub</a></li>
        </ul>
      </div>

      <div class="page-footer__col">
        <h4 class="page-footer__heading">Ecosystem</h4>
        <ul class="page-footer__list">
          <li><a href="/">SpecScore</a> — the open standard</li>
          <li><a href="/ai/specstudio-skills/">SpecStudio Skills</a> — Claude Code plugin</li>
          <li><a href="https://specscore.studio">SpecScore Studio</a> — web viewer</li>
        </ul>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ── Hero (mirrors /cli two-column rhythm) ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-7);
    background: var(--cream);
    overflow: hidden;
  }
  .hero__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 38fr 62fr;
    gap: var(--space-3) var(--space-6);
    align-items: center;
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
  }
  .hero__inner > .hero__headline {
    grid-column: 1 / -1;
    margin-bottom: 0;
  }
  .hero__copy {
    animation: hero-copy-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 280ms;
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
    max-width: 52ch;
  }
  .hero__sub strong { color: var(--ink); }
  .hero__context {
    margin-top: var(--space-3);
    font-size: var(--fs-small);
    color: var(--pale-ink);
  }
  .hero__art {
    animation: hero-art-in 700ms cubic-bezier(0.22, 0.61, 0.36, 1) both 100ms;
    min-width: 0;
  }
  .hero__art pre.terminal {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.65;
  }

  @keyframes hero-copy-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-art-in {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 860px) {
    .hero { padding: var(--space-5) var(--space-3) var(--space-6); }
    .hero__inner { grid-template-columns: 1fr; gap: var(--space-4); }
    .hero__copy { order: 1; }
    .hero__art  { order: 2; }
  }

  /* ── Section scaffolding ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  .section-lead {
    color: var(--mid-ink);
    line-height: 1.6;
    max-width: 60ch;
    margin-bottom: var(--space-4);
  }
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
  }
  .prose-p strong { color: var(--ink); }

  /* ── Validator columns (used by both "checks" and "#limits") ── */
  .validators-section { background: var(--cream); }
  .limits-section {
    background: var(--cream-2);
    scroll-margin-top: var(--space-5);
  }

  .validator__head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .validator__layer {
    font-family: var(--font-display);
    font-size: var(--fs-tiny);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--pale-ink);
  }
  .validator__title {
    font-size: var(--fs-h3);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .validator__kind {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--mid-ink);
  }
  .validator__lead {
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .checks-terminal {
    margin-bottom: var(--space-3);
  }
  .checks-terminal pre.terminal {
    margin: 0;
    font-size: 0.72rem;
    line-height: 1.65;
  }

  .vcols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }
  .vlist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .vlist li {
    position: relative;
    padding-left: 1.6rem;
    color: var(--ink);
    line-height: 1.5;
    font-size: var(--fs-small);
  }
  .vlist code {
    font-size: 0.9em;
    background: var(--surface);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .mark {
    position: absolute;
    left: 0;
    font-weight: 700;
    font-family: var(--font-code);
  }
  .mark--pass { color: var(--validator-green); }
  .mark--fail { color: var(--mark-red); }
  .vnote { color: var(--pale-ink); }

  @media (max-width: 640px) {
    .vcols { grid-template-columns: 1fr; gap: var(--space-4); }
  }

  /* ── Synthesis bands ── */
  .bands {
    list-style: none;
    margin: var(--space-5) 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .band {
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-top: 3px solid var(--validator-green);
    padding: var(--space-3);
  }
  .band--mid { border-top-color: var(--ink-blue); }
  .band--human { border-top-color: var(--mark-red); }
  .band__step {
    font-family: var(--font-display);
    font-size: var(--fs-small);
    font-weight: 700;
    color: var(--pale-ink);
  }
  .band__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin: var(--space-1) 0;
  }
  .band__desc {
    font-size: var(--fs-small);
    color: var(--mid-ink);
    line-height: 1.55;
  }

  @media (max-width: 720px) {
    .bands { grid-template-columns: 1fr; }
  }

  /* ── Worked example ── */
  .worked {
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-left: 3px solid var(--ink);
    padding: var(--space-4);
  }
  .worked__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .worked__body {
    color: var(--mid-ink);
    line-height: 1.65;
  }
  .worked__body + .worked__body { margin-top: var(--space-2); }
  .worked__body strong { color: var(--ink); }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    text-align: center;
  }
  .final-cta__title {
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .final-cta__buttons {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  /* ── Footer ── */
  .page-footer {
    background: var(--cream);
    padding: var(--space-6) var(--space-3) var(--space-5);
  }
  .page-footer__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-4);
  }
  .page-footer__brand .wordmark { margin-bottom: var(--space-2); }
  .page-footer__tagline { color: var(--mid-ink); margin-bottom: var(--space-2); max-width: 36ch; line-height: 1.5; font-size: 0.95rem; }
  .page-footer__copyright { color: var(--pale-ink); font-size: 0.825rem; font-family: var(--font-code); }
  .page-footer__heading { font-family: var(--font-display); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--mid-ink); margin-bottom: var(--space-2); }
  .page-footer__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.4rem; }
  .page-footer__list a { color: var(--ink); font-size: 0.9rem; border-bottom: 1px solid transparent; transition: border-color 120ms ease; }
  .page-footer__list a:hover { border-bottom-color: var(--ink); }
  .page-footer__list a:focus-visible { outline: 2px solid var(--ink-blue); outline-offset: 2px; border-radius: 2px; }

  @media (max-width: 800px) {
    .page-footer__inner { grid-template-columns: 1fr 1fr; }
    .page-footer__brand { grid-column: 1 / -1; }
  }
</style>
