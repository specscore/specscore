---
// Brazilian Portuguese variant of /validators.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooterPtBr from '../../../components/SiteFooterPtBr.astro';
import LintExample from '../../../components/LintExample.astro';
import ScoreExample from '../../../components/ScoreExample.astro';
---

<BaseLayout
  lang="pt-BR"
  title="O que o SpecScore valida — e o que ele não consegue."
  description="O SpecScore verifica suas specs com dois validadores: um linter determinístico e um revisor de IA. Veja exatamente o que cada um pega — e onde a validação automática para e o seu julgamento assume."
  canonical="https://specscore.md/pt-br/validators/"
>
  <SiteHeader />

  <main>
    {/* ── Hero: orient the cold reader, then show lint passing ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <h1 id="hero-title" class="hero__headline">
          O que o SpecScore<br />valida.
        </h1>
        <div class="hero__copy">
          <p class="hero__sub">
            O SpecScore é um formato aberto em Markdown para features, requisitos
            e critérios de aceitação — verificado por dois validadores: um
            <strong>linter</strong> determinístico e um
            <strong>revisor de IA</strong>. Veja o que cada um pega, e onde a
            verificação automática para.
          </p>
          <p class="hero__context">
            Novo no SpecScore? <a class="xref" href="/pt-br/">Comece por aqui</a> ·
            <a class="xref" href="/pt-br/cli/">O CLI</a> ·
            <a class="xref" href="/pt-br/ai/">Skills de IA</a>
          </p>
        </div>

        <div
          class="hero__art"
          role="img"
          aria-label="Saída do terminal: specscore lint numa spec de checkout passa todos os 24 requisitos — estrutura, referências e IDs válidos, sem desvio de índice, sem links quebrados. 0 problemas, exit 0."
        >
<pre class="terminal terminal--window"><span class="prompt">$</span> specscore lint checkout/

  <span class="mark-pass">✓</span> 24 requirements — structure, references, IDs valid
  <span class="mark-pass">✓</span> no index drift · no broken links · no slug collisions

  <span class="dim">0 problems   exit 0</span></pre>
        </div>
      </div>
    </section>

    {/* ── The three layers ── */}
    <section class="section" aria-labelledby="layers-title">
      <div class="section-inner section-inner--prose">
        <h2 id="layers-title" class="section-title">Três camadas, não uma.</h2>
        <p class="prose-p">
          O SpecScore valida em camadas, da mais barata e mais certa para a
          mais cara. O <strong>lint</strong> é determinístico — rápido, gratuito,
          roda em todo commit. A <strong>revisão de IA</strong> é probabilística
          — mais profunda, custa tokens, pega coisas que o lint não alcança. O
          <strong>julgamento humano</strong> é a terceira camada: as costuras que
          as duas primeiras não fecham ainda precisam de uma pessoa — nenhuma
          ferramenta consegue fechá-las de forma confiável hoje. As duas camadas
          automáticas são complementares, não redundantes: o lint pega o que a IA
          não consegue justificar; a IA pega o que o lint não alcança.
        </p>
      </div>
    </section>

    {/* ── What each validator checks (the positive half) ── */}
    <section class="section validators-section" aria-labelledby="checks-title">
      <div class="section-inner">
        <h2 id="checks-title" class="section-title">O que cada validador verifica.</h2>
        <div class="vcols">
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">Camada 1</span>
              <h3 class="validator__title">Linter do CLI</h3>
              <span class="validator__kind">determinístico</span>
            </div>
            <p class="validator__lead">
              Mesmo resultado a cada execução, sem LLM, sem custo. Se passa aqui,
              é um fato — não uma opinião.
            </p>
            <div
              class="checks-terminal"
              role="img"
              aria-label="Saída do specscore lint: R1 e R2 têm critérios de aceitação; R3 não tem nenhum, um link Related Feature não resolve e a seção obrigatória Open Questions está faltando. 3 problemas, exit 1."
            >
              <LintExample />
            </div>
            <ul class="vlist">
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Integridade referencial — links resolvem, IDs são únicos</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Convenções estruturais — seções obrigatórias, formato do frontmatter</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Higiene de status e desvio de índice</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Colisões de slug</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Validade de prefixos em campos de metadados (ex.: <code>Related Ideas:</code>)</li>
            </ul>
          </div>
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">Camada 2</span>
              <h3 class="validator__title">Revisão e nota por IA</h3>
              <span class="validator__kind">não determinístico</span>
            </div>
            <p class="validator__lead">
              Lê em busca de significado, como faria um revisor humano — e, como
              um humano, não é perfeitamente repetível.
            </p>
            <div
              class="checks-terminal"
              role="img"
              aria-label="Saída do /score: a spec recebe a nota B com duas observações acionáveis — um gatilho vago no AC-2 e um caminho de erro ausente no AC-3."
            >
              <ScoreExample />
            </div>
            <ul class="vlist">
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> ACs formulados como Given/When/Then verificáveis</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Consistência interna dentro de um artefato</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Conteúdo vago ou de preenchimento</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Legibilidade para um revisor humano</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Feedback acionável pelo autor e marcado por severidade</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Uma nota de prontidão de A a F</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── #limits — what they don't catch (the honest half) ── */}
    <section class="section limits-section" id="limits" aria-labelledby="limits-title">
      <div class="section-inner">
        <h2 id="limits-title" class="section-title">O que eles não pegam.</h2>
        <p class="section-lead">
          Nenhum validador é mágica. Aqui é onde cada um para — para que você
          saiba exatamente onde o seu próprio julgamento ainda tem que fazer o
          trabalho.
        </p>
        <div class="vcols">
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">Camada 1</span>
              <h3 class="validator__title">Linter do CLI</h3>
            </div>
            <ul class="vlist">
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Contradições implícitas ao longo de hierarquias profundas</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Desvio entre spec e código <span class="vnote">(melhorando com a chegada do <code>specstudio:recap</code>)</span></li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Correção semântica dos critérios de aceitação</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Se um nome realmente faz sentido</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Se os requisitos resolvem o problema declarado</li>
            </ul>
          </div>
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">Camada 2</span>
              <h3 class="validator__title">Revisão e nota por IA</h3>
              <span class="validator__kind">pega de forma inconsistente</span>
            </div>
            <ul class="vlist">
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Reprodutibilidade total entre execuções — vereditos podem variar dentro da tolerância</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Contradições entre artefatos em uma árvore grande sem verificações cruzadas explícitas</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Se os requisitos realmente resolvem o problema — sinaliza lacunas óbvias, mas perde as específicas do domínio</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Vieses herdados da LLM subjacente</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Correção semântica com certeza absoluta</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> Qualquer coisa que a rubrica não pondere</li>
            </ul>
          </div>
        </div>

        <ol class="bands" aria-label="As três camadas de validação, em ordem de alcance">
          <li class="band">
            <span class="band__step">1</span>
            <h3 class="band__title">O lint alcança até aqui</h3>
            <p class="band__desc">
              Estrutura, referências, higiene. Barato e certo — mas cego ao
              significado.
            </p>
          </li>
          <li class="band band--mid">
            <span class="band__step">2</span>
            <h3 class="band__title">A IA alcança até aqui</h3>
            <p class="band__desc">
              Significado, clareza, consistência dentro de um artefato. Mais
              profunda — mas probabilística, e fraca ao longo de uma árvore
              grande.
            </p>
          </li>
          <li class="band band--human">
            <span class="band__step">3</span>
            <h3 class="band__title">Ainda fica por sua conta</h3>
            <p class="band__desc">
              Julgamento transversal sobre o sistema inteiro — um trabalho que
              nenhuma ferramenta consegue fazer de forma confiável hoje, então
              ainda exige um revisor humano.
            </p>
          </li>
        </ol>

        <div class="worked">
          <h3 class="worked__title">O caso do qual nenhuma ferramenta vai te salvar</h3>
          <p class="worked__body">
            Imagine uma árvore de specs real e profunda. A feature&nbsp;A exige
            <em>X</em>. A feature&nbsp;B exige <em>Y</em>. A feature&nbsp;C exige
            <em>Z</em>. Então a feature&nbsp;D silenciosamente exige algo que
            contradiz B — mas só quando A também está ativa. O lint vê quatro
            documentos válidos e bem conectados e passa. O revisor de IA, lendo
            os artefatos um de cada vez, não tem motivo para carregar os quatro
            e notar a interação entre os três.
          </p>
          <p class="worked__body">
            <strong>Nenhuma das camadas pega isso de forma confiável — e não
            vamos fingir o contrário.</strong> É exatamente essa classe de
            contradição que justifica a existência da terceira camada. O trabalho
            do SpecScore é deixar a árvore navegável o bastante para que um
            humano revisando as costuras consiga <em>encontrar</em> o conflito —
            questões em aberto sobem pela hierarquia, requisitos relacionados
            estão a uma consulta de distância — e não afirmar que uma ferramenta
            já o encontrou.
          </p>
        </div>
      </div>
    </section>
  </main>

  {/* ── Final CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">Ferramentas honestas, specs honestas.</h2>
      <div class="final-cta__buttons">
        <a href="/pt-br/cli/install/" class="btn btn--primary">Instalar o CLI</a>
        <a href="/pt-br/ai/specstudio-skills/" class="btn btn--secondary">Skills de IA para seu agente</a>
        <a
          href="https://github.com/specscore/specscore-cli"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          Código aberto no GitHub
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <SiteFooterPtBr />
</BaseLayout>

<style>
  /* ── Hero (mirrors /cli two-column rhythm) ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-7);
    background: var(--cream);
    overflow: hidden;
  }
  .hero__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 38fr 62fr;
    gap: var(--space-3) var(--space-6);
    align-items: center;
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
  }
  .hero__inner > .hero__headline {
    grid-column: 1 / -1;
    margin-bottom: 0;
  }
  .hero__copy {
    animation: hero-copy-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 280ms;
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
    max-width: 52ch;
  }
  .hero__sub strong { color: var(--ink); }
  .hero__context {
    margin-top: var(--space-3);
    font-size: var(--fs-small);
    color: var(--pale-ink);
  }
  .hero__art {
    animation: hero-art-in 700ms cubic-bezier(0.22, 0.61, 0.36, 1) both 100ms;
    min-width: 0;
  }
  .hero__art pre.terminal {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.65;
  }

  @keyframes hero-copy-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-art-in {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 860px) {
    .hero { padding: var(--space-5) var(--space-3) var(--space-6); }
    .hero__inner { grid-template-columns: 1fr; gap: var(--space-4); }
    .hero__copy { order: 1; }
    .hero__art  { order: 2; }
  }

  /* ── Section scaffolding ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  .section-lead {
    color: var(--mid-ink);
    line-height: 1.6;
    max-width: 60ch;
    margin-bottom: var(--space-4);
  }
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
  }
  .prose-p strong { color: var(--ink); }

  /* ── Validator columns (used by both "checks" and "#limits") ── */
  .validators-section { background: var(--cream); }
  .limits-section {
    background: var(--cream-2);
    scroll-margin-top: var(--space-5);
  }

  .validator__head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .validator__layer {
    font-family: var(--font-display);
    font-size: var(--fs-tiny);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--pale-ink);
  }
  .validator__title {
    font-size: var(--fs-h3);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .validator__kind {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--mid-ink);
  }
  .validator__lead {
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .checks-terminal {
    margin-bottom: var(--space-3);
  }
  .checks-terminal pre.terminal {
    margin: 0;
    font-size: 0.72rem;
    line-height: 1.65;
  }

  .vcols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }
  .vlist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .vlist li {
    position: relative;
    padding-left: 1.6rem;
    color: var(--ink);
    line-height: 1.5;
    font-size: var(--fs-small);
  }
  .vlist code {
    font-size: 0.9em;
    background: var(--surface);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .mark {
    position: absolute;
    left: 0;
    font-weight: 700;
    font-family: var(--font-code);
  }
  .mark--pass { color: var(--validator-green); }
  .mark--fail { color: var(--mark-red); }
  .vnote { color: var(--pale-ink); }

  @media (max-width: 640px) {
    .vcols { grid-template-columns: 1fr; gap: var(--space-4); }
  }

  /* ── Synthesis bands ── */
  .bands {
    list-style: none;
    margin: var(--space-5) 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .band {
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-top: 3px solid var(--validator-green);
    padding: var(--space-3);
  }
  .band--mid { border-top-color: var(--ink-blue); }
  .band--human { border-top-color: var(--mark-red); }
  .band__step {
    font-family: var(--font-display);
    font-size: var(--fs-small);
    font-weight: 700;
    color: var(--pale-ink);
  }
  .band__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin: var(--space-1) 0;
  }
  .band__desc {
    font-size: var(--fs-small);
    color: var(--mid-ink);
    line-height: 1.55;
  }

  @media (max-width: 720px) {
    .bands { grid-template-columns: 1fr; }
  }

  /* ── Worked example ── */
  .worked {
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-left: 3px solid var(--ink);
    padding: var(--space-4);
  }
  .worked__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .worked__body {
    color: var(--mid-ink);
    line-height: 1.65;
  }
  .worked__body + .worked__body { margin-top: var(--space-2); }
  .worked__body strong { color: var(--ink); }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    text-align: center;
  }
  .final-cta__title {
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .final-cta__buttons {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>
