---
// /pt-br/vs/openspec/ — SpecScore vs OpenSpec comparison (pt-br).
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../../components/SiteHeader.astro';
---

<BaseLayout
  lang="pt-BR"
  title="SpecScore vs OpenSpec — Comparação honesta."
  description="Uma comparação factual e lado a lado entre SpecScore e OpenSpec: formato de spec, linting, ciclo de vida, rastreabilidade, CLI e suporte a agentes. Honesta sobre ambos."
  canonical="https://specscore.md/pt-br/vs/openspec/"
>
  <SiteHeader />

  <main>
    {/* ── Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <p class="hero__breadcrumb"><a href="/pt-br/vs/" class="xref">Comparações</a></p>
        <h1 id="hero-title" class="hero__headline">
          SpecScore vs OpenSpec
        </h1>
        <p class="hero__sub">
          Ambos colocam especificações em Markdown, junto ao seu código, legíveis por agentes de IA. Eles respondem a perguntas diferentes: o OpenSpec organiza specs e gera comandos para agentes. O SpecScore faz lint do conteúdo das specs, impõe ciclo de vida e rastreia o código de volta aos requisitos.
        </p>
      </div>
    </section>

    {/* ── What they share ── */}
    <section class="section" aria-labelledby="shared-title">
      <div class="section-inner section-inner--prose">
        <h2 id="shared-title" class="section-title">O que têm em comum.</h2>
        <ul class="shared-list">
          <li>As specs vivem no seu repositório como arquivos Markdown — versionadas, revisáveis em PRs.</li>
          <li>Ambos são open source sob a licença MIT.</li>
          <li>Ambos usam critérios de aceitação no formato Given/When/Then.</li>
          <li>Ambos suportam agentes de IA como consumidores de primeira classe das specs.</li>
        </ul>
      </div>
    </section>

    {/* ── What OpenSpec does well ── */}
    <section class="section" aria-labelledby="openspec-title">
      <div class="section-inner section-inner--prose">
        <h2 id="openspec-title" class="section-title">O que o OpenSpec faz bem.</h2>

        <div class="credit-card">
          <h3 class="credit-card__title">Suporte mais amplo a agentes</h3>
          <p class="credit-card__desc">
            O OpenSpec suporta 29 agentes de IA via arquivos de skills gerados — Claude, Cursor, Copilot, Gemini, Windsurf, Cline e outros. Se o seu agente está na lista, o OpenSpec se integra sem nenhuma configuração.
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">Baixa barreira de entrada</h3>
          <p class="credit-card__desc">
            <code>npm install -g @fission-ai/openspec &amp;&amp; openspec init</code> e você já está escrevendo specs. Sem schema para aprender, sem frontmatter obrigatório. Projetado para ser simples — especialmente para codebases existentes.
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">Modelo limpo de change-delta</h3>
          <p class="credit-card__desc">
            O formato <code>ADDED / MODIFIED / REMOVED</code> do OpenSpec para evolução de specs é bem projetado. Cada mudança é uma pasta com uma proposta, specs delta e tarefas — uma forma estruturada de propor modificações.
          </p>
        </div>
      </div>
    </section>

    {/* ── Feature comparison table ── */}
    <section class="section table-section" aria-labelledby="table-title">
      <div class="section-inner">
        <h2 id="table-title" class="section-title">Comparação de funcionalidades.</h2>

        <div class="table-wrap">
          <table class="compare-table" aria-label="Comparação de funcionalidades SpecScore vs OpenSpec">
            <thead>
              <tr>
                <th scope="col">Funcionalidade</th>
                <th scope="col">OpenSpec</th>
                <th scope="col">SpecScore</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Formato da spec</td>
                <td>Markdown (sem frontmatter)</td>
                <td>Markdown + YAML frontmatter</td>
              </tr>
              <tr>
                <td>Linting de spec</td>
                <td>Apenas estrutura de arquivos</td>
                <td><strong>Qualidade do conteúdo</strong> — verbos vagos, ACs ausentes, referências soltas</td>
              </tr>
              <tr>
                <td>IDs de requisitos</td>
                <td>Nenhum (referenciado por título)</td>
                <td><strong>Baseado em slug</strong> (<code>REQ: slug-format</code>)</td>
              </tr>
              <tr>
                <td>IDs de critérios de aceitação</td>
                <td>Nenhum</td>
                <td><strong>IDs endereçáveis por máquina</strong></td>
              </tr>
              <tr>
                <td>Status do ciclo de vida</td>
                <td>Implícito (localização do arquivo)</td>
                <td><strong>Imposto</strong> — Draft → Under Review → Approved → Implementing → Stable → Deprecated</td>
              </tr>
              <tr>
                <td>Rastreabilidade código-para-spec</td>
                <td>Nenhuma</td>
                <td><strong><code>specscore:</code> anotações</strong> + <code>Verifies:</code> trailers de commit</td>
              </tr>
              <tr>
                <td>Sub-features</td>
                <td>Não</td>
                <td><strong>Sim</strong> (diretórios aninhados)</td>
              </tr>
              <tr>
                <td>Referências cruzadas</td>
                <td>Sem mecanismo formal</td>
                <td><strong>Dependências, Ideas de origem, referências a planos</strong></td>
              </tr>
              <tr>
                <td>Integração com CI</td>
                <td>Básica (<code>openspec validate</code>)</td>
                <td><strong><code>specscore lint</code></strong> com severidade configurável, hooks de pre-commit</td>
              </tr>
              <tr>
                <td>Suporte a agentes</td>
                <td><strong>29 agentes</strong></td>
                <td>Claude Code como principal + CLI para qualquer agente</td>
              </tr>
              <tr>
                <td>Customização de schema</td>
                <td><strong>Sim</strong> (<code>schema.yaml</code>, fork/init)</td>
                <td>Schema fixo (consistência por design)</td>
              </tr>
              <tr>
                <td>Propostas de mudança</td>
                <td><strong>Modelo delta</strong> (ADDED/MODIFIED/REMOVED)</td>
                <td>Ideas de change-request + propostas</td>
              </tr>
              <tr>
                <td>Dependência de runtime</td>
                <td>Node.js 20.19+</td>
                <td><strong>Nenhuma</strong> — binário Go único</td>
              </tr>
              <tr>
                <td>Licença</td>
                <td>MIT</td>
                <td>MIT</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {/* ── Where SpecScore goes further ── */}
    <section class="section" aria-labelledby="further-title">
      <div class="section-inner">
        <h2 id="further-title" class="section-title">Onde o SpecScore vai além.</h2>

        <div class="diff-grid">
          <div class="diff-card">
            <h3 class="diff-card__title">O linting de specs detecta ambiguidade antes dos agentes</h3>
            <p class="diff-card__desc">
              O <code>validate</code> do OpenSpec verifica a estrutura de arquivos — se o arquivo existe, se tem as seções corretas. O <code>lint</code> do SpecScore verifica o conteúdo: verbos vagos sem objeto/condição, critérios de aceitação ausentes, referências cruzadas soltas, transições de status incompatíveis.
            </p>
            <div class="diff-card__example">
<pre class="terminal"><span class="prompt">$</span> specscore lint checkout/apply-discount.md
  <span class="mark-fail">✗</span> R3  Discount application
       <span class="dim">AC-3:18</span>  ambiguous AC — "higher-of rule" doesn't specify the tiebreaker
                <span class="dim">fix:</span> specify "higher discount wins; if tied, site-wide wins"</pre>
            </div>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Todo requisito tem um ID legível por máquina</h3>
            <p class="diff-card__desc">
              O OpenSpec referencia requisitos pelo título — frágil a renomeações. O SpecScore atribui IDs baseados em slug (<code>REQ: slug-format</code>) e IDs de AC que sobrevivem a renomeações, refatorações e transferências entre agentes.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">O ciclo de vida é imposto, não implícito</h3>
            <p class="diff-card__desc">
              No OpenSpec, o ciclo de vida de uma spec é sua localização no sistema de arquivos: <code>specs/</code> (atual), <code>changes/</code> (proposta), <code>archive/</code> (concluída). No SpecScore, o ciclo de vida é um campo de status imposto — Draft → Under Review → Approved → Implementing → Stable → Deprecated — validado pelo lint, transicionado via <code>specscore change-status</code> a partir de git hooks ou CI.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">O código rastreia de volta às specs</h3>
            <p class="diff-card__desc">
              O OpenSpec não tem mecanismo de rastreabilidade. O SpecScore tem anotações <code>specscore:</code> em comentários no código e trailers <code>Verifies:</code> nos commits. Execute <code>specscore code refs</code> e obtenha uma resposta determinística para "qual código implementa este requisito?"
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Sem dependência de runtime</h3>
            <p class="diff-card__desc">
              O OpenSpec requer Node.js 20.19+. O SpecScore é um binário Go único — sem runtime, sem <code>node_modules</code>. Funciona em projetos Go, Rust, Python e Java sem adicionar Node ao toolchain.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Hierarquia de artefatos composável</h3>
            <p class="diff-card__desc">
              As specs do OpenSpec são planas por domínio. O SpecScore tem uma hierarquia tipada: Ideas promovem para Features, Features contêm requisitos e ACs, Plans referenciam ACs, Tasks referenciam Plans. Todos os relacionamentos são navegáveis por máquina via CLI.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── When to use which ── */}
    <section class="section" aria-labelledby="when-title">
      <div class="section-inner">
        <h2 id="when-title" class="section-title">Quando usar cada um.</h2>

        <div class="when-grid">
          <div class="when-card">
            <h3 class="when-card__title">Comece com o OpenSpec quando…</h3>
            <ul class="when-card__list">
              <li>Você usa Cursor, Copilot ou agentes que não são Claude e precisa de integração pronta para uso.</li>
              <li>Você está adicionando specs a uma codebase existente pela primeira vez e quer zero fricção.</li>
              <li>Seu time valoriza flexibilidade de schema em vez de imposição.</li>
            </ul>
          </div>

          <div class="when-card when-card--primary">
            <h3 class="when-card__title">Use o SpecScore quando…</h3>
            <ul class="when-card__list">
              <li>Você precisa de controle de qualidade de specs — o lint detecta ambiguidade antes que agentes desperdicem tokens com ela.</li>
              <li>Você precisa de rastreabilidade código-para-spec — "qual código implementa este requisito?" retorna uma resposta determinística.</li>
              <li>Você está construindo um sistema grande com muitas features, sub-features e transições de ciclo de vida.</li>
              <li>Você quer zero dependências de runtime — um binário, sem necessidade de Node.js.</li>
              <li>Você precisa de quality gates para specs no CI — <code>specscore lint</code> retorna código diferente de zero em falhas, igual ao ESLint ou <code>go vet</code>.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── The integration opportunity ── */}
    <section class="section" aria-labelledby="bridge-title">
      <div class="section-inner section-inner--prose">
        <h2 id="bridge-title" class="section-title">Eles não são mutuamente exclusivos.</h2>
        <p class="prose-p">
          O SpecScore pode fazer lint dos arquivos <code>spec.md</code> do OpenSpec. Times que começam com o OpenSpec podem adicionar a camada de qualidade do SpecScore sem migrar — faça lint das specs que você já tem, adicione rastreabilidade quando precisar, imponha ciclo de vida quando seu time crescer.
        </p>
        <p class="prose-p">
          O OpenSpec é uma boa rampa de entrada. O SpecScore são as proteções laterais.
        </p>
      </div>
    </section>
  </main>

  {/* ── Final CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">Specs que passam.</h2>
      <div class="final-cta__buttons">
        <a href="/cli/install/" class="btn btn--primary">Instalar o CLI</a>
        <a href="/ai/specstudio-skills/" class="btn btn--secondary">Obter skills de IA para seu agente</a>
        <a href="https://github.com/specscore/specscore" rel="noopener" class="btn btn--tertiary">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" /></svg>
          Open-source no GitHub
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <footer class="page-footer">
    <div class="page-footer__inner">
      <div class="page-footer__col page-footer__brand">
        <a href="/pt-br/" class="wordmark" aria-label="SpecScore home">
          <span class="wordmark__clef" aria-hidden="true">&#x1D11E;</span>
          <span class="wordmark__name">SpecScore.md</span>
        </a>
        <p class="page-footer__tagline">Um padrão aberto para especificações, requisitos e critérios de aceitação.</p>
        <p class="page-footer__copyright">&copy; 2026 SpecScore contributors. MIT license.</p>
      </div>
      <div class="page-footer__col">
        <h4 class="page-footer__heading">Produto</h4>
        <ul class="page-footer__list">
          <li><a href="/cli/">SpecScore CLI</a></li>
          <li><a href="/cli/install/">Instalar</a></li>
          <li><a href="https://github.com/specscore/specscore-cli">GitHub</a></li>
        </ul>
      </div>
      <div class="page-footer__col">
        <h4 class="page-footer__heading">Ecossistema</h4>
        <ul class="page-footer__list">
          <li><a href="https://specscore.md">SpecScore</a> — o padrão aberto</li>
          <li><a href="/ai/specstudio-skills/">SpecStudio Skills</a></li>
          <li><a href="https://specscore.studio">SpecScore Studio</a> — visualizador web</li>
        </ul>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  .hero { padding: var(--space-6) var(--space-3) var(--space-5); background: var(--cream); }
  .hero__inner { max-width: var(--max-prose); margin: 0 auto; animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms; }
  .hero__breadcrumb { font-family: var(--font-code); font-size: var(--fs-small); color: var(--pale-ink); margin-bottom: var(--space-2); }
  .hero__headline { font-size: var(--fs-hero); font-weight: 700; line-height: 1.04; letter-spacing: -0.02em; margin-bottom: var(--space-3); }
  .hero__sub { font-size: 1.125rem; color: var(--mid-ink); line-height: 1.55; max-width: 52ch; }
  @keyframes fade-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .section-title { font-size: var(--fs-h2); font-weight: 700; letter-spacing: -0.01em; margin-bottom: var(--space-3); }
  .shared-list { list-style: none; margin: 0; padding: 0; }
  .shared-list li { position: relative; padding-left: 1.4rem; color: var(--mid-ink); line-height: 1.6; margin-bottom: var(--space-1); }
  .shared-list li::before { content: '='; position: absolute; left: 0; font-family: var(--font-code); font-weight: 700; color: var(--pale-ink); }
  .credit-card { background: var(--surface); border: 1px solid var(--hairline); padding: var(--space-3); margin-bottom: var(--space-2); }
  .credit-card__title { font-family: var(--font-display); font-size: var(--fs-h3); font-weight: 600; margin-bottom: var(--space-1); }
  .credit-card__desc { color: var(--mid-ink); line-height: 1.6; font-size: var(--fs-body); }
  .credit-card__desc code { font-size: 0.9em; background: var(--cream); padding: 0.05em 0.3em; border-radius: 2px; }
  .table-section { background: var(--cream-2); }
  .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .compare-table { width: 100%; border-collapse: collapse; font-size: var(--fs-small); line-height: 1.5; }
  .compare-table th, .compare-table td { text-align: left; padding: 0.65rem 0.85rem; border-bottom: 1px solid var(--hairline); vertical-align: top; }
  .compare-table thead th { font-family: var(--font-display); font-weight: 600; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--mid-ink); border-bottom: 2px solid var(--graphite); white-space: nowrap; }
  .compare-table td:first-child { font-weight: 500; white-space: nowrap; min-width: 160px; }
  .compare-table td:nth-child(2), .compare-table td:nth-child(3) { min-width: 200px; }
  .compare-table td code { font-size: 0.88em; background: var(--surface); padding: 0.05em 0.3em; border-radius: 2px; }
  .compare-table strong { font-weight: 600; color: var(--ink); }
  .diff-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-3); }
  .diff-card { background: var(--surface); border: 1px solid var(--hairline); padding: var(--space-3); }
  .diff-card__title { font-family: var(--font-display); font-size: var(--fs-h3); font-weight: 600; margin-bottom: var(--space-1); }
  .diff-card__desc { color: var(--mid-ink); font-size: var(--fs-small); line-height: 1.6; }
  .diff-card__desc code { font-size: 0.9em; background: var(--cream-2); padding: 0.05em 0.3em; border-radius: 2px; }
  .diff-card__example { margin-top: var(--space-2); }
  .diff-card__example .terminal { font-size: 0.78rem; line-height: 1.6; }
  @media (max-width: 860px) { .diff-grid { grid-template-columns: 1fr; } }
  .when-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-3); }
  .when-card { background: var(--surface); border: 1px solid var(--hairline); padding: var(--space-4); }
  .when-card--primary { border-color: var(--validator-green); border-width: 2px; }
  .when-card__title { font-family: var(--font-display); font-size: var(--fs-h3); font-weight: 600; margin-bottom: var(--space-2); }
  .when-card__list { list-style: none; margin: 0; padding: 0; }
  .when-card__list li { position: relative; padding-left: 1.2rem; color: var(--mid-ink); line-height: 1.6; margin-bottom: var(--space-1); font-size: var(--fs-small); }
  .when-card__list li::before { content: '→'; position: absolute; left: 0; color: var(--pale-ink); font-family: var(--font-code); }
  .when-card--primary .when-card__list li::before { color: var(--validator-green); }
  .when-card__list code { font-size: 0.9em; background: var(--cream-2); padding: 0.05em 0.3em; border-radius: 2px; }
  @media (max-width: 860px) { .when-grid { grid-template-columns: 1fr; } }
  .prose-p { color: var(--mid-ink); line-height: 1.65; margin-bottom: var(--space-2); }
  .prose-p:last-child { margin-bottom: 0; font-weight: 500; color: var(--ink); }
  .prose-p code { font-size: 0.9em; background: var(--cream-2); padding: 0.05em 0.3em; border-radius: 2px; }
  .final-cta { background: var(--cream-2); padding: var(--space-7) var(--space-3); border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }
  .final-cta__inner { max-width: var(--max-content); margin: 0 auto; text-align: center; }
  .final-cta__title { font-size: clamp(2.2rem, 4.2vw, 3.2rem); margin-bottom: var(--space-4); letter-spacing: -0.02em; line-height: 1.05; }
  .final-cta__buttons { display: inline-flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; }
  .page-footer { background: var(--cream); padding: var(--space-6) var(--space-3) var(--space-5); }
  .page-footer__inner { max-width: var(--max-content); margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr; gap: var(--space-4); }
  .page-footer__brand .wordmark { margin-bottom: var(--space-2); }
  .page-footer__tagline { color: var(--mid-ink); margin-bottom: var(--space-2); max-width: 36ch; line-height: 1.5; font-size: 0.95rem; }
  .page-footer__copyright { color: var(--pale-ink); font-size: 0.825rem; font-family: var(--font-code); }
  .page-footer__heading { font-family: var(--font-display); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--mid-ink); margin-bottom: var(--space-2); }
  .page-footer__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.4rem; }
  .page-footer__list a { color: var(--ink); font-size: 0.9rem; border-bottom: 1px solid transparent; transition: border-color 120ms ease; }
  .page-footer__list a:hover { border-bottom-color: var(--ink); }
  @media (max-width: 800px) { .page-footer__inner { grid-template-columns: 1fr 1fr; } .page-footer__brand { grid-column: 1 / -1; } }
</style>
