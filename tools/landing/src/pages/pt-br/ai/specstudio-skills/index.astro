---
// SpecStudio Skills — landing page em Português Brasileiro.
// Canonical campaign URL: specscore.md/pt-br/ai/specstudio-skills/
// Per STRATEGY.md § Domain authority strategy: this is the mid-funnel
// surface where campaign links (articles, blog posts, social CTAs) point.
// Content follows the marketing draft at marketing/distribution/specstudio-skills-website-homepage.md
// Design matches the specscore.md homepage Astro app (paper-and-ink, same tokens).
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../../components/SiteHeader.astro';
import SiteFooter from '../../../../components/SiteFooter.astro';
import QsTabsScript from '../../../../components/QsTabsScript.astro';
---

<BaseLayout
  lang="pt-BR"
  title="SpecStudio Skills — Specs que o seu agente de IA consegue seguir de verdade."
  description="Plugin gratuito para Claude Code que transforma prompts vagos em specs estruturadas e pontuadas que o agente lê antes de escrever uma única linha de código. Construído sobre o protocolo aberto SpecScore."
  canonical="https://specscore.md/pt-br/ai/specstudio-skills/"
>
  <SiteHeader />

  <main>
    {/* ── Seção 1: Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <h1 id="hero-title" class="hero__headline">
          Specs que o seu agente de IA<br />consegue seguir de verdade.
        </h1>
        <p class="hero__sub">
          SpecStudio Skills é um plugin gratuito para Claude Code que
          transforma prompts vagos em specs estruturadas e pontuadas que
          o agente lê antes de escrever uma única linha de código.
          Construído sobre o protocolo aberto
          <a class="xref" href="/">SpecScore</a>.
        </p>
        <div class="hero__install" id="install">
          <div class="qs-tabs" role="tablist" aria-label="Método de instalação">
            <button type="button" role="tab" id="qs-tab-claude" aria-controls="qs-panel-claude" aria-selected="true" tabindex="0" class="qs-tab is-active" data-tab="claude">Claude Code</button>
            <button type="button" role="tab" id="qs-tab-setup" aria-controls="qs-panel-setup" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="setup">Outros agentes de IA</button>
            <button type="button" role="tab" id="qs-tab-manual" aria-controls="qs-panel-manual" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="manual">Manual</button>
          </div>

          <div id="qs-panel-claude" role="tabpanel" aria-labelledby="qs-tab-claude" class="qs-panel is-active" data-panel="claude">
<pre class="terminal"><span class="prompt">$</span> /plugin marketplace add specscore/ai-marketplace
<span class="prompt">$</span> /plugin install specstudio@specscore</pre>
          </div>
          <div id="qs-panel-setup" role="tabpanel" aria-labelledby="qs-tab-setup" class="qs-panel" data-panel="setup" hidden>
<pre class="terminal"><span class="prompt">$</span> specscore agent setup &lt;nome-do-agente&gt;</pre>
            <p class="qs-note">
              Escreve o arquivo de instruções certo para o seu agente —
              <code>claude</code>, <code>copilot</code>, <code>cursor</code>, <code>codex</code>,
              <code>antigravity.google</code>, <code>pi.dev</code> ou <code>opencode</code>.
              Execute dentro de um projeto gerenciado pelo SpecScore. Requer a
              <a class="xref" href="/pt-br/cli/">SpecScore CLI</a>.
            </p>
          </div>
          <div id="qs-panel-manual" role="tabpanel" aria-labelledby="qs-tab-manual" class="qs-panel" data-panel="manual" hidden>
<pre class="terminal"><span class="prompt">$</span> git clone https://github.com/specscore/specstudio-skills
<span class="prompt">$</span> cp -r specstudio-skills/commands /caminho/para/seu/agente/commands/
<span class="prompt">$</span> cp -r specstudio-skills/skills /caminho/para/seu/agente/skills/</pre>
            <p class="qs-note">
              Clone o repositório do plugin e copie os diretórios
              <code>commands/</code> e <code>skills/</code> para onde seu agente
              carrega os arquivos de comandos e skills.
            </p>
          </div>
        </div>
        <p class="hero__demo-link">
          <a href="#demo" class="xref">Veja a demo de 60 segundos ↓</a>
        </p>
      </div>
    </section>

    {/* ── Seção 2: Demo ── */}
    <section class="section" id="demo" aria-labelledby="demo-title">
      <div class="section-inner">
        <h2 id="demo-title" class="section-title">
          De ideia vaga a spec pontuada, em 60 segundos.
        </h2>

        <div class="demo-placeholder">
          <div class="terminal-frame">
            <div class="terminal-frame__head">
              <span class="terminal-frame__title">Claude Code</span>
              <span class="terminal-frame__hint">demo</span>
            </div>
<pre class="terminal terminal-frame__body"><span class="prompt">&gt;</span> /specstudio:ideate A password reset flow for our SaaS app.

<span class="dim">Refining idea...</span>
<span class="dim">Producing spec/ideas/password-reset.md</span>

<span class="prompt">&gt;</span> /specstudio:specify spec/ideas/password-reset.md

<span class="dim">Writing Feature spec...</span>
<span class="dim">spec/features/password-reset/README.md</span>

<span class="prompt">$</span> specscore lint spec/features/password-reset/
<span class="mark-pass">PASS</span>  Feature: password-reset
  <span class="mark-pass">PASS</span>  has title, status, and description
  <span class="mark-pass">PASS</span>  requirements have acceptance criteria
  <span class="mark-pass">PASS</span>  all AC IDs are unique
  <span class="mark-pass">PASS</span>  no orphan cross-references

<span class="mark-pass">Score: 92 / 100</span></pre>
          </div>
          <p class="demo-caption">
            Sem edição. Sem cortes. Claude Code do zero → instalar plugin →
            pontuar uma spec real → o agente entrega a coisa certa.
          </p>
        </div>
      </div>
    </section>

    {/* ── Seção 3: O problema ── */}
    <section class="section" aria-labelledby="wedge-title">
      <div class="section-inner section-inner--prose">
        <h2 id="wedge-title" class="section-title">
          Por que o seu agente insiste em construir a coisa errada.
        </h2>
        <p class="prose-p">
          Prompts vagos funcionam até não funcionarem mais. O agente construiu
          metade da feature. Interpretou o requisito errado. Inventou uma
          chamada de API. Escolheu a biblioteca errada. Você re-prompta. E
          re-prompta de novo. Na terceira rodada, você já está digitando a spec
          inteira na mão, direto na caixa de chat.
        </p>
        <p class="prose-p">
          O problema não é o agente. É que "me constrói uma feature" não é uma
          spec — é um desejo. Agentes são estocásticos. Desejos são
          amigáveis ao estocástico. Specs não são.
        </p>
        <p class="prose-p">
          SpecStudio Skills oferece um fluxo para escrever specs que o seu
          agente consegue de fato interpretar: features estruturadas,
          requisitos, critérios de aceitação, pontuados por completude antes
          do agente sequer vê-los. A mesma velocidade do vibe-coding, com
          variância dramaticamente menor no resultado.
        </p>
      </div>
    </section>

    {/* ── Seção 4: O pipeline ── */}
    <section class="section pipeline-section" aria-labelledby="pipeline-title">
      <div class="section-inner">
        <h2 id="pipeline-title" class="section-title">
          Quatro comandos. Um pipeline.
        </h2>
        <p class="pipeline-intro">
          Instale uma vez e execute em ordem — da ideia bruta ao plano executável.
        </p>

        <div class="pipeline-grid">
          <div class="pipeline-card">
            <div class="pipeline-card__head">
              <span class="pipeline-card__cmd">/ideate</span>
            </div>
            <p class="pipeline-card__desc">
              Refina uma ideia bruta por meio de pensamento divergente e
              convergente estruturado. Produz um one-pager pré-spec validável pelo linter.
            </p>
          </div>

          <div class="pipeline-card">
            <div class="pipeline-card__head">
              <span class="pipeline-card__cmd">/specify</span>
            </div>
            <p class="pipeline-card__desc">
              Transforma uma ideia aprovada em uma Feature SpecScore com
              requisitos, critérios de aceitação e blocos Given/When/Then.
            </p>
          </div>

          <div class="pipeline-card">
            <div class="pipeline-card__head">
              <span class="pipeline-card__cmd">/plan</span>
            </div>
            <p class="pipeline-card__desc">
              Decompõe uma feature em uma lista ordenada de tarefas. Cada
              tarefa é mapeada a um ou mais critérios de aceitação.
            </p>
          </div>

          <div class="pipeline-card">
            <div class="pipeline-card__head">
              <span class="pipeline-card__cmd">/implement</span>
            </div>
            <p class="pipeline-card__desc">
              Executa a próxima tarefa do plano. Um subagente por tarefa,
              commits rastreáveis por AC, diff preparado para a sua aprovação.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── Seção 5: O que vem incluso ── */}
    <section class="section" aria-labelledby="box-title">
      <div class="section-inner section-inner--prose">
        <h2 id="box-title" class="section-title">
          O que vem incluso.
        </h2>

        <h3 class="list-heading">Faz:</h3>
        <ul class="feature-list feature-list--does">
          <li>Adiciona slash commands para o fluxo SDD completo: <code>/ideate</code>, <code>/specify</code>, <code>/plan</code>, <code>/implement</code>.</li>
          <li>Pontua completude e ambiguidade da spec antes do agente vê-la.</li>
          <li>Escreve specs no formato aberto SpecScore — sem extensão proprietária.</li>
        </ul>

        <h3 class="list-heading">Não faz:</h3>
        <ul class="feature-list feature-list--doesnt">
          <li>Rodar o agente por você. O plugin é uma camada de workflow; o agente continua sendo o Claude.</li>
          <li>Enviar dados para fora. Specs e pontuações ficam locais.</li>
          <li>Prender você. Se desinstalar, suas specs continuam sendo Markdown válido e pontuável pela CLI <a class="xref" href="https://github.com/specscore/specscore">specscore</a>.</li>
        </ul>

        <p class="sibling-callout">
          Procurando a interface CLI neutra?
          <a class="xref" href="https://github.com/specscore/ai-plugin-specscore">ai-plugin-specscore</a>
          é o wrapper leve. SpecStudio Skills é o workflow opinativo construído por cima.
        </p>
      </div>
    </section>

    {/* ── Seção 6: Aberto por baixo ── */}
    <section class="section" aria-labelledby="open-title">
      <div class="section-inner section-inner--prose">
        <h2 id="open-title" class="section-title">
          Construído sobre o protocolo aberto SpecScore.
        </h2>
        <p class="prose-p">
          SpecStudio Skills escreve specs em
          <a class="xref" href="/">SpecScore</a>, um padrão
          aberto. O formato é Markdown legível por humanos. O schema é
          publicado. A CLI é open source. Sem vendor lock-in. Se você sair do
          SpecStudio, suas specs vão junto com você.
        </p>
      </div>
    </section>
  </main>

  {/* ── CTA final ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">Experimente.</h2>
      <div class="final-cta__install">
        <div class="qs-tabs" role="tablist" aria-label="Método de instalação">
          <button type="button" role="tab" id="qs-tab-claude-b" aria-controls="qs-panel-claude-b" aria-selected="true" tabindex="0" class="qs-tab is-active" data-tab="claude">Claude Code</button>
          <button type="button" role="tab" id="qs-tab-setup-b" aria-controls="qs-panel-setup-b" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="setup">Outros agentes de IA</button>
          <button type="button" role="tab" id="qs-tab-manual-b" aria-controls="qs-panel-manual-b" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="manual">Manual</button>
        </div>

        <div id="qs-panel-claude-b" role="tabpanel" aria-labelledby="qs-tab-claude-b" class="qs-panel is-active" data-panel="claude">
<pre class="terminal"><span class="prompt">$</span> /plugin marketplace add specscore/ai-marketplace
<span class="prompt">$</span> /plugin install specstudio@specscore</pre>
        </div>
        <div id="qs-panel-setup-b" role="tabpanel" aria-labelledby="qs-tab-setup-b" class="qs-panel" data-panel="setup" hidden>
<pre class="terminal"><span class="prompt">$</span> specscore agent setup &lt;nome-do-agente&gt;</pre>
          <p class="qs-note">
            Escreve o arquivo de instruções certo para o seu agente —
            <code>claude</code>, <code>copilot</code>, <code>cursor</code>, <code>codex</code>,
            <code>antigravity.google</code>, <code>pi.dev</code> ou <code>opencode</code>.
            Execute dentro de um projeto gerenciado pelo SpecScore. Requer a
            <a class="xref" href="/pt-br/cli/">SpecScore CLI</a>.
          </p>
        </div>
        <div id="qs-panel-manual-b" role="tabpanel" aria-labelledby="qs-tab-manual-b" class="qs-panel" data-panel="manual" hidden>
<pre class="terminal"><span class="prompt">$</span> git clone https://github.com/specscore/specstudio-skills
<span class="prompt">$</span> cp -r specstudio-skills/commands /caminho/para/seu/agente/commands/
<span class="prompt">$</span> cp -r specstudio-skills/skills /caminho/para/seu/agente/skills/</pre>
          <p class="qs-note">
            Clone o repositório do plugin e copie os diretórios
            <code>commands/</code> e <code>skills/</code> para onde seu agente
            carrega os arquivos de comandos e skills.
          </p>
        </div>
      </div>
      <p class="final-cta__note">
        Gratuito para repositórios públicos e open-source. Licença MIT.
      </p>
    </div>
  </section>

  {/* ── Rodapé ── */}
  <footer class="page-footer">
    <div class="page-footer__inner">
      <div class="page-footer__col page-footer__brand">
        <a href="/pt-br/" class="wordmark" aria-label="Página inicial do SpecScore">
          <span class="wordmark__clef" aria-hidden="true">&#x1D11E;</span>
          <span class="wordmark__name">SpecScore.md</span>
        </a>
        <p class="page-footer__tagline">
          Um padrão aberto para especificações, requisitos
          e critérios de aceitação.
        </p>
        <p class="page-footer__copyright">
          &copy; 2026 Contribuidores do SpecScore. Licença MIT.
        </p>
      </div>

      <div class="page-footer__col">
        <h4 class="page-footer__heading">SpecStudio Skills</h4>
        <ul class="page-footer__list">
          <li><a href="https://github.com/specscore/specstudio-skills">GitHub</a></li>
          <li><a href="https://github.com/specscore/specstudio-skills/blob/main/CHANGELOG.md">Changelog</a></li>
          <li><a href="https://github.com/specscore/specstudio-skills/blob/main/LICENSE">Licença: MIT</a></li>
        </ul>
      </div>

      <div class="page-footer__col">
        <h4 class="page-footer__heading">Ecossistema</h4>
        <ul class="page-footer__list">
          <li><a href="/">SpecScore</a> — o padrão aberto</li>
          <li><a href="https://github.com/specscore/ai-plugin-specscore">ai-plugin-specscore</a> — wrapper leve para CLI</li>
          <li><a href="https://specscore.studio">SpecScore Studio</a> — visualizador web</li>
        </ul>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-7) var(--space-3) var(--space-6);
    background: var(--cream);
  }
  .hero__inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms;
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    line-height: 1.55;
  }
  .hero__install {
    margin-bottom: var(--space-3);
  }
  .hero__demo-link {
    font-size: var(--fs-small);
    color: var(--mid-ink);
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Section titles ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }

  /* ── Demo ── */
  .demo-placeholder {
    margin-top: var(--space-3);
  }
  .demo-caption {
    margin-top: var(--space-2);
    font-size: var(--fs-small);
    color: var(--mid-ink);
  }

  /* Terminal frame (shared with homepage AiSkills pattern) */
  .terminal-frame {
    border: 1px solid var(--hairline);
    background: var(--surface);
  }
  .terminal-frame__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.5rem 0.875rem;
    border-bottom: 1px solid var(--hairline);
    background: var(--cream-2);
    font-family: var(--font-code);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .terminal-frame__title { color: var(--graphite); font-weight: 700; }
  .terminal-frame__hint  { color: var(--mid-ink); }
  .terminal-frame__body  { border: none !important; }

  /* ── Wedge (prose sections) ── */
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
    margin-bottom: var(--space-3);
  }
  .prose-p:last-child {
    margin-bottom: 0;
  }

  /* ── Pipeline grid ── */
  .pipeline-section {
    background: var(--cream-2);
  }
  .pipeline-intro {
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    line-height: 1.6;
  }
  .pipeline-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
  }
  .pipeline-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
  }
  .pipeline-card__head {
    margin-bottom: var(--space-2);
  }
  .pipeline-card__cmd {
    font-family: var(--font-code);
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
  }
  .pipeline-card__desc {
    font-size: var(--fs-small);
    color: var(--mid-ink);
    line-height: 1.55;
  }

  @media (max-width: 860px) {
    .pipeline-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 520px) {
    .pipeline-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── What's in the box ── */
  .list-heading {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-top: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .list-heading:first-of-type {
    margin-top: 0;
  }
  .feature-list {
    margin: 0 0 var(--space-3) 0;
    padding-left: 1.25rem;
    color: var(--mid-ink);
    line-height: 1.65;
  }
  .feature-list li {
    margin-bottom: 0.5rem;
  }
  .feature-list li:last-child {
    margin-bottom: 0;
  }
  .feature-list code {
    font-size: 0.9em;
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: 0.1em 0.35em;
    border-radius: 2px;
  }
  .sibling-callout {
    margin-top: var(--space-4);
    padding: var(--space-2) var(--space-3);
    border-left: 3px solid var(--hairline);
    font-size: var(--fs-small);
    color: var(--mid-ink);
    line-height: 1.55;
  }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    text-align: center;
  }
  .final-cta__title {
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .final-cta__install {
    display: inline-block;
    text-align: left;
    margin-bottom: var(--space-3);
  }
  .final-cta__note {
    color: var(--mid-ink);
    font-size: var(--fs-small);
  }

  /* ── Page footer (per-page variant matching the specstudio-skills draft) ── */
  .page-footer {
    background: var(--cream);
    padding: var(--space-6) var(--space-3) var(--space-5);
  }
  .page-footer__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-4);
  }
  .page-footer__brand .wordmark {
    margin-bottom: var(--space-2);
  }
  .page-footer__tagline {
    color: var(--mid-ink);
    margin-bottom: var(--space-2);
    max-width: 36ch;
    line-height: 1.5;
    font-size: 0.95rem;
  }
  .page-footer__copyright {
    color: var(--pale-ink);
    font-size: 0.825rem;
    font-family: var(--font-code);
  }
  .page-footer__heading {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mid-ink);
    margin-bottom: var(--space-2);
  }
  .page-footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .page-footer__list a {
    color: var(--ink);
    font-size: 0.9rem;
    border-bottom: 1px solid transparent;
    transition: border-color 120ms ease;
  }
  .page-footer__list a:hover {
    border-bottom-color: var(--ink);
  }
  .page-footer__list a:focus-visible {
    outline: 2px solid var(--ink-blue);
    outline-offset: 2px;
    border-radius: 2px;
  }

  @media (max-width: 800px) {
    .page-footer__inner {
      grid-template-columns: 1fr 1fr;
    }
    .page-footer__brand {
      grid-column: 1 / -1;
    }
  }
</style>

<QsTabsScript />
