---
// /ai/ index — Brazilian Portuguese translation.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooterPtBr from '../../../components/SiteFooterPtBr.astro';
---

<BaseLayout
  lang="pt-BR"
  title="Skills de IA para desenvolvimento baseado em specs | SpecScore"
  description="Os Skills de IA para SpecScore trazem desenvolvimento baseado em specs para o seu agente de IA. Instale o SpecStudio Skills para o workflow guiado, ou o CLI Skills para acesso direto ao linter."
  canonical="https://specscore.md/pt-br/ai/"
>
  <SiteHeader />

  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <h1 id="hero-title" class="hero__headline">
          Skills de IA para SpecScore.
        </h1>
        <p class="hero__sub">
          Os Skills de IA para SpecScore trazem um workflow baseado em specs
          para o seu agente de IA. Eles envolvem a <a class="xref" href="/pt-br/cli/">CLI
          do SpecScore</a> para que o agente possa ler, escrever e validar
          specs nativamente — escolha o que se encaixa no seu jeito de trabalhar.
        </p>
      </div>
    </section>

    <section class="section" aria-labelledby="plugins-title">
      <div class="section-inner">
        <h2 id="plugins-title" class="sr-only">Plugins disponiveis</h2>

        <div class="plugin-grid">
          <div class="plugin-card plugin-card--primary">
            <span class="plugin-card__badge">★ Recomendado</span>
            <h3 class="plugin-card__name">
              <a href="/pt-br/ai/specstudio-skills/">SpecStudio Skills</a>
            </h3>
            <p class="plugin-card__repo">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
              </svg>
              <a href="https://github.com/specscore/specstudio-skills" target="_blank"><span class="plugin-card__repo-host">github.com/</span>specscore/specstudio-skills</a>
            </p>
            <p class="plugin-card__desc">
              O workflow opinado para desenvolvimento baseado em specs.
              Quatro slash commands — <code>/ideate</code>, <code>/specify</code>,
              <code>/plan</code>, <code>/implement</code> — que levam voce de
              uma ideia crua ate codigo funcional com uma spec pontuada em cada etapa.
            </p>
            <p class="plugin-card__pitch">
              A forma mais fácil e eficaz de começar com SpecScore.
            </p>
            <a href="/pt-br/ai/specstudio-skills/" class="plugin-card__cta">Saiba mais →</a>
          </div>

          <div class="plugin-card">
            <h3 class="plugin-card__name">
              <a href="/pt-br/ai/cli-skills/">CLI Skills</a>
            </h3>
            <p class="plugin-card__repo">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
              </svg>
              <a href="https://github.com/specscore/ai-plugin-specscore" target="_blank"><span class="plugin-card__repo-host">github.com/</span>specscore/ai-plugin-specscore</a>
            </p>
            <p class="plugin-card__desc">
              Wrapper fino em torno da CLI do SpecScore. Expoe
              <code>specscore lint</code>, <code>specscore feature</code>,
              <code>specscore task</code> e <code>specscore change-status</code>
              como comandos nativos do Claude Code.
            </p>
            <p class="plugin-card__audience">
              Para usuarios avancados que ja conhecem o SpecScore, e para tool builders
              criando seus proprios workflows.
            </p>
            <a href="/pt-br/ai/cli-skills/" class="plugin-card__cta">Saiba mais →</a>
          </div>
        </div>

        <p class="community-note">
          Construindo seu proprio plugin para SpecScore? Quando plugins da comunidade
          forem lancados, serao listados aqui.
          <a class="xref" href="https://github.com/specscore/specscore/blob/main/CONTRIBUTING.md">Guia de contribuicao →</a>
        </p>
      </div>
    </section>
  </main>

  <SiteFooterPtBr />
</BaseLayout>

<style>
  .hero { padding: var(--space-6) var(--space-3) var(--space-5); background: var(--cream); }
  .hero__inner { max-width: var(--max-prose); margin: 0 auto; animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms; }
  .hero__headline { font-size: var(--fs-h2); font-weight: 700; letter-spacing: -0.01em; margin-bottom: var(--space-3); }
  .hero__sub { font-size: 1.125rem; color: var(--mid-ink); line-height: 1.55; }
  @keyframes fade-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
  /* ── Plugin cards + community note + grid styles live in global.css ── */
</style>
