---
// /zh-cn/vs/datarim/ — SpecScore vs Datarim comparison (zh-cn).
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../../components/SiteHeader.astro';
import SiteFooterZhCn from '../../../../components/SiteFooterZhCn.astro';
import ComparisonFeedback from '../../../../components/ComparisonFeedback.astro';
---

<BaseLayout
  lang="zh-CN"
  title="SpecScore vs Datarim — 客观对比"
  description="SpecScore 与 Datarim 基于事实的对比：一个 Claude Code 工作流套件 vs 一种开放、可移植的规范格式。处于不同层面——而且它们可以组合。"
  canonical="https://specscore.md/zh-cn/vs/datarim/"
>
  <SiteHeader />

  <main>
    {/* ── Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <p class="hero__breadcrumb"><a href="/zh-cn/vs/" class="xref">对比列表</a></p>
        <h1 id="hero-title" class="hero__headline">
          SpecScore vs Datarim
        </h1>
        <p class="hero__sub">
          不同的层面。Datarim 是一套面向 Claude Code 的、有主见的<strong>工作流套件</strong>——
          一组斜杠命令，把项目从需求一路运行到完成。SpecScore 是规范书写所用的<strong>开放格式</strong>，
          外加一个用于 lint、查询和追溯它们的 CLI。一个工作流可以以它为目标。
        </p>
      </div>
    </section>

    {/* ── What they share ── */}
    <section class="section" aria-labelledby="shared-title">
      <div class="section-inner section-inner--prose">
        <h2 id="shared-title" class="section-title">两者的共同点。</h2>
        <ul class="shared-list">
          <li>两者都为 AI 辅助开发带来结构化的方法论。</li>
          <li>两者均基于 MIT 许可证开源。</li>
          <li>两者都在 Claude Code 内运行——Datarim 以命令形式，SpecScore 通过 SpecStudio Skills。</li>
          <li>两者都将其状态以 Markdown 形式保存在仓库中，受版本控制。</li>
        </ul>
      </div>
    </section>

    {/* ── What Datarim does well ── */}
    <section class="section" aria-labelledby="datarim-title">
      <div class="section-inner section-inner--prose">
        <h2 id="datarim-title" class="section-title">Datarim 的优势。</h2>
        <p class="section-note">
          <a href="https://github.com/Arcanada-one/datarim" rel="nofollow noopener" target="_blank" class="xref">Datarim</a>
          是一个为 Claude Code 打造的通用迭代式工作流框架。
        </p>

        <div class="credit-card">
          <h3 class="credit-card__title">原生的斜杠命令体验</h3>
          <p class="credit-card__desc">
            一条以命令形式呈现的完整流水线——<code>/dr-prd</code>、<code>/dr-plan</code>、
            <code>/dr-design</code>、<code>/dr-do</code>、<code>/dr-qa</code>——
            在 Claude Code 中宛如归家。一次 <code>install.sh</code> 到 <code>~/.claude/</code>
            你就开始运行了。
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">复杂度感知的路由（L1–L4）</h3>
          <p class="credit-card__desc">
            Datarim 会评估工作的规模并据此路由：一个 L1 快速修复跳过
            规划，而一个 L4 重大变更则运行一条带多轮审查的分阶段流水线。
            让仪式与范围相匹配是一个真正出色的想法。
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">Consilium 与多领域覆盖</h3>
          <p class="credit-card__desc">
            它的 "consilium" 会组建一个代理专家组，在给出建议之前先就权衡展开辩论。
            而且它不限于软件——Datarim 还面向研究、法律和内容类工作流。
          </p>
        </div>
      </div>
    </section>

    {/* ── Feature comparison table ── */}
    <section class="section table-section" aria-labelledby="table-title">
      <div class="section-inner">
        <h2 id="table-title" class="section-title">功能对比。</h2>
        <p class="section-note">
          一个是工作流，另一个是格式——这张表对比的是角色，而非胜负。
        </p>

        <div class="table-wrap">
          <table class="compare-table" aria-label="SpecScore 与 Datarim 功能对比">
            <thead>
              <tr>
                <th scope="col">能力</th>
                <th scope="col">Datarim</th>
                <th scope="col">SpecScore</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>主要角色</td>
                <td>Claude Code 工作流套件</td>
                <td><strong>开放规范格式 + CLI</strong></td>
              </tr>
              <tr>
                <td>运行方式</td>
                <td>斜杠命令（<code>/dr-*</code>）</td>
                <td>格式文件 + CLI <span class="dim">（+ Claude Code 中的 SpecStudio Skills）</span></td>
              </tr>
              <tr>
                <td>状态存储</td>
                <td><code>backlog.md</code> + <code>CLAUDE.md</code>（工作流形态）</td>
                <td><strong>可移植的 <code>spec/</code> 树</strong>（Markdown + YAML）</td>
              </tr>
              <tr>
                <td>脱离工具仍可存续</td>
                <td>绑定于 Datarim 运行时</td>
                <td><strong>可以</strong> — 在构造上即可移植</td>
              </tr>
              <tr>
                <td>规范 linting</td>
                <td>无</td>
                <td><strong>内容质量</strong> — 模糊动词、缺失验收标准、悬空引用</td>
              </tr>
              <tr>
                <td>需求 / 验收标准 ID</td>
                <td>无</td>
                <td><strong>机器可寻址的 ID</strong>（<code>REQ: slug</code>）</td>
              </tr>
              <tr>
                <td>代码到规范的可追溯性</td>
                <td>无</td>
                <td><strong><code>specscore:</code> 注解</strong> + <code>Verifies:</code> 尾注</td>
              </tr>
              <tr>
                <td>复杂度路由（L1–L4）</td>
                <td><strong>支持</strong></td>
                <td>不支持（格式，而非工作流）</td>
              </tr>
              <tr>
                <td>可查询的规范图谱</td>
                <td>不支持</td>
                <td><strong>支持</strong> — <code>feature list / show / deps</code></td>
              </tr>
              <tr>
                <td>绑定 Claude Code</td>
                <td>为它而生</td>
                <td><strong>否</strong> — 任意代理，或不用代理</td>
              </tr>
              <tr>
                <td>许可证</td>
                <td>MIT</td>
                <td>MIT / CC BY 4.0</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {/* ── Where SpecScore goes further ── */}
    <section class="section" aria-labelledby="further-title">
      <div class="section-inner">
        <h2 id="further-title" class="section-title">SpecScore 增添了什么。</h2>

        <div class="diff-grid">
          <div class="diff-card">
            <h3 class="diff-card__title">产出比工作流更长久</h3>
            <p class="diff-card__desc">
              Datarim 的状态存在于它自己的 backlog 和 <code>CLAUDE.md</code> 形态中——
              当你运行 Datarim 时它很有价值。SpecScore 的规范是一种可移植的格式，
              即便完全没有安装任何 SpecScore 工具，也依然可读、可 lint、可查询。
              工作流可以更换；规范跟着你走。
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">规范是可 lint 的</h3>
            <p class="diff-card__desc">
              工作流引导编写，但并不为结果设门禁。SpecScore 的
              <code>lint</code> 校验每个需求都有验收标准、
              交叉引用可解析、状态转换合法。
            </p>
            <div class="diff-card__example">
<pre class="terminal"><span class="prompt">$</span> specscore lint checkout/apply-discount.md
  <span class="mark-fail">✗</span> R3  no acceptance criteria
  <span class="mark-fail">✗</span> link  <span class="dim">"Related Feature: discount-tiers" not found</span></pre>
            </div>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">代码可追溯回规范</h3>
            <p class="diff-card__desc">
              SpecScore 添加了 <code>specscore:</code> 源注解和
              <code>Verifies:</code> 提交尾注——<code>specscore code refs</code>
              能确定性地回答"哪些代码实现了这个需求？"，
              与产出该规范的工作流无关。
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">不绑定单一代理</h3>
            <p class="diff-card__desc">
              Datarim 为 Claude Code 而生。SpecScore 是任何代理都能读取的格式，
              也是任何 CI 都能运行的单个 Go 二进制文件——无需 Claude Code，无需
              <code>~/.claude/</code> 安装。
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── When to use which ── */}
    <section class="section" aria-labelledby="when-title">
      <div class="section-inner">
        <h2 id="when-title" class="section-title">何时使用哪个。</h2>

        <div class="when-grid">
          <div class="when-card">
            <h3 class="when-card__title">以下场景适合使用 Datarim……</h3>
            <ul class="when-card__list">
              <li>你想要在 Claude Code 中立刻拥有一条完整、有主见的流水线。</li>
              <li>你看重复杂度感知的路由和多代理决策仪式。</li>
              <li>你的工作横跨多个领域——研究、法律、内容，而不仅仅是代码。</li>
            </ul>
          </div>

          <div class="when-card when-card--primary">
            <h3 class="when-card__title">以下场景适合使用 SpecScore……</h3>
            <ul class="when-card__list">
              <li>你想要比任何单一工作流或工具都更长久的规范。</li>
              <li>你需要 lint、ID、生命周期，以及代码到规范的可追溯性。</li>
              <li>你跨多个代理工作——或不用代理——而不只是 Claude Code。</li>
              <li>你想要一个代理可以查询、而非反复阅读仓库的 CLI。</li>
              <li>你需要在 CI 中设置返回非零退出码的规范质量门禁。</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── Two packs, one format ── */}
    <section class="section" aria-labelledby="bridge-title">
      <div class="section-inner section-inner--prose">
        <h2 id="bridge-title" class="section-title">两个工作流套件，一种开放格式。</h2>
        <p class="prose-p">
          Datarim 和 SpecStudio Skills 都是构建在 Claude
          Code 之上、有主见的工作流。SpecScore 是底层的开放格式——一个工作流可以
          产出的工件，让规范在流水线结束之后依然可移植、可 lint、可追溯。一个能输出
          SpecScore 的 Datarim 既能保留它的体验，又能获得持久的产出。
        </p>
        <p class="prose-p">
          为流水线选择 Datarim。为它留下的工件使用 SpecScore。
        </p>
      </div>
    </section>

    <ComparisonFeedback page="datarim" />
  </main>

  {/* ── Final CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">通过检查的规范。</h2>
      <div class="final-cta__buttons">
        <a href="/cli/install/" class="btn btn--primary">安装 CLI</a>
        <a href="/ai/specstudio-skills/" class="btn btn--secondary">获取 AI 代理技能</a>
        <a
          href="https://github.com/specscore/specscore"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          在 GitHub 上开源
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <SiteFooterZhCn />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-5);
    background: var(--cream);
  }
  .hero__inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms;
  }
  .hero__breadcrumb {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--pale-ink);
    margin-bottom: var(--space-2);
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
    max-width: 52ch;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Section titles ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }

  /* ── Shared list ── */
  .shared-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .shared-list li {
    position: relative;
    padding-left: 1.4rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
  }
  .shared-list li::before {
    content: '=';
    position: absolute;
    left: 0;
    font-family: var(--font-code);
    font-weight: 700;
    color: var(--pale-ink);
  }

  /* ── Section note ── */
  .section-note {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    margin-bottom: var(--space-3);
  }

  /* ── Credit cards ── */
  .credit-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .credit-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .credit-card__desc {
    color: var(--mid-ink);
    line-height: 1.6;
    font-size: var(--fs-body);
  }
  .credit-card__desc code {
    font-size: 0.9em;
    background: var(--cream);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Feature comparison table ── */
  .table-section { background: var(--cream-2); }
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-small);
    line-height: 1.5;
  }
  .compare-table th,
  .compare-table td {
    text-align: left;
    padding: 0.65rem 0.85rem;
    border-bottom: 1px solid var(--hairline);
    vertical-align: top;
  }
  .compare-table thead th {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mid-ink);
    border-bottom: 2px solid var(--graphite);
    white-space: nowrap;
  }
  .compare-table td:first-child {
    font-weight: 500;
    white-space: nowrap;
    min-width: 160px;
  }
  .compare-table td:nth-child(2),
  .compare-table td:nth-child(3) {
    min-width: 200px;
  }
  .compare-table td code {
    font-size: 0.88em;
    background: var(--surface);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .compare-table strong {
    font-weight: 600;
    color: var(--ink);
  }
  .compare-table .dim {
    color: var(--pale-ink);
  }

  /* ── Diff grid ── */
  .diff-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .diff-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
  }
  .diff-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .diff-card__desc {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    line-height: 1.6;
  }
  .diff-card__desc code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .diff-card__example {
    margin-top: var(--space-2);
  }
  .diff-card__example .terminal {
    font-size: 0.78rem;
    line-height: 1.6;
  }

  @media (max-width: 860px) {
    .diff-grid { grid-template-columns: 1fr; }
  }

  /* ── When to use which ── */
  .when-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .when-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-4);
  }
  .when-card--primary {
    border-color: var(--validator-green);
    border-width: 2px;
  }
  .when-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .when-card__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .when-card__list li {
    position: relative;
    padding-left: 1.2rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
    font-size: var(--fs-small);
  }
  .when-card__list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--pale-ink);
    font-family: var(--font-code);
  }
  .when-card--primary .when-card__list li::before {
    color: var(--validator-green);
  }
  .when-card__list code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  @media (max-width: 860px) {
    .when-grid { grid-template-columns: 1fr; }
  }

  /* ── Bridge section ── */
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
    margin-bottom: var(--space-2);
  }
  .prose-p:last-child {
    margin-bottom: 0;
    font-weight: 500;
    color: var(--ink);
  }
  .prose-p code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    text-align: center;
  }
  .final-cta__title {
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .final-cta__buttons {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>
