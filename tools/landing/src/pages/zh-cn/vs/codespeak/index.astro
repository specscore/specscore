---
// /zh-cn/vs/codespeak/ — SpecScore vs CodeSpeak comparison (zh-cn).
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../../components/SiteHeader.astro';
import SiteFooterZhCn from '../../../../components/SiteFooterZhCn.astro';
import ComparisonFeedback from '../../../../components/ComparisonFeedback.astro';
---

<BaseLayout
  lang="zh-CN"
  title="SpecScore vs CodeSpeak — 客观对比"
  description="SpecScore 与 CodeSpeak 基于事实的逐项对比：规范即源码 vs 规范即契约、代码生成、可移植性、linting 和可追溯性。"
  canonical="https://specscore.md/zh-cn/vs/codespeak/"
>
  <SiteHeader />

  <main>
    {/* ── Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <p class="hero__breadcrumb"><a href="/zh-cn/vs/" class="xref">对比列表</a></p>
        <h1 id="hero-title" class="hero__headline">
          SpecScore vs CodeSpeak
        </h1>
        <p class="hero__sub">
          对于"规范应当用来做什么"的两种答案。CodeSpeak 把规范当作
          <strong>源代码</strong>——由 LLM 编译它，你维护规范而非代码。
          SpecScore 把规范当作一份<strong>持久、开放的契约</strong>——
          你保留你的代码，任何代理（或不用代理）都能读取、lint 并追溯它。
        </p>
      </div>
    </section>

    {/* ── What they share ── */}
    <section class="section" aria-labelledby="shared-title">
      <div class="section-inner section-inner--prose">
        <h2 id="shared-title" class="section-title">两者的共同点。</h2>
        <ul class="shared-list">
          <li>两者都把规范置于软件开发的中心。</li>
          <li>两者都为 AI 辅助的世界而生——先有意图，再有实现。</li>
          <li>两者都致力于通过改变规范来让软件更易于变更。</li>
        </ul>
      </div>
    </section>

    {/* ── What CodeSpeak does well ── */}
    <section class="section" aria-labelledby="codespeak-title">
      <div class="section-inner section-inner--prose">
        <h2 id="codespeak-title" class="section-title">CodeSpeak 的优势。</h2>
        <p class="section-note">
          <a href="https://codespeak.dev/" rel="nofollow noopener" target="_blank" class="xref">CodeSpeak</a>
          是一个由 LLM 驱动的编程系统，能把结构化英文规范编译成代码。
        </p>

        <div class="credit-card">
          <h3 class="credit-card__title">大胆的论点，论证可信</h3>
          <p class="credit-card__desc">
            "维护规范，而非代码"是一次真正的重新定义，而非增量式的小修小补。
            它出自 Kotlin 语言的设计者，值得认真对待：如果规范才是源码，
            那么生成的代码就成了一个实现细节。
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">代码到规范的接管</h3>
          <p class="credit-card__desc">
            <code>codespeak takeover</code> 读取现有源码并产出一份
            捕获其行为的规范——为存量代码提供低摩擦的入口匝道，
            据报道规范对代码的压缩比约为 5–10×。
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">从代理会话中恢复意图</h3>
          <p class="credit-card__desc">
            CodeSpeak 的 Intent Studio 从先前的代理会话中提取需求——
            收割你已经表达过的意图，而不是让你从一张白纸开始撰写
            规范。
          </p>
        </div>
      </div>
    </section>

    {/* ── Feature comparison table ── */}
    <section class="section table-section" aria-labelledby="table-title">
      <div class="section-inner">
        <h2 id="table-title" class="section-title">功能对比。</h2>
        <p class="section-note">
          两者下的是不同的赌注，所以这张表对比的是理念与机制，而非胜负。
        </p>

        <div class="table-wrap">
          <table class="compare-table" aria-label="SpecScore 与 CodeSpeak 功能对比">
            <thead>
              <tr>
                <th scope="col">能力</th>
                <th scope="col">CodeSpeak</th>
                <th scope="col">SpecScore</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>事实来源</td>
                <td>规范（编译输入）</td>
                <td><strong>规范是契约；代码是交付物</strong></td>
              </tr>
              <tr>
                <td>生成的代码</td>
                <td>由 LLM 产出，非手工维护</td>
                <td><strong>你和你的代理编写并拥有代码</strong></td>
              </tr>
              <tr>
                <td>规范格式</td>
                <td>纯英文，由 CodeSpeak 定义</td>
                <td><strong>开放的 Markdown + YAML 标准</strong>，已发布 schema</td>
              </tr>
              <tr>
                <td>规范 → 代码</td>
                <td>核心功能（专有 LLM 编译器）</td>
                <td>不在范围内 — 由任意代理实现</td>
              </tr>
              <tr>
                <td>脱离厂商仍可用</td>
                <td>规范需经 CodeSpeak 编译</td>
                <td><strong>可以</strong> — 规范适用于任意代理，或不用代理</td>
              </tr>
              <tr>
                <td>规范 linting</td>
                <td>无文档说明</td>
                <td><strong>内容质量</strong> — 模糊动词、缺失验收标准、悬空引用</td>
              </tr>
              <tr>
                <td>代码到规范的可追溯性</td>
                <td>通过重新生成</td>
                <td><strong><code>specscore:</code> 注解</strong> + <code>Verifies:</code> 尾注</td>
              </tr>
              <tr>
                <td>确定性</td>
                <td>LLM 编译（非确定性）</td>
                <td><strong>确定性的 CLI 查询</strong>；代码照常编写</td>
              </tr>
              <tr>
                <td>代码 → 规范</td>
                <td><strong><code>codespeak takeover</code></strong></td>
                <td><code>survey</code> + 撰写</td>
              </tr>
              <tr>
                <td>开放性</td>
                <td>专有系统</td>
                <td><strong>开放</strong> — CC BY 4.0 格式，MIT / Apache-2.0 工具</td>
              </tr>
              <tr>
                <td>阶段</td>
                <td>Alpha 预览</td>
                <td>已发布</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {/* ── Where SpecScore differs ── */}
    <section class="section" aria-labelledby="further-title">
      <div class="section-inner">
        <h2 id="further-title" class="section-title">SpecScore 的不同之处。</h2>

        <div class="diff-grid">
          <div class="diff-card">
            <h3 class="diff-card__title">你保留你的代码</h3>
            <p class="diff-card__desc">
              CodeSpeak 生成并重新生成实现；代码是一种输出，而非一项资产。
              SpecScore 把代码留在它该在的地方——在你手中、用你的语言、
              可逐行审查。规范在不带走代码的前提下，增添清晰度
              和可追溯性。
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">你的规范是可移植的</h3>
            <p class="diff-card__desc">
              一份 CodeSpeak 规范之所以有价值，是因为 CodeSpeak 编译它。一份 SpecScore
              规范本身就有价值——它是结构良好的 Markdown，任何
              代理都能读取，而且即便完全没有安装任何 SpecScore 工具，它依然有用。
              用任意工具采用它，或不用工具。随时离开。
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">歧义在产生代价之前被捕获</h3>
            <p class="diff-card__desc">
              使用 LLM 编译器时，一份有歧义的规范会在构建时变成错误的代码。
              SpecScore 的 <code>lint</code> 会<em>在</em>代理据此行动<em>之前</em>，
              浮现出模糊动词、缺失的验收标准和悬空引用。
            </p>
            <div class="diff-card__example">
<pre class="terminal"><span class="prompt">$</span> specscore lint checkout/apply-discount.md
  <span class="mark-fail">✗</span> R3  no acceptance criteria
  <span class="mark-fail">✗</span> verb  <span class="dim">"handle gracefully" — unmeasurable</span></pre>
            </div>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">确定性与可追溯性</h3>
            <p class="diff-card__desc">
              CodeSpeak 对"哪些代码实现了这个？"的回答是"全部，重新生成"。
              SpecScore 的回答是一个具体的文件和行号，通过
              <code>specscore code refs</code> 和 <code>Verifies:</code> 提交
              尾注——确定性、可审计、可 diff。
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">结构化的工件图谱</h3>
            <p class="diff-card__desc">
              CodeSpeak 的单元是一份散文形式的规范文件。SpecScore 拥有类型化的
              层级结构——Idea 晋升为 Feature，Feature 携带带 ID 的 Requirement 和
              Acceptance Criteria，Plan 引用 AC，Task 引用 Plan——
              所有这些都可机器导航。
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">构建路径中没有厂商</h3>
            <p class="diff-card__desc">
              SpecScore 是单个 Go 二进制文件。Lint 在 CI 和 pre-commit 钩子中运行，
              无需账户、无需服务调用、构建中没有 LLM 往返。
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── When to use which ── */}
    <section class="section" aria-labelledby="when-title">
      <div class="section-inner">
        <h2 id="when-title" class="section-title">何时使用哪个。</h2>

        <div class="when-grid">
          <div class="when-card">
            <h3 class="when-card__title">以下场景适合使用 CodeSpeak……</h3>
            <ul class="when-card__list">
              <li>你想停止维护代码，让规范成为源码。</li>
              <li>你乐于为那份杠杆而依赖某厂商的编译器。</li>
              <li>你想把一个现有代码库压缩成一份短得多的规范。</li>
            </ul>
          </div>

          <div class="when-card when-card--primary">
            <h3 class="when-card__title">以下场景适合使用 SpecScore……</h3>
            <ul class="when-card__list">
              <li>你想要比任何单一工具都更长久的规范——在构造上即可移植。</li>
              <li>你想保留你的代码，用你的语言，可审查、可拥有。</li>
              <li>你需要规范质量的强制执行——lint 尽早捕获歧义。</li>
              <li>你需要确定性的代码到规范可追溯性。</li>
              <li>你想要构建路径中没有厂商、没有 LLM 往返。</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── Two different bets ── */}
    <section class="section" aria-labelledby="bets-title">
      <div class="section-inner section-inner--prose">
        <h2 id="bets-title" class="section-title">两种不同的赌注。</h2>
        <p class="prose-p">
          CodeSpeak 押注于编译器：把规范交给它，并信任它产出
          并复现代码。SpecScore 押注于格式：让规范保持开放
          且可移植，让代码归你所有，并让任何代理基于它工作。
        </p>
        <p class="prose-p">
          一方以可移植性换取杠杆。另一方让你保持自由——而且可 lint。
        </p>
      </div>
    </section>

    <ComparisonFeedback page="codespeak" />
  </main>

  {/* ── Final CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">通过检查的规范。</h2>
      <div class="final-cta__buttons">
        <a href="/cli/install/" class="btn btn--primary">安装 CLI</a>
        <a href="/ai/specstudio-skills/" class="btn btn--secondary">获取 AI 代理技能</a>
        <a
          href="https://github.com/specscore/specscore"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          在 GitHub 上开源
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <SiteFooterZhCn />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-5);
    background: var(--cream);
  }
  .hero__inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms;
  }
  .hero__breadcrumb {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--pale-ink);
    margin-bottom: var(--space-2);
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
    max-width: 52ch;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Section titles ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }

  /* ── Shared list ── */
  .shared-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .shared-list li {
    position: relative;
    padding-left: 1.4rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
  }
  .shared-list li::before {
    content: '=';
    position: absolute;
    left: 0;
    font-family: var(--font-code);
    font-weight: 700;
    color: var(--pale-ink);
  }

  /* ── Section note ── */
  .section-note {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    margin-bottom: var(--space-3);
  }

  /* ── Credit cards ── */
  .credit-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .credit-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .credit-card__desc {
    color: var(--mid-ink);
    line-height: 1.6;
    font-size: var(--fs-body);
  }
  .credit-card__desc code {
    font-size: 0.9em;
    background: var(--cream);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Feature comparison table ── */
  .table-section { background: var(--cream-2); }
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-small);
    line-height: 1.5;
  }
  .compare-table th,
  .compare-table td {
    text-align: left;
    padding: 0.65rem 0.85rem;
    border-bottom: 1px solid var(--hairline);
    vertical-align: top;
  }
  .compare-table thead th {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mid-ink);
    border-bottom: 2px solid var(--graphite);
    white-space: nowrap;
  }
  .compare-table td:first-child {
    font-weight: 500;
    white-space: nowrap;
    min-width: 160px;
  }
  .compare-table td:nth-child(2),
  .compare-table td:nth-child(3) {
    min-width: 200px;
  }
  .compare-table td code {
    font-size: 0.88em;
    background: var(--surface);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .compare-table strong {
    font-weight: 600;
    color: var(--ink);
  }

  /* ── Diff grid ── */
  .diff-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .diff-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
  }
  .diff-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .diff-card__desc {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    line-height: 1.6;
  }
  .diff-card__desc code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .diff-card__example {
    margin-top: var(--space-2);
  }
  .diff-card__example .terminal {
    font-size: 0.78rem;
    line-height: 1.6;
  }

  @media (max-width: 860px) {
    .diff-grid { grid-template-columns: 1fr; }
  }

  /* ── When to use which ── */
  .when-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .when-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-4);
  }
  .when-card--primary {
    border-color: var(--validator-green);
    border-width: 2px;
  }
  .when-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .when-card__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .when-card__list li {
    position: relative;
    padding-left: 1.2rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
    font-size: var(--fs-small);
  }
  .when-card__list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--pale-ink);
    font-family: var(--font-code);
  }
  .when-card--primary .when-card__list li::before {
    color: var(--validator-green);
  }
  .when-card__list code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  @media (max-width: 860px) {
    .when-grid { grid-template-columns: 1fr; }
  }

  /* ── Bets section ── */
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
    margin-bottom: var(--space-2);
  }
  .prose-p:last-child {
    margin-bottom: 0;
    font-weight: 500;
    color: var(--ink);
  }
  .prose-p code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    text-align: center;
  }
  .final-cta__title {
