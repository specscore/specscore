---
// /zh-cn/vs/spec-kit/ — SpecScore vs GitHub Spec Kit comparison (zh-cn).
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../../components/SiteHeader.astro';
import SiteFooterZhCn from '../../../../components/SiteFooterZhCn.astro';
import ComparisonFeedback from '../../../../components/ComparisonFeedback.astro';
---

<BaseLayout
  lang="zh-CN"
  title="SpecScore vs Spec Kit — 客观对比"
  description="SpecScore 与 GitHub Spec Kit 基于事实的逐项对比：工作流 vs 格式、linting、生命周期、可追溯性和 CLI。它们可以组合使用——这里说明如何配合。"
  canonical="https://specscore.md/zh-cn/vs/spec-kit/"
>
  <SiteHeader />

  <main>
    {/* ── Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <p class="hero__breadcrumb"><a href="/zh-cn/vs/" class="xref">对比列表</a></p>
        <h1 id="hero-title" class="hero__headline">
          SpecScore vs Spec Kit
        </h1>
        <p class="hero__sub">
          它们运作在不同的层面。Spec Kit 是一套<strong>工作流</strong>——
          一个引导代理从想法走向实现的有序流程。
          SpecScore 是规范书写所用的<strong>格式</strong>，外加一个用于 lint、查询和追溯它们的 CLI。
          Spec Kit 可以产出 SpecScore 文件。
        </p>
      </div>
    </section>

    {/* ── What they share ── */}
    <section class="section" aria-labelledby="shared-title">
      <div class="section-inner section-inner--prose">
        <h2 id="shared-title" class="section-title">两者的共同点。</h2>
        <ul class="shared-list">
          <li>相同的北极星——先有规范再有代码，并将 AI 代理作为一等读者。</li>
          <li>规范以 Markdown 形式存放在你的仓库中——受版本控制、可在 PR 中审查。</li>
          <li>两者均基于 MIT 许可证开源。</li>
          <li>两者都面向 Claude Code、Cursor、Copilot 及其他 AI 编码代理。</li>
        </ul>
      </div>
    </section>

    {/* ── What Spec Kit does well ── */}
    <section class="section" aria-labelledby="speckit-title">
      <div class="section-inner section-inner--prose">
        <h2 id="speckit-title" class="section-title">Spec Kit 的优势。</h2>
        <p class="section-note">
          <a href="https://github.com/github/spec-kit" rel="nofollow noopener" target="_blank" class="xref">Spec Kit</a>
          是来自 GitHub Next 的规范驱动开发工作流。
        </p>

        <div class="credit-card">
          <h3 class="credit-card__title">完整、有主见的流程</h3>
          <p class="credit-card__desc">
            Spec Kit 给你整条主线：
            <code>constitution → specify → plan → tasks → implement</code>。
            每一步都有一个斜杠命令和一段提示词，旨在让代理保持在轨道上。
            如果你想要一套流程，Spec Kit 直接递给你一套。
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">强大的分发与影响力</h3>
          <p class="credit-card__desc">
            背靠 GitHub Next，拥有庞大的社区和不断增长的扩展库。
            对许多开发者而言，Spec Kit 是他们接触到的第一个规范驱动工作流。
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">与代理无关的命令</h3>
          <p class="credit-card__desc">
            Spec Kit 的命令在 Claude Code、Cursor、Copilot 等之间通用——
            无论你运行哪一个，工作流都能驱动代理。
          </p>
        </div>
      </div>
    </section>

    {/* ── Feature comparison table ── */}
    <section class="section table-section" aria-labelledby="table-title">
      <div class="section-inner">
        <h2 id="table-title" class="section-title">功能对比。</h2>
        <p class="section-note">
          这些工具回答的是不同的问题，所以这张表对比的是角色，而非胜负。
        </p>

        <div class="table-wrap">
          <table class="compare-table" aria-label="SpecScore 与 Spec Kit 功能对比">
            <thead>
              <tr>
                <th scope="col">能力</th>
                <th scope="col">Spec Kit</th>
                <th scope="col">SpecScore</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>主要角色</td>
                <td>工作流 / 方法论</td>
                <td><strong>存储格式 + CLI</strong></td>
              </tr>
              <tr>
                <td>规范产出</td>
                <td>自由格式 Markdown</td>
                <td><strong>Markdown + YAML frontmatter</strong>（结构化）</td>
              </tr>
              <tr>
                <td>规范 linting</td>
                <td>无</td>
                <td><strong>内容质量</strong> — 模糊动词、缺失验收标准、悬空引用</td>
              </tr>
              <tr>
                <td>需求 / 验收标准 ID</td>
                <td>无</td>
                <td><strong>机器可寻址的 ID</strong>（<code>REQ: slug</code>）</td>
              </tr>
              <tr>
                <td>生命周期状态</td>
                <td>隐式（工作流步骤）</td>
                <td><strong>强制执行</strong> — Draft → Approved → Implementing → Stable → Deprecated</td>
              </tr>
              <tr>
                <td>代码到规范的可追溯性</td>
                <td>无</td>
                <td><strong><code>specscore:</code> 注解</strong> + <code>Verifies:</code> 提交尾注</td>
              </tr>
              <tr>
                <td>从 CLI 查询规范</td>
                <td>脚手架（<code>specify</code>、<code>plan</code>、<code>tasks</code>）</td>
                <td><strong>查询 API</strong> — <code>feature list / show / deps</code>、<code>lint</code>、<code>code refs</code></td>
              </tr>
              <tr>
                <td>运行时依赖</td>
                <td>Python</td>
                <td><strong>无</strong> — 单个 Go 二进制文件</td>
              </tr>
              <tr>
                <td>CI 集成</td>
                <td>运行工作流</td>
                <td><strong><code>specscore lint</code></strong> 返回非零退出码，支持 pre-commit 钩子</td>
              </tr>
              <tr>
                <td>关系</td>
                <td colspan="2"><strong>它们可以组合</strong> — Spec Kit 可以产出 SpecScore 文件</td>
              </tr>
              <tr>
                <td>许可证</td>
                <td>MIT</td>
                <td>MIT</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {/* ── Where SpecScore goes further ── */}
    <section class="section" aria-labelledby="further-title">
      <div class="section-inner">
        <h2 id="further-title" class="section-title">SpecScore 增添了什么。</h2>

        <div class="diff-grid">
          <div class="diff-card">
            <h3 class="diff-card__title">产出是可 lint 的</h3>
            <p class="diff-card__desc">
              Spec Kit 产出自由格式 Markdown——无论好坏，它都会交付。
              SpecScore 分两层检查结果：<code>lint</code>
              确定性地校验每个需求都有验收标准、交叉引用可解析、
              状态转换合法——而 AI
              审查器（<code>/review</code>、<code>/score</code>）则捕获含糊的
              标准和模糊的动词。
            </p>
            <div class="diff-card__example">
<pre class="terminal"><span class="prompt">$</span> specscore lint checkout/apply-discount.md
  <span class="mark-fail">✗</span> R3  no acceptance criteria
  <span class="mark-fail">✗</span> link  <span class="dim">"Related Feature: discount-tiers" not found</span></pre>
            </div>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">产出是可查询的</h3>
            <p class="diff-card__desc">
              Spec Kit 写文件；要回头读它们就得打开它们。SpecScore
              的规范能从 CLI 回答问题：<code>specscore feature list</code>、
              <code>feature deps</code>、<code>code refs</code>——这样代理无需
              阅读仓库中的每个文件即可导航规范图谱。
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">每个需求都有 ID</h3>
            <p class="diff-card__desc">
              Spec Kit 通过散文引用需求。SpecScore 分配基于 slug 的
              ID（<code>REQ: slug-format</code>）和验收标准 ID，在重命名、
              重构和代理交接时保持稳定。
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">生命周期是强制的</h3>
            <p class="diff-card__desc">
              在 Spec Kit 中，规范的阶段取决于你处在工作流的何处。
              在 SpecScore 中，生命周期是一个强制执行的状态字段——Draft → Approved
              → Implementing → Stable → Deprecated——由 lint 验证，并通过 git 钩子或 CI 中的
              <code>specscore change-status</code> 进行状态转换。
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">代码可追溯回规范</h3>
            <p class="diff-card__desc">
              Spec Kit 没有可追溯性机制。SpecScore 拥有
              <code>specscore:</code> 源注解和 <code>Verifies:</code>
              提交尾注——运行 <code>specscore code refs</code> 即可确定性地回答
              "哪些代码实现了这个需求？"。
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">无运行时依赖</h3>
            <p class="diff-card__desc">
              SpecScore 是单个 Go 二进制文件——无需安装任何运行时。
              可直接用于 Go、Rust、Python、Java 或 JavaScript 项目，
              无需在工具链中引入任何东西。
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── When to use which ── */}
    <section class="section" aria-labelledby="when-title">
      <div class="section-inner">
        <h2 id="when-title" class="section-title">何时使用哪个。</h2>

        <div class="when-grid">
          <div class="when-card">
            <h3 class="when-card__title">以下场景适合使用 Spec Kit……</h3>
            <ul class="when-card__list">
              <li>你想要一套有引导、有主见的流程，从想法走向实现。</li>
              <li>你的团队需要明确的 specify / plan / tasks 步骤所带来的纪律。</li>
              <li>你正在团队范围内统一驱动代理的方式。</li>
            </ul>
          </div>

          <div class="when-card when-card--primary">
            <h3 class="when-card__title">以下场景适合使用 SpecScore……</h3>
            <ul class="when-card__list">
              <li>你需要代理无需阅读每个文件即可 lint、查询和修改的规范。</li>
              <li>你需要带有确定性答案的代码到规范可追溯性。</li>
              <li>你正在构建具有大量功能和生命周期转换的大型系统。</li>
              <li>你想要零运行时依赖——一个二进制文件，无需任何语言工具链。</li>
              <li>你需要在 CI 中设置返回非零退出码的规范质量门禁，就像 ESLint 或 <code>go vet</code>。</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── The integration opportunity ── */}
    <section class="section" aria-labelledby="bridge-title">
      <div class="section-inner section-inner--prose">
        <h2 id="bridge-title" class="section-title">SpecScore 扩展 Spec Kit——而非取代它。</h2>
        <p class="prose-p">
          Spec Kit 是产出规范的流程；SpecScore 是该规范可以书写所用的格式。
          一个能输出 SpecScore 格式的 Spec Kit 扩展正在开发中——
          运行 Spec Kit 工作流，在另一端得到可 lint、可查询、可追溯的规范。
        </p>
        <p class="prose-p">
          为流程选择 Spec Kit。为工件选择 SpecScore。当你两者都想要时，两者一起用。
        </p>
      </div>
    </section>

    <ComparisonFeedback page="spec-kit" />
  </main>

  {/* ── Final CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">通过检查的规范。</h2>
      <div class="final-cta__buttons">
        <a href="/cli/install/" class="btn btn--primary">安装 CLI</a>
        <a href="/ai/specstudio-skills/" class="btn btn--secondary">获取 AI 代理技能</a>
        <a
          href="https://github.com/specscore/specscore"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          在 GitHub 上开源
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <SiteFooterZhCn />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-5);
    background: var(--cream);
  }
  .hero__inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms;
  }
  .hero__breadcrumb {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--pale-ink);
    margin-bottom: var(--space-2);
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
    max-width: 52ch;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Section titles ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }

  /* ── Shared list ── */
  .shared-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .shared-list li {
    position: relative;
    padding-left: 1.4rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
  }
  .shared-list li::before {
    content: '=';
    position: absolute;
    left: 0;
    font-family: var(--font-code);
    font-weight: 700;
    color: var(--pale-ink);
  }

  /* ── Section note ── */
  .section-note {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    margin-bottom: var(--space-3);
  }

  /* ── Credit cards ── */
  .credit-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .credit-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .credit-card__desc {
    color: var(--mid-ink);
    line-height: 1.6;
    font-size: var(--fs-body);
  }
  .credit-card__desc code {
    font-size: 0.9em;
    background: var(--cream);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Feature comparison table ── */
  .table-section { background: var(--cream-2); }
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-small);
    line-height: 1.5;
  }
  .compare-table th,
  .compare-table td {
    text-align: left;
    padding: 0.65rem 0.85rem;
    border-bottom: 1px solid var(--hairline);
    vertical-align: top;
  }
  .compare-table thead th {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mid-ink);
    border-bottom: 2px solid var(--graphite);
    white-space: nowrap;
  }
  .compare-table td:first-child {
    font-weight: 500;
    white-space: nowrap;
    min-width: 160px;
  }
  .compare-table td:nth-child(2),
  .compare-table td:nth-child(3) {
    min-width: 200px;
  }
  .compare-table td code {
    font-size: 0.88em;
    background: var(--surface);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .compare-table strong {
    font-weight: 600;
    color: var(--ink);
  }

  /* ── Diff grid ── */
  .diff-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .diff-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
  }
  .diff-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .diff-card__desc {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    line-height: 1.6;
  }
  .diff-card__desc code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .diff-card__example {
    margin-top: var(--space-2);
  }
  .diff-card__example .terminal {
    font-size: 0.78rem;
    line-height: 1.6;
  }

  @media (max-width: 860px) {
    .diff-grid { grid-template-columns: 1fr; }
  }

  /* ── When to use which ── */
  .when-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .when-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-4);
  }
  .when-card--primary {
    border-color: var(--validator-green);
    border-width: 2px;
  }
  .when-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .when-card__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .when-card__list li {
    position: relative;
    padding-left: 1.2rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
    font-size: var(--fs-small);
  }
  .when-card__list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--pale-ink);
    font-family: var(--font-code);
  }
  .when-card--primary .when-card__list li::before {
    color: var(--validator-green);
  }
  .when-card__list code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  @media (max-width: 860px) {
    .when-grid { grid-template-columns: 1fr; }
  }

  /* ── Bridge section ── */
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
    margin-bottom: var(--space-2);
  }
  .prose-p:last-child {
    margin-bottom: 0;
    font-weight: 500;
    color: var(--ink);
  }
  .prose-p code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    text-align: center;
  }
  .final-cta__title {
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .final-cta__buttons {
