---
// /zh-cn/faq/ — Frequently asked questions (Simplified Chinese).
// Simplified Chinese variant of /faq/index.astro. Anchor IDs stay
// verbatim (vs-spec-kit, vs-superpowers, why-cli, naming, token-savings)
// so the homepage teaser link targets land correctly.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import FinalCta from '../../../components/FinalCtaZhCn.astro';
import SiteFooter from '../../../components/SiteFooterZhCn.astro';
---

<BaseLayout
  lang="zh-CN"
  title="FAQ — SpecScore"
  description="对评审者真正提出的问题给出诚实回答：SpecScore 与 spec-kit 的区别、为什么在技能之外还要有 CLI、“Score”是什么意思、token 节省的数据从哪里来。"
  canonical="https://specscore.md/zh-cn/faq/"
>
  <SiteHeader />

  <main>
    <section class="faq-hero" aria-labelledby="faq-hero-title">
      <div class="faq-hero__inner">
        <h1 id="faq-hero-title" class="faq-hero__headline">
          评审者真正问过的问题。
        </h1>
        <p class="faq-hero__sub">
          来自发布前的同行反馈。每个答案都是诚实版，不是营销版。
        </p>
      </div>
    </section>

    <section class="faq-body section" aria-labelledby="faq-list-title">
      <div class="section-inner">
        <h2 id="faq-list-title" class="sr-only">FAQ 列表</h2>

        <article class="faq-item">
          <h2 id="vs-spec-kit" class="faq-item__q">
            SpecScore 和 spec-kit 有什么区别？
          </h2>
          <div class="faq-item__a">
            <p>
              <strong>spec-kit 是一种方法论——写规格说明的流程。</strong>
              SpecScore 是你所写规格说明的<strong>存储格式</strong>，外加
              一个用于查询和编辑的 CLI。两者可以组合：spec-kit 能产生
              SpecScore 文件，一个以 SpecScore 格式输出的 spec-kit 扩展
              正在开发中。
            </p>
            <p>
              需要流程时选 spec-kit。需要 AI 代理无需读取仓库中每个文件
              就能进行 lint、查询和变更的规格说明时，选 SpecScore。
              两者都要的时候，就都用。
            </p>
          </div>
        </article>

        <article class="faq-item">
          <h2 id="vs-superpowers" class="faq-item__q">
            SpecStudio Skills 与 Superpowers、agent-skills 有何不同？
          </h2>
          <div class="faq-item__a">
            <p>
              理念相近。三者都是引导 AI 代理走完 ideate → specify →
              plan → implement 的技能库。差异在机制上，不在理念上。
            </p>
            <p>
              <strong>SpecStudio Skills 以 SpecScore 格式
              （定义好的 Markdown + YAML 结构）写出产物</strong>，并通过
              <code>specscore</code> CLI 完成查询、lint 和状态变更。
              Superpowers 和 agent-skills 主要通过技能文本直接读写文件。
            </p>
            <p>
              当 token 消耗很重要时，选 SpecStudio Skills——CLI 通过一次
              调用就能给出 <em>"所有带未决问题的开放 Feature"</em>
              这样的结构化答案，而基于文件的技能要回答同样的问题，
              就得读 N 份文档。
            </p>
          </div>
        </article>

        <article class="faq-item">
          <h2 id="why-cli" class="faq-item__q">
            为什么要 CLI——只装技能不行吗？
          </h2>
          <div class="faq-item__a">
            <p>
              技能可以读写文件。但它们无法可靠地做到：
            </p>
            <ul>
              <li>在整棵规格树上保证引用完整性（链接能解析、ID 唯一、索引保持同步）；</li>
              <li>不读取每个文件就返回一份过滤后的"带未决问题的开放 Feature"列表；</li>
              <li>在每个产物上、在正确的时机、变更正确的状态字段。</li>
            </ul>
            <p>
              CLI 让代理在每项任务上只需一次干净的调用——就像
              <code>jq</code> 让你只需一次干净的调用就能查询 JSON。
              单靠技能则消耗更多 token、更容易漂移、还经常忘记更新索引。
            </p>
          </div>
        </article>

        <article class="faq-item">
          <h2 id="naming" class="faq-item__q">
            为什么叫"SpecScore"——它在给什么打分？
          </h2>
          <div class="faq-item__a">
            <p>
              "Score"可以有两种解读，且都是有意为之。
            </p>
            <p>
              <strong>Partitura（总谱）。</strong>一份结构化的需求总谱——
              就像乐谱组织声部、声线和时序那样。打开一棵 SpecScore 树，
              你应该能像指挥读总谱那样去读它：层级、声部、引用，一目了然。
            </p>
            <p>
              <strong>字面意义上的质量评级。</strong>CLI 检查器是
              确定性的分数（规格的结构是否站得住？）。
              <a href="https://specscore.studio/app/github.com/specscore/specstudio-skills/spec/ideas/manual-review-and-score-commands"><code>/score</code> 技能</a>
              是 AI 评判的分数——每个产物的 A–F 就绪度评级，并附给作者
              逐项反馈。名字里"Score"的那一半，从一种愿景变成了
              工具实际产出的能力。
            </p>
          </div>
        </article>

        <article class="faq-item">
          <h2 id="token-savings" class="faq-item__q">
            把 token 节省数据拿出来看看。
          </h2>
          <div class="faq-item__a">
            <p>
              实测的并排对比正在进行中，会在 Habr 文章前发布——同一项任务
              （"我接下来该做什么？"）跑两次：一次是普通代理读文档，
              一次是同一个代理调用 SpecScore CLI。两边都给出 token 计数
              和响应时间。
            </p>
            <p>
              在那些数字落地之前，主张是结构层面的：向 CLI 询问开放
              Feature 和未决问题的代理，得到的是一份小而结构化的回应；
              没有 CLI 的同一个代理则要读 N 份文档——N 通常以十计。
              CLI 的接口正是为了避开这种扇出读取而设计的。
            </p>
          </div>
        </article>

        <p class="faq-extend">
          还有别的问题，或者对其中某条有更尖锐的版本？请到
          <a href="https://github.com/specscore/specscore/issues">specscore/specscore</a>
          开一个 issue——这页是 FAQ 的权威版本，它从真实评审者的提问中生长而来。
        </p>
      </div>
    </section>
  </main>

  <FinalCta />
  <SiteFooter />
</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap; border: 0;
  }

  .faq-hero {
    padding: var(--space-6) var(--space-3) var(--space-5);
    background: var(--cream);
  }
  .faq-hero__inner {
    max-width: var(--max-content);
    margin: 0 auto;
  }
  .faq-hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
    max-width: 22ch;
  }
  .faq-hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    max-width: 50ch;
    line-height: 1.5;
  }

  .faq-body { background: var(--surface); }

  .faq-item {
    border-top: 1px solid var(--hairline);
    padding: var(--space-4) 0;
    max-width: 70ch;
  }
  .faq-item:last-of-type { border-bottom: 1px solid var(--hairline); }
  .faq-item__q {
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
    scroll-margin-top: var(--space-4);
  }
  .faq-item__a p,
  .faq-item__a ul {
    color: var(--mid-ink);
    line-height: 1.65;
    margin-bottom: var(--space-2);
  }
  .faq-item__a ul {
    padding-left: 1.25rem;
  }
  .faq-item__a li {
    margin-bottom: 0.4rem;
  }
  .faq-item__a a {
    color: var(--ink-blue);
    border-bottom: 1px solid currentColor;
  }
  .faq-item__a code {
    font-family: var(--font-code);
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  .faq-extend {
    margin-top: var(--space-5);
    font-size: 0.95rem;
    color: var(--mid-ink);
    max-width: 60ch;
  }
  .faq-extend a {
    color: var(--ink-blue);
    border-bottom: 1px solid currentColor;
  }
</style>
