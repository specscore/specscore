---
// SpecScore CLI — product page (zh-CN).
// Open-source linter for SpecScore specifications.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import LintExample from '../../../components/LintExample.astro';
import HeroGitHubLink from '../../../components/HeroGitHubLink.astro';
import QsTabsScript from '../../../components/QsTabsScript.astro';
---

<BaseLayout
  lang="zh-CN"
  title="SpecScore CLI — 像检查代码一样检查你的规格说明。"
  description="开源的 SpecScore 规格检查器。从命令行或 CI 流水线验证功能、需求和验收标准。无需账户，无遥测。"
  canonical="https://specscore.md/zh-cn/cli/"
>
  <SiteHeader />

  <main>
    {/* ── Hero: copy left, terminal demo right ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <h1 id="hero-title" class="hero__headline">
          像检查代码一样<br />检查你的规格说明。
        </h1>
        <div class="hero__copy">
          <p class="hero__sub">
            SpecScore CLI 从命令行验证功能、需求和验收标准。
            在本地运行，集成到 CI，或让你的 AI 代理调用它。
            开源，无需账户，无遥测。
          </p>
          <HeroGitHubLink repo="specscore/specscore-cli" label="在 GitHub 上开源" />
          <div class="hero__cta">
            <a href="/zh-cn/cli/install/" class="btn btn--primary">安装</a>
          </div>        </div>

        <div
          class="hero__art"
          role="img"
          aria-label="specscore lint 的终端输出：R1 和 R2 具有验收标准（绿色对勾）；R3 没有验收标准、一个 Related Feature 链接无法解析、缺少必需的 Open Questions 章节（红色叉号）。3 个问题，exit 1。"
        >
<LintExample />
        </div>
      </div>
    </section>

    {/* ── 快速安装 ── */}
    <section class="section" id="install" aria-labelledby="install-title">
      <div class="section-inner">
        <h2 id="install-title" class="section-title">60 秒安装。</h2>

        <div class="qs-tabs" role="tablist" aria-label="适合你操作系统的安装命令">
          <button type="button" role="tab" id="qs-tab-unix" aria-controls="qs-panel-unix" aria-selected="true" tabindex="0" class="qs-tab is-active" data-tab="unix">Linux / macOS</button>
          <button type="button" role="tab" id="qs-tab-win" aria-controls="qs-panel-win" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="win">Windows</button>
          <button type="button" role="tab" id="qs-tab-brew" aria-controls="qs-panel-brew" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="brew">Homebrew</button>
        </div>

        <div id="qs-panel-unix" role="tabpanel" aria-labelledby="qs-tab-unix" class="qs-panel is-active" data-panel="unix">
<pre class="terminal"><span class="prompt">$</span> curl -fsSL https://specscore.md/install/get-cli | sh</pre>
        </div>
        <div id="qs-panel-win" role="tabpanel" aria-labelledby="qs-tab-win" class="qs-panel" data-panel="win" hidden>
<pre class="terminal"><span class="prompt">PS&gt;</span> powershell -c "irm https://specscore.md/install/get-cli.ps1 | iex"</pre>
        </div>
        <div id="qs-panel-brew" role="tabpanel" aria-labelledby="qs-tab-brew" class="qs-panel" data-panel="brew" hidden>
<pre class="terminal"><span class="prompt">$</span> brew install specscore/tap/specscore</pre>
        </div>

        <p class="qs-more">
          <a class="xref" href="/zh-cn/cli/install/">所有安装方式 →</a>
        </p>
      </div>
    </section>

    {/* ── 功能特性 ── */}
    <section class="section features-section" aria-labelledby="features-title">
      <div class="section-inner">
        <h2 id="features-title" class="section-title">你将获得什么。</h2>

        <div class="features-grid">
          <div class="feature-card">
            <h3 class="feature-card__title">Lint</h3>
            <p class="feature-card__desc">
              验证结构、元数据、交叉引用和 AC 唯一性。
              按需求输出 pass/fail 报告，附修复建议。
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">Score</h3>
            <p class="feature-card__desc">
              以 0-100 分评估规格完整性。发现遗漏的参与者、
              触发器、错误状态、安全模型和限制。
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">CI 就绪</h3>
            <p class="feature-card__desc">
              出错时返回非零退出码。将 <code>specscore lint</code>
              集成到你的 CI 流水线中，与 ESLint、Prettier 和测试并行运行。
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">无遥测</h3>
            <p class="feature-card__desc">
              CLI 不向外发送任何数据。规格和评分保留在你的机器上。
              无需账户、无需 API 密钥、不依赖云服务。
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">可移植</h3>
            <p class="feature-card__desc">
              单一可执行文件。支持 macOS、Linux、Windows。零依赖。
              适用于任何 Markdown 规格目录。
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">开源</h3>
            <p class="feature-card__desc">
              MIT 许可证。源代码在
              <a class="xref" href="https://github.com/specscore/specscore-cli">specscore/specscore-cli</a>。
              永久免费。
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── 与 AI 代理配合使用 ── */}
    <section class="section" aria-labelledby="agents-title">
      <div class="section-inner section-inner--prose">
        <h2 id="agents-title" class="section-title">与 AI 代理配合使用。</h2>
        <p class="prose-p">
          CLI 是两个 Claude Code 插件底层的引擎。如果你的代理在编写规格，
          CLI 会在代理写任何代码之前告诉你规格是否合格。
        </p>
        <div class="agent-links">
          <a href="/zh-cn/ai/specstudio-skills/" class="btn btn--secondary">SpecStudio Skills</a>
          <a href="/zh-cn/ai/cli-skills/" class="btn btn--tertiary">CLI Skills（轻量包装）</a>
        </div>
      </div>
    </section>
  </main>

  {/* ── 最终 CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">通过检查的规格说明。</h2>
      <div class="final-cta__buttons">
        <a href="/zh-cn/cli/install/" class="btn btn--primary">安装 CLI</a>
        <a href="/zh-cn/ai/specstudio-skills/" class="btn btn--secondary">获取 AI 技能插件</a>
        <a
          href="https://github.com/specscore/specscore-cli"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          在 GitHub 上开源
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <footer class="page-footer">
    <div class="page-footer__inner">
      <div class="page-footer__col page-footer__brand">
        <a href="/zh-cn/" class="wordmark" aria-label="SpecScore 首页">
          <span class="wordmark__clef" aria-hidden="true">&#x1D11E;</span>
          <span class="wordmark__name">SpecScore.md</span>
        </a>
        <p class="page-footer__tagline">
          用于规范、需求和验收标准的开放标准。
        </p>
        <p class="page-footer__copyright">
          &copy; 2026 SpecScore contributors. MIT license.
        </p>
      </div>

      <div class="page-footer__col">
        <h4 class="page-footer__heading">SpecScore CLI</h4>
        <ul class="page-footer__list">
          <li><a href="/zh-cn/cli/install/">安装</a></li>
          <li><a href="https://github.com/specscore/specscore-cli">GitHub</a></li>
          <li><a href="https://github.com/specscore/specscore-cli/releases">发布</a></li>
        </ul>
      </div>

      <div class="page-footer__col">
        <h4 class="page-footer__heading">生态系统</h4>
        <ul class="page-footer__list">
          <li><a href="/">SpecScore</a> — 开放标准</li>
          <li><a href="/zh-cn/ai/specstudio-skills/">SpecStudio Skills</a> — Claude Code 插件</li>
          <li><a href="https://specscore.studio">SpecScore Studio</a> — Web 查看器</li>
        </ul>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ── Hero: two-column on desktop (copy left, terminal right),
        stacked on mobile. Mirrors the landing hero's rhythm. ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-7);
    background: var(--cream);
    overflow: hidden;
  }
  .hero__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 30fr 70fr;
    gap: var(--space-3) var(--space-6);
    align-items: center;
  }
  .hero__copy {
    animation: hero-copy-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 280ms;
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__inner > .hero__headline {
    grid-column: 1 / -1;
    margin-bottom: 0;
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    line-height: 1.55;
    max-width: 42ch;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .hero__art {
    animation: hero-art-in 700ms cubic-bezier(0.22, 0.61, 0.36, 1) both 100ms;
    min-width: 0;
  }
  .hero__art pre.terminal {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.65;
  }

  @keyframes hero-copy-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-art-in {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 860px) {
    .hero { padding: var(--space-5) var(--space-3) var(--space-6); }
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .hero__copy { order: 1; }
    .hero__art  { order: 2; }
  }

  /* ── Section titles ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  .section-intro {
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    line-height: 1.6;
  }
  .section-intro code {
    background: var(--cream-2);
    padding: 0.05em 0.35em;
    border-radius: 2px;
    font-size: 0.92em;
    color: var(--ink);
  }

  /* ── Features grid ── */
  .features-section { background: var(--cream-2); }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .feature-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
  }
  .feature-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .feature-card__desc {
    font-size: var(--fs-small);
    color: var(--mid-ink);
    line-height: 1.55;
  }
  .feature-card__desc code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  @media (max-width: 860px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .features-grid { grid-template-columns: 1fr; }
  }

  /* ── AI agents section ── */
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
    margin-bottom: var(--space-3);
  }
  .agent-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: var(--space-3);
  }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    text-align: center;
  }
  .final-cta__title {
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .final-cta__buttons {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  /* ── Footer ── */
  .page-footer {
    background: var(--cream);
    padding: var(--space-6) var(--space-3) var(--space-5);
  }
  .page-footer__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-4);
  }
  .page-footer__brand .wordmark { margin-bottom: var(--space-2); }
  .page-footer__tagline { color: var(--mid-ink); margin-bottom: var(--space-2); max-width: 36ch; line-height: 1.5; font-size: 0.95rem; }
  .page-footer__copyright { color: var(--pale-ink); font-size: 0.825rem; font-family: var(--font-code); }
  .page-footer__heading { font-family: var(--font-display); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--mid-ink); margin-bottom: var(--space-2); }
  .page-footer__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.4rem; }
  .page-footer__list a { color: var(--ink); font-size: 0.9rem; border-bottom: 1px solid transparent; transition: border-color 120ms ease; }
  .page-footer__list a:hover { border-bottom-color: var(--ink); }
  .page-footer__list a:focus-visible { outline: 2px solid var(--ink-blue); outline-offset: 2px; border-radius: 2px; }

  @media (max-width: 800px) {
    .page-footer__inner { grid-template-columns: 1fr 1fr; }
    .page-footer__brand { grid-column: 1 / -1; }
  }
</style>

<QsTabsScript />
