---
// Simplified Chinese variant of /validators.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooterZhCn from '../../../components/SiteFooterZhCn.astro';
import LintExample from '../../../components/LintExample.astro';
import ScoreExample from '../../../components/ScoreExample.astro';
---

<BaseLayout
  lang="zh-CN"
  title="SpecScore 校验什么 — 又有什么是它做不到的。"
  description="SpecScore 用两个校验器检查你的规格：确定性的代码检查器和 AI 审查器。看看每一个究竟能捕获什么 — 以及自动校验在哪里止步，从此交给你的判断。"
  canonical="https://specscore.md/zh-cn/validators/"
>
  <SiteHeader />

  <main>
    {/* ── Hero: orient the cold reader, then show lint passing ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <h1 id="hero-title" class="hero__headline">
          SpecScore<br />校验什么。
        </h1>
        <div class="hero__copy">
          <p class="hero__sub">
            SpecScore 是一种用于功能、需求和验收标准的开放式 Markdown
            格式 — 由两个校验器检查：确定性的<strong>代码检查器</strong>和
            <strong>AI 审查器</strong>。下面就是每一个能捕获什么，以及自动检查在哪里止步。
          </p>
          <p class="hero__context">
            初次了解 SpecScore？<a class="xref" href="/zh-cn/">从这里开始</a> ·
            <a class="xref" href="/zh-cn/cli/">CLI</a> ·
            <a class="xref" href="/zh-cn/ai/">AI 技能</a>
          </p>
        </div>

        <div
          class="hero__art"
          role="img"
          aria-label="终端输出：specscore lint 在 checkout 规格上通过全部 24 个需求 — 结构、引用、ID 均合法，无索引漂移、无失效链接、无 slug 冲突。0 个问题，exit 0。"
        >
<pre class="terminal terminal--window"><span class="prompt">$</span> specscore lint checkout/

  <span class="mark-pass">✓</span> 24 requirements — structure, references, IDs valid
  <span class="mark-pass">✓</span> no index drift · no broken links · no slug collisions

  <span class="dim">0 problems   exit 0</span></pre>
        </div>
      </div>
    </section>

    {/* ── The three layers ── */}
    <section class="section" aria-labelledby="layers-title">
      <div class="section-inner section-inner--prose">
        <h2 id="layers-title" class="section-title">三层，而非一层。</h2>
        <p class="prose-p">
          SpecScore 分层校验，最廉价、最确定的优先。<strong>代码检查器</strong>是确定性的 —
          快速、免费，每次提交都运行。<strong>AI 审查</strong>是概率性的 —
          更深入，消耗 token，能捕获代码检查器够不着的东西。<strong>人的判断</strong>是第三层：
          前两层无法弥合的缝隙仍然需要人 — 因为目前还没有工具能可靠地弥合它们。
          这两个自动层是互补的，而非冗余的：代码检查器捕获 AI 无法佐证的问题，AI 捕获代码检查器够不着的问题。
        </p>
      </div>
    </section>

    {/* ── What each validator checks (the positive half) ── */}
    <section class="section validators-section" aria-labelledby="checks-title">
      <div class="section-inner">
        <h2 id="checks-title" class="section-title">每个校验器检查什么。</h2>
        <div class="vcols">
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">Layer 1</span>
              <h3 class="validator__title">CLI 代码检查器</h3>
              <span class="validator__kind">deterministic</span>
            </div>
            <p class="validator__lead">
              每次运行结果相同，不用 LLM，零成本。如果在这里通过了，那就是事实 — 而非意见。
            </p>
            <div
              class="checks-terminal"
              role="img"
              aria-label="specscore lint 的输出：R1 和 R2 具有验收标准；R3 没有，一个 Related Feature 链接无法解析，缺少必需的 Open Questions 章节。3 个问题，exit 1。"
            >
              <LintExample />
            </div>
            <ul class="vlist">
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 引用完整性 — 链接可解析、ID 唯一</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 结构约定 — 必需的章节、frontmatter 的形态</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 状态卫生与索引漂移</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> slug 冲突</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 元数据字段上的前缀合法性（例如 <code>Related Ideas:</code>）</li>
            </ul>
          </div>
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">Layer 2</span>
              <h3 class="validator__title">AI 审查与评分</h3>
              <span class="validator__kind">non-deterministic</span>
            </div>
            <p class="validator__lead">
              像人类审查者那样按含义阅读 — 也和人一样，并非完全可重复。
            </p>
            <div
              class="checks-terminal"
              role="img"
              aria-label="/score 的输出：该规格获得 B 等级，并附有两条可操作的提示 — AC-2 上的触发条件含糊，AC-3 缺少错误处理路径。"
            >
              <ScoreExample />
            </div>
            <ul class="vlist">
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 验收标准是否写成可验证的 Given/When/Then</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 单个工件内部的一致性</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 含糊或占位性的内容</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 对人类审查者而言的可读性</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 作者可操作、标注了严重级别的反馈</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> A–F 的就绪度评级</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── #limits — what they don't catch (the honest half) ── */}
    <section class="section limits-section" id="limits" aria-labelledby="limits-title">
      <div class="section-inner">
        <h2 id="limits-title" class="section-title">它们捕获不到什么。</h2>
        <p class="section-lead">
          没有哪个校验器是魔法。下面就是每一个止步之处 — 好让你清楚地知道，哪里仍然需要你自己的判断来完成工作。
        </p>
        <div class="vcols">
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">Layer 1</span>
              <h3 class="validator__title">CLI 代码检查器</h3>
            </div>
            <ul class="vlist">
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 跨深层级的隐式矛盾</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 规格与代码之间的漂移 <span class="vnote">（随着 <code>specstudio:recap</code> 上线而改善）</span></li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 验收标准在语义上的正确性</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 一个名称是否真的讲得通</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 这些需求是否解决了所陈述的问题</li>
            </ul>
          </div>
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">Layer 2</span>
              <h3 class="validator__title">AI 审查与评分</h3>
              <span class="validator__kind">捕获并不稳定</span>
            </div>
            <ul class="vlist">
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 完全的逐次可重现性 — 在容差范围内裁决可能会变化</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 没有显式交叉检查时，大型树中跨工件的矛盾</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 需求是否真正解决了问题 — 能标出明显的缺口，会漏掉特定领域的缺口</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 从底层 LLM 继承而来的偏见</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 以绝对的把握保证语义正确性</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 任何评分细则没有纳入权重的东西</li>
            </ul>
          </div>
        </div>

        <ol class="bands" aria-label="校验的三个层次，按覆盖深度排列">
          <li class="band">
            <span class="band__step">1</span>
            <h3 class="band__title">代码检查器够到这里</h3>
            <p class="band__desc">
              结构、引用、卫生。廉价又确定 — 但对含义视而不见。
            </p>
          </li>
          <li class="band band--mid">
            <span class="band__step">2</span>
            <h3 class="band__title">AI 够到这里</h3>
            <p class="band__desc">
              含义、清晰度、单个工件内部的一致性。更深入 — 但是概率性的，在大型树上较弱。
            </p>
          </li>
          <li class="band band--human">
            <span class="band__step">3</span>
            <h3 class="band__title">仍然要靠你</h3>
            <p class="band__desc">
              对整个系统的贯穿式判断 — 这是目前没有工具能可靠完成的工作，所以仍然需要一位人类审查者。
            </p>
          </li>
        </ol>

        <div class="worked">
          <h3 class="worked__title">两个工具都救不了你的那种情形</h3>
          <p class="worked__body">
            想象一棵真实而深的规格树。功能&nbsp;A 要求 <em>X</em>。功能&nbsp;B 要求
            <em>Y</em>。功能&nbsp;C 要求 <em>Z</em>。然后功能&nbsp;D 悄悄要求了某个与 B
            矛盾的东西 — 但只在 A 同时生效时才矛盾。代码检查器看到的是四份合法、彼此链接良好的文档，于是通过了。
            AI 审查器逐个阅读工件，没有理由把这四份一起加载进来，从而注意到这种三方交互。
          </p>
          <p class="worked__body">
            <strong>这两层都无法可靠地捕获它 — 我们也不会假装不是这样。</strong>
            正是这一类矛盾，才是第三层存在的理由。SpecScore 的职责是把这棵树做得足够易于导航，
            让一位审查缝隙的人能够<em>找到</em>冲突 — 开放问题沿层级向上传播、相关需求只需一次查询即达 —
            而不是声称某个工具已经替你找到了它。
          </p>
        </div>
      </div>
    </section>
  </main>

  {/* ── Final CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">诚实的工具，诚实的规格。</h2>
      <div class="final-cta__buttons">
        <a href="/zh-cn/cli/install/" class="btn btn--primary">安装 CLI</a>
        <a href="/zh-cn/ai/specstudio-skills/" class="btn btn--secondary">为你的代理获取 AI 技能</a>
        <a
          href="https://github.com/specscore/specscore-cli"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          在 GitHub 上开源
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <SiteFooterZhCn />
</BaseLayout>

<style>
  /* ── Hero (mirrors /cli two-column rhythm) ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-7);
    background: var(--cream);
    overflow: hidden;
  }
  .hero__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 38fr 62fr;
    gap: var(--space-3) var(--space-6);
    align-items: center;
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
  }
  .hero__inner > .hero__headline {
    grid-column: 1 / -1;
    margin-bottom: 0;
  }
  .hero__copy {
    animation: hero-copy-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 280ms;
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
    max-width: 52ch;
  }
  .hero__sub strong { color: var(--ink); }
  .hero__context {
    margin-top: var(--space-3);
    font-size: var(--fs-small);
    color: var(--pale-ink);
  }
  .hero__art {
    animation: hero-art-in 700ms cubic-bezier(0.22, 0.61, 0.36, 1) both 100ms;
    min-width: 0;
  }
  .hero__art pre.terminal {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.65;
  }

  @keyframes hero-copy-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-art-in {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 860px) {
    .hero { padding: var(--space-5) var(--space-3) var(--space-6); }
    .hero__inner { grid-template-columns: 1fr; gap: var(--space-4); }
    .hero__copy { order: 1; }
    .hero__art  { order: 2; }
  }

  /* ── Section scaffolding ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  .section-lead {
    color: var(--mid-ink);
    line-height: 1.6;
    max-width: 60ch;
    margin-bottom: var(--space-4);
  }
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
  }
  .prose-p strong { color: var(--ink); }

  /* ── Validator columns (used by both "checks" and "#limits") ── */
  .validators-section { background: var(--cream); }
  .limits-section {
    background: var(--cream-2);
    scroll-margin-top: var(--space-5);
  }

  .validator__head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .validator__layer {
    font-family: var(--font-display);
    font-size: var(--fs-tiny);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--pale-ink);
  }
  .validator__title {
    font-size: var(--fs-h3);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .validator__kind {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--mid-ink);
  }
  .validator__lead {
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .checks-terminal {
    margin-bottom: var(--space-3);
  }
  .checks-terminal pre.terminal {
    margin: 0;
    font-size: 0.72rem;
    line-height: 1.65;
  }

  .vcols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }
  .vlist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .vlist li {
    position: relative;
    padding-left: 1.6rem;
    color: var(--ink);
    line-height: 1.5;
    font-size: var(--fs-small);
  }
  .vlist code {
    font-size: 0.9em;
    background: var(--surface);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .mark {
    position: absolute;
    left: 0;
    font-weight: 700;
    font-family: var(--font-code);
  }
  .mark--pass { color: var(--validator-green); }
  .mark--fail { color: var(--mark-red); }
  .vnote { color: var(--pale-ink); }

  @media (max-width: 640px) {
    .vcols { grid-template-columns: 1fr; gap: var(--space-4); }
  }

  /* ── Synthesis bands ── */
  .bands {
    list-style: none;
    margin: var(--space-5) 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .band {
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-top: 3px solid var(--validator-green);
    padding: var(--space-3);
  }
  .band--mid { border-top-color: var(--ink-blue); }
  .band--human { border-top-color: var(--mark-red); }
  .band__step {
    font-family: var(--font-display);
    font-size: var(--fs-small);
    font-weight: 700;
    color: var(--pale-ink);
  }
  .band__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin: var(--space-1) 0;
  }
  .band__desc {
    font-size: var(--fs-small);
    color: var(--mid-ink);
    line-height: 1.55;
  }

  @media (max-width: 720px) {
    .bands { grid-template-columns: 1fr; }
  }

  /* ── Worked example ── */
  .worked {
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-left: 3px solid var(--ink);
    padding: var(--space-4);
  }
  .worked__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .worked__body {
    color: var(--mid-ink);
    line-height: 1.65;
  }
  .worked__body + .worked__body { margin-top: var(--space-2); }
  .worked__body strong { color: var(--ink); }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    text-align: center;
  }
  .final-cta__title {
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .final-cta__buttons {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>
