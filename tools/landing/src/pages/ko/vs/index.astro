---
// /ko/vs/ — Comparison index page (ko).
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import ComparisonFeedback from '../../../components/ComparisonFeedback.astro';
---

<BaseLayout
  lang="ko"
  title="SpecScore vs — SpecScore 비교 분석."
  description="SpecScore와 다른 스펙 기반 개발 도구 간의 솔직하고 상세한 비교. 기능 테이블, 아키텍처 차이점, 그리고 언제 어떤 도구를 사용해야 하는지 안내합니다."
  canonical="https://specscore.md/ko/vs/"
>
  <SiteHeader />

  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <h1 id="hero-title" class="hero__headline">
          SpecScore 비교 분석.
        </h1>
        <p class="hero__sub">
          스펙 기반 개발은 빠르게 성장하는 분야입니다. 이 비교는 사실에 기반하며, 각 도구가 더 강한 영역에 대해 솔직하게 설명합니다.
        </p>
      </div>
    </section>

    <section class="section" aria-labelledby="comparisons-title">
      <div class="section-inner">
        <h2 id="comparisons-title" class="sr-only">비교</h2>

        <div class="compare-grid">
          <a href="/ko/vs/openspec/" class="compare-card">
            <h3 class="compare-card__name">SpecScore vs OpenSpec</h3>
            <p class="compare-card__desc">
              둘 다 Markdown으로 스펙을 작성합니다. OpenSpec은 스펙을 구성하고, SpecScore는 lint, 점수 평가, 추적성을 제공합니다. 전체 비교: 형식, CLI, 라이프사이클, 추적성, 에이전트 지원.
            </p>
            <span class="compare-card__cta">비교 읽기 →</span>
          </a>
        </div>
      </div>
    </section>

    <ComparisonFeedback />
  </main>

  <footer class="page-footer">
    <div class="page-footer__inner">
      <div class="page-footer__col page-footer__brand">
        <a href="/ko/" class="wordmark" aria-label="SpecScore home">
          <span class="wordmark__clef" aria-hidden="true">&#x1D11E;</span>
          <span class="wordmark__name">SpecScore.md</span>
        </a>
        <p class="page-footer__tagline">
          사양, 요구사항, 인수 기준을 위한 오픈 표준.
        </p>
        <p class="page-footer__copyright">
          &copy; 2026 SpecScore contributors. MIT license.
        </p>
      </div>

      <div class="page-footer__col">
        <h4 class="page-footer__heading">제품</h4>
        <ul class="page-footer__list">
          <li><a href="/cli/">SpecScore CLI</a></li>
          <li><a href="/cli/install/">설치</a></li>
          <li><a href="https://github.com/specscore/specscore-cli">GitHub</a></li>
        </ul>
      </div>

      <div class="page-footer__col">
        <h4 class="page-footer__heading">생태계</h4>
        <ul class="page-footer__list">
          <li><a href="/">SpecScore</a> — 오픈 표준</li>
          <li><a href="/ai/specstudio-skills/">SpecStudio Skills</a></li>
          <li><a href="https://specscore.studio">SpecScore Studio</a> — 웹 뷰어</li>
        </ul>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  .hero { padding: var(--space-6) var(--space-3) var(--space-5); background: var(--cream); }
  .hero__inner { max-width: var(--max-prose); margin: 0 auto; animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms; }
  .hero__headline { font-size: var(--fs-h2); font-weight: 700; letter-spacing: -0.01em; margin-bottom: var(--space-3); }
  .hero__sub { font-size: 1.125rem; color: var(--mid-ink); line-height: 1.55; }
  @keyframes fade-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }
  .compare-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-3); }
  .compare-card { display: block; background: var(--surface); border: 1px solid var(--hairline); padding: var(--space-4); transition: border-color 160ms ease, box-shadow 160ms ease; text-decoration: none; color: inherit; }
  .compare-card:hover { border-color: var(--graphite); box-shadow: 0 2px 8px rgba(26, 26, 26, 0.06); }
  .compare-card:focus-visible { outline: 2px solid var(--ink-blue); outline-offset: 2px; }
  .compare-card__name { font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; margin-bottom: var(--space-2); }
  .compare-card__desc { color: var(--mid-ink); font-size: var(--fs-body); line-height: 1.6; margin-bottom: var(--space-3); }
  .compare-card__cta { font-family: var(--font-display); font-size: var(--fs-small); font-weight: 600; color: var(--validator-green); }
  @media (max-width: 720px) { .compare-grid { grid-template-columns: 1fr; } }
  .page-footer { background: var(--cream); padding: var(--space-6) var(--space-3) var(--space-5); border-top: 1px solid var(--hairline); }
  .page-footer__inner { max-width: var(--max-content); margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr; gap: var(--space-4); }
  .page-footer__brand .wordmark { margin-bottom: var(--space-2); }
  .page-footer__tagline { color: var(--mid-ink); margin-bottom: var(--space-2); max-width: 36ch; line-height: 1.5; font-size: 0.95rem; }
  .page-footer__copyright { color: var(--pale-ink); font-size: 0.825rem; font-family: var(--font-code); }
  .page-footer__heading { font-family: var(--font-display); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--mid-ink); margin-bottom: var(--space-2); }
  .page-footer__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.4rem; }
  .page-footer__list a { color: var(--ink); font-size: 0.9rem; border-bottom: 1px solid transparent; transition: border-color 120ms ease; }
  .page-footer__list a:hover { border-bottom-color: var(--ink); }
  @media (max-width: 800px) { .page-footer__inner { grid-template-columns: 1fr 1fr; } .page-footer__brand { grid-column: 1 / -1; } }
</style>
