---
// /ko/vs/ — Comparison index page (ko).
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooterKo from '../../../components/SiteFooterKo.astro';
import ComparisonFeedback from '../../../components/ComparisonFeedback.astro';
---

<BaseLayout
  lang="ko"
  title="SpecScore vs — SpecScore 비교 분석."
  description="SpecScore와 다른 스펙 기반 개발 도구 간의 솔직하고 상세한 비교. 기능 테이블, 아키텍처 차이점, 그리고 언제 어떤 도구를 사용해야 하는지 안내합니다."
  canonical="https://specscore.md/ko/vs/"
>
  <SiteHeader />

  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <h1 id="hero-title" class="hero__headline">
          SpecScore 비교 분석.
        </h1>
        <p class="hero__sub">
          스펙 기반 개발은 성장하는 분야입니다. 이 비교는 사실에 기반한
          나란히 비교이며, 각 도구가 더 강한 영역에 대해 솔직합니다.
        </p>
      </div>
    </section>

    <section class="section minis-section" aria-labelledby="comparisons-title">
      <div class="section-inner">
        <h2 id="comparisons-title" class="sr-only">비교</h2>

        <p class="minis__lead">
          <span class="minis__brand">SpecScore</span>
          <span class="minis__vs">vs</span>
        </p>

        <div class="minis">
          <a href="/vs/plain-markdown/" class="mini">
            <span class="mini__name">Plain Markdown</span>
            <span class="mini__line">기본값. SpecScore는 Markdown이 성장해 도달하는 지점입니다.</span>
          </a>
          <a href="/ko/vs/openspec/" class="mini">
            <span class="mini__name">OpenSpec</span>
            <span class="mini__line">확실한 진입로. SpecScore는 가드레일입니다.</span>
          </a>
          <a href="/vs/spec-kit/" class="mini">
            <span class="mini__name">Spec Kit</span>
            <span class="mini__line">Spec Kit은 워크플로우. SpecScore는 아티팩트입니다.</span>
          </a>
          <a href="/vs/datarim/" class="mini">
            <span class="mini__name">Datarim</span>
            <span class="mini__line">Datarim은 파이프라인을 실행하고, SpecScore는 그것이 남기는 결과물입니다.</span>
          </a>
          <a href="/vs/codespeak/" class="mini">
            <span class="mini__name">CodeSpeak</span>
            <span class="mini__line">CodeSpeak은 컴파일러에 베팅하고, SpecScore는 포맷에 베팅합니다.</span>
          </a>
        </div>
      </div>
    </section>

    {/* ── Cross-comparison matrix ── */}
    <section class="section table-section" aria-labelledby="matrix-title">
      <div class="section-inner">
        <h2 id="matrix-title" class="section-title">SpecScore 한눈에 보기.</h2>
        <p class="section-note">
          가장 가까운 도구들을 가로질러 본 개략적인 시각입니다. 각 도구는
          진짜 강점이 있습니다 — 솔직하고 상세한 버전은 위의 비교를
          따라가 보세요.
        </p>

        <div class="table-wrap">
          <table class="matrix-table" aria-label="SpecScore vs Plain Markdown, OpenSpec, Spec Kit, Datarim, CodeSpeak">
            <thead>
              <tr>
                <th scope="col">기능</th>
                <th scope="col" class="matrix-table__own">SpecScore</th>
                <th scope="col"><a href="/vs/plain-markdown/" class="matrix-table__link">Plain Markdown</a></th>
                <th scope="col"><a href="/ko/vs/openspec/" class="matrix-table__link">OpenSpec</a></th>
                <th scope="col"><a href="/vs/spec-kit/" class="matrix-table__link">Spec Kit</a></th>
                <th scope="col"><a href="/vs/datarim/" class="matrix-table__link">Datarim</a></th>
                <th scope="col"><a href="/vs/codespeak/" class="matrix-table__link">CodeSpeak</a></th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>주요 역할</td>
                <td class="matrix-table__own">Lint 가능한 스펙 포맷 + CLI</td>
                <td>자유 형식 문서 (기본값)</td>
                <td>스펙 구성 프레임워크</td>
                <td>워크플로우 / 방법론</td>
                <td>Claude Code 워크플로우 팩</td>
                <td>LLM 컴파일러 (스펙 → 코드)</td>
              </tr>
              <tr>
                <td>스펙 형식</td>
                <td class="matrix-table__own">Markdown + YAML (구조화)</td>
                <td>자유 형식 Markdown</td>
                <td>Markdown</td>
                <td>자유 형식 Markdown</td>
                <td>Markdown (워크플로우 형태)</td>
                <td>일반 영어</td>
              </tr>
              <tr>
                <td>코드는 그대로 유지</td>
                <td class="matrix-table__own"><span class="yes">예</span></td>
                <td><span class="yes">예</span></td>
                <td><span class="yes">예</span></td>
                <td><span class="yes">예</span></td>
                <td><span class="yes">예</span></td>
                <td><span class="no">코드가 생성됨</span></td>
              </tr>
              <tr>
                <td>오픈 소스 / 무료</td>
                <td class="matrix-table__own"><span class="yes">예</span> (CC BY / MIT)</td>
                <td><span class="yes">무료</span></td>
                <td><span class="yes">예</span> (MIT)</td>
                <td><span class="yes">예</span> (MIT)</td>
                <td><span class="yes">예</span> (MIT)</td>
                <td><span class="no">독점 시스템</span></td>
              </tr>
              <tr>
                <td>스펙 콘텐츠 linting</td>
                <td class="matrix-table__own"><span class="yes">예</span></td>
                <td><span class="no">아니오</span></td>
                <td>구조만</td>
                <td><span class="no">아니오</span></td>
                <td><span class="no">아니오</span></td>
                <td>문서화되지 않음</td>
              </tr>
              <tr>
                <td>요구사항 / 인수 기준 ID</td>
                <td class="matrix-table__own"><span class="yes">예</span></td>
                <td><span class="no">아니오</span></td>
                <td><span class="no">아니오</span></td>
                <td><span class="no">아니오</span></td>
                <td><span class="no">아니오</span></td>
                <td><span class="no">아니오</span></td>
              </tr>
              <tr>
                <td>강제 적용 라이프사이클</td>
                <td class="matrix-table__own"><span class="yes">예</span></td>
                <td><span class="no">아니오</span></td>
                <td><span class="no">아니오</span></td>
                <td><span class="no">아니오</span></td>
                <td><span class="no">아니오</span></td>
                <td><span class="no">아니오</span></td>
              </tr>
              <tr>
                <td>코드-스펙 추적성</td>
                <td class="matrix-table__own"><span class="yes">예</span></td>
                <td><span class="no">아니오</span></td>
                <td><span class="no">아니오</span></td>
                <td><span class="no">아니오</span></td>
                <td><span class="no">아니오</span></td>
                <td>재생성을 통해</td>
              </tr>
              <tr>
                <td>런타임 의존성</td>
                <td class="matrix-table__own">없음 (Go 바이너리)</td>
                <td>없음</td>
                <td>Node.js</td>
                <td>Python</td>
                <td>Claude Code</td>
                <td>벤더 컴파일러</td>
              </tr>
              <tr>
                <td>모든 에이전트, 또는 에이전트 없이도 작동</td>
                <td class="matrix-table__own"><span class="yes">예</span></td>
                <td>모든 파일을 읽음</td>
                <td>다수의 에이전트</td>
                <td>다수의 에이전트</td>
                <td>Claude Code</td>
                <td>CodeSpeak을 통해</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <ComparisonFeedback />
  </main>

  <SiteFooterKo />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-4) var(--space-3) var(--space-2);
    background: var(--cream);
  }
  .hero__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms;
  }
  .hero__headline {
    font-size: var(--fs-h3);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-1);
  }
  .hero__sub {
    font-size: 1rem;
    color: var(--mid-ink);
    line-height: 1.5;
  }

  /* Pull the mini-cards up tight under the hero */
  .minis-section {
    padding-top: var(--space-3);
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Screen-reader only ── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Mini comparison cards ── */
  .minis__lead {
    text-align: center;
    line-height: 1.05;
    margin-bottom: var(--space-3);
  }
  .minis__brand {
    display: block;
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .minis__vs {
    display: block;
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--pale-ink);
  }
  .minis {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-2);
  }
  .mini {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-top: 2px solid var(--validator-green);
    padding: var(--space-3);
    text-decoration: none;
    color: inherit;
    transition: border-color 160ms ease, box-shadow 160ms ease;
  }
  .mini:hover {
    border-color: var(--graphite);
    box-shadow: 0 2px 8px rgba(26, 26, 26, 0.06);
  }
  .mini:focus-visible {
    outline: 2px solid var(--ink-blue);
    outline-offset: 2px;
  }
  .mini__name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
  }
  .mini__line {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    line-height: 1.45;
  }

  @media (max-width: 980px) {
    .minis { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .minis { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── Section title / note (matrix) ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  .section-note {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    margin-bottom: var(--space-3);
    max-width: 60ch;
  }

  /* ── Cross-comparison matrix ── */
  .table-section { background: var(--cream-2); }
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .matrix-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-small);
    line-height: 1.5;
  }
  .matrix-table th,
  .matrix-table td {
    text-align: left;
    padding: 0.65rem 0.85rem;
    border-bottom: 1px solid var(--hairline);
    vertical-align: top;
  }
  .matrix-table thead th {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mid-ink);
    border-bottom: 2px solid var(--graphite);
    white-space: nowrap;
  }
  .matrix-table td:first-child {
    font-weight: 500;
    white-space: nowrap;
    min-width: 160px;
  }
  .matrix-table td,
  .matrix-table th {
    min-width: 130px;
  }
  /* Highlight the SpecScore column */
  .matrix-table__own {
    background: var(--surface);
    font-weight: 600;
    color: var(--ink);
    border-left: 2px solid var(--validator-green);
    border-right: 2px solid var(--validator-green);
  }
  thead .matrix-table__own {
    color: var(--validator-green);
    border-bottom-color: var(--validator-green);
  }
  /* Column-header links to each comparison */
  .matrix-table__link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px dotted var(--pale-ink);
    transition: color 160ms ease, border-color 160ms ease;
  }
  .matrix-table__link:hover {
    color: var(--validator-green);
    border-bottom-color: var(--validator-green);
  }
  .matrix-table__link:focus-visible {
    outline: 2px solid var(--ink-blue);
    outline-offset: 2px;
  }
  .matrix-table .yes {
    color: var(--validator-green);
    font-weight: 600;
  }
  .matrix-table .no {
    color: var(--pale-ink);
  }
</style>
