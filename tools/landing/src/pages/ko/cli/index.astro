---
// SpecScore CLI — product page (KO).
// Open-source linter for SpecScore specifications.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import HeroGitHubLink from '../../../components/HeroGitHubLink.astro';
---

<BaseLayout
  lang="ko"
  title="SpecScore CLI — 코드를 린트하듯 명세를 린트하세요."
  description="SpecScore 명세를 위한 오픈소스 린터. 커맨드라인 또는 CI 파이프라인에서 기능, 요구사항, 인수 기준을 검증합니다. 계정 불필요, 텔레메트리 없음."
  canonical="https://specscore.md/ko/cli/"
>
  <SiteHeader />

  <main>
    {/* ── 히어로 ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <h1 id="hero-title" class="hero__headline">
          명세를 린트하세요,<br />코드를 린트하듯이.
        </h1>
        <div class="hero__copy">
          <p class="hero__sub">
            SpecScore CLI는 커맨드라인에서 기능, 요구사항, 인수 기준을
            검증합니다. 로컬에서 실행하고, CI에 통합하고, AI 에이전트가
            호출하도록 하세요. 오픈소스, 계정 불필요, 텔레메트리 없음.
          </p>
          <HeroGitHubLink repo="specscore/specscore-cli" label="GitHub 오픈소스" />
          <div class="hero__cta">
            <a href="/ko/cli/install/" class="btn btn--primary">설치하기</a>
          </div>        </div>

        <div
          class="hero__art"
          role="img"
          aria-label="specscore lint 터미널 출력: R1과 R2는 녹색 체크로 통과, R3은 빨간색 표시와 오류 메시지로 실패."
        >
<pre class="terminal terminal--window"><span class="prompt">$</span> specscore lint checkout/apply-discount.md

  checkout/apply-discount.md
    <span class="mark-pass">✓</span> R1  Single-code limit
    <span class="mark-pass">✓</span> R2  Code validity
    <span class="mark-fail">✗</span> R3  Discount application
         <span class="dim">AC-3:18</span>  ambiguous AC — "higher-of rule" doesn't specify the tiebreaker
                  <span class="dim">expected:</span> concrete tie-break behavior, or reference to a defined rule
                  <span class="dim">fix:</span>      specify "higher discount wins; if tied, site-wide promotion wins"

  <span class="dim">1 of 3 requirements failing</span>
  <span class="dim">exit 1</span></pre>
        </div>
      </div>
    </section>

    {/* ── 빠른 설치 ── */}
    <section class="section" id="install" aria-labelledby="install-title">
      <div class="section-inner">
        <h2 id="install-title" class="section-title">60초 만에 설치.</h2>

        <div class="qs-tabs" role="tablist" aria-label="운영체제별 설치 명령">
          <button type="button" role="tab" id="qs-tab-unix" aria-controls="qs-panel-unix" aria-selected="true" tabindex="0" class="qs-tab is-active" data-tab="unix">Linux / macOS</button>
          <button type="button" role="tab" id="qs-tab-win" aria-controls="qs-panel-win" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="win">Windows</button>
          <button type="button" role="tab" id="qs-tab-brew" aria-controls="qs-panel-brew" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="brew">Homebrew</button>
        </div>

        <div id="qs-panel-unix" role="tabpanel" aria-labelledby="qs-tab-unix" class="qs-panel is-active" data-panel="unix">
<pre class="terminal"><span class="prompt">$</span> curl -fsSL https://specscore.md/install/get-cli | sh</pre>
        </div>
        <div id="qs-panel-win" role="tabpanel" aria-labelledby="qs-tab-win" class="qs-panel" data-panel="win" hidden>
<pre class="terminal"><span class="prompt">PS&gt;</span> powershell -c "irm https://specscore.md/install/get-cli.ps1 | iex"</pre>
        </div>
        <div id="qs-panel-brew" role="tabpanel" aria-labelledby="qs-tab-brew" class="qs-panel" data-panel="brew" hidden>
<pre class="terminal"><span class="prompt">$</span> brew install specscore/tap/specscore</pre>
        </div>

        <p class="qs-more">
          <a class="xref" href="/ko/cli/install/">모든 설치 방법 →</a>
        </p>
      </div>
    </section>

    {/* ── 포함된 것 ── */}
    <section class="section features-section" aria-labelledby="features-title">
      <div class="section-inner">
        <h2 id="features-title" class="section-title">제공하는 것.</h2>

        <div class="features-grid">
          <div class="feature-card">
            <h3 class="feature-card__title">Lint</h3>
            <p class="feature-card__desc">
              구조, 메타데이터, 교차 참조, AC 고유성을 검증합니다.
              각 요구사항에 대한 pass/fail 리포트와 수정 제안.
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">Score</h3>
            <p class="feature-card__desc">
              0-100 척도의 명세 완전성 점수. 누락된 액터, 트리거,
              오류 상태, 보안 모델, 제한 사항을 찾습니다.
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">CI 지원</h3>
            <p class="feature-card__desc">
              오류 시 0이 아닌 종료 코드. <code>specscore lint</code>를
              ESLint, Prettier, 테스트와 함께 CI 파이프라인에 통합하세요.
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">텔레메트리 없음</h3>
            <p class="feature-card__desc">
              CLI는 외부로 데이터를 전송하지 않습니다. 명세와 점수는 로컬
              머신에 유지됩니다. 계정 없음, API 키 없음, 클라우드 의존성 없음.
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">이식성</h3>
            <p class="feature-card__desc">
              단일 바이너리. macOS, Linux, Windows. 의존성 없음.
              Markdown 명세가 있는 모든 디렉토리에서 작동합니다.
            </p>
          </div>

          <div class="feature-card">
            <h3 class="feature-card__title">오픈소스</h3>
            <p class="feature-card__desc">
              MIT 라이선스. 소스는
              <a class="xref" href="https://github.com/specscore/specscore-cli">specscore/specscore-cli</a>에
              있습니다. 영구 무료.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── AI 에이전트와 함께 사용 ── */}
    <section class="section" aria-labelledby="agents-title">
      <div class="section-inner section-inner--prose">
        <h2 id="agents-title" class="section-title">AI 에이전트와 함께 사용하세요.</h2>
        <p class="prose-p">
          CLI는 두 Claude Code 플러그인의 엔진입니다. 에이전트가 명세를
          작성한다면, CLI가 코드 한 줄 쓰기 전에 명세의 품질을 알려줍니다.
        </p>
        <div class="agent-links">
          <a href="/ko/ai/specstudio-skills/" class="btn btn--secondary">SpecStudio Skills</a>
          <a href="/ko/ai/cli-skills/" class="btn btn--tertiary">CLI Skills (얇은 래퍼)</a>
        </div>
      </div>
    </section>
  </main>

  {/* ── 최종 CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">통과하는 명세.</h2>
      <div class="final-cta__buttons">
        <a href="/ko/cli/install/" class="btn btn--primary">CLI 설치하기</a>
        <a href="/ko/ai/specstudio-skills/" class="btn btn--secondary">AI 에이전트용 스킬</a>
        <a
          href="https://github.com/specscore/specscore-cli"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          GitHub 오픈소스
        </a>
      </div>
    </div>
  </section>

  {/* ── 푸터 ── */}
  <footer class="page-footer">
    <div class="page-footer__inner">
      <div class="page-footer__col page-footer__brand">
        <a href="/ko/" class="wordmark" aria-label="SpecScore 홈">
          <span class="wordmark__clef" aria-hidden="true">&#x1D11E;</span>
          <span class="wordmark__name">SpecScore.md</span>
        </a>
        <p class="page-footer__tagline">
          명세, 요구사항, 인수 기준을 위한 오픈 표준.
        </p>
        <p class="page-footer__copyright">
          &copy; 2026 SpecScore contributors. MIT license.
        </p>
      </div>

      <div class="page-footer__col">
        <h4 class="page-footer__heading">SpecScore CLI</h4>
        <ul class="page-footer__list">
          <li><a href="/ko/cli/install/">설치</a></li>
          <li><a href="https://github.com/specscore/specscore-cli">GitHub</a></li>
          <li><a href="https://github.com/specscore/specscore-cli/releases">릴리스</a></li>
        </ul>
      </div>

      <div class="page-footer__col">
        <h4 class="page-footer__heading">에코시스템</h4>
        <ul class="page-footer__list">
          <li><a href="https://specscore.md">SpecScore</a> — 오픈 표준</li>
          <li><a href="/ko/ai/specstudio-skills/">SpecStudio Skills</a> — Claude Code 플러그인</li>
          <li><a href="https://specscore.studio">SpecScore Studio</a> — 웹 뷰어</li>
        </ul>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ── Hero: two-column on desktop (copy left, terminal right),
        stacked on mobile. Mirrors the landing hero's rhythm. ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-7);
    background: var(--cream);
    overflow: hidden;
  }
  .hero__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 30fr 70fr;
    gap: var(--space-3) var(--space-6);
    align-items: center;
  }
  .hero__copy {
    animation: hero-copy-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 280ms;
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__inner > .hero__headline {
    grid-column: 1 / -1;
    margin-bottom: 0;
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    line-height: 1.55;
    max-width: 42ch;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .hero__art {
    animation: hero-art-in 700ms cubic-bezier(0.22, 0.61, 0.36, 1) both 100ms;
    min-width: 0;
  }
  .hero__art pre.terminal {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.65;
  }

  @keyframes hero-copy-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-art-in {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 860px) {
    .hero { padding: var(--space-5) var(--space-3) var(--space-6); }
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .hero__copy { order: 1; }
    .hero__art  { order: 2; }
  }

  /* ── Section titles ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  .section-intro {
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    line-height: 1.6;
  }
  .section-intro code {
    background: var(--cream-2);
    padding: 0.05em 0.35em;
    border-radius: 2px;
    font-size: 0.92em;
    color: var(--ink);
  }

  /* ── Tabbed install ── */
  .qs-tabs {
    display: inline-flex;
    gap: 0;
    border-bottom: 1px solid var(--hairline);
    margin-bottom: 0;
  }
  .qs-tab {
    background: transparent;
    border: none;
    padding: 0.55rem 0.95rem;
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--mid-ink);
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    cursor: pointer;
    transition: color 120ms ease, border-color 120ms ease;
  }
  .qs-tab:hover { color: var(--ink); }
  .qs-tab.is-active {
    color: var(--ink);
    border-bottom-color: var(--validator-green);
  }
  .qs-tab:focus-visible {
    outline: 2px solid var(--ink-blue);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .qs-panel { margin-top: 0; }
  .qs-panel pre { border-top-width: 0; }
  .qs-more {
    margin-top: var(--space-3);
    font-size: var(--fs-small);
    color: var(--mid-ink);
  }

  /* ── Features grid ── */
  .features-section { background: var(--cream-2); }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .feature-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
  }
  .feature-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .feature-card__desc {
    font-size: var(--fs-small);
    color: var(--mid-ink);
    line-height: 1.55;
  }
  .feature-card__desc code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  @media (max-width: 860px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .features-grid { grid-template-columns: 1fr; }
  }

  /* ── AI agents section ── */
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
    margin-bottom: var(--space-3);
  }
  .agent-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: var(--space-3);
  }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    text-align: center;
  }
  .final-cta__title {
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .final-cta__buttons {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  /* ── Footer ── */
  .page-footer {
    background: var(--cream);
    padding: var(--space-6) var(--space-3) var(--space-5);
  }
  .page-footer__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-4);
  }
  .page-footer__brand .wordmark { margin-bottom: var(--space-2); }
  .page-footer__tagline { color: var(--mid-ink); margin-bottom: var(--space-2); max-width: 36ch; line-height: 1.5; font-size: 0.95rem; }
  .page-footer__copyright { color: var(--pale-ink); font-size: 0.825rem; font-family: var(--font-code); }
  .page-footer__heading { font-family: var(--font-display); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--mid-ink); margin-bottom: var(--space-2); }
  .page-footer__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.4rem; }
  .page-footer__list a { color: var(--ink); font-size: 0.9rem; border-bottom: 1px solid transparent; transition: border-color 120ms ease; }
  .page-footer__list a:hover { border-bottom-color: var(--ink); }
  .page-footer__list a:focus-visible { outline: 2px solid var(--ink-blue); outline-offset: 2px; border-radius: 2px; }

  @media (max-width: 800px) {
    .page-footer__inner { grid-template-columns: 1fr 1fr; }
    .page-footer__brand { grid-column: 1 / -1; }
  }
</style>

<script is:inline>
  (function () {
    var tabs = document.querySelectorAll('.qs-tab');
    var panels = document.querySelectorAll('.qs-panel');
    if (!tabs.length) return;

    function activate(name, focus) {
      tabs.forEach(function (t) {
        var on = t.getAttribute('data-tab') === name;
        t.classList.toggle('is-active', on);
        t.setAttribute('aria-selected', on ? 'true' : 'false');
        t.setAttribute('tabindex', on ? '0' : '-1');
        if (on && focus) t.focus();
      });
      panels.forEach(function (p) {
        var on = p.getAttribute('data-panel') === name;
        p.classList.toggle('is-active', on);
        if (on) p.removeAttribute('hidden');
        else p.setAttribute('hidden', '');
      });
    }

    try {
      if (/Windows/i.test(navigator.userAgent)) activate('win', false);
    } catch (e) { /* ignore */ }

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        activate(tab.getAttribute('data-tab'), false);
      });
      tab.addEventListener('keydown', function (ev) {
        var key = ev.key;
        if (key !== 'ArrowRight' && key !== 'ArrowLeft' &&
            key !== 'Home' && key !== 'End') return;
        ev.preventDefault();
        var i = Array.prototype.indexOf.call(tabs, ev.currentTarget);
        var next;
        if (key === 'ArrowRight') next = (i + 1) % tabs.length;
        else if (key === 'ArrowLeft') next = (i - 1 + tabs.length) % tabs.length;
        else if (key === 'Home') next = 0;
        else next = tabs.length - 1;
        activate(tabs[next].getAttribute('data-tab'), true);
      });
    });
  })();
</script>
