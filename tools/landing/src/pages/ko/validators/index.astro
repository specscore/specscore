---
// Korean variant of /validators.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import LintExample from '../../../components/LintExample.astro';
import ScoreExample from '../../../components/ScoreExample.astro';
---

<BaseLayout
  lang="ko"
  title="SpecScore가 검증하는 것 — 그리고 검증할 수 없는 것."
  description="SpecScore는 두 가지 검증기로 명세를 점검합니다: 결정적 린터와 AI 리뷰어. 각각이 정확히 무엇을 잡아내는지, 그리고 자동 검증이 멈추고 여러분의 판단이 시작되는 지점이 어디인지 확인하세요."
  canonical="https://specscore.md/ko/validators/"
>
  <SiteHeader />

  <main>
    {/* ── Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <h1 id="hero-title" class="hero__headline">
          SpecScore가<br />검증하는 것.
        </h1>
        <div class="hero__copy">
          <p class="hero__sub">
            SpecScore는 기능, 요구사항, 인수 기준을 위한 오픈 Markdown
            포맷이며, 두 가지 검증기가 점검합니다: 결정적
            <strong>린터</strong>와 <strong>AI 리뷰어</strong>. 각각이 무엇을
            잡아내는지, 그리고 자동 점검이 어디서 멈추는지 살펴보세요.
          </p>
          <p class="hero__context">
            SpecScore가 처음이신가요? <a class="xref" href="/ko/">여기서 시작하세요</a> ·
            <a class="xref" href="/ko/cli/">CLI</a> ·
            <a class="xref" href="/ko/ai/">AI 스킬</a>
          </p>
        </div>

        <div
          class="hero__art"
          role="img"
          aria-label="터미널 출력: checkout 명세에 대한 specscore lint가 24개 요구사항을 모두 통과합니다 — 구조, 참조, ID가 유효하고, 인덱스 드리프트나 끊어진 링크가 없습니다. 0개 문제, exit 0."
        >
<pre class="terminal terminal--window"><span class="prompt">$</span> specscore lint checkout/

  <span class="mark-pass">✓</span> 24 requirements — structure, references, IDs valid
  <span class="mark-pass">✓</span> no index drift · no broken links · no slug collisions

  <span class="dim">0 problems   exit 0</span></pre>
        </div>
      </div>
    </section>

    {/* ── 세 개의 레이어 ── */}
    <section class="section" aria-labelledby="layers-title">
      <div class="section-inner section-inner--prose">
        <h2 id="layers-title" class="section-title">하나가 아니라 세 개의 레이어.</h2>
        <p class="prose-p">
          SpecScore는 가장 저렴하고 가장 확실한 것부터 차례대로, 레이어로
          검증합니다. <strong>린터</strong>는 결정적입니다 — 빠르고, 무료이며,
          모든 커밋에서 실행됩니다. <strong>AI 리뷰</strong>는 확률적입니다 —
          더 깊이 들여다보고, 토큰을 소모하며, 린터가 닿지 못하는 것을
          잡아냅니다. <strong>사람의 판단</strong>이 세 번째 레이어입니다: 앞의
          두 레이어가 메우지 못하는 틈은 여전히 사람이 필요합니다 — 오늘날 어떤
          도구도 그것을 안정적으로 메울 수 없기 때문입니다. 두 자동 레이어는
          중복이 아니라 상호 보완적입니다: 린터는 AI가 근거를 댈 수 없는 것을
          잡고, AI는 린터가 닿지 못하는 것을 잡습니다.
        </p>
      </div>
    </section>

    {/* ── 각 검증기가 점검하는 것 ── */}
    <section class="section validators-section" aria-labelledby="checks-title">
      <div class="section-inner">
        <h2 id="checks-title" class="section-title">각 검증기가 점검하는 것.</h2>
        <div class="vcols">
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">레이어 1</span>
              <h3 class="validator__title">CLI 린터</h3>
              <span class="validator__kind">결정적</span>
            </div>
            <p class="validator__lead">
              실행할 때마다 같은 결과, LLM 없이, 비용 없이. 여기서 통과하면
              그것은 의견이 아니라 사실입니다.
            </p>
            <div
              class="checks-terminal"
              role="img"
              aria-label="specscore lint 출력: R1과 R2에는 인수 기준이 있습니다. R3에는 없고, Related Feature 링크가 해석되지 않으며, 필수 Open Questions 섹션이 누락되었습니다. 3개 문제, exit 1."
            >
              <LintExample />
            </div>
            <ul class="vlist">
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 참조 무결성 — 링크가 해석되고, ID가 고유함</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 구조적 규약 — 필수 섹션, frontmatter 형식</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 상태 위생과 인덱스 드리프트</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> Slug 충돌</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 메타데이터 필드의 접두사 유효성 (예: <code>Related Ideas:</code>)</li>
            </ul>
          </div>
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">레이어 2</span>
              <h3 class="validator__title">AI 리뷰 &amp; 스코어</h3>
              <span class="validator__kind">비결정적</span>
            </div>
            <p class="validator__lead">
              사람 리뷰어처럼 의미를 읽어냅니다 — 그리고 사람과 마찬가지로
              완벽하게 재현되지는 않습니다.
            </p>
            <div
              class="checks-terminal"
              role="img"
              aria-label="/score 출력: 명세는 두 가지 실행 가능한 지적과 함께 B 등급을 받습니다 — AC-2의 모호한 트리거와 AC-3의 누락된 오류 경로."
            >
              <ScoreExample />
            </div>
            <ul class="vlist">
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 검증 가능한 Given/When/Then 형식의 인수 기준</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 아티팩트 내부의 일관성</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 모호하거나 자리표시자에 불과한 내용</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 사람 리뷰어를 위한 가독성</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> 작성자가 바로 손볼 수 있는, 심각도가 표시된 피드백</li>
              <li><span class="mark mark--pass" aria-hidden="true">✓</span> A–F 준비도 등급</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── #limits — 잡아내지 못하는 것 ── */}
    <section class="section limits-section" id="limits" aria-labelledby="limits-title">
      <div class="section-inner">
        <h2 id="limits-title" class="section-title">잡아내지 못하는 것.</h2>
        <p class="section-lead">
          어떤 검증기도 마법이 아닙니다. 각각이 어디서 멈추는지 — 여러분 자신의
          판단이 여전히 일을 해야 하는 지점이 정확히 어디인지 — 여기 적어
          두었습니다.
        </p>
        <div class="vcols">
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">레이어 1</span>
              <h3 class="validator__title">CLI 린터</h3>
            </div>
            <ul class="vlist">
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 깊은 계층 구조에 걸친 암묵적 모순</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 명세와 코드 사이의 드리프트 <span class="vnote">(<code>specstudio:recap</code>이 나오면서 개선 중)</span></li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 인수 기준의 의미적 정확성</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 이름이 실제로 말이 되는지 여부</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 요구사항이 명시된 문제를 푸는지 여부</li>
            </ul>
          </div>
          <div class="vcol">
            <div class="validator__head">
              <span class="validator__layer">레이어 2</span>
              <h3 class="validator__title">AI 리뷰 &amp; 스코어</h3>
              <span class="validator__kind">일관되지 않게 잡아냄</span>
            </div>
            <ul class="vlist">
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 실행 간 완전한 재현성 — 판정은 허용 범위 안에서 흔들릴 수 있음</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 명시적인 교차 점검 없이 큰 트리 전체에 걸친 아티팩트 간 모순</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 요구사항이 문제를 정말로 푸는지 — 명백한 공백은 표시하지만 도메인 특화된 공백은 놓침</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 기반 LLM에서 물려받은 편향</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 절대적 확신을 동반한 의미적 정확성</li>
              <li><span class="mark mark--fail" aria-hidden="true">✗</span> 루브릭이 가중치를 두지 않는 모든 것</li>
            </ul>
          </div>
        </div>

        <ol class="bands" aria-label="검증의 세 레이어, 도달 범위 순서대로">
          <li class="band">
            <span class="band__step">1</span>
            <h3 class="band__title">린터는 여기까지 닿습니다</h3>
            <p class="band__desc">
              구조, 참조, 위생. 저렴하고 확실하지만 — 의미에는 눈을 감고 있습니다.
            </p>
          </li>
          <li class="band band--mid">
            <span class="band__step">2</span>
            <h3 class="band__title">AI는 여기까지 닿습니다</h3>
            <p class="band__desc">
              아티팩트 내부의 의미, 명료성, 일관성. 더 깊지만 — 확률적이고, 큰
              트리 전체에서는 약합니다.
            </p>
          </li>
          <li class="band band--human">
            <span class="band__step">3</span>
            <h3 class="band__title">여전히 여러분의 몫</h3>
            <p class="band__desc">
              시스템 전체를 가로지르는 판단. 오늘날 어떤 도구도 이를 안정적으로
              해낼 수 없기에 — 여전히 사람 리뷰어가 필요합니다. 이것은 게으름이
              아니라 오늘의 한계를 솔직히 그은 선입니다.
            </p>
          </li>
        </ol>

        <div class="worked">
          <h3 class="worked__title">어느 도구도 여러분을 구해 주지 못하는 경우</h3>
          <p class="worked__body">
            실제로 깊은 명세 트리를 떠올려 보세요. 기능&nbsp;A는 <em>X</em>를
            요구합니다. 기능&nbsp;B는 <em>Y</em>를 요구합니다. 기능&nbsp;C는
            <em>Z</em>를 요구합니다. 그런데 기능&nbsp;D가 슬며시 B와 모순되는
            무언가를 요구합니다 — 하지만 오직 A도 함께 활성화되어 있을 때만요.
            린터는 잘 연결된 유효한 네 개의 문서를 보고 통과시킵니다. AI
            리뷰어는 아티팩트를 하나씩 읽기 때문에, 네 개를 모두 불러와 이
            세 갈래의 상호작용을 알아챌 이유가 없습니다.
          </p>
          <p class="worked__body">
            <strong>어느 레이어도 이를 안정적으로 잡아내지 못합니다 — 그리고
            우리는 그렇지 않은 척하지 않겠습니다.</strong> 바로 이런 종류의
            모순이 세 번째 레이어가 존재하는 이유입니다. SpecScore의 역할은
            도구가 이미 그것을 찾아냈다고 주장하는 것이 아니라, 틈을 살피는
            사람이 충돌을 <em>찾아낼</em> 수 있을 만큼 트리를 탐색 가능하게
            만드는 것입니다 — 미해결 질문은 계층을 따라 위로 전파되고, 관련
            요구사항은 쿼리 한 번 거리에 있습니다.
          </p>
        </div>
      </div>
    </section>
  </main>

  {/* ── Final CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">솔직한 도구, 솔직한 명세.</h2>
      <div class="final-cta__buttons">
        <a href="/ko/cli/install/" class="btn btn--primary">CLI 설치하기</a>
        <a href="/ko/ai/specstudio-skills/" class="btn btn--secondary">에이전트용 AI 스킬 받기</a>
        <a
          href="https://github.com/specscore/specscore-cli"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          GitHub에서 오픈소스로 공개
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <footer class="page-footer">
    <div class="page-footer__inner">
      <div class="page-footer__col page-footer__brand">
        <a href="/ko/" class="wordmark" aria-label="SpecScore 홈">
          <span class="wordmark__clef" aria-hidden="true">&#x1D11E;</span>
          <span class="wordmark__name">SpecScore.md</span>
        </a>
        <p class="page-footer__tagline">
          사양, 요구사항, 인수 기준을 위한 오픈 표준.
        </p>
        <p class="page-footer__copyright">
          &copy; 2026 SpecScore contributors. MIT license.
        </p>
      </div>

      <div class="page-footer__col">
        <h4 class="page-footer__heading">SpecScore CLI</h4>
        <ul class="page-footer__list">
          <li><a href="/ko/cli/">개요</a></li>
          <li><a href="/ko/cli/install/">설치</a></li>
          <li><a href="https://github.com/specscore/specscore-cli">GitHub</a></li>
        </ul>
      </div>

      <div class="page-footer__col">
        <h4 class="page-footer__heading">생태계</h4>
        <ul class="page-footer__list">
          <li><a href="/ko/">SpecScore</a> — 오픈 표준</li>
          <li><a href="/ko/ai/specstudio-skills/">SpecStudio Skills</a> — Claude Code 플러그인</li>
          <li><a href="https://specscore.studio">SpecScore Studio</a> — 웹 뷰어</li>
        </ul>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ── Hero (mirrors /cli two-column rhythm) ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-7);
    background: var(--cream);
    overflow: hidden;
  }
  .hero__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 38fr 62fr;
    gap: var(--space-3) var(--space-6);
    align-items: center;
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
  }
  .hero__inner > .hero__headline {
    grid-column: 1 / -1;
    margin-bottom: 0;
  }
  .hero__copy {
    animation: hero-copy-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 280ms;
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
    max-width: 52ch;
  }
  .hero__sub strong { color: var(--ink); }
  .hero__context {
    margin-top: var(--space-3);
    font-size: var(--fs-small);
    color: var(--pale-ink);
  }
  .hero__art {
    animation: hero-art-in 700ms cubic-bezier(0.22, 0.61, 0.36, 1) both 100ms;
    min-width: 0;
  }
  .hero__art pre.terminal {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.65;
  }

  @keyframes hero-copy-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes hero-art-in {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 860px) {
    .hero { padding: var(--space-5) var(--space-3) var(--space-6); }
    .hero__inner { grid-template-columns: 1fr; gap: var(--space-4); }
    .hero__copy { order: 1; }
    .hero__art  { order: 2; }
  }

  /* ── Section scaffolding ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  .section-lead {
    color: var(--mid-ink);
    line-height: 1.6;
    max-width: 60ch;
    margin-bottom: var(--space-4);
  }
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
  }
  .prose-p strong { color: var(--ink); }

  /* ── Validator columns (used by both "checks" and "#limits") ── */
  .validators-section { background: var(--cream); }
  .limits-section {
    background: var(--cream-2);
    scroll-margin-top: var(--space-5);
  }

  .validator__head {
    display: flex;
