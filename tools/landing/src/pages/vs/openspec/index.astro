---
// /vs/openspec/ — SpecScore vs OpenSpec comparison.
// Honest, factual, side-by-side. Credits OpenSpec's real strengths,
// then shows where SpecScore goes further.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
---

<BaseLayout
  title="SpecScore vs OpenSpec — Honest comparison."
  description="A factual, side-by-side comparison of SpecScore and OpenSpec: spec format, linting, lifecycle, traceability, CLI, and agent support. Honest about both."
  canonical="https://specscore.md/vs/openspec/"
>
  <SiteHeader />

  <main>
    {/* ── Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <p class="hero__breadcrumb"><a href="/vs/" class="xref">Comparisons</a></p>
        <h1 id="hero-title" class="hero__headline">
          SpecScore vs OpenSpec
        </h1>
        <p class="hero__sub">
          Both put specifications in Markdown, next to your code, readable by AI agents.
          They answer different questions: OpenSpec organizes specs and generates agent
          commands. SpecScore lints spec content, enforces lifecycle, and traces code
          back to requirements.
        </p>
      </div>
    </section>

    {/* ── What they share ── */}
    <section class="section" aria-labelledby="shared-title">
      <div class="section-inner section-inner--prose">
        <h2 id="shared-title" class="section-title">What they share.</h2>
        <ul class="shared-list">
          <li>Specs live in your repo as Markdown files — version-controlled, PR-reviewable.</li>
          <li>Both are open source under the MIT license.</li>
          <li>Both use Given/When/Then acceptance criteria.</li>
          <li>Both support AI coding agents as first-class consumers of specs.</li>
        </ul>
      </div>
    </section>

    {/* ── What OpenSpec does well ── */}
    <section class="section" aria-labelledby="openspec-title">
      <div class="section-inner section-inner--prose">
        <h2 id="openspec-title" class="section-title">What OpenSpec does well.</h2>
        <p class="section-note">
          <a href="https://openspec.dev/" rel="nofollow noopener" target="_blank" class="xref">OpenSpec</a>
          (<a href="https://github.com/fission-ai/openspec" rel="nofollow noopener" target="_blank" class="xref">GitHub</a>)
          is a spec-driven development framework by Fission AI.
        </p>

        <div class="credit-card">
          <h3 class="credit-card__title">Broadest agent support</h3>
          <p class="credit-card__desc">
            OpenSpec supports 29 AI coding agents via generated skill files — Claude,
            Cursor, Copilot, Gemini, Windsurf, Cline, and more. If your agent is on the
            list, OpenSpec integrates with zero configuration.
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">Low barrier to entry</h3>
          <p class="credit-card__desc">
            <code>npm install -g @fission-ai/openspec &amp;&amp; openspec init</code> and
            you're writing specs. No schema to learn, no required frontmatter. Designed
            to feel effortless — especially for brownfield codebases.
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">Clean change-delta model</h3>
          <p class="credit-card__desc">
            OpenSpec's <code>ADDED / MODIFIED / REMOVED</code> format for evolving specs
            is well-designed. Each change is a folder with a proposal, delta specs, and
            tasks — a structured way to propose modifications.
          </p>
        </div>
      </div>
    </section>

    {/* ── Feature comparison table ── */}
    <section class="section table-section" aria-labelledby="table-title">
      <div class="section-inner">
        <h2 id="table-title" class="section-title">Feature comparison.</h2>

        <div class="table-wrap">
          <table class="compare-table" aria-label="SpecScore vs OpenSpec feature comparison">
            <thead>
              <tr>
                <th scope="col">Capability</th>
                <th scope="col">OpenSpec</th>
                <th scope="col">SpecScore</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Spec format</td>
                <td>Markdown (no frontmatter)</td>
                <td>Markdown + YAML frontmatter</td>
              </tr>
              <tr>
                <td>Spec linting</td>
                <td>File structure only</td>
                <td><strong>Content quality</strong> — vague verbs, missing ACs, dangling refs</td>
              </tr>
              <tr>
                <td>Requirement IDs</td>
                <td>None (referenced by title)</td>
                <td><strong>Slug-based</strong> (<code>REQ: slug-format</code>)</td>
              </tr>
              <tr>
                <td>Acceptance criteria IDs</td>
                <td>None</td>
                <td><strong>Machine-addressable IDs</strong></td>
              </tr>
              <tr>
                <td>Lifecycle status</td>
                <td>Implicit (file location)</td>
                <td><strong>Enforced</strong> — Draft → Under Review → Approved → Implementing → Stable → Deprecated</td>
              </tr>
              <tr>
                <td>Code-to-spec traceability</td>
                <td>None</td>
                <td><strong><code>specscore:</code> annotations</strong> + <code>Verifies:</code> commit trailers</td>
              </tr>
              <tr>
                <td>Sub-features</td>
                <td>No</td>
                <td><strong>Yes</strong> (nested directories)</td>
              </tr>
              <tr>
                <td>Cross-references</td>
                <td>No formal mechanism</td>
                <td><strong>Dependencies, Source Ideas, plan references</strong></td>
              </tr>
              <tr>
                <td>CI integration</td>
                <td>Basic (<code>openspec validate</code>)</td>
                <td><strong><code>specscore lint</code></strong> with configurable severity, pre-commit hooks</td>
              </tr>
              <tr>
                <td>Agent support</td>
                <td><strong>29 agents</strong></td>
                <td>Claude Code primary + CLI for any agent</td>
              </tr>
              <tr>
                <td>Schema customization</td>
                <td><strong>Yes</strong> (<code>schema.yaml</code>, fork/init)</td>
                <td>Fixed schema (consistency by design)</td>
              </tr>
              <tr>
                <td>Change proposals</td>
                <td><strong>Delta model</strong> (ADDED/MODIFIED/REMOVED)</td>
                <td>Change-request ideas + proposals</td>
              </tr>
              <tr>
                <td>Runtime dependency</td>
                <td>Node.js 20.19+</td>
                <td><strong>None</strong> — single Go binary</td>
              </tr>
              <tr>
                <td>License</td>
                <td>MIT</td>
                <td>MIT</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {/* ── Where SpecScore goes further ── */}
    <section class="section" aria-labelledby="further-title">
      <div class="section-inner">
        <h2 id="further-title" class="section-title">Where SpecScore goes further.</h2>

        <div class="diff-grid">
          <div class="diff-card">
            <h3 class="diff-card__title">Spec linting catches ambiguity before agents do</h3>
            <p class="diff-card__desc">
              OpenSpec's <code>validate</code> checks file structure — does the file
              exist, does it have the right sections. SpecScore's <code>lint</code>
              checks content: vague verbs without object/condition, missing acceptance
              criteria, dangling cross-references, mismatched status transitions.
            </p>
            <div class="diff-card__example">
<pre class="terminal"><span class="prompt">$</span> specscore lint checkout/apply-discount.md
  <span class="mark-fail">✗</span> R3  Discount application
       <span class="dim">AC-3:18</span>  ambiguous AC — "higher-of rule" doesn't specify the tiebreaker
                <span class="dim">fix:</span> specify "higher discount wins; if tied, site-wide wins"</pre>
            </div>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Every requirement has a machine-readable ID</h3>
            <p class="diff-card__desc">
              OpenSpec references requirements by title — fragile to renames.
              SpecScore assigns slug-based IDs (<code>REQ: slug-format</code>) and
              AC IDs that survive renames, refactors, and agent handoffs.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Lifecycle is enforced, not implied</h3>
            <p class="diff-card__desc">
              In OpenSpec, a spec's lifecycle is its file location: <code>specs/</code>
              (current), <code>changes/</code> (proposed), <code>archive/</code> (done).
              In SpecScore, lifecycle is an enforced status field — Draft → Under Review
              → Approved → Implementing → Stable → Deprecated — validated by lint,
              transitioned by <code>specscore change-status</code> from git hooks or CI.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Code traces back to specs</h3>
            <p class="diff-card__desc">
              OpenSpec has no traceability mechanism. SpecScore has <code>specscore:</code>
              source annotations in code comments and <code>Verifies:</code> commit
              trailers. Run <code>specscore code refs</code> and get a deterministic
              answer to "which code implements this requirement?"
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">No runtime dependency</h3>
            <p class="diff-card__desc">
              OpenSpec requires Node.js 20.19+. SpecScore is a single Go binary —
              no runtime, no <code>node_modules</code>. Works in Go, Rust, Python,
              Java projects without adding Node to the toolchain.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Composable artifact hierarchy</h3>
            <p class="diff-card__desc">
              OpenSpec specs are flat by domain. SpecScore has a typed hierarchy:
              Ideas promote to Features, Features contain Requirements and ACs,
              Plans reference ACs, Tasks reference Plans. All relationships are
              machine-navigable via the CLI.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── When to use which ── */}
    <section class="section" aria-labelledby="when-title">
      <div class="section-inner">
        <h2 id="when-title" class="section-title">When to use which.</h2>

        <div class="when-grid">
          <div class="when-card">
            <h3 class="when-card__title">Start with OpenSpec when…</h3>
            <ul class="when-card__list">
              <li>You use Cursor, Copilot, or non-Claude agents and need out-of-the-box integration.</li>
              <li>You're adding specs to an existing codebase for the first time and want zero friction.</li>
              <li>Your team values schema flexibility over enforcement.</li>
            </ul>
          </div>

          <div class="when-card when-card--primary">
            <h3 class="when-card__title">Use SpecScore when…</h3>
            <ul class="when-card__list">
              <li>You need spec quality enforcement — lint catches ambiguity before agents waste tokens on it.</li>
              <li>You need code-to-spec traceability — "which code implements this requirement?" returns a deterministic answer.</li>
              <li>You're building a large system with many features, sub-features, and lifecycle transitions.</li>
              <li>You want zero runtime dependencies — one binary, no Node.js required.</li>
              <li>You need spec quality gates in CI — <code>specscore lint</code> exits non-zero on failures, same as ESLint or <code>go vet</code>.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── The integration opportunity ── */}
    <section class="section" aria-labelledby="bridge-title">
      <div class="section-inner section-inner--prose">
        <h2 id="bridge-title" class="section-title">They're not mutually exclusive.</h2>
        <p class="prose-p">
          SpecScore can lint OpenSpec's <code>spec.md</code> files.
          Teams that start with OpenSpec can add SpecScore's quality layer
          without migrating — lint the specs you already have, add
          traceability when you need it, enforce lifecycle when your team
          grows.
        </p>
        <p class="prose-p">
          OpenSpec is a solid on-ramp. SpecScore is the guardrails.
        </p>
      </div>
    </section>

    {/* ── Feedback ── */}
    <section class="section feedback-section" aria-labelledby="feedback-title">
      <div class="section-inner section-inner--prose">
        <h2 id="feedback-title" class="sr-only">Feedback</h2>
        <p class="feedback-p">
          This comparison is based on publicly available documentation and source code.
          Something wrong or outdated?
          <a
            href="https://github.com/specscore/specscore/issues/new?labels=comparison%2Ccorrection&title=%5Bvs%2Fopenspec%5D+Factual+correction&body=%2A%2APage%3A%2A%2A+%2Fvs%2Fopenspec%2F%0A%2A%2ASection%3A%2A%2A+%0A%2A%2AWhat%27s+incorrect%3A%2A%2A+%0A%2A%2AWhat+it+should+say%3A%2A%2A+%0A%2A%2ASource%3A%2A%2A+"
            rel="noopener"
            class="xref"
          >Open a correction issue</a>.
          Want us to compare SpecScore with another tool?
          <a
            href="https://github.com/specscore/specscore/issues/new?labels=comparison%2Crequest&title=%5Bvs%5D+Add+comparison+with+...&body=%2A%2ATool%2Fformat+name%3A%2A%2A+%0A%2A%2AWebsite%3A%2A%2A+%0A%2A%2AWhy+compare%3A%2A%2A+"
            rel="noopener"
            class="xref"
          >Request one</a>.
        </p>
      </div>
    </section>
  </main>

  {/* ── Final CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">Specs that pass.</h2>
      <div class="final-cta__buttons">
        <a href="/cli/install/" class="btn btn--primary">Install the CLI</a>
        <a href="/ai/specstudio-skills/" class="btn btn--secondary">Get AI skills for your agent</a>
        <a
          href="https://github.com/specscore/specscore"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          Open-source on GitHub
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <footer class="page-footer">
    <div class="page-footer__inner">
      <div class="page-footer__col page-footer__brand">
        <a href="/" class="wordmark" aria-label="SpecScore home">
          <span class="wordmark__clef" aria-hidden="true">&#x1D11E;</span>
          <span class="wordmark__name">SpecScore.md</span>
        </a>
        <p class="page-footer__tagline">
          An open standard for specifications, requirements,
          and acceptance criteria.
        </p>
        <p class="page-footer__copyright">
          &copy; 2026 SpecScore contributors. MIT license.
        </p>
      </div>

      <div class="page-footer__col">
        <h4 class="page-footer__heading">Product</h4>
        <ul class="page-footer__list">
          <li><a href="/cli/">SpecScore CLI</a></li>
          <li><a href="/cli/install/">Install</a></li>
          <li><a href="https://github.com/specscore/specscore-cli">GitHub</a></li>
        </ul>
      </div>

      <div class="page-footer__col">
        <h4 class="page-footer__heading">Ecosystem</h4>
        <ul class="page-footer__list">
          <li><a href="https://specscore.md">SpecScore</a> — the open standard</li>
          <li><a href="/ai/specstudio-skills/">SpecStudio Skills</a></li>
          <li><a href="https://specscore.studio">SpecScore Studio</a> — web viewer</li>
        </ul>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-5);
    background: var(--cream);
  }
  .hero__inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms;
  }
  .hero__breadcrumb {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--pale-ink);
    margin-bottom: var(--space-2);
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
    max-width: 52ch;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Section titles ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }

  /* ── Shared list ── */
  .shared-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .shared-list li {
    position: relative;
    padding-left: 1.4rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
  }
  .shared-list li::before {
    content: '=';
    position: absolute;
    left: 0;
    font-family: var(--font-code);
    font-weight: 700;
    color: var(--pale-ink);
  }

  /* ── Section note (OpenSpec intro) ── */
  .section-note {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    margin-bottom: var(--space-3);
  }

  /* ── Credit cards (OpenSpec strengths) ── */
  .credit-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .credit-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .credit-card__desc {
    color: var(--mid-ink);
    line-height: 1.6;
    font-size: var(--fs-body);
  }
  .credit-card__desc code {
    font-size: 0.9em;
    background: var(--cream);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Feature comparison table ── */
  .table-section { background: var(--cream-2); }
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-small);
    line-height: 1.5;
  }
  .compare-table th,
  .compare-table td {
    text-align: left;
    padding: 0.65rem 0.85rem;
    border-bottom: 1px solid var(--hairline);
    vertical-align: top;
  }
  .compare-table thead th {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mid-ink);
    border-bottom: 2px solid var(--graphite);
    white-space: nowrap;
  }
  .compare-table td:first-child {
    font-weight: 500;
    white-space: nowrap;
    min-width: 160px;
  }
  .compare-table td:nth-child(2),
  .compare-table td:nth-child(3) {
    min-width: 200px;
  }
  .compare-table td code {
    font-size: 0.88em;
    background: var(--surface);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .compare-table strong {
    font-weight: 600;
    color: var(--ink);
  }

  /* ── Diff grid (SpecScore advantages) ── */
  .diff-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .diff-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
  }
  .diff-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .diff-card__desc {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    line-height: 1.6;
  }
  .diff-card__desc code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .diff-card__example {
    margin-top: var(--space-2);
  }
  .diff-card__example .terminal {
    font-size: 0.78rem;
    line-height: 1.6;
  }

  @media (max-width: 860px) {
    .diff-grid { grid-template-columns: 1fr; }
  }

  /* ── When to use which ── */
  .when-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .when-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-4);
  }
  .when-card--primary {
    border-color: var(--validator-green);
    border-width: 2px;
  }
  .when-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .when-card__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .when-card__list li {
    position: relative;
    padding-left: 1.2rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
    font-size: var(--fs-small);
  }
  .when-card__list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--pale-ink);
    font-family: var(--font-code);
  }
  .when-card--primary .when-card__list li::before {
    color: var(--validator-green);
  }
  .when-card__list code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  @media (max-width: 860px) {
    .when-grid { grid-template-columns: 1fr; }
  }

  /* ── Bridge section ── */
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
    margin-bottom: var(--space-2);
  }
  .prose-p:last-child {
    margin-bottom: 0;
    font-weight: 500;
    color: var(--ink);
  }
  .prose-p code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Feedback ── */
  .feedback-section { border-top: none; }
  .feedback-p {
