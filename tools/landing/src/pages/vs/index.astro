---
// /vs/ — Comparison index page.
// Lists tools that compete or coexist with SpecScore.
// Currently only OpenSpec; more entries can be added here.
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import ComparisonFeedback from '../../components/ComparisonFeedback.astro';
---

<BaseLayout
  title="SpecScore vs — How SpecScore compares."
  description="Honest, detailed comparisons between SpecScore and other spec-driven development tools. Feature tables, architecture differences, and when to use which."
  canonical="https://specscore.md/vs/"
>
  <SiteHeader />

  <main>
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <h1 id="hero-title" class="hero__headline">
          How SpecScore compares.
        </h1>
        <p class="hero__sub">
          Spec-driven development is a growing space. These comparisons are
          factual, side-by-side, and honest about where each tool is stronger.
        </p>
      </div>
    </section>

    <section class="section" aria-labelledby="comparisons-title">
      <div class="section-inner">
        <h2 id="comparisons-title" class="sr-only">Comparisons</h2>

        <div class="compare-grid">
          <a href="/vs/plain-markdown/" class="compare-card">
            <h3 class="compare-card__name">SpecScore vs plain Markdown</h3>
            <p class="compare-card__desc">
              The real default — ad-hoc Markdown, Notion, Jira tickets.
              Same Markdown, plus the structure an agent can lint, query,
              and trace. How to graduate the specs you already have.
            </p>
            <span class="compare-card__cta">Read the comparison →</span>
          </a>

          <a href="/vs/openspec/" class="compare-card">
            <h3 class="compare-card__name">SpecScore vs OpenSpec</h3>
            <p class="compare-card__desc">
              Both write specs in Markdown. OpenSpec organizes them —
              SpecScore lints, scores, and traces them.
              The full comparison: format, CLI, lifecycle, traceability, agent support.
            </p>
            <span class="compare-card__cta">Read the comparison →</span>
          </a>

          <a href="/vs/spec-kit/" class="compare-card">
            <h3 class="compare-card__name">SpecScore vs Spec Kit</h3>
            <p class="compare-card__desc">
              Different layers. Spec Kit is the workflow; SpecScore is the
              format the specs are written in. They compose — here's how, and
              when to run both.
            </p>
            <span class="compare-card__cta">Read the comparison →</span>
          </a>

          <a href="/vs/codespeak/" class="compare-card">
            <h3 class="compare-card__name">SpecScore vs CodeSpeak</h3>
            <p class="compare-card__desc">
              Two bets. CodeSpeak compiles the spec into code you don't maintain.
              SpecScore keeps your code and your specs open and portable.
            </p>
            <span class="compare-card__cta">Read the comparison →</span>
          </a>

          <a href="/vs/datarim/" class="compare-card">
            <h3 class="compare-card__name">SpecScore vs Datarim</h3>
            <p class="compare-card__desc">
              A Claude Code workflow pack vs an open format. Datarim runs the
              pipeline; SpecScore is the portable, lintable artifact a workflow
              can leave behind.
            </p>
            <span class="compare-card__cta">Read the comparison →</span>
          </a>
        </div>
      </div>
    </section>

    {/* ── Cross-comparison matrix ── */}
    <section class="section table-section" aria-labelledby="matrix-title">
      <div class="section-inner">
        <h2 id="matrix-title" class="section-title">SpecScore at a glance.</h2>
        <p class="section-note">
          A high-level view across the closest tools. Each has real strengths —
          follow a comparison above for the honest, detailed version.
        </p>

        <div class="table-wrap">
          <table class="matrix-table" aria-label="SpecScore vs plain Markdown, OpenSpec, Spec Kit, Datarim, and CodeSpeak">
            <thead>
              <tr>
                <th scope="col">Capability</th>
                <th scope="col" class="matrix-table__own">SpecScore</th>
                <th scope="col"><a href="/vs/plain-markdown/" class="matrix-table__link">Plain Markdown</a></th>
                <th scope="col"><a href="/vs/openspec/" class="matrix-table__link">OpenSpec</a></th>
                <th scope="col"><a href="/vs/spec-kit/" class="matrix-table__link">Spec Kit</a></th>
                <th scope="col"><a href="/vs/datarim/" class="matrix-table__link">Datarim</a></th>
                <th scope="col"><a href="/vs/codespeak/" class="matrix-table__link">CodeSpeak</a></th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Primary role</td>
                <td class="matrix-table__own">Lintable spec format + CLI</td>
                <td>Freeform docs (the default)</td>
                <td>Spec organization framework</td>
                <td>Workflow / methodology</td>
                <td>Claude Code workflow pack</td>
                <td>LLM compiler (spec → code)</td>
              </tr>
              <tr>
                <td>Spec format</td>
                <td class="matrix-table__own">Markdown + YAML (structured)</td>
                <td>Freeform Markdown</td>
                <td>Markdown</td>
                <td>Freeform Markdown</td>
                <td>Markdown (workflow-shaped)</td>
                <td>Plain English</td>
              </tr>
              <tr>
                <td>You keep your code</td>
                <td class="matrix-table__own"><span class="yes">Yes</span></td>
                <td><span class="yes">Yes</span></td>
                <td><span class="yes">Yes</span></td>
                <td><span class="yes">Yes</span></td>
                <td><span class="yes">Yes</span></td>
                <td><span class="no">Code is generated</span></td>
              </tr>
              <tr>
                <td>Open source / free</td>
                <td class="matrix-table__own"><span class="yes">Yes</span> (CC BY / MIT)</td>
                <td><span class="yes">Free</span></td>
                <td><span class="yes">Yes</span> (MIT)</td>
                <td><span class="yes">Yes</span> (MIT)</td>
                <td><span class="yes">Yes</span> (MIT)</td>
                <td><span class="no">Proprietary system</span></td>
              </tr>
              <tr>
                <td>Spec content linting</td>
                <td class="matrix-table__own"><span class="yes">Yes</span></td>
                <td><span class="no">No</span></td>
                <td>Structure only</td>
                <td><span class="no">No</span></td>
                <td><span class="no">No</span></td>
                <td>Not documented</td>
              </tr>
              <tr>
                <td>Requirement / AC IDs</td>
                <td class="matrix-table__own"><span class="yes">Yes</span></td>
                <td><span class="no">No</span></td>
                <td><span class="no">No</span></td>
                <td><span class="no">No</span></td>
                <td><span class="no">No</span></td>
                <td><span class="no">No</span></td>
              </tr>
              <tr>
                <td>Enforced lifecycle</td>
                <td class="matrix-table__own"><span class="yes">Yes</span></td>
                <td><span class="no">No</span></td>
                <td><span class="no">No</span></td>
                <td><span class="no">No</span></td>
                <td><span class="no">No</span></td>
                <td><span class="no">No</span></td>
              </tr>
              <tr>
                <td>Code-to-spec traceability</td>
                <td class="matrix-table__own"><span class="yes">Yes</span></td>
                <td><span class="no">No</span></td>
                <td><span class="no">No</span></td>
                <td><span class="no">No</span></td>
                <td><span class="no">No</span></td>
                <td>Via regeneration</td>
              </tr>
              <tr>
                <td>Runtime dependency</td>
                <td class="matrix-table__own">None (Go binary)</td>
                <td>None</td>
                <td>Node.js</td>
                <td>Python</td>
                <td>Claude Code</td>
                <td>Vendor compiler</td>
              </tr>
              <tr>
                <td>Works with any agent, or none</td>
                <td class="matrix-table__own"><span class="yes">Yes</span></td>
                <td>Read every file</td>
                <td>Many agents</td>
                <td>Many agents</td>
                <td>Claude Code</td>
                <td>Through CodeSpeak</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <ComparisonFeedback />
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-5);
    background: var(--cream);
  }
  .hero__inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms;
  }
  .hero__headline {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Screen-reader only ── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Comparison cards ── */
  .compare-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .compare-card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-4);
    transition: border-color 160ms ease, box-shadow 160ms ease;
    text-decoration: none;
    color: inherit;
  }
  .compare-card:hover {
    border-color: var(--graphite);
    box-shadow: 0 2px 8px rgba(26, 26, 26, 0.06);
  }
  .compare-card:focus-visible {
    outline: 2px solid var(--ink-blue);
    outline-offset: 2px;
  }
  .compare-card__name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: var(--space-2);
  }
  .compare-card__desc {
    color: var(--mid-ink);
    font-size: var(--fs-body);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }
  .compare-card__cta {
    font-family: var(--font-display);
    font-size: var(--fs-small);
    font-weight: 600;
    color: var(--validator-green);
  }

  @media (max-width: 720px) {
    .compare-grid { grid-template-columns: 1fr; }
  }

  /* ── Section title / note (matrix) ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  .section-note {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    margin-bottom: var(--space-3);
    max-width: 60ch;
  }

  /* ── Cross-comparison matrix ── */
  .table-section { background: var(--cream-2); }
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .matrix-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-small);
    line-height: 1.5;
  }
  .matrix-table th,
  .matrix-table td {
    text-align: left;
    padding: 0.65rem 0.85rem;
    border-bottom: 1px solid var(--hairline);
    vertical-align: top;
  }
  .matrix-table thead th {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mid-ink);
    border-bottom: 2px solid var(--graphite);
    white-space: nowrap;
  }
  .matrix-table td:first-child {
    font-weight: 500;
    white-space: nowrap;
    min-width: 160px;
  }
  .matrix-table td,
  .matrix-table th {
    min-width: 130px;
  }
  /* Highlight the SpecScore column */
  .matrix-table__own {
    background: var(--surface);
    font-weight: 600;
    color: var(--ink);
    border-left: 2px solid var(--validator-green);
    border-right: 2px solid var(--validator-green);
  }
  thead .matrix-table__own {
    color: var(--validator-green);
    border-bottom-color: var(--validator-green);
  }
  /* Column-header links to each comparison */
  .matrix-table__link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px dotted var(--pale-ink);
    transition: color 160ms ease, border-color 160ms ease;
  }
  .matrix-table__link:hover {
    color: var(--validator-green);
    border-bottom-color: var(--validator-green);
  }
  .matrix-table__link:focus-visible {
    outline: 2px solid var(--ink-blue);
    outline-offset: 2px;
  }
  .matrix-table .yes {
    color: var(--validator-green);
    font-weight: 600;
  }
  .matrix-table .no {
    color: var(--pale-ink);
  }
</style>
