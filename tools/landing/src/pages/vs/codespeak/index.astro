---
// /vs/codespeak/ — SpecScore vs CodeSpeak comparison.
// Honest, factual, side-by-side. Credits CodeSpeak's bold thesis,
// then frames the core difference: a bet on a compiler vs a bet on a format.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import ComparisonFeedback from '../../../components/ComparisonFeedback.astro';
---

<BaseLayout
  title="SpecScore vs CodeSpeak — Honest comparison."
  description="A factual, side-by-side comparison of SpecScore and CodeSpeak: spec-as-source vs spec-as-contract, code generation, portability, linting, and traceability."
  canonical="https://specscore.md/vs/codespeak/"
>
  <SiteHeader />

  <main>
    {/* ── Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <p class="hero__breadcrumb"><a href="/vs/" class="xref">Comparisons</a></p>
        <h1 id="hero-title" class="hero__headline">
          SpecScore vs CodeSpeak
        </h1>
        <p class="hero__sub">
          Two answers to "what should specs be for." CodeSpeak treats the spec as
          <strong>source code</strong> — an LLM compiles it, and you maintain the spec
          instead of the code. SpecScore treats the spec as a <strong>durable, open
          contract</strong> — you keep your code, and any agent (or none) can read,
          lint, and trace it.
        </p>
      </div>
    </section>

    {/* ── What they share ── */}
    <section class="section" aria-labelledby="shared-title">
      <div class="section-inner section-inner--prose">
        <h2 id="shared-title" class="section-title">What they share.</h2>
        <ul class="shared-list">
          <li>Both put the specification at the center of software development.</li>
          <li>Both are built for an AI-assisted world — intent before implementation.</li>
          <li>Both aim to make software easier to change by changing the spec.</li>
        </ul>
      </div>
    </section>

    {/* ── What CodeSpeak does well ── */}
    <section class="section" aria-labelledby="codespeak-title">
      <div class="section-inner section-inner--prose">
        <h2 id="codespeak-title" class="section-title">What CodeSpeak does well.</h2>
        <p class="section-note">
          <a href="https://codespeak.dev/" rel="nofollow noopener" target="_blank" class="xref">CodeSpeak</a>
          is an LLM-powered programming system that compiles structured-English specs to code.
        </p>

        <div class="credit-card">
          <h3 class="credit-card__title">A bold thesis, credibly argued</h3>
          <p class="credit-card__desc">
            "Maintain the spec, not the code" is a genuine reframing, not an
            incremental tweak. It comes from the designer of the Kotlin language,
            and it's worth taking seriously: if the spec is the source, the
            generated code becomes an implementation detail.
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">Code-to-spec takeover</h3>
          <p class="credit-card__desc">
            <code>codespeak takeover</code> reads existing source and produces a spec
            that captures its behavior — a low-friction on-ramp for brownfield code,
            with reported spec-to-code compression of roughly 5–10×.
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">Intent recovery from agent sessions</h3>
          <p class="credit-card__desc">
            CodeSpeak's Intent Studio extracts requirements from prior agent sessions —
            harvesting intent you've already expressed rather than asking you to author
            a spec from a blank page.
          </p>
        </div>
      </div>
    </section>

    {/* ── Feature comparison table ── */}
    <section class="section table-section" aria-labelledby="table-title">
      <div class="section-inner">
        <h2 id="table-title" class="section-title">Feature comparison.</h2>
        <p class="section-note">
          The two make different bets, so the table compares philosophy and mechanics, not winners.
        </p>

        <div class="table-wrap">
          <table class="compare-table" aria-label="SpecScore vs CodeSpeak feature comparison">
            <thead>
              <tr>
                <th scope="col">Capability</th>
                <th scope="col">CodeSpeak</th>
                <th scope="col">SpecScore</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Source of truth</td>
                <td>The spec (compile input)</td>
                <td><strong>The spec is the contract; code is the deliverable</strong></td>
              </tr>
              <tr>
                <td>Generated code</td>
                <td>Produced by an LLM, not hand-maintained</td>
                <td><strong>You and your agents write and own the code</strong></td>
              </tr>
              <tr>
                <td>Spec format</td>
                <td>Plain English, CodeSpeak-defined</td>
                <td><strong>Open Markdown + YAML standard</strong>, published schema</td>
              </tr>
              <tr>
                <td>Spec → code</td>
                <td>Core feature (proprietary LLM compiler)</td>
                <td>Out of scope — any agent implements</td>
              </tr>
              <tr>
                <td>Works without the vendor</td>
                <td>Specs compile through CodeSpeak</td>
                <td><strong>Yes</strong> — specs work with any agent, or none</td>
              </tr>
              <tr>
                <td>Spec linting</td>
                <td>Not documented</td>
                <td><strong>Content quality</strong> — vague verbs, missing ACs, dangling refs</td>
              </tr>
              <tr>
                <td>Code-to-spec traceability</td>
                <td>Via regeneration</td>
                <td><strong><code>specscore:</code> annotations</strong> + <code>Verifies:</code> trailers</td>
              </tr>
              <tr>
                <td>Determinism</td>
                <td>LLM compile (non-deterministic)</td>
                <td><strong>Deterministic CLI queries</strong>; code authored normally</td>
              </tr>
              <tr>
                <td>Code → spec</td>
                <td><strong><code>codespeak takeover</code></strong></td>
                <td><code>survey</code> + author</td>
              </tr>
              <tr>
                <td>Openness</td>
                <td>Proprietary system</td>
                <td><strong>Open</strong> — CC BY 4.0 format, MIT / Apache-2.0 tools</td>
              </tr>
              <tr>
                <td>Stage</td>
                <td>Alpha preview</td>
                <td>Shipping</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {/* ── Where SpecScore differs ── */}
    <section class="section" aria-labelledby="further-title">
      <div class="section-inner">
        <h2 id="further-title" class="section-title">Where SpecScore differs.</h2>

        <div class="diff-grid">
          <div class="diff-card">
            <h3 class="diff-card__title">You keep your code</h3>
            <p class="diff-card__desc">
              CodeSpeak generates and regenerates the implementation; the code is an
              output, not an asset. SpecScore leaves the code where it belongs — in
              your hands, in your language, reviewable line by line. The spec adds
              clarity and traceability without taking the code away.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Your specs are portable</h3>
            <p class="diff-card__desc">
              A CodeSpeak spec is valuable because CodeSpeak compiles it. A SpecScore
              spec is valuable on its own — it's well-structured Markdown that any
              agent can read, and it stays useful with no SpecScore tooling installed
              at all. Adopt it with any tool, or none. Leave any time.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Ambiguity is caught before it costs</h3>
            <p class="diff-card__desc">
              With an LLM compiler, an ambiguous spec becomes wrong code at build time.
              SpecScore's <code>lint</code> surfaces vague verbs, missing acceptance
              criteria, and dangling references <em>before</em> an agent acts on them.
            </p>
            <div class="diff-card__example">
<pre class="terminal"><span class="prompt">$</span> specscore lint checkout/apply-discount.md
  <span class="mark-fail">✗</span> R3  no acceptance criteria
  <span class="mark-fail">✗</span> verb  <span class="dim">"handle gracefully" — unmeasurable</span></pre>
            </div>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Determinism and traceability</h3>
            <p class="diff-card__desc">
              CodeSpeak's answer to "which code implements this?" is "all of it,
              regenerated." SpecScore's answer is a specific file and line, via
              <code>specscore code refs</code> and <code>Verifies:</code> commit
              trailers — deterministic, auditable, diff-able.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">A structured artifact graph</h3>
            <p class="diff-card__desc">
              CodeSpeak's unit is a spec file in prose. SpecScore has a typed
              hierarchy — Ideas promote to Features, Features carry Requirements and
              Acceptance Criteria with IDs, Plans reference ACs, Tasks reference Plans —
              all machine-navigable.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">No vendor in the build path</h3>
            <p class="diff-card__desc">
              SpecScore is a single Go binary. Lint runs in CI and pre-commit hooks
              with no account, no service call, no LLM round-trip in your build.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── When to use which ── */}
    <section class="section" aria-labelledby="when-title">
      <div class="section-inner">
        <h2 id="when-title" class="section-title">When to use which.</h2>

        <div class="when-grid">
          <div class="when-card">
            <h3 class="when-card__title">Reach for CodeSpeak when…</h3>
            <ul class="when-card__list">
              <li>You want to stop maintaining code and let the spec be the source.</li>
              <li>You're comfortable depending on a vendor's compiler for that leverage.</li>
              <li>You want to compress an existing codebase into a much shorter spec.</li>
            </ul>
          </div>

          <div class="when-card when-card--primary">
            <h3 class="when-card__title">Use SpecScore when…</h3>
            <ul class="when-card__list">
              <li>You want specs that outlive any single tool — portable by construction.</li>
              <li>You want to keep your code, in your language, reviewable and owned.</li>
              <li>You need spec quality enforcement — lint catches ambiguity early.</li>
              <li>You need deterministic code-to-spec traceability.</li>
              <li>You want no vendor and no LLM round-trip in your build path.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── Two different bets ── */}
    <section class="section" aria-labelledby="bets-title">
      <div class="section-inner section-inner--prose">
        <h2 id="bets-title" class="section-title">Two different bets.</h2>
        <p class="prose-p">
          CodeSpeak is a bet on a compiler: hand it the spec, and trust it to produce
          and reproduce the code. SpecScore is a bet on a format: keep the spec open
          and portable, keep the code yours, and let any agent work against it.
        </p>
        <p class="prose-p">
          One trades portability for leverage. The other keeps you free — and lintable.
        </p>
      </div>
    </section>

    <ComparisonFeedback page="codespeak" />
  </main>

  {/* ── Final CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">Specs that pass.</h2>
      <div class="final-cta__buttons">
        <a href="/cli/install/" class="btn btn--primary">Install the CLI</a>
        <a href="/ai/specstudio-skills/" class="btn btn--secondary">Get AI skills for your agent</a>
        <a
          href="https://github.com/specscore/specscore"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          Open-source on GitHub
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <SiteFooter />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-5);
    background: var(--cream);
  }
  .hero__inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms;
  }
  .hero__breadcrumb {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--pale-ink);
    margin-bottom: var(--space-2);
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
    max-width: 52ch;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Section titles ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }

  /* ── Shared list ── */
  .shared-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .shared-list li {
    position: relative;
    padding-left: 1.4rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
  }
  .shared-list li::before {
    content: '=';
    position: absolute;
    left: 0;
    font-family: var(--font-code);
    font-weight: 700;
    color: var(--pale-ink);
  }

  /* ── Section note ── */
  .section-note {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    margin-bottom: var(--space-3);
  }

  /* ── Credit cards ── */
  .credit-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .credit-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .credit-card__desc {
    color: var(--mid-ink);
    line-height: 1.6;
    font-size: var(--fs-body);
  }
  .credit-card__desc code {
    font-size: 0.9em;
    background: var(--cream);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Feature comparison table ── */
  .table-section { background: var(--cream-2); }
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-small);
    line-height: 1.5;
  }
  .compare-table th,
  .compare-table td {
    text-align: left;
    padding: 0.65rem 0.85rem;
    border-bottom: 1px solid var(--hairline);
    vertical-align: top;
  }
  .compare-table thead th {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mid-ink);
    border-bottom: 2px solid var(--graphite);
    white-space: nowrap;
  }
  .compare-table td:first-child {
    font-weight: 500;
    white-space: nowrap;
    min-width: 160px;
  }
  .compare-table td:nth-child(2),
  .compare-table td:nth-child(3) {
    min-width: 200px;
  }
  .compare-table td code {
    font-size: 0.88em;
    background: var(--surface);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .compare-table strong {
    font-weight: 600;
    color: var(--ink);
  }

  /* ── Diff grid ── */
  .diff-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .diff-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
  }
  .diff-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .diff-card__desc {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    line-height: 1.6;
  }
  .diff-card__desc code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .diff-card__example {
    margin-top: var(--space-2);
  }
  .diff-card__example .terminal {
    font-size: 0.78rem;
    line-height: 1.6;
  }

  @media (max-width: 860px) {
    .diff-grid { grid-template-columns: 1fr; }
  }

  /* ── When to use which ── */
  .when-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .when-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-4);
  }
  .when-card--primary {
    border-color: var(--validator-green);
    border-width: 2px;
  }
  .when-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .when-card__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .when-card__list li {
    position: relative;
    padding-left: 1.2rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
    font-size: var(--fs-small);
  }
  .when-card__list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--pale-ink);
    font-family: var(--font-code);
  }
  .when-card--primary .when-card__list li::before {
    color: var(--validator-green);
  }
  .when-card__list code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  @media (max-width: 860px) {
    .when-grid { grid-template-columns: 1fr; }
  }

  /* ── Bets section ── */
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
    margin-bottom: var(--space-2);
  }
  .prose-p:last-child {
    margin-bottom: 0;
    font-weight: 500;
    color: var(--ink);
  }
  .prose-p code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    text-align: center;
  }
  .final-cta__title {
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .final-cta__buttons {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>
