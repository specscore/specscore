---
// /vs/datarim/ — SpecScore vs Datarim comparison.
// Datarim is a Claude Code workflow pack; SpecScore is the open format
// a workflow can target. No public attack — two packs, one open format.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import ComparisonFeedback from '../../../components/ComparisonFeedback.astro';
---

<BaseLayout
  title="SpecScore vs Datarim — Honest comparison."
  description="A factual comparison of SpecScore and Datarim: a Claude Code workflow pack vs an open, portable spec format. Different layers — and they can compose."
  canonical="https://specscore.md/vs/datarim/"
>
  <SiteHeader />

  <main>
    {/* ── Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <p class="hero__breadcrumb"><a href="/vs/" class="xref">Comparisons</a></p>
        <h1 id="hero-title" class="hero__headline">
          SpecScore vs Datarim
        </h1>
        <p class="hero__sub">
          Different layers. Datarim is an opinionated <strong>workflow pack</strong> for
          Claude Code — slash commands that run a project from requirements to
          completion. SpecScore is the <strong>open format</strong> the specs are written
          in, plus a CLI to lint, query, and trace them. A workflow can target it.
        </p>
      </div>
    </section>

    {/* ── What they share ── */}
    <section class="section" aria-labelledby="shared-title">
      <div class="section-inner section-inner--prose">
        <h2 id="shared-title" class="section-title">What they share.</h2>
        <ul class="shared-list">
          <li>Both bring structured methodology to AI-assisted development.</li>
          <li>Both are open source under the MIT license.</li>
          <li>Both run inside Claude Code — Datarim as commands, SpecScore via SpecStudio Skills.</li>
          <li>Both keep their state as Markdown in the repo, version-controlled.</li>
        </ul>
      </div>
    </section>

    {/* ── What Datarim does well ── */}
    <section class="section" aria-labelledby="datarim-title">
      <div class="section-inner section-inner--prose">
        <h2 id="datarim-title" class="section-title">What Datarim does well.</h2>
        <p class="section-note">
          <a href="https://github.com/Arcanada-one/datarim" rel="nofollow noopener" target="_blank" class="xref">Datarim</a>
          is a universal iterative workflow framework built for Claude Code.
        </p>

        <div class="credit-card">
          <h3 class="credit-card__title">Native slash-command UX</h3>
          <p class="credit-card__desc">
            A full pipeline as commands — <code>/dr-prd</code>, <code>/dr-plan</code>,
            <code>/dr-design</code>, <code>/dr-do</code>, <code>/dr-qa</code> — that feel
            at home in Claude Code. One <code>install.sh</code> into <code>~/.claude/</code>
            and you're running.
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">Complexity-aware routing (L1–L4)</h3>
          <p class="credit-card__desc">
            Datarim sizes the work and routes accordingly: an L1 quick fix skips
            planning, while an L4 major change runs a phased pipeline with multiple
            review cycles. Matching ceremony to scope is a genuinely good idea.
          </p>
        </div>

        <div class="credit-card">
          <h3 class="credit-card__title">Consilium and multi-domain reach</h3>
          <p class="credit-card__desc">
            Its "consilium" assembles a panel of agents to debate trade-offs before
            recommending a decision. And it isn't software-only — Datarim also targets
            research, legal, and content workflows.
          </p>
        </div>
      </div>
    </section>

    {/* ── Feature comparison table ── */}
    <section class="section table-section" aria-labelledby="table-title">
      <div class="section-inner">
        <h2 id="table-title" class="section-title">Feature comparison.</h2>
        <p class="section-note">
          One is a workflow, the other a format — the table compares roles, not winners.
        </p>

        <div class="table-wrap">
          <table class="compare-table" aria-label="SpecScore vs Datarim feature comparison">
            <thead>
              <tr>
                <th scope="col">Capability</th>
                <th scope="col">Datarim</th>
                <th scope="col">SpecScore</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Primary role</td>
                <td>Claude Code workflow pack</td>
                <td><strong>Open spec format + CLI</strong></td>
              </tr>
              <tr>
                <td>Runs as</td>
                <td>Slash commands (<code>/dr-*</code>)</td>
                <td>Format files + CLI <span class="dim">(+ SpecStudio Skills in Claude Code)</span></td>
              </tr>
              <tr>
                <td>State storage</td>
                <td><code>backlog.md</code> + <code>CLAUDE.md</code> (workflow-shaped)</td>
                <td><strong>Portable <code>spec/</code> tree</strong> (Markdown + YAML)</td>
              </tr>
              <tr>
                <td>Survives without the tool</td>
                <td>Tied to the Datarim runtime</td>
                <td><strong>Yes</strong> — portable by construction</td>
              </tr>
              <tr>
                <td>Spec linting</td>
                <td>None</td>
                <td><strong>Content quality</strong> — vague verbs, missing ACs, dangling refs</td>
              </tr>
              <tr>
                <td>Requirement / AC IDs</td>
                <td>None</td>
                <td><strong>Machine-addressable IDs</strong> (<code>REQ: slug</code>)</td>
              </tr>
              <tr>
                <td>Code-to-spec traceability</td>
                <td>None</td>
                <td><strong><code>specscore:</code> annotations</strong> + <code>Verifies:</code> trailers</td>
              </tr>
              <tr>
                <td>Complexity routing (L1–L4)</td>
                <td><strong>Yes</strong></td>
                <td>No (format, not workflow)</td>
              </tr>
              <tr>
                <td>Queryable spec graph</td>
                <td>No</td>
                <td><strong>Yes</strong> — <code>feature list / show / deps</code></td>
              </tr>
              <tr>
                <td>Tied to Claude Code</td>
                <td>Built for it</td>
                <td><strong>No</strong> — any agent, or none</td>
              </tr>
              <tr>
                <td>License</td>
                <td>MIT</td>
                <td>MIT / CC BY 4.0</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {/* ── Where SpecScore goes further ── */}
    <section class="section" aria-labelledby="further-title">
      <div class="section-inner">
        <h2 id="further-title" class="section-title">What SpecScore adds.</h2>

        <div class="diff-grid">
          <div class="diff-card">
            <h3 class="diff-card__title">The output outlives the workflow</h3>
            <p class="diff-card__desc">
              Datarim's state lives in its own backlog and <code>CLAUDE.md</code> shape —
              valuable while you run Datarim. SpecScore specs are a portable format that
              stays readable, lintable, and queryable with no SpecScore tooling installed
              at all. The workflow can change; the specs come with you.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Specs are lintable</h3>
            <p class="diff-card__desc">
              A workflow guides authoring, but doesn't gate the result. SpecScore's
              <code>lint</code> checks every requirement has acceptance criteria,
              cross-references resolve, and status transitions are valid.
            </p>
            <div class="diff-card__example">
<pre class="terminal"><span class="prompt">$</span> specscore lint checkout/apply-discount.md
  <span class="mark-fail">✗</span> R3  no acceptance criteria
  <span class="mark-fail">✗</span> link  <span class="dim">"Related Feature: discount-tiers" not found</span></pre>
            </div>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Code traces back to specs</h3>
            <p class="diff-card__desc">
              SpecScore adds <code>specscore:</code> source annotations and
              <code>Verifies:</code> commit trailers — <code>specscore code refs</code>
              answers "which code implements this requirement?" deterministically,
              independent of the workflow that produced the spec.
            </p>
          </div>

          <div class="diff-card">
            <h3 class="diff-card__title">Not tied to one agent</h3>
            <p class="diff-card__desc">
              Datarim is built for Claude Code. SpecScore is a format any agent can read,
              and a single Go binary any CI can run — no Claude Code, no
              <code>~/.claude/</code> install required.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ── When to use which ── */}
    <section class="section" aria-labelledby="when-title">
      <div class="section-inner">
        <h2 id="when-title" class="section-title">When to use which.</h2>

        <div class="when-grid">
          <div class="when-card">
            <h3 class="when-card__title">Reach for Datarim when…</h3>
            <ul class="when-card__list">
              <li>You want a complete, opinionated pipeline inside Claude Code today.</li>
              <li>You value complexity-aware routing and a multi-agent decision ritual.</li>
              <li>Your work spans domains — research, legal, content, not just code.</li>
            </ul>
          </div>

          <div class="when-card when-card--primary">
            <h3 class="when-card__title">Use SpecScore when…</h3>
            <ul class="when-card__list">
              <li>You want specs that outlive any single workflow or tool.</li>
              <li>You need lint, IDs, lifecycle, and code-to-spec traceability.</li>
              <li>You work across agents — or none — not just Claude Code.</li>
              <li>You want a CLI agents can query instead of re-reading the repo.</li>
              <li>You need spec quality gates in CI that exit non-zero.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ── Two packs, one format ── */}
    <section class="section" aria-labelledby="bridge-title">
      <div class="section-inner section-inner--prose">
        <h2 id="bridge-title" class="section-title">Two workflow packs, one open format.</h2>
        <p class="prose-p">
          Datarim and SpecStudio Skills are both opinionated workflows on top of Claude
          Code. SpecScore is the open format underneath — the artifact a workflow can
          produce so the specs stay portable, lintable, and traceable after the pipeline
          finishes. A Datarim that emits SpecScore would keep its UX and gain durable
          output.
        </p>
        <p class="prose-p">
          Pick Datarim for the pipeline. Use SpecScore for the artifact it leaves behind.
        </p>
      </div>
    </section>

    <ComparisonFeedback page="datarim" />
  </main>

  {/* ── Final CTA ── */}
  <section class="final-cta" aria-labelledby="cta-title">
    <div class="final-cta__inner">
      <h2 id="cta-title" class="final-cta__title">Specs that pass.</h2>
      <div class="final-cta__buttons">
        <a href="/cli/install/" class="btn btn--primary">Install the CLI</a>
        <a href="/ai/specstudio-skills/" class="btn btn--secondary">Get AI skills for your agent</a>
        <a
          href="https://github.com/specscore/specscore"
          rel="noopener"
          class="btn btn--tertiary"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          Open-source on GitHub
        </a>
      </div>
    </div>
  </section>

  {/* ── Footer ── */}
  <SiteFooter />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-5);
    background: var(--cream);
  }
  .hero__inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms;
  }
  .hero__breadcrumb {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--pale-ink);
    margin-bottom: var(--space-2);
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    line-height: 1.55;
    max-width: 52ch;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Section titles ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }

  /* ── Shared list ── */
  .shared-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .shared-list li {
    position: relative;
    padding-left: 1.4rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
  }
  .shared-list li::before {
    content: '=';
    position: absolute;
    left: 0;
    font-family: var(--font-code);
    font-weight: 700;
    color: var(--pale-ink);
  }

  /* ── Section note ── */
  .section-note {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    margin-bottom: var(--space-3);
  }

  /* ── Credit cards ── */
  .credit-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .credit-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .credit-card__desc {
    color: var(--mid-ink);
    line-height: 1.6;
    font-size: var(--fs-body);
  }
  .credit-card__desc code {
    font-size: 0.9em;
    background: var(--cream);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Feature comparison table ── */
  .table-section { background: var(--cream-2); }
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-small);
    line-height: 1.5;
  }
  .compare-table th,
  .compare-table td {
    text-align: left;
    padding: 0.65rem 0.85rem;
    border-bottom: 1px solid var(--hairline);
    vertical-align: top;
  }
  .compare-table thead th {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mid-ink);
    border-bottom: 2px solid var(--graphite);
    white-space: nowrap;
  }
  .compare-table td:first-child {
    font-weight: 500;
    white-space: nowrap;
    min-width: 160px;
  }
  .compare-table td:nth-child(2),
  .compare-table td:nth-child(3) {
    min-width: 200px;
  }
  .compare-table td code {
    font-size: 0.88em;
    background: var(--surface);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .compare-table strong {
    font-weight: 600;
    color: var(--ink);
  }
  .compare-table .dim {
    color: var(--pale-ink);
  }

  /* ── Diff grid ── */
  .diff-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .diff-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-3);
  }
  .diff-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-1);
  }
  .diff-card__desc {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    line-height: 1.6;
  }
  .diff-card__desc code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }
  .diff-card__example {
    margin-top: var(--space-2);
  }
  .diff-card__example .terminal {
    font-size: 0.78rem;
    line-height: 1.6;
  }

  @media (max-width: 860px) {
    .diff-grid { grid-template-columns: 1fr; }
  }

  /* ── When to use which ── */
  .when-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
  }
  .when-card {
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: var(--space-4);
  }
  .when-card--primary {
    border-color: var(--validator-green);
    border-width: 2px;
  }
  .when-card__title {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    font-weight: 600;
    margin-bottom: var(--space-2);
  }
  .when-card__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .when-card__list li {
    position: relative;
    padding-left: 1.2rem;
    color: var(--mid-ink);
    line-height: 1.6;
    margin-bottom: var(--space-1);
    font-size: var(--fs-small);
  }
  .when-card__list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--pale-ink);
    font-family: var(--font-code);
  }
  .when-card--primary .when-card__list li::before {
    color: var(--validator-green);
  }
  .when-card__list code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  @media (max-width: 860px) {
    .when-grid { grid-template-columns: 1fr; }
  }

  /* ── Bridge section ── */
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
    margin-bottom: var(--space-2);
  }
  .prose-p:last-child {
    margin-bottom: 0;
    font-weight: 500;
    color: var(--ink);
  }
  .prose-p code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* ── Final CTA ── */
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    text-align: center;
  }
  .final-cta__title {
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .final-cta__buttons {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>
