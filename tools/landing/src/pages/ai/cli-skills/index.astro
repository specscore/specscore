---
// ai-plugin-specscore (CLI Skills) — product page.
// Per surfaces.md: targets power users already comfortable with SpecScore;
// tool builders writing alt-workflows. Less marketing emphasis than specstudio-skills.
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import QsTabsScript from '../../../components/QsTabsScript.astro';
---

<BaseLayout
  title="CLI Skills — SpecScore CLI inside Claude Code"
  description="Thin Claude Code plugin wrapping the SpecScore CLI. Surfaces specscore lint, feature, task, and change-status as native plugin commands."
  canonical="https://specscore.md/ai/cli-skills/"
>
  <SiteHeader />

  <main>
    {/* ── Hero ── */}
    <section class="hero" aria-labelledby="hero-title">
      <div class="hero__inner">
        <h1 id="hero-title" class="hero__headline">
          The SpecScore CLI, inside Claude Code.
        </h1>
        <p class="hero__sub">
          <code>ai-plugin-specscore</code> is a thin Claude Code plugin that
          wraps the open-source
          <a class="xref" href="/cli/">SpecScore CLI</a>. It surfaces
          <code>specscore lint</code>, <code>specscore feature</code>,
          <code>specscore task</code>, and <code>specscore change-status</code>
          as native plugin commands — no shell escaping, no context-switching.
        </p>
        <div class="hero__install" id="install">
          <div class="qs-tabs" role="tablist" aria-label="Install method">
            <button type="button" role="tab" id="qs-tab-claude" aria-controls="qs-panel-claude" aria-selected="true" tabindex="0" class="qs-tab is-active" data-tab="claude">Claude Code</button>
            <button type="button" role="tab" id="qs-tab-setup" aria-controls="qs-panel-setup" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="setup">Other AI agents</button>
            <button type="button" role="tab" id="qs-tab-manual" aria-controls="qs-panel-manual" aria-selected="false" tabindex="-1" class="qs-tab" data-tab="manual">Manual</button>
          </div>

          <div id="qs-panel-claude" role="tabpanel" aria-labelledby="qs-tab-claude" class="qs-panel is-active" data-panel="claude">
<pre class="terminal"><span class="prompt">$</span> /plugin marketplace add specscore/ai-marketplace
<span class="prompt">$</span> /plugin install cli-skills@specscore</pre>
          </div>
          <div id="qs-panel-setup" role="tabpanel" aria-labelledby="qs-tab-setup" class="qs-panel" data-panel="setup" hidden>
<pre class="terminal"><span class="prompt">$</span> specscore agent setup &lt;agent-name&gt;</pre>
            <p class="qs-note">
              Writes the right instruction file for your agent —
              <code>claude</code>, <code>copilot</code>, <code>cursor</code>, <code>codex</code>,
              <code>antigravity.google</code>, <code>pi.dev</code>, or <code>opencode</code>.
              Run inside a SpecScore-managed project. Requires the
              <a class="xref" href="/cli/">SpecScore CLI</a>.
            </p>
          </div>
          <div id="qs-panel-manual" role="tabpanel" aria-labelledby="qs-tab-manual" class="qs-panel" data-panel="manual" hidden>
<pre class="terminal"><span class="prompt">$</span> git clone https://github.com/specscore/ai-plugin-specscore
<span class="prompt">$</span> cp -r ai-plugin-specscore/skills /path/to/your/agent/skills/</pre>
            <p class="qs-note">
              Clone the plugin repo and copy the <code>skills/</code> directory
              into wherever your agent loads skill files from.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-inner section-inner--prose">
        <p class="prose-p">
          This is a <strong>thin wrapper</strong> around the SpecScore CLI
          for use inside your AI agent — nothing more. No workflow opinions,
          no lifecycle orchestration, no slash-command pipeline.
        </p>
        <p class="prose-p">
          If you want the opinionated spec-driven development workflow —
          <code>/ideate</code>, <code>/specify</code>, <code>/plan</code>,
          <code>/implement</code> — install
          <a class="xref" href="/ai/specstudio-skills/">SpecStudio Skills</a>
          instead. Both compose on top of the same SpecScore CLI.
        </p>

        <div class="callout">
          <strong>When to use which:</strong>
          <ul class="callout-list">
            <li><strong>CLI Skills</strong> — you already know SpecScore and want the raw CLI in your agent loop.</li>
            <li><strong>SpecStudio Skills</strong> — you're new to SpecScore and want a guided workflow.</li>
          </ul>
        </div>
      </div>
    </section>

    {/* ── Commands ── */}
    <section class="section" aria-labelledby="commands-title">
      <div class="section-inner section-inner--prose">
        <h2 id="commands-title" class="section-title">Commands</h2>

        <div class="cmd-block">
          <h3 class="cmd-name">/specscore-lint</h3>
          <p class="cmd-desc">Lint a spec tree or single file. Reports pass/fail per rule.</p>
<pre class="terminal"><span class="prompt">&gt;</span> /specscore-lint spec/features/password-reset/
<span class="mark-pass">PASS</span>  Feature: password-reset
  <span class="mark-pass">PASS</span>  has title, status, and description
  <span class="mark-pass">PASS</span>  requirements have acceptance criteria
  <span class="mark-pass">PASS</span>  all AC IDs are unique</pre>
        </div>

        <div class="cmd-block">
          <h3 class="cmd-name">/specscore-feature</h3>
          <p class="cmd-desc">List, inspect, or scaffold SpecScore features.</p>
        </div>

        <div class="cmd-block">
          <h3 class="cmd-name">/specscore-task</h3>
          <p class="cmd-desc">Read and seed the project's task board.</p>
        </div>

        <div class="cmd-block">
          <h3 class="cmd-name">/specscore-change-status</h3>
          <p class="cmd-desc">Transition a Feature or Idea through its lifecycle.</p>
        </div>
      </div>
    </section>

    {/* ── For tool builders ── */}
    <section class="section" aria-labelledby="builders-title">
      <div class="section-inner section-inner--prose">
        <h2 id="builders-title" class="section-title">For tool builders</h2>
        <p class="prose-p">
          <code>ai-plugin-specscore</code> exists so that anyone building their
          own workflow plugin on top of SpecScore can depend on the CLI surface
          without reimplementing it. If you're writing a community alternative
          to SpecStudio Skills, this is your substrate.
        </p>
        <p class="prose-p">
          The source is at
          <a class="xref" href="https://github.com/specscore/ai-plugin-specscore">specscore/ai-plugin-specscore</a>
          — MIT-licensed and free forever.
        </p>
      </div>
    </section>
  </main>

  {/* ── Footer ── */}
  <footer class="page-footer">
    <div class="page-footer__inner">
      <div class="page-footer__col page-footer__brand">
        <a href="/" class="wordmark" aria-label="SpecScore home">
          <span class="wordmark__clef" aria-hidden="true">&#x1D11E;</span>
          <span class="wordmark__name">SpecScore.md</span>
        </a>
        <p class="page-footer__tagline">
          An open standard for specifications, requirements,
          and acceptance criteria.
        </p>
        <p class="page-footer__copyright">
          &copy; 2026 SpecScore contributors. MIT license.
        </p>
      </div>

      <div class="page-footer__col">
        <h4 class="page-footer__heading">CLI Skills</h4>
        <ul class="page-footer__list">
          <li><a href="https://github.com/specscore/ai-plugin-specscore">GitHub</a></li>
          <li><a href="https://github.com/specscore/ai-plugin-specscore/blob/main/LICENSE">License: MIT</a></li>
        </ul>
      </div>

      <div class="page-footer__col">
        <h4 class="page-footer__heading">Ecosystem</h4>
        <ul class="page-footer__list">
          <li><a href="https://specscore.md">SpecScore</a> — the open standard</li>
          <li><a href="/ai/specstudio-skills/">SpecStudio Skills</a> — opinionated SDD workflow</li>
          <li><a href="/cli/">SpecScore CLI</a> — the linter</li>
        </ul>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-5);
    background: var(--cream);
  }
  .hero__inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    animation: fade-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 180ms;
  }
  .hero__headline {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1rem;
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    line-height: 1.6;
  }
  .hero__sub code {
    font-size: 0.9em;
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: 0.1em 0.35em;
    border-radius: 2px;
  }
  .hero__install { margin-bottom: var(--space-2); }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Sections ── */
  .section-title {
    font-size: var(--fs-h2);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
  }
  .prose-p {
    color: var(--mid-ink);
    line-height: 1.65;
    margin-bottom: var(--space-3);
  }
  .prose-p:last-child { margin-bottom: 0; }
  .prose-p code {
    font-size: 0.9em;
    background: var(--surface);
    border: 1px solid var(--hairline);
    padding: 0.1em 0.35em;
    border-radius: 2px;
  }

  /* ── Callout ── */
  .callout {
    margin-top: var(--space-4);
    padding: var(--space-2) var(--space-3);
    border-left: 3px solid var(--hairline);
    font-size: var(--fs-small);
    color: var(--mid-ink);
    line-height: 1.6;
  }
  .callout-list {
    margin: var(--space-1) 0 0;
    padding-left: 1.25rem;
  }
  .callout-list li { margin-bottom: 0.35rem; }

  /* ── Command blocks ── */
  .cmd-block {
    margin-bottom: var(--space-4);
  }
  .cmd-block:last-child { margin-bottom: 0; }
  .cmd-name {
    font-family: var(--font-code);
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: var(--space-1);
  }
  .cmd-desc {
    color: var(--mid-ink);
    font-size: var(--fs-small);
    margin-bottom: var(--space-2);
    line-height: 1.55;
  }

  /* ── Footer ── */
  .page-footer {
    background: var(--cream);
    padding: var(--space-6) var(--space-3) var(--space-5);
    border-top: 1px solid var(--hairline);
  }
  .page-footer__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-4);
  }
  .page-footer__brand .wordmark { margin-bottom: var(--space-2); }
  .page-footer__tagline {
    color: var(--mid-ink);
    margin-bottom: var(--space-2);
    max-width: 36ch;
    line-height: 1.5;
    font-size: 0.95rem;
  }
  .page-footer__copyright {
    color: var(--pale-ink);
    font-size: 0.825rem;
    font-family: var(--font-code);
  }
  .page-footer__heading {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mid-ink);
    margin-bottom: var(--space-2);
  }
  .page-footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .page-footer__list a {
    color: var(--ink);
    font-size: 0.9rem;
    border-bottom: 1px solid transparent;
    transition: border-color 120ms ease;
  }
  .page-footer__list a:hover { border-bottom-color: var(--ink); }
  .page-footer__list a:focus-visible {
    outline: 2px solid var(--ink-blue);
    outline-offset: 2px;
    border-radius: 2px;
  }

  @media (max-width: 800px) {
    .page-footer__inner { grid-template-columns: 1fr 1fr; }
    .page-footer__brand { grid-column: 1 / -1; }
  }
</style>

<QsTabsScript />
