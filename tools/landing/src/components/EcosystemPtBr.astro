---
// Brazilian Portuguese variant of Ecosystem.astro. Tool names stay English (product names).
---

<section class="ecosystem section" aria-labelledby="ecosystem-title">
  <div class="section-inner">
    <h2 id="ecosystem-title" class="ecosystem__title">Feito sobre SpecScore.</h2>

    <ul class="ecosystem__grid">
      <li class="eco-card">
        <h3 class="eco-card__title">DALgo</h3>
        <p class="eco-card__body">
          Camada de acesso a dados em Go, especificada com SpecScore desde o início.
        </p>
        <a class="eco-card__link" href="https://dal-go.github.io/" target="_blank">
          dal-go.github.io <span aria-hidden="true">→</span>
        </a>
      </li>
      <li class="eco-card">
        <h3 class="eco-card__title">Rehearse</h3>
        <p class="eco-card__body">
          Framework de testes nativo de Markdown. Testa specs SpecScore
          contra o código que as implementa.
        </p>
        <a class="eco-card__link" href="https://rehearse.ink" target="_blank">
          rehearse.ink <span aria-hidden="true">→</span>
        </a>
      </li>
      <li class="eco-card">
        <h3 class="eco-card__title">SpecScore Studio</h3>
        <p class="eco-card__body">
          Interface web para visualizar e editar especificações SpecScore.
        </p>
        <a class="eco-card__link" href="https://specscore.studio" target="_blank">
          specscore.studio <span aria-hidden="true">→</span>
        </a>
      </li>
    </ul>
  </div>
</section>

<style>
  .ecosystem { background: var(--cream); }
  .ecosystem__title {
    font-size: var(--fs-h2);
    margin-bottom: var(--space-4);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .ecosystem__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }
  .eco-card {
    border-top: 1px solid var(--graphite);
    padding-top: var(--space-2);
    display: flex;
    flex-direction: column;
  }
  .eco-card__title {
    font-size: 1.05rem;
    margin-bottom: var(--space-2);
    font-weight: 700;
  }
  .eco-card__body {
    color: var(--mid-ink);
    font-size: 0.95rem;
    line-height: 1.55;
    margin-bottom: var(--space-2);
    flex-grow: 1;
  }
  .eco-card__link {
    font-family: var(--font-code);
    font-size: 0.825rem;
    color: var(--ink-blue);
    border-bottom: 1px solid currentColor;
    align-self: flex-start;
  }
  .eco-card__link:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  @media (max-width: 800px) {
    .ecosystem__grid {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
  }
</style>
