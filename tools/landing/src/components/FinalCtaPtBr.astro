---
// Brazilian Portuguese variant of FinalCta.astro. Headline stays as a calm declarative.
---

<section class="final-cta" aria-labelledby="final-cta-title">
  <div class="final-cta__inner">
    <h2 id="final-cta-title" class="final-cta__title">Specs que passam.</h2>
    <div class="final-cta__buttons">
      <a href="/pt-br/ai/specstudio-skills/" class="btn btn--primary">Skills de IA para o seu agente</a>
      <a href="#quickstart" class="btn btn--secondary">Instalar a CLI</a>
      <a
        href="https://github.com/specscore/specscore"
        rel="noopener"
        class="btn btn--tertiary"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
        </svg>
        Open-source no GitHub
      </a>
    </div>
    <p class="final-cta__after">
      ou <a class="xref" href="https://specscore.md/docs">leia a documentação</a>
    </p>
  </div>
</section>

<style>
  .final-cta {
    background: var(--cream-2);
    padding: var(--space-7) var(--space-3);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .final-cta__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    text-align: center;
  }
  .final-cta__title {
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }
  .final-cta__buttons {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
  .final-cta__after {
    margin-top: var(--space-3);
    color: var(--mid-ink);
    font-size: var(--fs-small);
  }
</style>
