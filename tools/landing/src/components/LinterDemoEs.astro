---
// Spanish variant of LinterDemo.astro — Check your spec in two passes.
// Two-column: the deterministic linter and the non-deterministic AI review/score.
// Terminal output stays English — it's literal CLI stdout.
import LintExample from './LintExample.astro';
import ScoreExample from './ScoreExample.astro';
---

<section class="passes section" aria-labelledby="passes-title">
  <div class="section-inner">
    <h2 id="passes-title" class="passes__title">Revisa tu spec en dos pasadas.</h2>
    <p class="passes__intro">
      Un linter determinista y rápido, y luego una revisión de IA más profunda —
      ejecutados sobre la spec que acabas de ver. Dos pasadas, dos tipos de
      certeza.
    </p>

    <div class="passes__grid">
      {/* ── Pass 1 — the linter (shipped, real output) ── */}
      <div class="pass">
        <div class="pass__head">
          <h3 class="pass__name">Ejecuta el linter.</h3>
          <span class="pass__kind">deterministic</span>
        </div>
        <div
          class="pass__terminal"
          role="img"
          aria-label="Salida del terminal de specscore lint: R1 y R2 tienen criterios de aceptación (checks verdes); R3 no tiene, un enlace Related Feature no se resuelve y falta la sección obligatoria Open Questions (marcas rojas). 3 problemas, exit 1."
        >
          <LintExample />
        </div>
        <p class="pass__caption">
          El mismo resultado en cada ejecución. Gratis, rápido, se ejecuta en cada commit.
        </p>
      </div>

      {/* ── Pass 2 — AI review/score (Approved Idea, labeled preview) ── */}
      <div class="pass">
        <div class="pass__head">
          <h3 class="pass__name">Revisa y puntúa con IA.</h3>
          <span class="pass__kind">non-deterministic</span>
        </div>
        <div
          class="pass__terminal"
          role="img"
          aria-label="Una revisión de IA: la spec obtiene una nota B con dos observaciones accionables — un trigger vago en AC-2 y una ruta de error ausente en AC-3."
        >
          <ScoreExample />
        </div>
        <p class="pass__caption">
          Lee buscando el sentido, como un revisor humano.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .passes { background: var(--cream); }
  .passes__title {
    font-size: var(--fs-h2);
    margin-bottom: var(--space-2);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .passes__intro {
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .passes__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .pass {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .pass__head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .pass__name {
    font-size: var(--fs-h3);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .pass__kind {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--mid-ink);
  }

  .pass__terminal {
    margin-bottom: var(--space-2);
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .pass__terminal pre.terminal {
    margin: 0;
    font-size: 0.72rem;
    line-height: 1.65;
    flex: 1;
  }

  .pass__caption {
    font-size: var(--fs-small);
    color: var(--mid-ink);
    line-height: 1.55;
  }
  .pass__caption .xref code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* Two-column only: reserve a consistent caption height so both
     terminals stretch to the same height. */
  @media (min-width: 721px) {
    .pass__caption { min-height: 2lh; }
  }

  @media (max-width: 720px) {
    .passes__grid { grid-template-columns: 1fr; gap: var(--space-5); }
  }
</style>
