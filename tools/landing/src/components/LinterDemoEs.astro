---
// Spanish variant of LinterDemo.astro.
// Terminal output stays English — it's literal CLI stdout.
import LintExample from './LintExample.astro';
---

<section class="linter section" aria-labelledby="linter-title">
  <div class="section-inner">
    <h2 id="linter-title" class="linter__title">Ejecuta el linter.</h2>
    <p class="linter__intro">
      Ejecuta <code>specscore lint</code> sobre la spec que acabas de ver.
      Esto es lo que te dice.
    </p>

    <div
      class="linter__terminal"
      role="img"
      aria-label="Salida en terminal de specscore lint: R1 y R2 pasan con marcas verdes, R3 falla con marca roja y un mensaje de error corregible."
    >
<LintExample />
    </div>
  </div>
</section>

<style>
  .linter { background: var(--cream); }
  .linter__title {
    font-size: var(--fs-h2);
    margin-bottom: var(--space-2);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .linter__intro {
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
  }
  .linter__intro code {
    background: var(--cream-2);
    padding: 0.05em 0.35em;
    border-radius: 2px;
    font-size: 0.92em;
    color: var(--ink);
  }
  .linter__terminal {
    margin-bottom: var(--space-3);
  }
</style>
