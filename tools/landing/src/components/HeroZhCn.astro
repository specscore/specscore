---
// Simplified Chinese variant of Hero.astro.
// Structure / CSS classes match the English Hero exactly; only the prose changes.
// Product names (SpecStudio, SpecScore, Claude Code, GitHub) stay English.
import { Image } from 'astro:assets';
import heroImage from '../assets/hero.webp';
import HeroGitHubLink from './HeroGitHubLink.astro';
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__inner">
    <div class="hero__copy">
      <h1 id="hero-title" class="hero__headline">
        规格说明中的每一处歧义，<br />都是你的 AI 代理烧掉的 token。
      </h1>
      <p class="hero__stakes">
        然后是开发途中的一个澄清问题。然后是上线之后的一次修复。
        然后是你一遍遍重新解释的上下文。
      </p>
      <p class="hero__sub">
        SpecScore 是一种用于规格说明的开放、可 lint 的文件格式——
        就像 JSON 之于数据。并配有 CLI，供你的 AI 代理调用以查询和
        编辑它们——就像 <code>jq</code> 之于 JSON。
      </p>
      <HeroGitHubLink repo="specscore/specscore" label="在 GitHub 上开源" />
      <div class="hero__cta">
        <a href="/zh-cn/ai/" class="btn btn--primary">获取 AI 技能插件</a>
        <a href="/zh-cn/cli/" class="btn btn--secondary">安装 CLI</a>
      </div>
    </div>

    <figure
      class="hero__art"
      aria-label="一份 SpecScore 规格说明呈现在奶油色的绘图纸上：两项需求通过检查（绿色对勾），一项未通过（红色标记）。"
    >
      <Image
        src={heroImage}
        widths={[700, 1050, 1400]}
        sizes="(max-width: 860px) 88vw, 52vw"
        alt=""
        loading="eager"
        decoding="async"
      />
    </figure>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-7);
    background: var(--cream);
    overflow: hidden;
  }
  .hero__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 45fr 55fr;
    gap: var(--space-6);
    align-items: center;
  }
  .hero__copy {
    animation: hero-copy-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 280ms;
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    max-width: 42ch;
    line-height: 1.5;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .hero__art {
    margin: 0;
    animation: hero-art-in 700ms cubic-bezier(0.22, 0.61, 0.36, 1) both 100ms;
  }
  .hero__art img {
    width: 100%;
    height: auto;
    display: block;
  }

  @keyframes hero-copy-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0);   }
  }
  @keyframes hero-art-in {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0);    }
  }

  @media (max-width: 860px) {
    .hero { padding: var(--space-5) var(--space-3) var(--space-6); }
    .hero__inner { grid-template-columns: 1fr; gap: var(--space-4); }
    .hero__art { order: 2; max-width: 520px; }
    .hero__copy { order: 1; }
  }
</style>
