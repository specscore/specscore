---
// Simplified Chinese variant of LinterDemo.astro.
// Terminal output stays English — it's literal CLI stdout.
import LintExample from './LintExample.astro';
---

<section class="linter section" aria-labelledby="linter-title">
  <div class="section-inner">
    <h2 id="linter-title" class="linter__title">运行代码检查器。</h2>
    <p class="linter__intro">
      对你刚才看到的规格运行 <code>specscore lint</code>。
      以下是它的输出结果。
    </p>

    <div
      class="linter__terminal"
      role="img"
      aria-label="specscore lint 的终端输出：R1 和 R2 通过（绿色对勾），R3 未通过（红色标记），并显示可修复的错误信息。"
    >
<LintExample />
    </div>
  </div>
</section>

<style>
  .linter { background: var(--cream); }
  .linter__title {
    font-size: var(--fs-h2);
    margin-bottom: var(--space-2);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .linter__intro {
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
  }
  .linter__intro code {
    background: var(--cream-2);
    padding: 0.05em 0.35em;
    border-radius: 2px;
    font-size: 0.92em;
    color: var(--ink);
  }
  .linter__terminal {
    margin-bottom: var(--space-3);
  }
</style>
