---
// Brazilian Portuguese variant of LinterDemo.astro.
// Terminal output stays English — it's literal CLI stdout.
import LintExample from './LintExample.astro';
---

<section class="linter section" aria-labelledby="linter-title">
  <div class="section-inner">
    <h2 id="linter-title" class="linter__title">Rode o linter.</h2>
    <p class="linter__intro">
      Rode <code>specscore lint</code> contra a spec que você acabou de
      ver. É isso que ele te diz.
    </p>

    <div
      class="linter__terminal"
      role="img"
      aria-label="Saída de specscore lint no terminal: R1 e R2 passam com marcas verdes, R3 falha com marca vermelha e mensagem de erro corrigível."
    >
<LintExample />
    </div>
  </div>
</section>

<style>
  .linter { background: var(--cream); }
  .linter__title {
    font-size: var(--fs-h2);
    margin-bottom: var(--space-2);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .linter__intro {
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
  }
  .linter__intro code {
    background: var(--cream-2);
    padding: 0.05em 0.35em;
    border-radius: 2px;
    font-size: 0.92em;
    color: var(--ink);
  }
  .linter__terminal {
    margin-bottom: var(--space-3);
  }
</style>
