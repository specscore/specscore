---
// Spanish variant of Hero.astro.
// Structure / CSS classes match the English Hero exactly; only the prose changes.
// Product names (SpecStudio, SpecScore, Claude Code, GitHub) stay English.
import { Image } from 'astro:assets';
import heroImage from '../assets/hero.webp';
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__inner">
    <div class="hero__copy">
      <h1 id="hero-title" class="hero__headline">
        Lintea tus specs<br />como linteas tu código.
      </h1>
      <p class="hero__sub">
        Un formato abierto en Markdown + YAML para features, requisitos
        y criterios de aceptación — con linter.
      </p>
      <div class="hero__github">
        <a href="https://github.com/specscore/specscore" class="hero__github-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.16c-3.2.7-3.87-1.36-3.87-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18.92-.26 1.91-.39 2.89-.39.98 0 1.97.13 2.89.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.15v3.19c0 .31.21.67.8.55C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z" />
          </svg>
          Código abierto en GitHub
        </a>
        <a href="https://github.com/specscore/specscore">
          <img src="https://img.shields.io/github/stars/specscore/specscore?style=social" alt="GitHub stars" loading="lazy" />
        </a>
      </div>
      <div class="hero__cta">
        <a href="/es/ai/specstudio-skills/" class="btn btn--primary">Skills de IA para tu agente</a>
        <a href="/es/cli/" class="btn btn--secondary">Instalar la CLI</a>
      </div>
    </div>

    <figure
      class="hero__art"
      aria-label="Una especificación SpecScore sobre papel de borrador color crema: dos requisitos pasan el linter (marcas verdes), uno no pasa (marca roja)."
    >
      <Image
        src={heroImage}
        widths={[700, 1050, 1400]}
        sizes="(max-width: 860px) 88vw, 52vw"
        alt=""
        loading="eager"
        decoding="async"
      />
    </figure>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-7);
    background: var(--cream);
    overflow: hidden;
  }
  .hero__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 45fr 55fr;
    gap: var(--space-6);
    align-items: center;
  }
  .hero__copy {
    animation: hero-copy-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 280ms;
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    max-width: 36ch;
    line-height: 1.5;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .hero__art {
    margin: 0;
    animation: hero-art-in 700ms cubic-bezier(0.22, 0.61, 0.36, 1) both 100ms;
  }
  .hero__art img {
    width: 100%;
    height: auto;
    display: block;
  }

  @keyframes hero-copy-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes hero-art-in {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 860px) {
    .hero {
      padding: var(--space-5) var(--space-3) var(--space-6);
    }
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .hero__art {
      order: 2;
      max-width: 520px;
    }
    .hero__copy {
      order: 1;
    }
  }
</style>
