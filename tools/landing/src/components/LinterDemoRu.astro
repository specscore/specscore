---
// Russian variant of LinterDemo.astro — two-pass section.
// Terminal examples are shared components (English CLI stdout).
// NOTE: Russian copy is a draft pending native review.
import LintExample from './LintExample.astro';
import ScoreExample from './ScoreExample.astro';
---

<section class="passes section" aria-labelledby="passes-title">
  <div class="section-inner">
    <h2 id="passes-title" class="passes__title">Проверьте спецификацию в два прохода.</h2>
    <p class="passes__intro">
      Сначала быстрый детерминированный линтер, затем более глубокая проверка
      ИИ — на той же спецификации, что вы только что видели. Два прохода — два
      вида уверенности.
    </p>

    <div class="passes__grid">
      {/* ── Проход 1 — линтер ── */}
      <div class="pass">
        <div class="pass__head">
          <h3 class="pass__name">Запустите линтер.</h3>
          <span class="pass__kind">детерминированный</span>
        </div>
        <div
          class="pass__terminal"
          role="img"
          aria-label="Вывод specscore lint: у R1 и R2 есть критерии приёмки (зелёные галочки); у R3 их нет, ссылка Related Feature не разрешается, отсутствует обязательная секция Open Questions (красные отметки). 3 проблемы, exit 1."
        >
          <LintExample />
        </div>
        <p class="pass__caption">
          Одинаковый результат при каждом запуске. Бесплатно, быстро, на каждом коммите.
        </p>
      </div>

      {/* ── Проход 2 — проверка и оценка ИИ ── */}
      <div class="pass">
        <div class="pass__head">
          <h3 class="pass__name">Проверка и оценка с помощью ИИ.</h3>
          <span class="pass__kind">недетерминированный</span>
        </div>
        <div
          class="pass__terminal"
          role="img"
          aria-label="Проверка ИИ: спецификация получает оценку B с двумя замечаниями по делу — расплывчатый триггер в AC-2 и отсутствие пути ошибки в AC-3."
        >
          <ScoreExample />
        </div>
        <p class="pass__caption">
          Читает по смыслу, как живой рецензент.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .passes { background: var(--cream); }
  .passes__title {
    font-size: var(--fs-h2);
    margin-bottom: var(--space-2);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .passes__intro {
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .passes__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .pass {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .pass__head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .pass__name {
    font-size: var(--fs-h3);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .pass__kind {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--mid-ink);
  }

  .pass__terminal {
    margin-bottom: var(--space-2);
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .pass__terminal pre.terminal {
    margin: 0;
    font-size: 0.72rem;
    line-height: 1.65;
    flex: 1;
  }

  .pass__caption {
    font-size: var(--fs-small);
    color: var(--mid-ink);
    line-height: 1.55;
  }

  @media (min-width: 721px) {
    .pass__caption { min-height: 2lh; }
  }

  @media (max-width: 720px) {
    .passes__grid { grid-template-columns: 1fr; gap: var(--space-5); }
  }
</style>
