<style>
  .what-is { background: var(--cream); }

  .what-is__title {
    font-size: var(--fs-h2);
    margin-bottom: var(--space-4);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .what-is__intro {
    font-size: 1.05rem;
    color: var(--mid-ink);
    margin-bottom: var(--space-3);
    max-width: 60ch;
    line-height: 1.6;
  }

  /* --- Grid --- */
  .what-is__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    align-items: start;
  }
  @media (min-width: 900px) {
    .what-is__grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
      gap: var(--space-5);
    }
  }
  .what-is__col { min-width: 0; }

  /* --- Diagram --- */
  .what-is__diagram {
    margin: var(--space-3) 0;
    border: 1px solid var(--hairline);
    background: var(--cream);
    padding: var(--space-3) var(--space-2);
  }
  .what-is__diagram-svg {
    width: 100%;
    height: auto;
    max-width: 560px;
    margin: 0 auto;
    display: block;
  }
  .what-is__diagram-svg .wf-node {
    fill: var(--cream);
    stroke: var(--graphite);
    stroke-width: 1.6;
  }
  .what-is__diagram-svg .wf-line {
    fill: none;
    stroke: var(--graphite);
    stroke-width: 1.4;
  }
