---
// Ukrainian variant of LinterDemo.astro.
// Two-column: the deterministic linter and the non-deterministic AI review/score.
// Terminal output stays English — it's literal CLI stdout.
import LintExample from './LintExample.astro';
import ScoreExample from './ScoreExample.astro';
---

<section class="passes section" aria-labelledby="passes-title">
  <div class="section-inner">
    <h2 id="passes-title" class="passes__title">Перевірте специфікацію у два проходи.</h2>
    <p class="passes__intro">
      Швидкий детермінований лінтер, а потім глибша AI-рецензія — запущені на
      специфікації, яку ви щойно бачили. Два проходи, два види впевненості.
    </p>

    <div class="passes__grid">
      {/* ── Pass 1 — the linter (shipped, real output) ── */}
      <div class="pass">
        <div class="pass__head">
          <h3 class="pass__name">Запустіть лінтер.</h3>
          <span class="pass__kind">детермінований</span>
        </div>
        <div
          class="pass__terminal"
          role="img"
          aria-label="Вивід терміналу specscore lint: у R1 і R2 є критерії приймання (зелені галочки); у R3 їх немає, посилання Related Feature не розв'язується, і відсутній обов'язковий розділ Open Questions (червоні позначки). 3 проблеми, exit 1."
        >
          <LintExample />
        </div>
        <p class="pass__caption">
          Однаковий результат при кожному запуску. Безкоштовно, швидко, працює на кожному коміті.
        </p>
      </div>

      {/* ── Pass 2 — AI review/score (Approved Idea, labeled preview) ── */}
      <div class="pass">
        <div class="pass__head">
          <h3 class="pass__name">Рецензія та оцінка від AI.</h3>
          <span class="pass__kind">недетермінований</span>
        </div>
        <div
          class="pass__terminal"
          role="img"
          aria-label="AI-рецензія: специфікація отримує оцінку B із двома дієвими зауваженнями — нечіткий тригер у AC-2 і відсутній шлях помилки в AC-3."
        >
          <ScoreExample />
        </div>
        <p class="pass__caption">
          Читає за змістом, як живий рецензент.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .passes { background: var(--cream); }
  .passes__title {
    font-size: var(--fs-h2);
    margin-bottom: var(--space-2);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .passes__intro {
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .passes__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .pass {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .pass__head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }
  .pass__name {
    font-size: var(--fs-h3);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .pass__kind {
    font-family: var(--font-code);
    font-size: var(--fs-small);
    color: var(--mid-ink);
  }

  .pass__terminal {
    margin-bottom: var(--space-2);
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .pass__terminal pre.terminal {
    margin: 0;
    font-size: 0.72rem;
    line-height: 1.65;
    flex: 1;
  }

  .pass__caption {
    font-size: var(--fs-small);
    color: var(--mid-ink);
    line-height: 1.55;
  }
  .pass__caption .xref code {
    font-size: 0.9em;
    background: var(--cream-2);
    padding: 0.05em 0.3em;
    border-radius: 2px;
  }

  /* Two-column only: reserve a consistent caption height so both
     terminals stretch to the same height. */
  @media (min-width: 721px) {
    .pass__caption { min-height: 2lh; }
  }

  @media (max-width: 720px) {
    .passes__grid { grid-template-columns: 1fr; gap: var(--space-5); }
  }
</style>
