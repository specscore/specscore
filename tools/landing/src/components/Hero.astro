---
// Section 1 — Hero.
// Per hero-scene.md: two-column desktop layout, copy left (~45%), score right (~55%).
// Animation: a quiet settle (~1.7s total), not a theatrical reveal.
import { Image } from 'astro:assets';
import heroImage from '../assets/hero.webp';
import HeroGitHubLink from './HeroGitHubLink.astro';
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__inner">
    <div class="hero__copy">
      <h1 id="hero-title" class="hero__headline">
        Lint your specs<br />like you lint your code.
      </h1>
      <p class="hero__sub">
        An open file format for specifications — like JSON for data.
        With a CLI your agents call to query, edit, and lint them —
        like <code>jq</code> for JSON.
      </p>
      <HeroGitHubLink repo="specscore/specscore" label="Open-source on GitHub" />
      <div class="hero__cta">
        <a href="/ai/" class="btn btn--primary">Get AI skills for your agent</a>
        <a href="/cli/" class="btn btn--secondary">Install the CLI</a>
      </div>
    </div>

    <figure
      class="hero__art"
      aria-label="A SpecScore specification on cream drafting paper: two requirements pass lint (green checks), one fails (red mark)."
    >
      <Image
        src={heroImage}
        widths={[700, 1050, 1400]}
        sizes="(max-width: 860px) 88vw, 52vw"
        alt=""
        loading="eager"
        decoding="async"
      />
    </figure>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-6) var(--space-3) var(--space-7);
    background: var(--cream);
    overflow: hidden;
  }
  .hero__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 45fr 55fr;
    gap: var(--space-6);
    align-items: center;
  }
  .hero__copy {
    animation: hero-copy-in 600ms cubic-bezier(0.22, 0.61, 0.36, 1) both 280ms;
  }
  .hero__headline {
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }
  .hero__sub {
    font-size: 1.125rem;
    color: var(--mid-ink);
    margin-bottom: var(--space-4);
    max-width: 36ch;
    line-height: 1.5;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .hero__art {
    margin: 0;
    animation: hero-art-in 700ms cubic-bezier(0.22, 0.61, 0.36, 1) both 100ms;
  }
  .hero__art img {
    width: 100%;
    height: auto;
    display: block;
  }

  @keyframes hero-copy-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes hero-art-in {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 860px) {
    .hero {
      padding: var(--space-5) var(--space-3) var(--space-6);
    }
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .hero__art {
      order: 2;
      max-width: 520px;
    }
    .hero__copy {
      order: 1;
    }
  }
</style>
