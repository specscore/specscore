---
// Site header — wordmark + Specifications + CLI + AI Skills + GitHub
// + language dropdown.
//
// The four nav items describe the shape of the site (what exists):
//   Specifications → the open standard (lives on the docs site,
//                    English-only URL — locale routing can be added
//                    when docs get translated)
//   CLI            → the primary tool (Astro page, locale-routed)
//   AI Skills      → AI agent integrations (Astro hub, locale-routed)
//   GitHub         → source-of-truth / open-source verification
//
// Dropdown is pure-CSS via :focus-within and :hover; the <ul><li><a>
// list stays in the DOM for crawler discovery of alternate-language URLs.
import { langs, localeFromPath, routeFromPath, localeHref } from '../lib/languages';

const path = Astro.url.pathname;
const locale = localeFromPath(path);
const route = routeFromPath(path);
const wordmarkHref = localeHref(locale, '/');
const currentLang = langs.find(l => l.code === locale)!;

// Specification points at the welcoming /docs hub (intro + role-based
// guides + links to the spec tree), NOT the raw spec-tree index at
// /specifications. The label promises a confident single thing ("the
// specification of SpecScore"); /docs delivers the approachable entry
// that suits cold visitors. /specifications stays available for power
// users via internal links from /docs. The docs site is currently
// English-only, so this URL doesn't get a locale prefix.
const specsHref = 'https://specscore.md/docs';

// Localized nav labels. CLI is kept as the universal acronym across all
// locales. Specification is singular per-locale (confident brand framing
// — "the specification" as one thing to read, not a catalog of docs).
const specsLabel: Record<string, string> = {
  'en': 'Specification', 'es': 'Especificación', 'pt-br': 'Especificação',
  'ru': 'Спецификация',  'uk': 'Специфікація',
  'ja': '仕様',           'zh-cn': '规范',          'ko': '명세',
};
const aiSkillsLabel: Record<string, string> = {
  'en': 'AI Skills',  'es': 'Skills de IA', 'pt-br': 'Skills de IA',
  'ru': 'AI-скилы',  'uk': 'AI-скіли',
  'ja': 'AIスキル',    'zh-cn': 'AI 技能',    'ko': 'AI 스킬',
};
---

<header class="site-header">
  <div class="site-header__inner">
    <a href={wordmarkHref} class="wordmark" aria-label="SpecScore home">
      <span class="wordmark__clef" aria-hidden="true">𝄞</span>
      <span class="wordmark__name">SpecScore.md</span>
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      <a href={specsHref} class="site-header__link">{specsLabel[locale]}</a>
      <a href={localeHref(locale, '/cli/')} class="site-header__link">CLI</a>
      <a href={localeHref(locale, '/ai/')} class="site-header__link">{aiSkillsLabel[locale]}</a>
      <a href={localeHref(locale, '/faq/')} class="site-header__link">FAQ</a>
      <a href="https://github.com/specscore/specscore" class="site-header__link">GitHub</a>
    </nav>

    <div class="lang-switcher">
      <button
        type="button"
        class="lang-switcher__trigger"
        aria-haspopup="true"
        aria-expanded="false"
        lang={currentLang.tag}
      >
        <span>{currentLang.label}</span>
        <svg class="lang-switcher__caret" viewBox="0 0 10 6" width="10" height="6" aria-hidden="true">
          <path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <ul class="lang-switcher__menu" role="menu" aria-label="Language">
        {langs.map(({ code, label, tag }) => (
          <li role="none">
            <a
              href={localeHref(code, route)}
              hreflang={tag}
              lang={tag}
              role="menuitem"
              class:list={['lang-switcher__item', code === locale && 'is-active']}
              aria-current={code === locale ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--cream);
    border-bottom: 1px solid var(--hairline);
  }
  .site-header__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    padding: 0.875rem var(--space-3);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .site-header__nav {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.25rem;
  }

  .site-header__link {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--ink);
    padding: 0.3rem 0.6rem;
    border-radius: 2px;
    transition: background 120ms ease;
  }
  .site-header__link:hover {
    background: var(--cream-2);
  }
  .site-header__link:focus-visible {
    outline: 2px solid var(--ink-blue);
    outline-offset: 2px;
  }

  /* --- Language dropdown --- */
  .lang-switcher {
    position: relative;
    margin-left: 1rem;   /* extra breathing room between nav links and dropdown */
  }
  .lang-switcher__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: transparent;
    border: 1px solid var(--hairline);
    border-radius: 2px;
    padding: 0.3rem 0.6rem;
    font-family: var(--font-code);
    font-size: 0.8rem;
    color: var(--ink);
    cursor: pointer;
    transition: background 120ms ease, border-color 120ms ease;
  }
  .lang-switcher__trigger:hover {
    background: var(--cream-2);
    border-color: var(--ink);
  }
  .lang-switcher__trigger:focus-visible {
    outline: 2px solid var(--ink-blue);
    outline-offset: 2px;
  }
  .lang-switcher__caret {
    color: var(--mid-ink);
    transition: transform 160ms ease;
  }
  .lang-switcher:hover .lang-switcher__caret,
  .lang-switcher:focus-within .lang-switcher__caret {
    transform: rotate(180deg);
  }

  .lang-switcher__menu {
    position: absolute;
    top: calc(100% + 4px);
    right: 0;
    min-width: 11rem;
    list-style: none;
    margin: 0;
    padding: 0.35rem;
    background: var(--cream);
    border: 1px solid var(--hairline);
    border-radius: 2px;
    box-shadow: 0 8px 24px rgba(26, 26, 26, 0.08);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 140ms ease, transform 140ms ease, visibility 0s linear 140ms;
    z-index: 60;
  }
  .lang-switcher:hover .lang-switcher__menu,
  .lang-switcher:focus-within .lang-switcher__menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition: opacity 140ms ease, transform 140ms ease, visibility 0s linear 0s;
  }

  .lang-switcher__item {
    display: block;
    padding: 0.4rem 0.6rem;
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--ink);
    border-radius: 2px;
    transition: background 100ms ease;
  }
  .lang-switcher__item:hover {
    background: var(--cream-2);
  }
  .lang-switcher__item:focus-visible {
    outline: 2px solid var(--ink-blue);
    outline-offset: -2px;
  }
  .lang-switcher__item.is-active {
    color: var(--ink);
    font-weight: 600;
    background: var(--cream-2);
  }

  @media (max-width: 720px) {
    /* Wordmark + language switcher stay on row 1; nav drops to row 2.
       Achieved by wrapping the flex container and forcing the nav to
       a 100% basis with explicit order. */
    .site-header__inner {
      flex-wrap: wrap;
      row-gap: 0.5rem;
      gap: var(--space-2);
      padding: 0.625rem var(--space-2);
    }
    .site-header__nav {
      order: 2;
      flex-basis: 100%;
      justify-content: flex-start;
      gap: 0.15rem;
    }
    .site-header__link { padding: 0.3rem 0.45rem; font-size: 0.82rem; }
    .lang-switcher {
      margin-left: auto;  /* push to right edge of row 1 */
    }
    .lang-switcher__trigger { padding: 0.25rem 0.45rem; font-size: 0.75rem; }
    .lang-switcher__menu { right: -4px; }
  }
</style>

<script>
  // Toggle aria-expanded on the trigger when the menu opens/closes
  // (driven by :focus-within / :hover in CSS). This keeps screen readers
  // in sync with the visual state.
  document.querySelectorAll<HTMLElement>('.lang-switcher').forEach((switcher) => {
    const trigger = switcher.querySelector<HTMLButtonElement>('.lang-switcher__trigger');
    if (!trigger) return;
    const sync = (open: boolean) => trigger.setAttribute('aria-expanded', String(open));
    // Mouse
    switcher.addEventListener('mouseenter', () => sync(true));
    switcher.addEventListener('mouseleave', () => {
      if (!switcher.contains(document.activeElement)) sync(false);
    });
    // Keyboard / click
    switcher.addEventListener('focusin', () => sync(true));
    switcher.addEventListener('focusout', (e) => {
      const next = e.relatedTarget as Node | null;
      if (!next || !switcher.contains(next)) sync(false);
    });
    // Escape closes menu and returns focus to trigger
    switcher.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        sync(false);
        trigger.focus();
        // Blur to dismiss :focus-within
        setTimeout(() => trigger.blur(), 0);
      }
    });
  });
</script>
