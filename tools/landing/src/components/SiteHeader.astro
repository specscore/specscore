---
// Site header — clef wordmark + centered language switcher + GitHub link.
// Language switcher uses Astro.url.pathname to detect current locale, so
// pages don't need to pass a prop. Language names appear in their own
// language (per the conversation: flag emoji was rejected — flags ≠ languages,
// inconsistent OS rendering, accessibility issues).
const path = Astro.url.pathname;
const locale =
  path.startsWith('/ru')    ? 'ru'    :
  path.startsWith('/uk')    ? 'uk'    :
  path.startsWith('/es')    ? 'es'    :
  path.startsWith('/pt-br') ? 'pt-br' :
  path.startsWith('/ja')    ? 'ja'    :
  path.startsWith('/zh-cn') ? 'zh-cn' :
  path.startsWith('/ko')    ? 'ko'    :
                              'en';
const wordmarkHref = locale === 'en' ? '/' : `/${locale}/`;

// Strip the current locale prefix to get the route portion of the path.
// e.g. "/es/vs/openspec/" → "/vs/openspec/", "/" → "/"
const localePattern = /^\/(es|pt-br|ru|uk|ja|zh-cn|ko)(\/|$)/;
const route = locale === 'en' ? path : path.replace(localePattern, '/');

// Build per-language hrefs that preserve the current route.
function langHref(code: string): string {
  return code === 'en' ? route : `/${code}${route}`;
}

// Order: English (default) first, then alphabetical by URL code.
// `tag` is the HTML lang attribute value (uppercase BR per RFC 5646);
// `code` matches the locale detector above.
const langs = [
  { code: 'en',    label: 'English',         short: 'EN', tag: 'en'    },
  { code: 'es',    label: 'Español',         short: 'ES', tag: 'es'    },
  { code: 'pt-br', label: 'Português (BR)',  short: 'PT', tag: 'pt-BR' },
  { code: 'ru',    label: 'Русский',         short: 'RU', tag: 'ru'    },
  { code: 'uk',    label: 'Українська',      short: 'Укр', tag: 'uk'    },
  { code: 'ja',    label: '日本語',           short: '日本語',  tag: 'ja'    },
  { code: 'zh-cn', label: '中文',             short: '中文',    tag: 'zh-CN' },
  { code: 'ko',    label: '한국어',            short: '한국어',   tag: 'ko'    },
];
---

<header class="site-header">
  <div class="site-header__inner">
    <a href={wordmarkHref} class="wordmark" aria-label="SpecScore home">
      <span class="wordmark__clef" aria-hidden="true">𝄞</span>
      <span class="wordmark__name">SpecScore.md</span>
    </a>

    <div class="site-header__lang" role="group" aria-label="Language">
      {langs.map(({ code, label, short, tag }) => (
        <a
          href={langHref(code)}
          class:list={['lang-tab', code === locale && 'is-active']}
          aria-current={code === locale ? 'page' : undefined}
          aria-label={label}
          lang={tag}
        >
          <span class="lang-full">{label}</span>
          <span class="lang-short">{short}</span>
        </a>
      ))}
    </div>

    <nav class="site-header__nav" aria-label="Primary">
      <a
        href="https://github.com/specscore/specscore"
        rel="noopener"
        class="site-header__link"
      >
        GitHub
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--cream);
    border-bottom: 1px solid var(--hairline);
  }
  .site-header__inner {
    max-width: var(--max-content);
    margin: 0 auto;
    padding: 0.875rem var(--space-3);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-3);
  }
  /* Wordmark stays left, nav stays right; switcher anchored to grid centre. */
  .site-header__inner > .wordmark { justify-self: start; }
  .site-header__nav { justify-self: end; }
  .site-header__lang { justify-self: center; }

  .site-header__link {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--ink);
    padding: 0.3rem 0.6rem;
    border-radius: 2px;
    transition: background 120ms ease;
  }
  .site-header__link:hover {
    background: var(--cream-2);
  }
  .site-header__link:focus-visible {
    outline: 2px solid var(--ink-blue);
    outline-offset: 2px;
  }

  /* --- Language switcher (tab pair) --- */
  .site-header__lang {
    display: inline-flex;
    gap: 0.25rem;
  }
  .lang-tab {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-code);
    font-size: 0.75rem;
    letter-spacing: 0.01em;
    color: var(--pale-ink);
    padding: 0.3rem 0.5rem;
    border-bottom: 2px solid transparent;
    transition: color 120ms ease, border-color 160ms ease, opacity 120ms ease;
  }
  .lang-tab:hover { color: var(--mid-ink); }
  .lang-tab:focus-visible {
    outline: 2px solid var(--ink-blue);
    outline-offset: -2px;
  }
  .lang-tab.is-active {
    color: var(--ink);
    border-bottom-color: var(--validator-green);
    font-weight: 600;
  }

  /* Full labels visible by default, short codes hidden */
  .lang-short { display: none; }

  @media (max-width: 720px) {
    .site-header__inner {
      grid-template-columns: auto auto auto;
      gap: var(--space-2);
      padding: 0.625rem var(--space-2);
    }
    /* Swap to 2-char codes on small screens */
    .lang-full { display: none; }
    .lang-short {
      display: inline;
      font-weight: 600;
      text-transform: uppercase;
    }
    .lang-tab { padding: 0.25rem 0.35rem; font-size: 0.72rem; }
  }
</style>
