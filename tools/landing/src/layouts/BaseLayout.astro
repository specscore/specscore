---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  lang?: 'en' | 'ru';
}

const {
  title = 'SpecScore — Lint your specs like you lint your code.',
  description = 'An open Markdown + YAML format for features, requirements, and acceptance criteria — with a linter.',
  canonical = 'https://specscore.md/',
  lang = 'en',
} = Astro.props;
---

<!doctype html>
<html lang={lang} data-theme="light">
  <!--autogenerated: do not edit!-->
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light only" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    {/* Force light on the landing page. The rest of the SpecScore site
        supports a dark toggle via localStorage 'specscore-theme'. The
        landing must ignore that; the brand register is paper-and-ink only. */}
    <script is:inline>
      try {
        document.documentElement.setAttribute('data-theme', 'light');
      } catch (e) {
        /* ignore */
      }
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/hero-og.webp" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />

    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
