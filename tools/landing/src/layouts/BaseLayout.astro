---
import '../styles/global.css';
import PageFeedback from '../components/PageFeedback.astro';
import FooterLanguages from '../components/FooterLanguages.astro';
import { localeFromPath } from '../lib/languages';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  lang?: 'en' | 'es' | 'pt-BR' | 'ru' | 'uk' | 'ja' | 'zh-CN' | 'ko';
}

const {
  title = 'SpecScore — Lint your specs like you lint your code.',
  description = 'An open Markdown + YAML format for features, requirements, and acceptance criteria — with a linter.',
  canonical = 'https://specscore.md/',
  lang = 'en',
} = Astro.props;

const currentLocale = localeFromPath(Astro.url.pathname);
---

<!doctype html>
<html lang={lang} data-theme="light">
  <!--autogenerated: do not edit!-->
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-9Y2D7ZQV9C" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-9Y2D7ZQV9C');
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light only" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    {/* Force light on the landing page. The rest of the SpecScore site
        supports a dark toggle via localStorage 'specscore-theme'. The
        landing must ignore that; the brand register is paper-and-ink only. */}
    <script is:inline>
      try {
        document.documentElement.setAttribute('data-theme', 'light');
      } catch (e) {
        /* ignore */
      }
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/hero-og.webp" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />

    <slot name="head" />
  </head>
  <body>
    <slot />
    <FooterLanguages currentLocale={currentLocale} />
    <PageFeedback />
  </body>
</html>
