---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  lang?: 'en' | 'es' | 'pt-BR' | 'ru' | 'uk' | 'ja' | 'zh-CN' | 'ko';
}

const {
  title = 'SpecScore — Lint your specs like you lint your code.',
  description = 'An open Markdown + YAML format for features, requirements, and acceptance criteria — with a linter.',
  canonical = 'https://specscore.md/',
  lang = 'en',
} = Astro.props;
---

<!doctype html>
<html lang={lang} data-theme="light">
  <!--autogenerated: do not edit!-->
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-9Y2D7ZQV9C" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-9Y2D7ZQV9C');
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light only" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    {/* Force light on the landing page. The rest of the SpecScore site
        supports a dark toggle via localStorage 'specscore-theme'. The
        landing must ignore that; the brand register is paper-and-ink only. */}
    <script is:inline>
      try {
        document.documentElement.setAttribute('data-theme', 'light');
      } catch (e) {
        /* ignore */
      }
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/hero-og.webp" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />

    <slot name="head" />
  </head>
  <body>
    <slot />
    {lang === 'es' && (
      <div class="translation-note"><p>¿Encontraste un error en la traducción? <a href="https://github.com/specscore/specscore/issues/new?labels=translation&title=Translation+issue" rel="noopener">Abre un issue</a> o envía un PR.</p></div>
    )}
    {lang === 'pt-BR' && (
      <div class="translation-note"><p>Encontrou um erro na tradução? <a href="https://github.com/specscore/specscore/issues/new?labels=translation&title=Translation+issue" rel="noopener">Abra uma issue</a> ou envie um PR.</p></div>
    )}
    {lang === 'ru' && (
      <div class="translation-note"><p>Нашли ошибку в переводе? <a href="https://github.com/specscore/specscore/issues/new?labels=translation&title=Translation+issue" rel="noopener">Откройте issue</a> или отправьте PR.</p></div>
    )}
    {lang === 'uk' && (
      <div class="translation-note"><p>Знайшли помилку в перекладі? <a href="https://github.com/specscore/specscore/issues/new?labels=translation&title=Translation+issue" rel="noopener">Відкрийте issue</a> або надішліть PR.</p></div>
    )}
    {lang === 'ja' && (
      <div class="translation-note"><p>翻訳の問題を見つけましたか？ <a href="https://github.com/specscore/specscore/issues/new?labels=translation&title=Translation+issue" rel="noopener">issueを作成</a>するかPRを送ってください。</p></div>
    )}
    {lang === 'zh-CN' && (
      <div class="translation-note"><p>发现翻译问题？<a href="https://github.com/specscore/specscore/issues/new?labels=translation&title=Translation+issue" rel="noopener">提交 issue</a> 或发送 PR。</p></div>
    )}
    {lang === 'ko' && (
      <div class="translation-note"><p>번역 오류를 발견하셨나요? <a href="https://github.com/specscore/specscore/issues/new?labels=translation&title=Translation+issue" rel="noopener">issue를 열거나</a> PR을 보내주세요.</p></div>
    )}
    <style>
      .translation-note {
        background: var(--cream-2);
        border-top: 1px solid var(--hairline);
        padding: 0.75rem var(--space-3);
        text-align: center;
        font-family: var(--font-code);
        font-size: 0.78rem;
        color: var(--pale-ink);
        letter-spacing: 0.01em;
      }
      .translation-note a {
        color: var(--ink-blue);
        border-bottom: 1px solid currentColor;
        transition: color 120ms ease;
      }
      .translation-note a:hover {
        color: var(--ink);
      }
    </style>
  </body>
</html>
